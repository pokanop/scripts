#!/usr/bin/env python3
"""
scripts — Toolkit installer & lifecycle manager  v1.0.0
Install, update, and diagnose the pokanop/scripts CLI toolkit.

Usage:
    scripts install [tools...]      Install harness, or add tools (use 'all' for every tool)
    scripts update [tools...]       Pull latest + refresh deps and wrappers
    scripts uninstall [tools...]    Remove install (all if none given)
    scripts doctor                  Check install, PATH, Python, and system deps
    scripts list                    Show available tools and install status
    scripts path                    Print install paths (for shell scripts)

Environment:
    SCRIPTS_HOME    Override install directory
    SCRIPTS_BIN     Override wrapper/bin directory
"""

from __future__ import annotations

import argparse
import json
import os
import platform
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

__version__ = "1.0.0"

# scriptkit is the shared toolkit library (lives alongside this file). It is
# import-safe without third-party deps, but this installer must survive even a
# broken/absent library — so the import is guarded and everything degrades to
# plain stdlib behavior when it is unavailable.
try:
    import scriptkit as _sk
except Exception:  # pragma: no cover - bootstrap safety net
    _sk = None

REPO_URL = "https://github.com/pokanop/scripts.git"
MARKER_NAME = ".scripts-install.json"
PATH_BEGIN = "# >>> scripts >>>"
PATH_END = "# <<< scripts <<<"

# Meta tool is always installed; other tools are optional CLI utilities.
TOOL_NAMES = ("medcat", "keyferry", "voxtract", "netsy", "pluck", "aikit")

