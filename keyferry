def _run_to_bitwarden(args, src, execute=False):
    cfg = load_config()
    if args.org:
        cfg["mapping"]["organization"] = args.org
    if args.skip_archived:
        cfg["mapping"]["archived_policy"] = "skip"
    elif args.archived_active:
        cfg["mapping"]["archived_policy"] = "active"
    match_keys = cfg["settings"]["match_keys"]
    tags_mode = "field" if (args.keep_tags or cfg["settings"].get("tags") == "field") else "drop"

    items = _load_source_items(src, args)

    bw = BwClient(port=cfg["settings"]["serve_port"], concurrency=cfg["settings"]["concurrency"])
    if not bw.available():
        raise KeyferryError("bw not installed")
    if (bw.status() or {}).get("status") != "unlocked":
        raise KeyferryError("Bitwarden vault is locked — run: bw unlock")

    with console.status("🛡️  Reading current Bitwarden vault…"):
        bw.cli_sync()
        org = _resolve_org(bw, cfg)
        collections = bw.cli_list_org_collections(org["id"]) if org else []
        col_by_name = {c["name"]: c["id"] for c in collections}
        col_by_id = {c["id"]: c["name"] for c in collections}
        existing = bw.cli_list_items(include_archived=True)
    index, title_index = build_existing_index(existing, col_by_id, match_keys)
    org_label = org["name"] if org else "(none — personal only)"
    print_info(f"Target org: {org_label} · {len(collections)} collections · {len(existing)} existing items")

    plan, skipped_archived = build_plan(items, cfg["mapping"], index, title_index, match_keys,
                                         overwrite=args.overwrite)

    # --- show the plan ---
    console.print()
    table = Table(title="📋 Migration plan", header_style="bold cyan", title_style="bold")
    table.add_column("Destination"); table.add_column("Create", justify="right", style="green")
    table.add_column("Update", justify="right", style="magenta")
    table.add_column("Duplicate (skip)", justify="right", style="yellow")
    tot_c = tot_d = tot_u = 0
    for key in sorted(plan):
        row = plan[key]
        tot_c += len(row.create); tot_d += len(row.duplicate); tot_u += len(row.update)
        table.add_row(row.dest.label(), str(len(row.create)), str(len(row.update)),
                      str(len(row.duplicate)))
    table.add_row("[bold]TOTAL[/bold]", f"[bold]{tot_c}[/bold]", f"[bold]{tot_u}[/bold]",
                  f"[bold]{tot_d}[/bold]")
    console.print(table)
    missing_cols = sorted({plan[k].dest.collection_name for k in plan
                           if plan[k].dest.kind == "collection"
                           and plan[k].dest.collection_name not in col_by_name
                           and (plan[k].create or plan[k].update)})
    if missing_cols:
        print_info(f"Collections to create: {', '.join(missing_cols)}")
    if skipped_archived:
        print_info(f"Archived items skipped by policy: {skipped_archived}")
    n_archive = sum(1 for k in plan for it in plan[k].create if should_archive(it, cfg["mapping"]))
    if n_archive:
        print_info(f"Will be archived in place (native Archive): {n_archive}")
    n_tagged = sum(1 for k in plan for it in plan[k].create if it.tags)
    if n_tagged:
        if tags_mode == "field":
            print_info(f"1Password tags on {n_tagged} item(s) → preserved as a custom field")
        else:
            print_info(f"1Password tags on {n_tagged} item(s) → dropped (Bitwarden has no tags; "
                       f"--keep-tags keeps them as a field; no folders are created)")
    n_att = sum(len(it.attachments) for k in plan for it in plan[k].create)
    if n_att:
        print_info(f"Attachments to upload: {n_att}")

    if not execute:
        console.print()
        print_info("This was a dry run. Run [bold]keyferry sync[/bold] to apply.")
        return

    if org is None and any(plan[k].dest.kind == "collection" and (plan[k].create or plan[k].update)
                           for k in plan):
        raise KeyferryError("shared-vault items need a Bitwarden organization — create one, "
                            "or remap those vaults to personal (keyferry map)")

    to_create = [(plan[k].dest, it) for k in plan for it in plan[k].create]
    to_update = [(plan[k].dest, it, eid) for k in plan for (it, eid) in plan[k].update]
    if not to_create and not to_update:
        console.print()
        print_success("Nothing to do — Bitwarden already in sync. 🎉")
        return

    console.print()
    if not args.yes and not _prompt_yes_no(
            f"Create {tot_c} item(s)" + (f", overwrite {tot_u}" if args.overwrite else "") + "?", True):
        print_warning("Aborted.")
        return

    _execute_migration(bw, org, col_by_name, to_create, to_update, args, cfg["mapping"], tags_mode)


def _execute_migration(bw, org, col_by_name, to_create, to_update, args, mapping, tags_mode="drop"):
    # 1. ensure collections exist
    dests = [d for d, _it in to_create] + [d for d, _it, _e in to_update]
    needed = sorted({d.collection_name for d in dests
                     if d.kind == "collection" and d.collection_name not in col_by_name})
    for name in needed:
        cid = bw.cli_create_collection(org["id"], name)
        col_by_name[name] = cid
        print_success(f"Created collection: {name}")

    # 2. create items via the serve fast-path (with attachment deferral)
    created_ok, created_fail = [], []
    attachment_jobs = []   # (item_id, source attachment info OR {'text':...,'name':...})

    def make(job):
        dest, it = job
        org_id = org["id"] if dest.kind == "collection" else None
        coll_ids = [col_by_name[dest.collection_name]] if dest.kind == "collection" else None
        deferred = []
        body = item_to_bw(it, org_id=org_id, collection_ids=coll_ids,
                          deferred_attachments=deferred, tags_mode=tags_mode)
        new_id, err = bw.create_item(body)
        return (it, new_id, err, deferred)

    with bw.serve():
        bw.serve_sync()
        results = bw.parallel(make, to_create, description="🛳️  Ferrying items")
        # overwrites
        if to_update:
            def upd(job):
                dest, it, eid = job
                org_id = org["id"] if dest.kind == "collection" else None
                coll_ids = [col_by_name[dest.collection_name]] if dest.kind == "collection" else None
                deferred = []
                existing_raw = bw.get_item(eid)
                body = item_to_bw(it, org_id=org_id, collection_ids=coll_ids,
                                  deferred_attachments=deferred, tags_mode=tags_mode)
                body = merge_bw_update(body, existing_raw)
                ok, err = bw.edit_item(eid, body)
                return (it, eid if ok else None, None if ok else err, deferred)
            results += bw.parallel(upd, to_update, description="♻️  Updating items")

    archive_ids = []
    for it, new_id, err, deferred in results:
        if new_id:
            created_ok.append(it)
            if should_archive(it, mapping):
                archive_ids.append(new_id)
            for d in deferred:
                attachment_jobs.append((new_id, {"text": d["text"], "name": d["name"]}))
            for att in it.attachments:
                attachment_jobs.append((new_id, att))
        else:
            created_fail.append((it, err))

    # 3. attachments (CLI, serve stopped to avoid local-cache races)
    if attachment_jobs and not args.no_attachments:
        _upload_attachments(bw, attachment_jobs)
    elif attachment_jobs:
        print_info(f"Skipped {len(attachment_jobs)} attachment(s) (--no-attachments)")

    # 4. native archive (CLI) for items archived at the source
    archived_ok = 0
    if archive_ids:
        bw.cli_sync()
        with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"),
                      BarColumn(), MofNCompleteColumn(), console=console) as progress:
            t = progress.add_task("🗄️  Archiving items", total=len(archive_ids))
            for aid in archive_ids:
                ok, _err = bw.cli_archive_item(aid)
                archived_ok += 1 if ok else 0
                progress.advance(t)
        print_success(f"Archived {archived_ok}/{len(archive_ids)} item(s) in place")

    # 5. summary
    console.print()
    print_success(f"Created {len(created_ok)} item(s)" + (f", updated {len(to_update)}" if to_update else ""))
    if created_fail:
        print_error(f"{len(created_fail)} item(s) failed:")
        for it, err in created_fail[:10]:
            console.print(f"     • {it.title}: [red]{err}[/red]")
    console.print(f"\n{EMOJI} [bold green]Ferry complete.[/bold green]\n")


def _upload_attachments(bw, jobs):
    bw.cli_sync()
    tmp = tempfile.mkdtemp(prefix="keyferry-")
    prepared = []
    for item_id, att in jobs:
        path = None
        if "text" in att:
            path = os.path.join(tmp, att["name"])
            Path(path).write_text(att["text"])
        elif att.get("pux") and att.get("docid"):
            path = extract_1pux_attachment(att["pux"], att["docid"], tmp)
        elif att.get("op_ref"):
            # live op file: op read of the file reference
            ref = f"op://{att['op_vault']}/{att['op_item']}/{att['op_ref']}"
            out = os.path.join(tmp, att.get("name") or att["op_ref"])
            code, _, _ = run(["op", "read", ref, "--out-file", out], timeout=120)
            path = out if code == 0 else None
        if path and os.path.exists(path):
            prepared.append((item_id, path))
    ok = 0
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"),
                  BarColumn(), MofNCompleteColumn(), console=console) as progress:
        t = progress.add_task("📎 Uploading attachments", total=len(prepared))
        for item_id, path in prepared:
            success, _err = bw.cli_create_attachment(item_id, path)
            ok += 1 if success else 0
            progress.advance(t)
    shutil.rmtree(tmp, ignore_errors=True)
    print_success(f"Uploaded {ok}/{len(prepared)} attachment(s)")


