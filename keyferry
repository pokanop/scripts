# Rendering: normalized Item → Bitwarden item JSON
# =============================================================================

def item_to_bw(it: Item, org_id=None, collection_ids=None, deferred_attachments=None, tags_mode="drop"):
    """Build a bw item JSON. Oversized field values are diverted to attachments.

    Bitwarden has no tags/labels concept, so 1Password tags are dropped by default
    (we never create folders for them). tags_mode="field" preserves them as a field.
    """
    fields = []
    notes = it.notes or ""
    if tags_mode == "field" and it.tags:
        fields.append({"name": "1Password Tags", "value": ", ".join(it.tags), "type": 0})

    def add_field(name, value, hidden):
        nonlocal notes
        if value is None:
            return
        value = str(value)
        if len(value) > BW_FIELD_MAX:
            # too large for any bw field → ship as a text attachment
            if deferred_attachments is not None:
                safe = re.sub(r"[^A-Za-z0-9._-]+", "_", name)[:60] or "field"
                deferred_attachments.append({"name": f"{safe}.txt", "text": value})
                notes += f"\n[{name}: stored as attachment {safe}.txt]"
                return
            value = value[:BW_FIELD_MAX]
        fields.append({"name": name, "value": value, "type": 1 if hidden else 0})

    for f in it.fields:
        add_field(f["name"], f["value"], f.get("hidden"))

    if len(notes) > BW_FIELD_MAX:
        if deferred_attachments is not None:
            deferred_attachments.append({"name": "notes.txt", "text": notes})
            notes = "[Full notes stored as attachment notes.txt]"
        else:
            notes = notes[:BW_FIELD_MAX]

    obj = {
        "type": BW_TYPE.get(it.category, 2),
        "name": it.title,
        "notes": notes or None,
        "favorite": it.favorite,
        "fields": fields,
        "organizationId": org_id,
        "collectionIds": collection_ids or None,
    }
    if it.category == "login":
        obj["login"] = {
            "username": it.username,
            "password": it.password,
            "totp": it.totp,
            "uris": [{"uri": u, "match": None} for u in it.uris],
        }
    elif it.category == "card":
        obj["card"] = it.card or {}
        # keep credentials discoverable even if unmapped
        if it.username or it.password:
            add_field("username", it.username, False)
            add_field("password", it.password, True)
    elif it.category == "identity":
        obj["identity"] = it.identity or {}
    elif it.category == "sshkey":
        obj["type"] = 2  # store as note unless we have structured key material
        obj["secureNote"] = {"type": 0}
    else:
        obj["secureNote"] = {"type": 0}
        if it.username or it.password or it.totp:
            add_field("username", it.username, False)
            add_field("password", it.password, True)
            if it.totp:
                add_field("totp", it.totp, True)
            obj["fields"] = fields
        for u in it.uris:
            add_field("url", u, False)
        obj["fields"] = fields
    return obj


def merge_bw_update(body, existing_raw):
    """Adapt an update payload to the existing Bitwarden item shape (preserve type/URIs)."""
    if not existing_raw:
        return body
    bw_type = existing_raw.get("type")
    if bw_type is not None:
        body["type"] = bw_type
    if bw_type == 1:
        uris = []
        for u in (body.get("login") or {}).get("uris") or []:
            if u.get("uri"):
                uris.append({"uri": u["uri"], "match": None})
        kept_fields = []
        for f in body.get("fields") or []:
            if _is_uri_field_name(f.get("name")):
                if f.get("value"):
                    uri = str(f["value"])
                    if not any(x.get("uri") == uri for x in uris):
                        uris.append({"uri": uri, "match": None})
            else:
                kept_fields.append(f)
        login = dict(existing_raw.get("login") or {})
        if uris:
            login["uris"] = uris
        body["login"] = login
        body["fields"] = kept_fields
        body.pop("secureNote", None)
    return body


