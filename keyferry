    it.category = BW_TYPE_FOLD.get(raw.get("type"), "note")
    it.source_category = it.category
    it.favorite = bool(raw.get("favorite"))
    it.modified_at = _parse_ts(raw.get("revisionDate"))
    it.notes = raw.get("notes") or ""
    if collections_by_id is not None:
        if raw.get("organizationId"):
            cids = raw.get("collectionIds") or []
            it.vault = collections_by_id.get(cids[0], "Shared") if cids else "Shared"
        else:
            it.vault = "Private"
    login = raw.get("login") or {}
    it.username = login.get("username")
    it.password = login.get("password")
    it.totp = login.get("totp")
    for u in login.get("uris", []) or []:
        if u.get("uri"):
            it.uris.append(u["uri"])
    for val in _uris_from_bw_fields(raw.get("fields")):
        if val not in it.uris:
            it.uris.append(val)
    for f in raw.get("fields", []) or []:
        it.fields.append({"name": f.get("name") or "field", "value": f.get("value") or "",
                          "hidden": f.get("type") == 1})
    if raw.get("card"):
        it.card = raw["card"]
    if raw.get("identity"):
        it.identity = raw["identity"]
    return it


def read_bw_live(bw_items, collections_by_id):
