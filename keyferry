def _config_set_nested(config, key_path, value):
    parts = key_path.split(".")
    node = config
    for part in parts[:-1]:
        node = node.setdefault(part, {})
    if isinstance(value, str):
        low = value.lower()
        if low in ("true", "yes"):
            value = True
        elif low in ("false", "no"):
            value = False
        elif low in ("null", "none"):
            value = None
        else:
            try:
                value = int(value)
            except ValueError:
                pass
    node[parts[-1]] = value


def _config_get_nested(config, key_path):
    node = config
    for part in key_path.split("."):
        if not isinstance(node, dict):
            return None
        node = node.get(part)
    return node


