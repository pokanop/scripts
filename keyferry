def _read_key():
    """Single keypress → 'up'/'down'/'space'/'enter'/'esc'/'q'/char. None if not a TTY."""
    if not sys.stdin.isatty() or not HAS_READCHAR:
        return None
    k = readchar.readkey()
    mapping = {
        readchar.key.UP: "up", readchar.key.DOWN: "down",
        readchar.key.ENTER: "enter", readchar.key.SPACE: "space",
        readchar.key.ESC: "esc", readchar.key.CTRL_C: "ctrl_c",
    }
    if k in mapping:
        if mapping[k] == "ctrl_c":
            raise KeyboardInterrupt()
        return mapping[k]
    return k if isinstance(k, str) else None


def _prompt(text_str, default="", style="bold cyan"):
    prompt = Text()
    prompt.append(f"  {text_str}", style=style)
    if default:
        prompt.append(f" [{default}]", style="dim")
    prompt.append(": ", style=style)
    try:
        val = console.input(prompt).strip()
    except EOFError:
        return default
    return val or default


def _prompt_yes_no(text_str, default=True):
    resp = _prompt(f"{text_str} ({'Y/n' if default else 'y/N'})", "")
    if not resp:
        return default
    return resp.lower().startswith("y")


