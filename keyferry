def cmd_tidy_folders(args):
    console.print(banner())
    console.print()
    bw = BwClient()
    if not bw.available() or (bw.status() or {}).get("status") != "unlocked":
        raise KeyferryError("bw not available or locked (run: bw unlock)")
    bw.cli_sync()
    folders = [f for f in bw.cli_list_folders() if f.get("id") and f.get("name") != "No Folder"]
    if not folders:
        print_success("No personal folders to tidy. 🎉")
        return

    # count items per folder (include archived) to show impact / find empties
    items = bw.cli_list_items(include_archived=True)
    in_use = {}
    for i in items:
        fid = i.get("folderId")
        if fid:
            in_use[fid] = in_use.get(fid, 0) + 1

    from collections import Counter
    dup_names = {n for n, c in Counter(f["name"] for f in folders).items() if c > 1}
    targets = [f for f in folders if not in_use.get(f["id"])] if args.empty_only else folders

    table = Table(title="🗂️  Personal folders", header_style="bold cyan", title_style="bold")
    table.add_column("Folder"); table.add_column("Items", justify="right")
    table.add_column("", style="dim")
    for f in sorted(folders, key=lambda x: x["name"]):
        flags = []
        if f["name"] in dup_names:
            flags.append("duplicate")
        if not in_use.get(f["id"]):
            flags.append("empty")
        table.add_row(f["name"], str(in_use.get(f["id"], 0)), ", ".join(flags))
    console.print(table)
    console.print()
    print_info("Bitwarden has no tags/labels — these usually come from a native 1Password import "
               "mapping tags→folders. Deleting a folder only un-assigns its items (no items are lost).")
    label = "empty folders" if args.empty_only else "ALL personal folders"
    print_warning(f"About to delete {len(targets)} {label}. Items move to 'No Folder'.")
    if not targets:
        print_success("Nothing to delete.")
        return
    if not args.yes and not _prompt_yes_no(f"Delete {len(targets)} folder(s)?", False):
        print_warning("Aborted.")
        return

    ok = 0
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"),
                  BarColumn(), MofNCompleteColumn(), console=console) as progress:
        t = progress.add_task("🗑️  Deleting folders", total=len(targets))
        for f in targets:
            success, _err = bw.cli_delete_folder(f["id"])
            ok += 1 if success else 0
            progress.advance(t)
    bw.cli_sync()
    print_success(f"Deleted {ok}/{len(targets)} folder(s). Items preserved in 'No Folder'.")


