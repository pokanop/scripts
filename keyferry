OP_CATEGORY = {"login": "LOGIN", "note": "SECURE_NOTE", "card": "CREDIT_CARD",
               "identity": "IDENTITY", "sshkey": "SECURE_NOTE"}


def item_to_op(it: Item):
    fields = []
    if it.category == "login" or it.username or it.password:
        fields.append({"id": "username", "type": "STRING", "purpose": "USERNAME",
                       "label": "username", "value": it.username or ""})
        fields.append({"id": "password", "type": "CONCEALED", "purpose": "PASSWORD",
                       "label": "password", "value": it.password or ""})
    fields.append({"id": "notesPlain", "type": "STRING", "purpose": "NOTES",
                   "label": "notesPlain", "value": it.notes or ""})
    if it.totp:
        fields.append({"id": "one-time password", "type": "OTP",
                       "label": "one-time password", "value": it.totp,
                       "section": {"id": "extra"}})
    # preserve structured card / identity data as fields (op has no 1:1 import here)
    for blob in (it.card, it.identity):
        if isinstance(blob, dict):
            for k, v in blob.items():
                if v in (None, ""):
                    continue
                fields.append({"id": re.sub(r"\W+", "_", str(k))[:40] or "field",
                               "type": "CONCEALED" if k in ("number", "code", "cvv") else "STRING",
                               "label": k, "value": str(v), "section": {"id": "extra"}})
    for f in it.fields:
        fields.append({"id": re.sub(r"\W+", "_", f["name"])[:40] or "field",
                       "type": "CONCEALED" if f.get("hidden") else "STRING",
                       "label": f["name"], "value": str(f["value"]),
                       "section": {"id": "extra"}})
    obj = {
        "title": it.title,
        "category": OP_CATEGORY.get(it.category, "SECURE_NOTE"),
        "fields": fields,
    }
    if it.uris:
        obj["urls"] = [{"href": u, "primary": (i == 0)} for i, u in enumerate(it.uris)]
    if any(f.get("section", {}).get("id") == "extra" for f in fields):
        obj["sections"] = [{"id": "extra", "label": "Imported fields"}]
    return obj


# =============================================================================
# Mapping resolver — 1P vault + state → Bitwarden destination
# =============================================================================

class Destination:
    PERSONAL = "personal"

    def __init__(self, kind, collection_name=None):
        self.kind = kind                       # "personal" | "collection"
        self.collection_name = collection_name

    def label(self):
        return "My Vault" if self.kind == "personal" else f"Collection: {self.collection_name}"

    def key(self):
        return "personal" if self.kind == "personal" else f"collection:{self.collection_name}"


def _parse_dest(spec):
    if spec == "personal":
        return Destination("personal")
    if spec and spec.startswith("collection:"):
        return Destination("collection", spec.split(":", 1)[1])
    return None


def resolve_destination(it: Item, mapping):
    if it.state == "archived":
        policy = mapping.get("archived_policy", "native")
        if policy == "skip":
            return None
        if policy.startswith("collection:"):
            return Destination("collection", policy.split(":", 1)[1])
        # "native" / "active" → fall through to the item's normal destination
    private = set(mapping.get("private_vaults", []))
    if it.vault in private:
        return _parse_dest(mapping.get("private_destination", "personal")) or Destination("personal")
    overrides = mapping.get("vault_to_collection", {})
    name = overrides.get(it.vault, it.vault)
    return Destination("collection", name)


def should_archive(it: Item, mapping):
    """True if this item must be natively archived after creation."""
    return it.state == "archived" and mapping.get("archived_policy", "native") == "native"


# =============================================================================
# Engine: plan + execute (1Password → Bitwarden)
# =============================================================================

class ExistingEntry:
    """A destination item matched by identity signature."""

    __slots__ = ("id", "revision_date", "fingerprint")

    def __init__(self, item_id, revision_date, fingerprint):
        self.id = item_id
        self.revision_date = revision_date
        self.fingerprint = fingerprint


class PlanRow:
    def __init__(self, dest):
        self.dest = dest
        self.create = []     # Items to create
        self.duplicate = []  # Items skipped (already present)
        self.update = []     # Items to update in place (existing id, new item)


def item_needs_update(src: Item, existing: ExistingEntry, overwrite=False):
    """True when a matched item should be written to the destination."""
    if overwrite:
        return True
    same_visible = src.public_fingerprint() == existing.fingerprint
    if same_visible:
        # Visible content matches — update only when source is newer (secret-only change).
        if src.modified_at and existing.revision_date:
            return src.modified_at > existing.revision_date
        return False
    # Visible content differs — update only when source is provably newer.
    if src.modified_at and existing.revision_date:
        return src.modified_at > existing.revision_date
    return False


def lookup_existing(dest_key, it, existing_index, title_index, match_keys):
    """Find a destination item by signature, falling back to an unambiguous title match."""
    existing = existing_index.get(dest_key, {}).get(it.signature(match_keys))
    if existing:
        return existing
    cands = title_index.get(dest_key, {}).get(_norm(it.title), [])
    unique = {c.id: c for c in cands}
    if len(unique) == 1:
        return next(iter(unique.values()))
    return None


def build_plan(items, mapping, existing_index, title_index, match_keys, overwrite=False):
    """Group items by destination, classifying each as create/duplicate/update."""
    plan = {}
    skipped_archived = 0
    for it in items:
        dest = resolve_destination(it, mapping)
        if dest is None:
            skipped_archived += 1
            continue
        row = plan.setdefault(dest.key(), PlanRow(dest))
        existing = lookup_existing(dest.key(), it, existing_index, title_index, match_keys)
        if existing:
            if item_needs_update(it, existing, overwrite=overwrite):
                row.update.append((it, existing.id))
            else:
                row.duplicate.append(it)
        else:
            row.create.append(it)
    return plan, skipped_archived


def build_existing_index(bw_items, collections_by_id, match_keys):
    """Index Bitwarden items by destination → signature and normalized title."""
    index = {}
    title_index = {}
    for raw in bw_items:
        it = _item_from_bw(raw)
        sig = it.signature(match_keys)
        entry = ExistingEntry(raw["id"], it.modified_at, it.public_fingerprint())

        def _add(dest_key):
            index.setdefault(dest_key, {})[sig] = entry
            title_index.setdefault(dest_key, {}).setdefault(_norm(it.title), []).append(entry)

        if raw.get("organizationId"):
            for cid in raw.get("collectionIds") or []:
                name = collections_by_id.get(cid)
                if name:
                    _add(f"collection:{name}")
        else:
            _add("personal")
    return index, title_index


