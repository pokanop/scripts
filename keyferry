        tot_a = sum(1 for i in active_items if i.get("organizationId") == org["id"])
        tot_r = sum(1 for i in archived_items if i.get("organizationId") == org["id"])
        bt.add_row(f"[bold]{org['name']}[/bold] (org)", str(tot_a), str(tot_r))
        for cid, cname in sorted(cmap.items(), key=lambda kv: kv[1]):
            bt.add_row(f"  └ {cname}", str(act_coll.get(cid, 0)), str(arc_coll.get(cid, 0)))
    console.print(bt)
    console.print()


