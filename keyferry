_OP_ALIASES = {"1password", "1p", "op", "onepassword"}
_BW_ALIASES = {"bitwarden", "bw", "vaultwarden", "vw"}


def resolve_endpoint(value):
    """Parse a --from/--to value into (platform, kind, ref).

    platform: "onepassword" | "bitwarden"
    kind:     "live" | "file"
    ref:      file path for kind=="file", else None
    Returns None if value is None.
    """
    if value is None:
        return None
    v = value.strip().lower()
    if v in _OP_ALIASES:
        return ("onepassword", "live", None)
    if v in _BW_ALIASES:
        return ("bitwarden", "live", None)
    if value.endswith(".1pux") or Path(value).exists():
        return ("onepassword", "file", value)
    raise KeyferryError(f"unknown endpoint {value!r} — use 1password, bitwarden, or a .1pux file path")


def _load_source_items(src, args):
    platform, kind, ref = src
    if platform == "onepassword" and kind == "file":
        if not Path(ref).exists():
            raise KeyferryError(f"file not found: {ref}")
        with console.status("📦 Reading 1Password export…"):
            items = read_1pux(ref)
        print_success(f"Read {len(items)} items from {Path(ref).name}")
        return items
    if platform == "onepassword" and kind == "live":
        op = OpClient(account=args.account)
        if not op.available() or not op.configured():
            raise KeyferryError("op not available or not signed in (run: op signin)")
        with console.status("🔐 Reading 1Password live via op…") as status:
            items = read_op_live(op, progress_cb=lambda v, n: status.update(f"🔐 Read vault {v} ({n})…"))
        print_success(f"Read {len(items)} items live from 1Password")
        return items
    raise KeyferryError(f"cannot read items from {platform}")


def _resolve_org(bw, cfg):
    orgs = bw.cli_list_organizations()
    want = cfg["mapping"].get("organization")
    if want:
        for o in orgs:
            if o["id"] == want or o["name"] == want:
                return o
    if len(orgs) == 1:
        return orgs[0]
    if not orgs:
        return None  # personal-only migrations don't need an org
    raise KeyferryError("multiple organizations; set mapping.organization in config or pass --org")


# =============================================================================
# Command: sync / plan — resolve --from/--to and dispatch the right direction
# =============================================================================

def cmd_sync(args, execute=False):
    console.print(banner())
    console.print()
    src = resolve_endpoint(args.source)
    dst = resolve_endpoint(args.target)
    if not src:
        raise KeyferryError("specify --from (1password | bitwarden | path/to.1pux)")
    if not dst:
        raise KeyferryError("specify --to (1password | bitwarden)")
    if dst[1] == "file":
        raise KeyferryError("--to must be a live platform (1password | bitwarden), not a file")
    if src[0] == dst[0]:
        raise KeyferryError(f"--from and --to are both {src[0]} — pick two different platforms")

    arrow = f"{src[0]}" + (f" ({Path(src[2]).name})" if src[1] == 'file' else "") + f" → {dst[0]}"
    print_info(f"Direction: {arrow}")
    console.print()

    if dst[0] == "bitwarden":
        _run_to_bitwarden(args, src, execute)
    else:  # → onepassword
        if src[0] != "bitwarden":
            raise KeyferryError("syncing to 1Password requires --from bitwarden")
        _run_to_onepassword(args, execute)


