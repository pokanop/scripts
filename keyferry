# Normalized item model + content signature (dedup)
# =============================================================================

def _norm(s):
    return re.sub(r"\s+", " ", (s or "").strip().lower())


def _uri_host(uri):
    """Reduce a URI to its bare host (drop scheme, port, path, query, www.)."""
    if not uri:
        return ""
    u = re.sub(r"^[a-z]+://", "", _norm(uri))
    host = re.split(r"[/?#]", u, maxsplit=1)[0]
    host = host.split("@")[-1].split(":")[0]
    return re.sub(r"^www\.", "", host)


_BW_URI_FIELD_NAMES = frozenset({"url", "website", "uri", "site"})


def _is_uri_field_name(name):
    """True for url-like field labels, including section-prefixed names ('Contact: website')."""
    n = _norm(name)
    if n in _BW_URI_FIELD_NAMES:
        return True
    return n.rsplit(":", 1)[-1].strip() in _BW_URI_FIELD_NAMES


def _uris_from_bw_fields(fields):
    """Recover URIs stored as custom fields (symmetric with item_to_bw note exports)."""
    uris = []
    for f in fields or []:
        if not _is_uri_field_name(f.get("name")):
            continue
        val = f.get("value")
        if val and val not in uris:
            uris.append(str(val))
    return uris


def _effective_uris(it):
    """URIs from overview/login plus url-like custom fields — used for identity matching."""
    uris = list(it.uris or [])
    for val in _uris_from_bw_fields(it.fields):
        if val not in uris:
            uris.append(val)
    return uris


def _parse_ts(value):
    """Parse a unix epoch or ISO-8601 string to UTC epoch seconds."""
    if value is None:
        return None
    if isinstance(value, (int, float)):
        return float(value)
    if isinstance(value, str):
        s = value.strip()
        if not s:
            return None
        if s.endswith("Z"):
            s = s[:-1] + "+00:00"
        try:
            from datetime import datetime
            return datetime.fromisoformat(s).timestamp()
        except ValueError:
            return None
    return None


class Item:
    """Source-agnostic credential. Sinks know how to render it for op or bw."""

    def __init__(self):
        self.title = ""
        self.category = "note"     # login|note|card|identity|sshkey
        self.source_category = ""  # original 1P/bw category name
        self.vault = ""            # source vault name
        self.state = "active"      # active|archived
        self.favorite = False
        self.username = None
        self.password = None
        self.totp = None
        self.uris = []
        self.notes = ""
        self.fields = []           # [{name, value, hidden}]
        self.card = None           # dict
        self.identity = None       # dict
        self.attachments = []      # [{name, path}]
        self.tags = []             # 1Password tags/labels (Bitwarden has no tag concept)
        self.modified_at = None    # source last-modified epoch (UTC); used for delta sync

    def primary_uri(self):
        eff = _effective_uris(self)
        return eff[0] if eff else ""

    def public_fingerprint(self):
        """Hash of non-secret sync content — comparable across source and destination."""
        parts = [self.category, _norm(self.title), _norm(self.username), _norm(self.totp)]
        parts.extend(sorted(_uri_host(u) for u in _effective_uris(self) if u))
        parts.append(_norm(self.notes))
        parts.append("1" if self.favorite else "0")
        for f in sorted(self.fields, key=lambda x: _norm(x.get("name"))):
            if _is_uri_field_name(f.get("name")):
                continue  # represented via it.uris
            if f.get("hidden"):
                continue
            parts.append(_norm(f.get("name")))
            parts.append(_norm(str(f.get("value") or "")))
        if isinstance(self.card, dict):
            parts.append(json.dumps(self.card, sort_keys=True, separators=(",", ":")))
        if isinstance(self.identity, dict):
            parts.append(json.dumps(self.identity, sort_keys=True, separators=(",", ":")))
        return hashlib.sha256("|".join(parts).encode()).hexdigest()

    def signature(self, match_keys):
        parts = []
        if "title" in match_keys:
            parts.append(_norm(self.title))
        if "username" in match_keys:
            parts.append(_norm(self.username))
        if "uri" in match_keys:
            # Match on host only — OAuth/SAML login URLs carry huge transient
            # query strings that differ every time, so full-URL matching misses.
            # Also consider url-like custom fields (e.g. identity "website").
            eff = _effective_uris(self)
            parts.append(_uri_host(eff[0] if eff else ""))
        if "category" in match_keys:
            parts.append(self.category)
        return hashlib.sha1("|".join(parts).encode()).hexdigest()


