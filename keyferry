def _field_string(val):
    if not isinstance(val, dict):
        return None
    for k in ("string", "concealed", "url", "email", "phone", "date", "monthYear", "menu"):
        if isinstance(val.get(k), str):
            return val[k]
        if val.get(k) is not None and not isinstance(val.get(k), dict):
            return str(val[k])
    return None


def read_1pux(path):
    """Yield (account_name, [Item]) reading a .1pux archive."""
    with zipfile.ZipFile(path) as z:
        data = json.loads(z.read("export.data"))
        disk_files = {n.split("/", 1)[1] for n in z.namelist() if n.startswith("files/") and "/" in n}
    docid_to_name = {}
    for fn in disk_files:
        docid = fn.split("__")[0].split(".")[0]
        docid_to_name[docid] = fn

    items = []
    for acct in data.get("accounts", []):
        for vault in acct.get("vaults", []):
            vname = vault.get("attrs", {}).get("name", "")
            for raw in vault.get("items", []):
                it = _item_from_1pux(raw, vname, docid_to_name, path)
                if it:
                    items.append(it)
    return items


def _item_from_1pux(raw, vname, docid_to_name, pux_path):
    cat_code = raw.get("categoryUuid") or raw.get("category")
    source_cat = ONEPUX_CATEGORIES.get(cat_code, cat_code or "Login")
    det = raw.get("details", {}) or {}
    ov = raw.get("overview", {}) or {}

    it = Item()
    it.title = ov.get("title") or "(untitled)"
    it.source_category = source_cat
    it.category = CATEGORY_FOLD.get(source_cat, "note")
    it.vault = vname
    it.state = raw.get("state", "active")
    it.modified_at = _parse_ts(raw.get("updatedAt"))
    it.favorite = bool(raw.get("favIndex"))
    it.tags = ov.get("tags") or raw.get("tags") or []
    it.notes = det.get("notesPlain") or ""

    # urls
    for u in ov.get("urls", []) or []:
        if u.get("url"):
            it.uris.append(u["url"])
    if ov.get("url") and ov["url"] not in it.uris:
        it.uris.append(ov["url"])

    # login fields
    for lf in det.get("loginFields", []) or []:
        des = lf.get("designation")
        val = lf.get("value")
        if val in (None, "", "✓"):
            continue
        if des == "username" and it.username is None:
            it.username = val
        elif des == "password" and it.password is None:
            it.password = val
        else:
            name = lf.get("name") or des or "field"
            it.fields.append({"name": name, "value": val,
                              "hidden": (lf.get("type") == "P" or des == "password")})

    # section fields (custom fields, totp, file attachments)
    for sec in det.get("sections", []) or []:
        sec_title = sec.get("title") or ""
        for f in sec.get("fields", []) or []:
            val = f.get("value", {})
            if not isinstance(val, dict):
                continue
            if "totp" in val and val["totp"]:
                it.totp = val["totp"]
                continue
            if isinstance(val.get("file"), dict) and val["file"].get("documentId"):
                fname = val["file"].get("fileName") or val["file"]["documentId"]
                it.attachments.append({"name": fname,
                                       "docid": val["file"]["documentId"], "pux": str(pux_path)})
                continue
            sval = _field_string(val)
            if sval in (None, ""):
                continue
            label = f.get("title") or "field"
            if sec_title:
                label = f"{sec_title}: {label}"
            concealed = "concealed" in val
            it.fields.append({"name": label, "value": sval, "hidden": concealed})

    # document-category attachment
    da = det.get("documentAttributes")
    if da and da.get("documentId"):
        it.attachments.append({"name": da.get("fileName") or da["documentId"],
                               "docid": da["documentId"], "pux": str(pux_path)})
    return it


def extract_1pux_attachment(pux_path, docid, out_dir):
    """Extract a file by document id from a .1pux to out_dir; return its path."""
    with zipfile.ZipFile(pux_path) as z:
        for n in z.namelist():
            if n.startswith("files/") and n.split("/", 1)[1].split("__")[0].split(".")[0] == docid:
                target = Path(out_dir) / Path(n).name
                target.write_bytes(z.read(n))
                return str(target)
    return None


