class OpClient:
    def __init__(self, account=None):
        self.account = account

    def _base(self):
        cmd = ["op"]
        if self.account:
            cmd += ["--account", self.account]
        return cmd

    def available(self):
        return which("op")

    def version(self):
        code, out, _ = run(["op", "--version"], timeout=10)
        return out if code == 0 else None

    def accounts(self):
        """Locally configured accounts — reads cached config, no biometric prompt."""
        code, out, _ = run(["op", "account", "list", "--format", "json"], timeout=10)
        if code != 0:
            return []
        try:
            return json.loads(out or "[]")
        except json.JSONDecodeError:
            return []

    def configured(self):
        """True if op has a usable account configured (no unlock prompt triggered)."""
        accts = self.accounts()
        if not accts:
            return None
        if self.account:
            for a in accts:
                if self.account in (a.get("shorthand"), a.get("url"), a.get("account_uuid"), a.get("email")):
                    return a
            return None
        return accts[0]

    def vaults(self):
        code, out, err = run(self._base() + ["vault", "list", "--format", "json"], timeout=30)
        if code != 0:
            raise KeyferryError(f"op vault list failed: {err}")
        return json.loads(out)

    def list_items(self, vault_id, include_archive=False):
        cmd = self._base() + ["item", "list", "--vault", vault_id, "--format", "json"]
        if include_archive:
            cmd.append("--include-archive")
        code, out, err = run(cmd, timeout=120)
        if code != 0:
            raise KeyferryError(f"op item list failed for vault {vault_id}: {err}")
        return json.loads(out or "[]")

    def get_items_full(self, vault_id, item_ids):
        """Batch-fetch full item details by piping ids into `op item get -`."""
        if not item_ids:
            return []
        payload = "\n".join(json.dumps({"id": i}) for i in item_ids)
        cmd = self._base() + ["item", "get", "-", "--vault", vault_id, "--format", "json"]
        code, out, err = run(cmd, timeout=600, input_text=payload)
        if code != 0:
            raise KeyferryError(f"op item get failed: {err}")
        data = json.loads(out or "[]")
        return data if isinstance(data, list) else [data]

    def ensure_vault(self, name):
        for v in self.vaults():
            if v["name"] == name:
                return v["id"]
        code, out, err = run(self._base() + ["vault", "create", name, "--format", "json"], timeout=30)
        if code != 0:
            raise KeyferryError(f"could not create vault {name!r}: {err}")
        return json.loads(out)["id"]

    def create_item(self, vault_id, op_item_json):
        cmd = self._base() + ["item", "create", "--vault", vault_id, "-", "--format", "json"]
        code, out, err = run(cmd, timeout=60, input_text=json.dumps(op_item_json))
        if code != 0:
            return None, err
        try:
            return json.loads(out), None
        except json.JSONDecodeError:
            return None, "unparseable op response"


# =============================================================================
# Bitwarden client (bw CLI + bw serve fast-path)
# =============================================================================

class BwClient:
    def __init__(self, port=8087, concurrency=8):
        self.port = port
        self.concurrency = concurrency
        self._proc = None
        self._base_url = f"http://localhost:{port}"
        self._session = requests.Session() if HAS_REQUESTS else None

    # ---- CLI ----
    def available(self):
        return which("bw")

    def version(self):
        code, out, _ = run(["bw", "--version"], timeout=10)
        return out if code == 0 else None

    def status(self):
        code, out, _ = run(["bw", "status"], timeout=15)
        if code != 0:
            return None
        try:
            return json.loads(out)
        except json.JSONDecodeError:
            return None

    def cli_sync(self):
        run(["bw", "sync"], timeout=120)

    # ---- serve lifecycle ----
    def start_serve(self):
        if not HAS_REQUESTS:
            raise KeyferryError("the 'requests' package is required (pip install requests)")
        self.stop_serve()
        self._proc = subprocess.Popen(
            ["bw", "serve", "--port", str(self.port)],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        atexit.register(self.stop_serve)
        # wait for readiness
        for _ in range(40):
            try:
                r = self._session.get(f"{self._base_url}/status", timeout=2)
                if r.ok and r.json().get("data", {}).get("template", {}).get("status") == "unlocked":
                    return
                if r.ok:
                    st = r.json().get("data", {}).get("template", {}).get("status")
                    if st and st != "unlocked":
                        raise KeyferryError(f"Bitwarden vault is '{st}'. Run: bw unlock")
            except KeyferryError:
                raise
            except Exception:  # noqa: BLE001
                pass
            time.sleep(0.5)
        raise KeyferryError("bw serve did not become ready (is the vault unlocked? run: bw unlock)")

    def stop_serve(self):
        if self._proc and self._proc.poll() is None:
            self._proc.terminate()
            try:
                self._proc.wait(timeout=5)
            except subprocess.TimeoutExpired:
                self._proc.kill()
        self._proc = None

    @contextmanager
    def serve(self):
        self.start_serve()
        try:
            yield self
        finally:
            self.stop_serve()

    # ---- serve requests ----
    def _get(self, path, params=None):
        r = self._session.get(f"{self._base_url}{path}", params=params, timeout=60)
        return r.json()

    def _post(self, path, body=None):
        r = self._session.post(f"{self._base_url}{path}", json=body, timeout=120)
        return self._parse_response(r)

    def _put(self, path, body=None):
        r = self._session.put(f"{self._base_url}{path}", json=body, timeout=120)
        return self._parse_response(r)

    def _delete(self, path):
        r = self._session.delete(f"{self._base_url}{path}", timeout=60)
        return self._parse_response(r)

    @staticmethod
    def _parse_response(r):
        try:
            return r.json()
        except ValueError:
            snippet = (r.text or "").strip()[:200]
            raise KeyferryError(
                f"Bitwarden API returned non-JSON (HTTP {r.status_code}): {snippet or '(empty)'}"
            )

    def serve_sync(self):
        self._post("/sync")

    def list_items(self):
        return self._get("/list/object/items").get("data", {}).get("data", [])

    def list_org_collections(self, org_id):
        return self._get("/list/object/org-collections",
                         {"organizationid": org_id}).get("data", {}).get("data", [])

    def create_item(self, item_json):
        resp = self._post("/object/item", item_json)
        if resp.get("success"):
            return resp.get("data", {}).get("id"), None
        return None, resp.get("message", "unknown error")

    def get_item(self, item_id):
        resp = self._get(f"/object/item/{item_id}")
        return resp.get("data") if resp.get("success") else None

    def edit_item(self, item_id, item_json):
        resp = self._put(f"/object/item/{item_id}", item_json)
        return resp.get("success"), resp.get("message")

    # ---- CLI-only operations (run with serve stopped to avoid cache races) ----
    def cli_list_items(self, include_archived=False):
        code, out, err = run(["bw", "list", "items"], timeout=120)
        if code != 0:
            raise KeyferryError(f"bw list items failed: {err}")
        items = json.loads(out or "[]")
        if include_archived:
            code, out, _ = run(["bw", "list", "items", "--archived"], timeout=120)
            if code == 0:
                items += json.loads(out or "[]")
        return items

    def cli_archive_item(self, item_id):
        code, _out, err = run(["bw", "archive", "item", item_id], timeout=30)
        return code == 0, err

    def cli_list_folders(self):
        code, out, _ = run(["bw", "list", "folders"], timeout=30)
        return json.loads(out or "[]") if code == 0 else []

    def cli_delete_folder(self, folder_id):
        # Deleting a folder only unassigns its items (they move to "No Folder").
        code, _out, err = run(["bw", "delete", "folder", folder_id], timeout=30)
        return code == 0, err

    def cli_list_organizations(self):
        code, out, _ = run(["bw", "list", "organizations"], timeout=30)
        return json.loads(out or "[]") if code == 0 else []

    def cli_list_org_collections(self, org_id):
        code, out, _ = run(["bw", "list", "org-collections", "--organizationid", org_id], timeout=30)
        return json.loads(out or "[]") if code == 0 else []

    def cli_create_collection(self, org_id, name):
        body = {"organizationId": org_id, "name": name, "externalId": None, "groups": []}
        enc = subprocess.run(["bw", "encode"], input=json.dumps(body),
                             capture_output=True, text=True).stdout.strip()
        code, out, err = run(["bw", "create", "org-collection", "--organizationid", org_id, enc], timeout=30)
        if code != 0:
            raise KeyferryError(f"could not create collection {name!r}: {err}")
        return json.loads(out)["id"]

    def cli_create_attachment(self, item_id, file_path):
        code, out, err = run(["bw", "create", "attachment", "--itemid", item_id, "--file", file_path], timeout=120)
        return code == 0, (err or out)

    def parallel(self, fn, items, description="Working"):
        """Run fn(item) across items via a thread pool with a progress bar."""
        results = []
        with Progress(
            SpinnerColumn(), TextColumn("[progress.description]{task.description}"),
            BarColumn(), MofNCompleteColumn(), TaskProgressColumn(), TimeElapsedColumn(),
            console=console,
        ) as progress:
            task = progress.add_task(description, total=len(items))
            with concurrent.futures.ThreadPoolExecutor(max_workers=self.concurrency) as pool:
                futures = {pool.submit(fn, it): it for it in items}
                for fut in concurrent.futures.as_completed(futures):
                    results.append(fut.result())
                    progress.advance(task)
        return results


