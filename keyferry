def build_parser():
    p = argparse.ArgumentParser(
        prog="keyferry",
        description=f"{EMOJI} keyferry v{__version__} — 1Password ⇄ Bitwarden/Vaultwarden ferry",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Endpoints (--from / --to):
              1password | 1p | op    1Password live via the op CLI
              bitwarden | bw         Bitwarden/Vaultwarden live via the bw CLI
              path/to/export.1pux    a 1Password .1pux export file (--from only)

            Examples:
              keyferry doctor                                       Check op/bw CLIs and auth
              keyferry status --from export.1pux                    Compare both sides
              keyferry plan --from export.1pux --to bitwarden       Preview (no writes, dedup-aware)
              keyferry sync --from export.1pux --to bitwarden       Ferry 1Password → Bitwarden
              keyferry sync --from 1password   --to bitwarden       Ferry live (deltas only)
              keyferry sync --from bitwarden   --to 1password       Reverse direction
              keyferry sync --from 1password --to bitwarden --overwrite
              keyferry map                                          Edit vault→collection mapping

            Matched items are updated when the source is newer than the destination.
            Pass --overwrite to force-update every match regardless of timestamps.
        """),
    )
    p.add_argument("-v", "--version", action="version", version=f"keyferry {__version__}")
    sub = p.add_subparsers(dest="command")

    def add_sync_args(sp):
        sp.add_argument("--from", dest="source", metavar="SRC",
                        help="source: 1password | bitwarden | path/to.1pux")
        sp.add_argument("--to", dest="target", metavar="DST",
                        help="target: 1password | bitwarden")
        sp.add_argument("--account", help="op account shorthand (for live 1Password)")
        sp.add_argument("--org", help="target Bitwarden organization name/id")
        sp.add_argument("--overwrite", action="store_true",
                        help="force-update all matched items, even when destination is newer")
        sp.add_argument("--skip-archived", action="store_true", help="don't transfer archived items")
        sp.add_argument("--archived-active", action="store_true",
                        help="transfer archived items but leave them active (don't native-archive)")
        sp.add_argument("--keep-tags", action="store_true",
                        help="preserve 1Password tags as a custom field (default: drop — Bitwarden has no tags)")
        sp.add_argument("--no-attachments", action="store_true", help="skip file attachments")
        sp.add_argument("-y", "--yes", action="store_true", help="skip confirmation")

    dp = sub.add_parser("doctor", help="Check CLIs, auth, versions")
    dp.add_argument("--account", help="op account shorthand")

    sp = sub.add_parser("status", help="Show both sides")
    sp.add_argument("--from", dest="source", metavar="SRC",
                    help="1Password source for the 1P side: 1password or a .1pux file")
    sp.add_argument("--account", help="op account shorthand")

    sp = sub.add_parser("plan", help="Dry-run: what would be created/skipped")
    add_sync_args(sp)

    sp = sub.add_parser("sync", help="Ferry credentials --from one side --to the other")
    add_sync_args(sp)

    sub.add_parser("map", help="Interactively edit the mapping")

    sp = sub.add_parser("tidy-folders", help="Delete personal folders (e.g. junk from a native import)")
    sp.add_argument("--empty-only", action="store_true", help="only delete folders with no items")
    sp.add_argument("-y", "--yes", action="store_true", help="skip confirmation")

    sp = sub.add_parser("config", help="Manage configuration")
    csub = sp.add_subparsers(dest="config_action")
    csub.add_parser("list")
    g = csub.add_parser("get"); g.add_argument("key")
    s = csub.add_parser("set"); s.add_argument("key"); s.add_argument("value")
    return p


def main():
    parser = build_parser()
    args = parser.parse_args()
    # normalize optional attrs that may be absent depending on subcommand
    for attr in ("source", "target", "account", "org", "overwrite",
                 "skip_archived", "archived_active", "keep_tags", "empty_only",
                 "no_attachments", "yes"):
        if not hasattr(args, attr):
            setattr(args, attr, None)

    try:
        if args.command == "doctor":
            cmd_doctor(args)
        elif args.command == "status":
            cmd_status(args)
        elif args.command == "plan":
            cmd_sync(args, execute=False)
        elif args.command == "sync":
            cmd_sync(args, execute=True)
        elif args.command == "map":
            cmd_map(args)
        elif args.command == "tidy-folders":
            cmd_tidy_folders(args)
        elif args.command == "config":
            cmd_config(args)
        else:
            console.print(banner())
            console.print()
            parser.print_help()
    except KeyferryError as e:
        print_error(str(e))
        sys.exit(1)
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Interrupted.[/yellow]")
        sys.exit(130)


if __name__ == "__main__":
    main()
