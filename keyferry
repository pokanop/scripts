def read_op_live(op: "OpClient", progress_cb=None):
    items = []
    vaults = op.vaults()
    for v in vaults:
        active_ids = [i["id"] for i in op.list_items(v["id"], include_archive=False)]
        all_ids = [i["id"] for i in op.list_items(v["id"], include_archive=True)]
        active_set = set(active_ids)
        full = op.get_items_full(v["id"], all_ids)
        for raw in full:
            it = _item_from_op(raw, v["name"])
            it.state = "active" if raw.get("id") in active_set else "archived"
            items.append(it)
        if progress_cb:
            progress_cb(v["name"], len(full))
    return items


OP_CAT_FOLD = {
    "LOGIN": "login", "PASSWORD": "login", "API_CREDENTIAL": "note",
    "CREDIT_CARD": "card", "BANK_ACCOUNT": "card",
    "IDENTITY": "identity", "PASSPORT": "identity", "DRIVER_LICENSE": "identity",
    "SOCIAL_SECURITY_NUMBER": "identity", "MEMBERSHIP": "identity",
    "SSH_KEY": "sshkey", "SECURE_NOTE": "note",
}


def _item_from_op(raw, vault_name):
    it = Item()
    it.title = raw.get("title") or "(untitled)"
    it.source_category = raw.get("category", "")
    it.category = OP_CAT_FOLD.get(raw.get("category", ""), "note")
    it.vault = vault_name
    it.modified_at = _parse_ts(raw.get("updated_at"))
    it.favorite = bool(raw.get("favorite"))
    it.tags = raw.get("tags") or []
    for u in raw.get("urls", []) or []:
        if u.get("href"):
            it.uris.append(u["href"])
    for f in raw.get("fields", []) or []:
        purpose = f.get("purpose")
        ftype = f.get("type")
        val = f.get("value")
        if purpose == "USERNAME":
            it.username = val
        elif purpose == "PASSWORD":
            it.password = val
        elif purpose == "NOTES":
            it.notes = val or ""
        elif ftype == "OTP" and val:
            it.totp = val
        elif val not in (None, ""):
            label = f.get("label") or f.get("id") or "field"
            sec = (f.get("section") or {}).get("id")
            if sec and sec != "add more":
                label = f"{sec}: {label}"
            it.fields.append({"name": label, "value": val, "hidden": ftype == "CONCEALED"})
    for fattr in raw.get("files", []) or []:
        it.attachments.append({"name": fattr.get("name"), "op_ref": fattr.get("id"),
                               "op_item": raw.get("id"), "op_vault": vault_name})
    return it


