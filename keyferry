def _run_to_onepassword(args, execute=False):
    cfg = load_config()
    match_keys = cfg["settings"]["match_keys"]

    op = OpClient(account=args.account)
    bw = BwClient()
    if not op.available() or not op.configured():
        raise KeyferryError("op not available or not signed in (run: op signin)")
    if not bw.available() or (bw.status() or {}).get("status") != "unlocked":
        raise KeyferryError("bw not available or locked (run: bw unlock)")

    with console.status("🛡️  Reading Bitwarden…"):
        bw.cli_sync()
        orgs = bw.cli_list_organizations()
        col_by_id = {}
        for o in orgs:
            for c in bw.cli_list_org_collections(o["id"]):
                col_by_id[c["id"]] = c["name"]
        bw_items = bw.cli_list_items()
    items = read_bw_live(bw_items, col_by_id)
    print_success(f"Read {len(items)} items from Bitwarden")

    # reverse mapping: BW vault label → op vault (Private→Private; collection name→same)
    rev = cfg["mapping"].get("reverse_vault_map", {})

    def op_vault_for(it):
        if it.vault == "Private":
            return rev.get("Private", "Private")
        return rev.get(it.vault, it.vault)

    # dedup against op
    with console.status("🔐 Indexing 1Password for dedup…"):
        op_vaults = {v["name"]: v["id"] for v in op.vaults()}
        op_index = {}
        for vname, vid in op_vaults.items():
            ids = [i["id"] for i in op.list_items(vid, include_archive=True)]
            for raw in op.get_items_full(vid, ids):
                oit = _item_from_op(raw, vname)
                op_index.setdefault(vname, set()).add(oit.signature(match_keys))

    to_create = []
    dup = 0
    for it in items:
        v = op_vault_for(it)
        if it.signature(match_keys) in op_index.get(v, set()):
            dup += 1
            continue
        to_create.append((v, it))

    console.print()
    t = Table(title="📋 Export plan (Bitwarden → 1Password)", header_style="bold cyan")
    t.add_column("1Password vault"); t.add_column("Create", justify="right", style="green")
    from collections import Counter
    cnt = Counter(v for v, _ in to_create)
    for v in sorted(cnt):
        t.add_row(v, str(cnt[v]))
    t.add_row("[bold]TOTAL[/bold]", f"[bold]{len(to_create)}[/bold]")
    console.print(t)
    print_info(f"Duplicates skipped: {dup}")

    if not execute:
        print_info("This was a dry run. Run [bold]keyferry sync[/bold] to apply.")
        return
    if not to_create:
        print_success("1Password already in sync. 🎉")
        return
    if not args.yes and not _prompt_yes_no(f"Create {len(to_create)} item(s) in 1Password?", True):
        print_warning("Aborted.")
        return

    vault_ids = {}
    ok = fail = 0
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"),
                  BarColumn(), MofNCompleteColumn(), console=console) as progress:
        task = progress.add_task("🛳️  Ferrying to 1Password", total=len(to_create))
        for vname, it in to_create:
            if vname not in vault_ids:
                vault_ids[vname] = op.ensure_vault(vname)
            _res, err = op.create_item(vault_ids[vname], item_to_op(it))
            ok += 1 if not err else 0
            fail += 1 if err else 0
            progress.advance(task)
    print_success(f"Created {ok} item(s) in 1Password" + (f"; {fail} failed" if fail else ""))
    console.print(f"\n{EMOJI} [bold green]Ferry complete.[/bold green]\n")


