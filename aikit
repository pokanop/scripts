# --- coverage capability model ---------------------------------------------
# Single source of truth for how (and whether) each agent in AGENTS reaches the
# gateway. The whole point of this model is that every agent lands in exactly one
# state, so `status`/`on`/`coverage` can account for all of them and never silently
# omit a detected tool.
#
#   renderer     aikit writes the tool's native config (the GATEWAY_TOOL_SPECS set)
#   env          routed by a standard/provider env var build_env_pairs() already sets
#   passthrough  routed through a native-protocol passthrough route (base URL + auth
#                var point at the route), resolved at RUNTIME from live discovery or a
#                user-declared custom mapping — see GATEWAY_PASSTHROUGH_ROUTES. A tool
#                only lands here when its route is usable AND it exposes a base-URL
#                override to point there; that makes it distinct from `env` (which is
#                wired unconditionally) and `unsupported` (no route, or no override).
#   pending      detected but not reliably routed yet — no renderer and the env path
#                is non-standard or absent; tracked here (visibly) until a later stage
#                adds a native renderer or a new env var
#   unsupported  no usable passthrough route AND no OpenAI-compatible/override path —
#                correct to exclude, but declared (with the real reason), not silent
COVERAGE_RENDERER = "renderer"
COVERAGE_ENV = "env"
COVERAGE_PASSTHROUGH = "passthrough"
COVERAGE_PENDING = "pending"
COVERAGE_UNSUPPORTED = "unsupported"
COVERAGE_UNCLASSIFIED = "unclassified"   # fallback for an agent nobody has classified

# Ordered for display (grouped, most-covered first) and for the `on` accounting.
COVERAGE_STATE_ORDER = (
    COVERAGE_RENDERER, COVERAGE_ENV, COVERAGE_PASSTHROUGH, COVERAGE_PENDING,
    COVERAGE_UNSUPPORTED, COVERAGE_UNCLASSIFIED,
)
# States that actually reach the gateway. Everything else is "detected but not routed".
COVERAGE_ROUTED_STATES = frozenset({COVERAGE_RENDERER, COVERAGE_ENV, COVERAGE_PASSTHROUGH})

# Declared coverage for every agent NOT handled by a native renderer. Renderer
