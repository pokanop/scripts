_serve_process = None

def do_serve(host=None, port=None, detach=False, stop=False):
    """Start/stop the web dashboard."""
    global _serve_process

    config = load_config()
    settings = config.get("settings", {})
    host = host or settings.get("web_host", "localhost")
    port = port or settings.get("web_port", 8765)

    # Stop existing server
    if stop:
        pid_file = CONFIG_DIR / "server.pid"
        if pid_file.exists():
            try:
                pid = int(pid_file.read_text().strip())
                os.kill(pid, signal.SIGTERM)
                pid_file.unlink()
                print_success("Server stopped")
            except (ProcessLookupError, ValueError):
                pid_file.unlink()
                print_info("Server was not running")
        return

    app = create_flask_app()

    if detach:
        # Fork and detach
        pid = os.fork()
        if pid > 0:
            # Parent
            CONFIG_DIR.mkdir(parents=True, exist_ok=True)
            (CONFIG_DIR / "server.pid").write_text(str(pid))
            print_success(f"Server started in background (PID {pid})")
            print_info(f"Dashboard: http://{host}:{port}")
            return
        # Child: detach from terminal
        os.setsid()

    print_panel("🌐 aikit Dashboard", f"Starting on http://{host}:{port}\nPress Ctrl-C to stop")

    try:
        app.run(host=host, port=port, debug=False, use_reloader=False)
    except KeyboardInterrupt:
        print_info("Server stopped")
        sys.exit(0)


