def _real_home():
    """Resolve the real user home, stripping Hermes profile overrides."""
    h = Path(os.environ.get("HOME", "/root")).resolve()
    parts = h.parts
    if ".hermes" in parts:
        idx = parts.index(".hermes")
        return Path(*parts[:idx]) if idx > 0 else Path("/")
    return h


_REAL_HOME = _real_home()


def discover_auth(agent_key):
    """Auto-detect whether an agent is authenticated by checking filesystem,
    environment variables, and credential files.
    Returns dict: {auth_configured: bool, method: str, source: str}
    """
    agent = AGENTS.get(agent_key)
    if not agent:
        return {"auth_configured": False, "method": "unknown", "source": ""}
    
    auth_type = agent.get("auth_type", "")
    env_vars = agent.get("auth_env_vars", [])
    
    # 1. Check environment variables (current process — most reliable)
    for var in env_vars:
        if os.environ.get(var):
            return {"auth_configured": True, "method": "env_var", "source": f"${var}"}
    
    # 2. Check agent-specific credential files (use real home, not Hermes-overridden home)
    home = _REAL_HOME
    
    # Claude Code: ~/.claude.json has oauthAccount, ~/.claude/.credentials.json has OAuth tokens
    if agent_key == "claude":
        # Primary: ~/.claude.json (contains oauthAccount, userID, hasCompletedOnboarding)
        claude_json = home / ".claude.json"
        if claude_json.exists() and claude_json.stat().st_size > 0:
            try:
                d = json.loads(claude_json.read_text())
                if d.get("oauthAccount") or d.get("hasCompletedOnboarding") or d.get("userID"):
                    return {"auth_configured": True, "method": "config_file", "source": str(claude_json)}
            except (json.JSONDecodeError, OSError):
                pass
        # Secondary: ~/.claude/.credentials.json (raw OAuth tokens)
        for cred_path in [home / ".claude" / ".credentials.json", home / ".claude" / "credentials.json"]:
            if cred_path.exists() and cred_path.stat().st_size > 0:
                try:
                    creds = json.loads(cred_path.read_text())
                    if creds:
                        for v in creds.values():
                            if isinstance(v, dict) and any(k in v for k in ("accessToken", "refreshToken")):
                                return {"auth_configured": True, "method": "cred_file", "source": str(cred_path)}
                except (json.JSONDecodeError, OSError):
                    pass
    
    # Cursor CLI: ~/.cursor/cli-config.json has authInfo block
    if agent_key == "cursor":
        cfg_path = home / ".cursor" / "cli-config.json"
        if cfg_path.exists():
            try:
                cfg = json.loads(cfg_path.read_text())
                ai = cfg.get("authInfo", {})
                if ai.get("email") or ai.get("userId"):
                    return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
            except (json.JSONDecodeError, OSError):
                pass
    
    # Hermes: ~/.hermes/.env or profile .env (API keys)
    if agent_key == "hermes":
        for env_path in [
            home / ".hermes" / ".env",
            home / ".hermes" / "profiles" / "coder" / ".env",
        ]:
            if env_path.exists():
                try:
                    content = env_path.read_text()
                    if 'ANTHROPIC_API_KEY=' in content or 'OPENROUTER_API_KEY=' in content:
                        return {"auth_configured": True, "method": "env_file", "source": str(env_path)}
                except OSError:
                    pass
    
    # Codex: ~/.codex/auth.json
    if agent_key == "codex":
        auth_file = home / ".codex" / "auth.json"
        if auth_file.exists() and auth_file.stat().st_size > 0:
            return {"auth_configured": True, "method": "cred_file", "source": str(auth_file)}
    
    # Kilo CLI: ~/.config/kilo/opencode.json(jsonc), ~/.kilo/config.json, opencode config
    if agent_key == "kilo":
        for cfg_path in [
            home / ".config" / "kilo" / "opencode.json",
            home / ".config" / "kilo" / "opencode.jsonc",
            home / ".kilo" / "config.json",
            home / ".config" / "opencode" / "opencode.json",
            home / ".config" / "opencode" / "opencode.jsonc",
        ]:
            if cfg_path.exists():
                try:
                    cfg_text = cfg_path.read_text()
                    if any(pat in cfg_text for pat in ("apiKey", "api_key", "provider", "ANTHROPIC_API_KEY", "OPENROUTER")):
                        return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
                except OSError:
                    pass
        # Kilo also stores auth at the project level — check current dir too
        for proj_path in [Path.cwd() / "opencode.json", Path.cwd() / "opencode.jsonc",
                          Path.cwd() / ".opencode" / "opencode.json"]:
            if proj_path.exists():
                try:
                    cfg_text = proj_path.read_text()
                    if any(pat in cfg_text for pat in ("apiKey", "api_key", "provider")):
                        return {"auth_configured": True, "method": "project_config", "source": str(proj_path)}
                except OSError:
                    pass
    
    # OpenCode: ~/.config/opencode/opencode.json or ~/.opencode/config.json
    if agent_key == "opencode":
        for cfg_path in [
            home / ".config" / "opencode" / "opencode.json",
            home / ".config" / "opencode" / "opencode.jsonc",
            home / ".opencode" / "config.json",
        ]:
            if cfg_path.exists():
                try:
                    cfg_text = cfg_path.read_text()
                    if any(pat in cfg_text for pat in ("apiKey", "api_key", "provider", "OPENROUTER", "ANTHROPIC")):
                        return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
                except OSError:
                    pass
    
    # GitHub Copilot: gh CLI auth or GITHUB_TOKEN/GH_TOKEN
    if agent_key == "copilot":
        gh_hosts = home / ".config" / "gh" / "hosts.yml"
        if gh_hosts.exists():
            content = gh_hosts.read_text()
            if "token:" in content:
                return {"auth_configured": True, "method": "gh_cli", "source": str(gh_hosts)}
    
    # Grok Build: ~/.grok/config.toml (xAI) + browser OAuth token
    if agent_key == "grok":
        cfg_path = home / ".grok" / "config.toml"
        if cfg_path.exists():
            try:
                content = cfg_path.read_text()
                if content.strip():
                    return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
            except OSError:
                pass
    
    # Antigravity: Google OAuth — check ~/.agy/ or gcloud credentials
    if agent_key == "antigravity":
        for agy_path in [home / ".agy", home / ".antigravity", home / ".config" / "antigravity"]:
            if agy_path.exists():
                try:
                    files = list(agy_path.glob("*"))
                    if files:
                        return {"auth_configured": True, "method": "config_dir", "source": str(agy_path)}
                except OSError:
                    pass
        # Also check gcloud
        for tok in [home / ".config" / "gcloud" / "application_default_credentials.json"]:
            if tok.exists() and tok.stat().st_size > 0:
                return {"auth_configured": True, "method": "gcloud_creds", "source": str(tok)}
    
    # Pi Coding Agent: ~/.pi or ~/.config/pi
    if agent_key == "pi":
        for pi_path in [
            home / ".pi",
            home / ".config" / "pi",
            home / ".earendil",
        ]:
            if pi_path.is_dir():
                try:
                    files = list(pi_path.glob("*"))
                    if files:
                        return {"auth_configured": True, "method": "config_dir", "source": str(pi_path)}
                except OSError:
                    pass
    
    # Aider: Python tool with API keys via env vars already covered above
    
    # Blackbox: npm tool — ~/.blackboxai or npm config
    if agent_key == "blackbox":
        bb_path = home / ".blackboxai"
        if bb_path.is_dir():
            return {"auth_configured": True, "method": "config_dir", "source": str(bb_path)}
        bb_config = home / ".blackboxcli"
        if bb_config.is_dir():
            return {"auth_configured": True, "method": "config_dir", "source": str(bb_config)}
    
    # Qwen: ~/.qwen or ~/.config/qwen
    if agent_key == "qwen":
        for qp in [home / ".qwen", home / ".config" / "qwen"]:
            if qp.is_dir():
                return {"auth_configured": True, "method": "config_dir", "source": str(qp)}
    
    # Kimi Code: ~/.kimi or ~/.kimi-code
    if agent_key == "kimi":
        for kp in [home / ".kimi", home / ".kimi-code", home / ".config" / "kimi"]:
            if kp.is_dir() or (kp.exists() and kp.stat().st_size > 0):
                return {"auth_configured": True, "method": "config_path", "source": str(kp)}
    
    # Kiro: ~/.kiro
    if agent_key == "kiro":
        for kp in [home / ".kiro", home / ".config" / "kiro"]:
            if kp.is_dir():
                return {"auth_configured": True, "method": "config_dir", "source": str(kp)}
    
    # OpenClaw: ~/.openclaw or ~/.claw
    if agent_key == "openclaw":
        for cp in [home / ".openclaw", home / ".claw", home / ".config" / "openclaw"]:
            if cp.is_dir() or (cp.exists() and cp.stat().st_size > 0):
                return {"auth_configured": True, "method": "config_path", "source": str(cp)}
    
    # For agents with auth_env_vars, check shell profile files
    if env_vars and not auth_type == "oauth_browser":
        for profile in [home / ".bashrc", home / ".zshrc", home / ".profile"]:
            if profile.exists():
                try:
                    content = profile.read_text()
                    for var in env_vars:
                        if f"{var}=" in content or f"export {var}" in content:
                            return {"auth_configured": True, "method": "shell_profile", "source": str(profile)}
                except OSError:
                    pass
    
    # 3. OAuth-based agents are hard to auto-detect — trust config file if previously marked
    config = load_config()
    agent_cfg = config.get("agents", {}).get(agent_key, {})
    if agent_cfg.get("auth_configured"):
        return {"auth_configured": True, "method": "previously_confirmed", "source": "~/.aikit/config.json"}
    
    return {"auth_configured": False, "method": "", "source": ""}


def discover_and_persist():
    """Run full system discovery: detect installed agents, versions, and auth state.
    Persists all findings to config. Called automatically by doctor, list, and install."""
    config = load_config()
    agents_cfg = config.get("agents", {})
    changed = False
    
    for key in AGENTS:
        current = agents_cfg.get(key, {})
        installed = detect_agent_bin(key)
        version = detect_agent_version(key) if installed else None
        auth_result = discover_auth(key)
        
        new_entry = {
            "installed": installed,
            "version": version,
            "auth_configured": auth_result.get("auth_configured", False),
            "auth_method": auth_result.get("method", ""),
            "auth_source": auth_result.get("source", ""),
            "install_date": current.get("install_date", ""),
            "auth_date": current.get("auth_date", ""),
        }
        
        # Merge: keep existing dates if we had them, merge auth info
        merged = {**current, **new_entry}
        # Preserve previous install_date if we had one and bin is still there
        if not installed:
            merged["install_date"] = ""
            merged["version"] = None
        if current.get("install_date") and installed:
            merged["install_date"] = current["install_date"]
        if current.get("auth_date") and auth_result.get("auth_configured"):
            merged["auth_date"] = current["auth_date"]
        
        if merged != current:
            agents_cfg[key] = merged
            changed = True
    
    if changed:
        config["agents"] = agents_cfg
        save_config(config)


