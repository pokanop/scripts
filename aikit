    @app.route("/api/install/<agent_key>", methods=["POST"])
    def api_install(agent_key):
        if agent_key not in AGENTS:
            return jsonify({"error": "Unknown agent"}), 404
        agent = AGENTS[agent_key]
        cmd = agent["install"].get(_CURRENT_PLATFORM, "")
        if not cmd:
            return jsonify({"error": f"No install command for {_CURRENT_PLATFORM}"}), 400

        exit_code, stdout, stderr = run(cmd, timeout=600)
        success = exit_code == 0 and detect_agent_bin(agent_key)

        if success:
            config = load_config()
            config["agents"][agent_key] = {
                "installed": True,
                "install_date": time.strftime("%Y-%m-%d"),
                "version": detect_agent_version(agent_key),
                "auth_configured": False,
            }
            save_config(config)

        return jsonify({
            "success": success,
            "exit_code": exit_code,
            "stdout": stdout[:500] if stdout else "",
            "stderr": stderr[:500] if stderr else "",
        })

    @app.route("/api/update/<agent_key>", methods=["POST"])
    def api_update(agent_key):
        if agent_key not in AGENTS:
            return jsonify({"error": "Unknown agent"}), 404
        agent = AGENTS[agent_key]
        update_cmd = agent.get("update_cmd")
        if not update_cmd:
            return jsonify({"error": "No update command"}), 400

        exit_code, stdout, stderr = run(update_cmd, timeout=300)
        success = exit_code == 0
        if success:
            config = load_config()
            config["agents"][agent_key] = {
                **config["agents"].get(agent_key, {}),
                "version": detect_agent_version(agent_key),
            }
            save_config(config)

        return jsonify({
            "success": success,
            "exit_code": exit_code,
            "stdout": stdout[:500] if stdout else "",
            "stderr": stderr[:500] if stderr else "",
        })

