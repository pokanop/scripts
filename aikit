def render_continue(base, models, detail):
    cfg = {"models": [
        {"title": m, "provider": "openai", "model": m,
         "apiBase": f"{base}/v1", "apiKey": "<OPENAI_API_KEY from gateway.env>"}
        for m in models
    ]}
    return json.dumps(cfg, indent=2) + "\n"


def render_kilo(base, models, detail):
    # Kilo is an OpenCode fork: same `provider` schema, but its own $schema URL and
    # config dir (~/.config/kilo/). `{env:...}` (single braces, no $) resolves the key
    # from the env at load — the secret stays out of the file. Verified against
    # Kilo-Org/kilocode (config/config.ts, config/variable.ts).
    cfg = {
        "$schema": "https://app.kilo.ai/config.json",
        "provider": {
            GATEWAY_TOOL_PROVIDER_ID: {
                "npm": "@ai-sdk/openai-compatible",
                "name": GATEWAY_TOOL_PROVIDER_NAME,
                "options": {"baseURL": f"{base}/v1", "apiKey": "{env:OPENAI_API_KEY}"},
                "models": {m: {"name": m} for m in models},
            }
        },
    }
    return json.dumps(cfg, indent=2) + "\n"


def render_qwen(base, models, detail):
    # Qwen Code (a gemini-cli fork), SETTINGS_VERSION 4. `envKey` names the env var the
    # key is read from (secret stays out of the file); the selected `model.name` must
    # match a provider entry `id`. The published docs show a v5 shape that crashes the
    # shipping CLI ("models is not iterable") — this is the v4 array form. Verified
    # against QwenLM/qwen-code (settingsSchema.ts, models/types.ts, modelConfigUtils.ts).
    providers = [{"id": m, "name": m, "baseUrl": f"{base}/v1", "envKey": "OPENAI_API_KEY"}
                 for m in models]
    cfg = {
        "$version": 4,
        "security": {"auth": {"selectedType": "openai"}},
        "model": {"name": _default_model(models)},
        "modelProviders": {"openai": providers},
    }
    return json.dumps(cfg, indent=2) + "\n"


def render_cline(base, models, detail):
    # Cline CLI persists providers to ~/.cline/data/settings/providers.json (Zod v1).
    # `apiKey` is optional, so this entry is keyless — the user supplies it at runtime
    # (`cline -k "$OPENAI_API_KEY"`), which reuses this pre-registered baseUrl/model. The
    # id must NOT be a reserved built-in (`openai`/`litellm`) or Cline treats it as the
    # built-in provider — hence `litellm-gw`. A fixed updatedAt keeps the renderer pure
    # and still satisfies the ISO-8601 check. Verified against cline/cline
    # (services/llms/provider-settings.ts, providers/ids.ts).
    provider_id = "litellm-gw"
    cfg = {
        "version": 1,
        "lastUsedProvider": provider_id,
        "providers": {
            provider_id: {
                "settings": {
                    "provider": provider_id,
                    "client": "openai-compatible",
                    "baseUrl": f"{base}/v1",
                    "model": _default_model(models),
                },
                "updatedAt": "1970-01-01T00:00:00.000Z",
                "tokenSource": "manual",
            }
        },
    }
    return json.dumps(cfg, indent=2) + "\n"


def render_gateway_env(pairs):
    """Portable, source-able export block (holds the virtual key — write 0600).

    Values go through ``shlex.quote`` so a key containing a quote, ``$``, or a backtick
    can't break ``source gateway.env`` or trigger shell expansion.
    """
    return ("# Source this to route tools through the gateway: `source gateway.env`\n"
            + "\n".join(f"export {k}={shlex.quote(v)}" for k, v in pairs) + "\n")


def render_gateway_summary(base, models, detail, generated):
