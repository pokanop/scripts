    # install
    install_p = sub.add_parser("install", help="Install AI coding agents")
    install_p.add_argument("agents", nargs="*", help="Agent keys to install (none = interactive picker)")
    install_p.add_argument("-y", "--yes", action="store_true", help="Skip confirmations")

    # update
    update_p = sub.add_parser("update", help="Update installed agents")
    update_p.add_argument("agents", nargs="*", help="Agent keys to update (none = all installed)")

    # uninstall
    uninstall_p = sub.add_parser("uninstall", help="Remove agents")
    uninstall_p.add_argument("agents", nargs="*", help="Agent keys to uninstall (none = interactive picker)")
    uninstall_p.add_argument("-y", "--yes", action="store_true", help="Skip confirmations")

    # list
    sub.add_parser("list", help="Show all agents and installation status")

    # auth
    auth_p = sub.add_parser("auth", help="Configure authentication for an agent")
    auth_p.add_argument("agent", nargs="?", help="Agent key to authenticate")

    # serve
    serve_p = sub.add_parser("serve", help="Start web dashboard")
    serve_p.add_argument("--host", help="Bind host (default: localhost)")
    serve_p.add_argument("--port", type=int, help="Bind port (default: 8765)")
    serve_p.add_argument("--detach", action="store_true", help="Run in background")
    serve_p.add_argument("--stop", action="store_true", help="Stop detached server")

    # doctor
    sub.add_parser("doctor", help="Diagnose environment and agents")

    # setup
    sub.add_parser("setup", help="Interactive first-run wizard")

    # config
    config_p = sub.add_parser("config", help="Manage configuration")
    config_sub = config_p.add_subparsers(dest="config_action")

    config_list = config_sub.add_parser("list", help="Show all config (secrets masked)")
    config_get = config_sub.add_parser("get", help="Get a config value")
    config_get.add_argument("config_key", metavar="key", help="Dot-path key (e.g. settings.web_port)")
    config_set = config_sub.add_parser("set", help="Set a config value")
    config_set.add_argument("config_key", metavar="key", help="Dot-path key")
    config_set.add_argument("value", help="Value to set")

    # -v/--version is added by sk.make_parser
    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    # Handle config sub-commands
    if args.command == "config":
        if args.config_action == "list":
            do_config_list()
        elif args.config_action == "get":
            do_config_get(args.config_key)
        elif args.config_action == "set":
            do_config_set(args.config_key, args.value)
        else:
            do_config_list()
        return

    # First-run: auto-discover and persist, then warn if no agents
    if not args.command and _needs_setup():
        discover_and_persist()
        config = load_config()
        installed_count = sum(1 for k in AGENTS if config.get("agents", {}).get(k, {}).get("installed", False))
        authenticated_count = sum(1 for k in AGENTS if config.get("agents", {}).get(k, {}).get("auth_configured", False))
        
        console.print(Panel(
            "[bold]👋 Welcome to aikit![/bold]\n\n"
            "aikit has auto-discovered your system state:\n"
            f"  [green]• {installed_count}/{len(AGENTS)} agents installed[/green]\n"
            f"  [green]• {authenticated_count} agents authenticated[/green]\n\n"
            "Run: [bold]aikit setup[/bold] for guided setup\n"
            "  or [bold]aikit list[/bold] to see the full table\n"
            "  or [bold]aikit doctor[/bold] to diagnose everything",
            border_style="cyan"
        ))
        SETUP_MARKER.touch()
        return

    # Dispatch with KeyboardInterrupt safety
    try:
        if args.command == "install":
            do_install(args.agents, yes=args.yes)
        elif args.command == "update":
            do_update(args.agents or None)
        elif args.command == "uninstall":
            do_uninstall(args.agents, yes=args.yes)
        elif args.command == "list":
            print_agent_table()
        elif args.command == "auth":
            if not args.agent:
                agent_keys = [k for k in AGENTS if detect_agent_bin(k)]
                if not agent_keys:
                    print_warning("No agents installed. Run 'aikit install' first.")
                    return
                try:
                    agent_keys = interactive_agent_picker("Select agent to authenticate", preselect_installed=True)
                except KeyboardInterrupt:
                    console.print("\n[yellow]⏹ Cancelled.[/yellow]")
                    return
                if agent_keys:
                    for key in agent_keys:
                        do_auth(key)
                else:
                    print_warning("No agent selected.")
            else:
                do_auth(args.agent)
        elif args.command == "serve":
            do_serve(
                host=args.host,
                port=args.port,
                detach=args.detach,
                stop=args.stop,
            )
        elif args.command == "doctor":
            do_doctor()
        elif args.command == "setup":
            do_setup()
        elif not args.command:
            # Default: show banner + help
            console.print(Panel(
                f"[bold]🤖 aikit v{__version__}[/bold]\n"
                f"AI Coding Agent CLI Installer & Manager\n"
                f"[dim]{len(AGENTS)} agents • {_CURRENT_PLATFORM} • ~/.aikit/config.json[/dim]",
                border_style="cyan"
            ))
            print_agent_table()
            console.print(f"\n[dim]Commands: install | update | uninstall | list | auth | serve | doctor | setup | config[/dim]")
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Interrupted.[/yellow]")
        sys.exit(130)


if __name__ == "__main__":
    main()
