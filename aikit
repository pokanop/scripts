def _prompt(text_str, default="", style="bold cyan"):
    """Prompt the user for input, safely handling brackets in default values.
    KeyboardInterrupt propagates up — NEVER caught here."""
    prompt = Text()
    prompt.append(f"  {text_str}", style=style)
    if default:
        prompt.append(f" [{default}]", style="dim")
    prompt.append(": ", style=style)
    try:
        val = console.input(prompt).strip()
    except EOFError:
        return default
    return val or default


def _prompt_yes_no(text_str, default=True):
    default_str = "Y/n" if default else "y/N"
    resp = _prompt(f"{text_str} ({default_str})", "")
    if not resp:
        return default
    return resp.lower().startswith("y")


# =============================================================================
# Raw terminal keypress reader — uses readchar library for cross-platform support
# Falls back to line input if no TTY or readchar not available
# =============================================================================

def _read_key():
    """Read a single keypress from stdin. Returns human-readable string.
    Uses readchar for reliable cross-platform terminal input.
    Returns: 'up','down','left','right','space','enter','tab','esc',
             'backspace', 'delete', or the actual character pressed.
    Returns None if stdin is not a TTY."""
    if not sys.stdin.isatty():
        return None
    
    if not HAS_READCHAR:
        return None
    
    try:
        k = readchar.readkey()
    except KeyboardInterrupt:
        raise
    
    if k == readchar.key.UP:
        return 'up'
    elif k == readchar.key.DOWN:
        return 'down'
    elif k == readchar.key.LEFT:
        return 'left'
    elif k == readchar.key.RIGHT:
        return 'right'
    elif k == readchar.key.ENTER:
        return 'enter'
    elif k == readchar.key.SPACE:
        return 'space'
    elif k == readchar.key.TAB:
        return 'tab'
    elif k == readchar.key.ESC:
        return 'esc'
    elif k == readchar.key.BACKSPACE:
        return 'backspace'
    elif k == readchar.key.DELETE:
        return 'delete'
    elif k == readchar.key.CTRL_C:
        raise KeyboardInterrupt()
    elif isinstance(k, str):
        return k
    return None


