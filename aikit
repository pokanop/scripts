def build_parser():
    parser = sk.make_parser(
        "aikit", __version__, TAGLINE, icon=ICON,
        epilog=textwrap.dedent(f"""\
            Examples:
              aikit setup              First-run interactive wizard
              aikit install            Multi-select agent picker (Space=toggle, Enter=done)
              aikit install claude codex cursor   Install specific agents
              aikit list               Show all {len(AGENTS)} agents and status
              aikit auth claude        Configure Claude auth
              aikit serve              Start web dashboard
              aikit doctor             Diagnose environment
        """),
    )

    sub = parser.add_subparsers(dest="command", help="Command")

    # install
    install_p = sub.add_parser("install", help="Install AI coding agents")
    install_p.add_argument("agents", nargs="*", help="Agent keys to install (none = interactive picker)")
    install_p.add_argument("-y", "--yes", action="store_true", help="Skip confirmations")

    # update
    update_p = sub.add_parser("update", help="Update installed agents")
    update_p.add_argument("agents", nargs="*", help="Agent keys to update (none = all installed)")
    update_p.add_argument(
        "--force", action="store_true",
        help="Run update commands even when upstream reports up to date",
    )

    # uninstall
    uninstall_p = sub.add_parser("uninstall", help="Remove agents")
    uninstall_p.add_argument("agents", nargs="*", help="Agent keys to uninstall (none = interactive picker)")
    uninstall_p.add_argument("-y", "--yes", action="store_true", help="Skip confirmations")

    # list
    sub.add_parser("list", help="Show all agents and installation status")

    # auth
    auth_p = sub.add_parser("auth", help="Configure authentication for an agent")
    auth_p.add_argument("agent", nargs="?", help="Agent key to authenticate")

    # serve
    serve_p = sub.add_parser("serve", help="Start web dashboard")
    serve_p.add_argument("--host", help="Bind host (default: localhost)")
    serve_p.add_argument("--port", type=int, help="Bind port (default: 8765)")
    serve_p.add_argument("--detach", action="store_true", help="Run in background")
    serve_p.add_argument("--stop", action="store_true", help="Stop detached server")

    # doctor
    sub.add_parser("doctor", help="Diagnose environment and agents")

    # setup
    sub.add_parser("setup", help="Interactive first-run wizard")

    # config
    config_p = sub.add_parser("config", help="Manage configuration")
    config_sub = config_p.add_subparsers(dest="config_action")

    config_sub.add_parser("list", help="Show all config (secrets masked)")
    config_get = config_sub.add_parser("get", help="Get a config value")
    config_get.add_argument("config_key", metavar="key", help="Dot-path key (e.g. settings.web_port)")
    config_set = config_sub.add_parser("set", help="Set a config value")
    config_set.add_argument("config_key", metavar="key", help="Dot-path key")
    config_set.add_argument("value", help="Value to set")

    # -v/--version is added by sk.make_parser
    return parser


def cmd_install(args):
    do_install(args.agents, yes=args.yes)


def cmd_update(args):
    do_update(args.agents or None, force=args.force)


def cmd_uninstall(args):
    do_uninstall(args.agents, yes=args.yes)


def cmd_list(args):
    print_agent_table()


def cmd_auth(args):
    if args.agent:
        do_auth(args.agent)
        return
    if not any(detect_agent_bin(k) for k in AGENTS):
        print_warning("No agents installed. Run 'aikit install' first.")
        return
    # Ctrl-C inside the picker means "cancel this prompt", not "abort aikit".
    try:
        agent_keys = interactive_agent_picker("Select agent to authenticate", preselect_installed=True)
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Cancelled.[/yellow]")
        return
    if not agent_keys:
        print_warning("No agent selected.")
        return
    for key in agent_keys:
        do_auth(key)


def cmd_serve(args):
    do_serve(host=args.host, port=args.port, detach=args.detach, stop=args.stop)


def cmd_doctor(args):
    return do_doctor()


def cmd_setup(args):
    do_setup()


def cmd_config(args):
    action = getattr(args, "config_action", None)
    if action == "get":
        do_config_get(args.config_key)
    elif action == "set":
        do_config_set(args.config_key, args.value)
    else:  # "list" or no sub-action
        do_config_list()


HANDLERS = {
    "install": cmd_install, "update": cmd_update, "uninstall": cmd_uninstall,
    "list": cmd_list, "auth": cmd_auth, "serve": cmd_serve,
    "doctor": cmd_doctor, "setup": cmd_setup, "config": cmd_config,
}

# Bare `aikit` shows the agent table — the at-a-glance default.
DEFAULT_COMMAND = "list"
_COMMANDS = frozenset(HANDLERS)


def _first_run_notice() -> None:
    """One-time welcome on a fresh machine: discover state, then point the way."""
    discover_and_persist()
    config = load_config()
    installed = sum(1 for k in AGENTS if config.get("agents", {}).get(k, {}).get("installed", False))
    authed = sum(1 for k in AGENTS if config.get("agents", {}).get(k, {}).get("auth_configured", False))
    console.print(Panel(
        "[bold]👋 Welcome to aikit![/bold]\n\n"
        "aikit has auto-discovered your system state:\n"
        f"  [green]• {installed}/{len(AGENTS)} agents installed[/green]\n"
        f"  [green]• {authed} agents authenticated[/green]\n\n"
        "Run: [bold]aikit setup[/bold] for guided setup\n"
        "  or [bold]aikit doctor[/bold] to diagnose everything",
        border_style="cyan",
    ))
    SETUP_MARKER.touch()


def main() -> int:
    parser = build_parser()
    bare = not any(tok in _COMMANDS for tok in sys.argv[1:])
    args = sk.parse_args(parser, default=DEFAULT_COMMAND)
    if bare and _needs_setup():
        _first_run_notice()  # then fall through to the default `list` table
    return sk.dispatch(
        args, HANDLERS, parser, default=DEFAULT_COMMAND,
        banner=sk.banner("aikit", __version__, TAGLINE, ICON),
    )


if __name__ == "__main__":
    sys.exit(sk.run_cli(main))
