def _real_home():
    """Resolve the real user home, stripping Hermes profile overrides."""
    h = Path(os.environ.get("HOME", "/root")).resolve()
    parts = h.parts
    if ".hermes" in parts:
        idx = parts.index(".hermes")
        return Path(*parts[:idx]) if idx > 0 else Path("/")
    return h


_REAL_HOME = _real_home()


def _config_text_has_credentials(cfg_text):
    """True when a config file likely stores credentials (not just provider names)."""
    return any(
        pat in cfg_text
        for pat in (
            '"apiKey"', "'apiKey'", "apiKey:",
            '"api_key"', "api_key:",
            "accessToken", "refreshToken",
            '"type": "oauth"', '"type":"oauth"',
            '"type": "api"', '"type":"api"',
        )
    )


def discover_auth(agent_key):
    """Auto-detect whether an agent is authenticated by checking filesystem,
    environment variables, and credential files.
    Returns dict: {auth_configured: bool, method: str, source: str}
    """
    agent = AGENTS.get(agent_key)
    if not agent:
        return {"auth_configured": False, "method": "unknown", "source": ""}
    
    auth_type = agent.get("auth_type", "")
    env_vars = agent.get("auth_env_vars", [])
    
    # 1. Check environment variables (current process — most reliable)
    for var in env_vars:
        if os.environ.get(var):
            return {"auth_configured": True, "method": "env_var", "source": f"${var}"}
    
    # 2. Check agent-specific credential files (use real home, not Hermes-overridden home)
    home = _REAL_HOME
    
    # Claude Code: ~/.claude.json has oauthAccount, ~/.claude/.credentials.json has OAuth tokens
    if agent_key == "claude":
        # Primary: ~/.claude.json (contains oauthAccount, userID, hasCompletedOnboarding)
        claude_json = home / ".claude.json"
        if claude_json.exists() and claude_json.stat().st_size > 0:
            try:
                d = json.loads(claude_json.read_text())
                if d.get("oauthAccount") or d.get("hasCompletedOnboarding") or d.get("userID"):
                    return {"auth_configured": True, "method": "config_file", "source": str(claude_json)}
            except (json.JSONDecodeError, OSError):
                pass
        # Secondary: ~/.claude/.credentials.json (raw OAuth tokens)
        for cred_path in [home / ".claude" / ".credentials.json", home / ".claude" / "credentials.json"]:
            if cred_path.exists() and cred_path.stat().st_size > 0:
                try:
                    creds = json.loads(cred_path.read_text())
                    if creds:
                        for v in creds.values():
                            if isinstance(v, dict) and any(k in v for k in ("accessToken", "refreshToken")):
                                return {"auth_configured": True, "method": "cred_file", "source": str(cred_path)}
                except (json.JSONDecodeError, OSError):
                    pass
    
    # Cursor CLI: ~/.cursor/cli-config.json has authInfo block
    if agent_key == "cursor":
        cfg_path = home / ".cursor" / "cli-config.json"
        if cfg_path.exists():
            try:
                cfg = json.loads(cfg_path.read_text())
                ai = cfg.get("authInfo", {})
                if ai.get("email") or ai.get("userId"):
                    return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
            except (json.JSONDecodeError, OSError):
                pass
    
    # Hermes: ~/.hermes/auth.json (Nous Portal OAuth) or profile .env (API keys)
    if agent_key == "hermes":
        auth_json = home / ".hermes" / "auth.json"
        if auth_json.exists() and auth_json.stat().st_size > 0:
            try:
                data = json.loads(auth_json.read_text())
                if data:
                    return {"auth_configured": True, "method": "cred_file", "source": str(auth_json)}
            except (json.JSONDecodeError, OSError):
                pass
        for env_path in [
            home / ".hermes" / ".env",
            home / ".hermes" / "profiles" / "coder" / ".env",
        ]:
            if env_path.exists():
                try:
                    content = env_path.read_text()
                    if 'ANTHROPIC_API_KEY=' in content or 'OPENROUTER_API_KEY=' in content:
                        return {"auth_configured": True, "method": "env_file", "source": str(env_path)}
                except OSError:
                    pass
    
    # Codex: ~/.codex/auth.json
    if agent_key == "codex":
        auth_file = home / ".codex" / "auth.json"
        if auth_file.exists() and auth_file.stat().st_size > 0:
            return {"auth_configured": True, "method": "cred_file", "source": str(auth_file)}
    
    # Kilo CLI: ~/.local/share/kilo/auth.json and ~/.config/kilo/* only (not OpenCode)
    if agent_key == "kilo":
        auth_file = home / ".local" / "share" / "kilo" / "auth.json"
        if auth_file.exists() and auth_file.stat().st_size > 0:
            try:
                data = json.loads(auth_file.read_text())
                if data:
                    return {"auth_configured": True, "method": "cred_file", "source": str(auth_file)}
            except (json.JSONDecodeError, OSError):
                pass
        for cfg_path in [
            home / ".config" / "kilo" / "kilo.jsonc",
            home / ".config" / "kilo" / "kilo.json",
            home / ".config" / "kilo" / "opencode.json",
            home / ".config" / "kilo" / "opencode.jsonc",
            home / ".kilo" / "config.json",
        ]:
            if cfg_path.exists():
                try:
                    cfg_text = cfg_path.read_text()
                    if _config_text_has_credentials(cfg_text):
                        return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
                except OSError:
                    pass
        for proj_path in [
            Path.cwd() / "kilo.jsonc",
            Path.cwd() / ".kilo" / "kilo.jsonc",
            Path.cwd() / ".kilo" / "opencode.json",
            Path.cwd() / ".kilo" / "opencode.jsonc",
        ]:
            if proj_path.exists():
                try:
                    cfg_text = proj_path.read_text()
                    if _config_text_has_credentials(cfg_text):
                        return {"auth_configured": True, "method": "project_config", "source": str(proj_path)}
                except OSError:
                    pass
    
    # OpenCode: ~/.local/share/opencode/auth.json or legacy config paths
    if agent_key == "opencode":
        auth_file = home / ".local" / "share" / "opencode" / "auth.json"
        if auth_file.exists() and auth_file.stat().st_size > 0:
            try:
                data = json.loads(auth_file.read_text())
                if data:
                    return {"auth_configured": True, "method": "cred_file", "source": str(auth_file)}
            except (json.JSONDecodeError, OSError):
                pass
        for cfg_path in [
            home / ".config" / "opencode" / "opencode.json",
            home / ".config" / "opencode" / "opencode.jsonc",
            home / ".opencode" / "config.json",
        ]:
            if cfg_path.exists():
                try:
                    cfg_text = cfg_path.read_text()
                    if _config_text_has_credentials(cfg_text):
                        return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
                except OSError:
                    pass
    
    # GitHub Copilot: env vars, ~/.copilot/config.json, or gh CLI fallback
    if agent_key == "copilot":
        copilot_cfg = home / ".copilot" / "config.json"
        if copilot_cfg.exists() and copilot_cfg.stat().st_size > 0:
            try:
                data = json.loads(copilot_cfg.read_text())
                if data.get("githubToken") or data.get("token"):
                    return {"auth_configured": True, "method": "config_file", "source": str(copilot_cfg)}
            except (json.JSONDecodeError, OSError):
                pass
        gh_hosts = home / ".config" / "gh" / "hosts.yml"
        if gh_hosts.exists():
            content = gh_hosts.read_text()
            if "token:" in content:
                return {"auth_configured": True, "method": "gh_cli", "source": str(gh_hosts)}
    
    # Grok Build: ~/.grok/config.toml (xAI) + browser OAuth token
    if agent_key == "grok":
        cfg_path = home / ".grok" / "config.toml"
        if cfg_path.exists():
            try:
                content = cfg_path.read_text()
                if content.strip():
                    return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}
            except OSError:
                pass
    
    # Antigravity: Google OAuth token under ~/.gemini/antigravity-cli/
    if agent_key == "antigravity":
        for tok_path in [
            home / ".gemini" / "antigravity-cli" / "antigravity-oauth-token",
            home / ".gemini" / "antigravity-cli" / "credentials.json",
        ]:
            if tok_path.exists() and tok_path.stat().st_size > 0:
                return {"auth_configured": True, "method": "cred_file", "source": str(tok_path)}
        for agy_path in [home / ".agy", home / ".antigravity", home / ".config" / "antigravity"]:
            if agy_path.exists():
                try:
                    files = list(agy_path.glob("*"))
                    if files:
                        return {"auth_configured": True, "method": "config_dir", "source": str(agy_path)}
                except OSError:
                    pass
    
    # Pi Coding Agent: ~/.pi/agent/auth.json or legacy config dirs
    if agent_key == "pi":
        auth_file = home / ".pi" / "agent" / "auth.json"
        if auth_file.exists() and auth_file.stat().st_size > 0:
            try:
                data = json.loads(auth_file.read_text())
                if data:
                    return {"auth_configured": True, "method": "cred_file", "source": str(auth_file)}
            except (json.JSONDecodeError, OSError):
                pass
        for pi_path in [
            home / ".pi",
            home / ".config" / "pi",
            home / ".earendil",
        ]:
            if pi_path.is_dir():
                try:
                    files = list(pi_path.glob("*"))
                    if files:
                        return {"auth_configured": True, "method": "config_dir", "source": str(pi_path)}
                except OSError:
                    pass
    
    # Aider: Python tool with API keys via env vars already covered above
    
    # Blackbox: npm tool — ~/.blackboxai or npm config
    if agent_key == "blackbox":
        bb_path = home / ".blackboxai"
        if bb_path.is_dir():
            return {"auth_configured": True, "method": "config_dir", "source": str(bb_path)}
        bb_config = home / ".blackboxcli"
        if bb_config.is_dir():
            return {"auth_configured": True, "method": "config_dir", "source": str(bb_config)}
    
    # Qwen: ~/.qwen/settings.json or config dir
    if agent_key == "qwen":
        settings = home / ".qwen" / "settings.json"
        if settings.exists():
            try:
                cfg_text = settings.read_text()
                if '"auth"' in cfg_text or any(
                    pat in cfg_text for pat in ("DASHSCOPE_API_KEY", "apiKey", "selectedType")
                ):
                    return {"auth_configured": True, "method": "config_file", "source": str(settings)}
            except OSError:
                pass
        for qp in [home / ".qwen", home / ".config" / "qwen"]:
            if qp.is_dir():
                try:
                    if any(qp.iterdir()):
                        return {"auth_configured": True, "method": "config_dir", "source": str(qp)}
                except OSError:
                    pass
    
    # Kimi Code: ~/.kimi-code/config.toml or legacy dirs
    if agent_key == "kimi":
        cfg_toml = home / ".kimi-code" / "config.toml"
        if cfg_toml.exists() and cfg_toml.stat().st_size > 0:
            return {"auth_configured": True, "method": "config_file", "source": str(cfg_toml)}
        for kp in [home / ".kimi", home / ".kimi-code", home / ".config" / "kimi"]:
            if kp.is_dir() or (kp.exists() and kp.stat().st_size > 0):
                return {"auth_configured": True, "method": "config_path", "source": str(kp)}
    
    # Kiro: ~/.kiro
    if agent_key == "kiro":
        for kp in [home / ".kiro", home / ".config" / "kiro"]:
            if kp.is_dir():
                return {"auth_configured": True, "method": "config_dir", "source": str(kp)}
    
    # OpenClaw: ~/.openclaw or ~/.claw
    if agent_key == "openclaw":
        for cp in [home / ".openclaw", home / ".claw", home / ".config" / "openclaw"]:
            if cp.is_dir() or (cp.exists() and cp.stat().st_size > 0):
                return {"auth_configured": True, "method": "config_path", "source": str(cp)}

    # Goose: ~/.config/goose
    if agent_key == "goose":
        for gp in [home / ".config" / "goose", home / ".goose"]:
            if gp.is_dir() or (gp.exists() and gp.stat().st_size > 0):
                return {"auth_configured": True, "method": "config_path", "source": str(gp)}

    # Cline: ~/.cline
    if agent_key == "cline":
        cline_dir = home / ".cline"
        if cline_dir.is_dir():
            return {"auth_configured": True, "method": "config_dir", "source": str(cline_dir)}

    # OpenHands: ~/.openhands/settings.json or agent_settings.json
    if agent_key == "openhands":
        oh_dir = home / ".openhands"
        for cfg_name in ("settings.json", "agent_settings.json", "cli_config.json"):
            cfg_path = oh_dir / cfg_name
            if cfg_path.exists() and cfg_path.stat().st_size > 0:
                return {"auth_configured": True, "method": "config_file", "source": str(cfg_path)}

    # Crush: ~/.config/crush/crush.json
    if agent_key == "crush":
        for cp in [
            home / ".config" / "crush" / "crush.json",
            home / ".local" / "share" / "crush" / "crush.json",
        ]:
            if cp.exists() and cp.stat().st_size > 0:
                return {"auth_configured": True, "method": "config_file", "source": str(cp)}

    # Amp: ~/.config/amp/settings.json (or .jsonc) after 'amp login' / API key
    if agent_key == "amp":
        for ap in [
            home / ".config" / "amp" / "settings.json",
            home / ".config" / "amp" / "settings.jsonc",
        ]:
            if ap.exists() and ap.stat().st_size > 0:
                return {"auth_configured": True, "method": "config_file", "source": str(ap)}

    # For agents with auth_env_vars, check shell profile files
    if env_vars and not auth_type == "oauth_browser":
        for profile in [home / ".bashrc", home / ".zshrc", home / ".profile"]:
            if profile.exists():
                try:
                    content = profile.read_text()
                    for var in env_vars:
                        if f"{var}=" in content or f"export {var}" in content:
                            return {"auth_configured": True, "method": "shell_profile", "source": str(profile)}
                except OSError:
                    pass
    
    # OAuth agents are hard to auto-detect — trust a prior successful auth only for those
    if auth_type in ("oauth_browser", "oauth_portal", "oauth_onboard"):
        config = load_config()
        agent_cfg = config.get("agents", {}).get(agent_key, {})
        if agent_cfg.get("auth_configured"):
            return {"auth_configured": True, "method": "previously_confirmed", "source": "~/.aikit/config.json"}

    return {"auth_configured": False, "method": "", "source": ""}


def _agent_entry_changed(current, merged):
    omit = "update_checked_at"
    return {k: v for k, v in merged.items() if k != omit} != {
        k: v for k, v in current.items() if k != omit
    }


def _discover_agent_entry(key, config):
    """Discover install/version/auth/update state for one agent."""
    agents_cfg = config.get("agents", {})
    current = agents_cfg.get(key, {})
    installed = detect_agent_bin(key)
    version = detect_agent_version(key) if installed else None
    auth_result = discover_auth(key)
    update_status = (
        check_update_status(key, config=config, current_raw=version)
        if installed else {}
    )

    new_entry = {
        "installed": installed,
        "version": version,
        "auth_configured": auth_result.get("auth_configured", False),
        "auth_method": auth_result.get("method", ""),
        "auth_source": auth_result.get("source", ""),
        "install_date": current.get("install_date", ""),
        "auth_date": current.get("auth_date", ""),
        "latest_version": update_status.get("latest"),
        "update_available": update_status.get("available"),
        "update_checked_at": update_status.get("checked_at"),
    }

    merged = {**current, **new_entry}
    if not installed:
        merged["install_date"] = ""
        merged["version"] = None
        merged["latest_version"] = None
        merged["update_available"] = None
        merged["update_checked_at"] = None
    if current.get("install_date") and installed:
        merged["install_date"] = current["install_date"]
    if current.get("auth_date") and auth_result.get("auth_configured"):
        merged["auth_date"] = current["auth_date"]

    return key, merged, _agent_entry_changed(current, merged)


def discover_and_persist():
    """Run full system discovery: detect installed agents, versions, and auth state.
    Persists all findings to config. Called automatically by doctor, list, and install.

    Only installed agents are kept in ``config["agents"]`` — uninstalled entries are
    pruned so uninstall + list does not resurrect ghost records."""
    config = load_config()
    agents_cfg = dict(config.get("agents", {}))
    changed = False

    results = sk.parallel_map(
        lambda key: _discover_agent_entry(key, config),
        list(AGENTS.keys()),
        "Discovering agents",
        max_workers=8,
    )

    for key, merged, entry_changed in results:
        if merged.get("installed"):
            if entry_changed:
                agents_cfg[key] = merged
                changed = True
        elif key in agents_cfg:
            del agents_cfg[key]
            changed = True

    if changed:
        config["agents"] = agents_cfg
        save_config(config)


def do_auth(agent_key):
    """Guide user through auth for an agent."""
    try:
        _do_auth_impl(agent_key)
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Auth setup cancelled.[/yellow]")
        sys.exit(130)


def _do_auth_impl(agent_key):
    validate_agent_keys([agent_key])
    agent = AGENTS[agent_key]

    icon = agent["icon"]

    if not detect_agent_bin(agent_key):
        print_error(f"{icon} {agent['name']} is not installed. Run 'aikit install {agent_key}' first.")
        return

    auth_type = agent.get("auth_type", "unknown")
    auth_note = agent.get("auth_note", "")
    env_vars = agent.get("auth_env_vars", [])
    
    # Check if already authenticated
    existing = discover_auth(agent_key)
    if existing["auth_configured"]:
        console.print(f"\n[bold cyan]🔑 {icon} {agent['name']}[/bold cyan]")
        print_success(f"Already authenticated! [dim](source: {existing['source']})[/dim]")
        # Ensure config is updated
        config = load_config()
        config["agents"][agent_key] = {
            **config["agents"].get(agent_key, {}),
            "auth_configured": True,
            "auth_date": config["agents"].get(agent_key, {}).get("auth_date", time.strftime("%Y-%m-%d")),
            "auth_method": existing["method"],
            "auth_source": existing["source"],
        }
        save_config(config)
        return

    console.print(f"\n[bold cyan]🔑 Authentication Setup: {icon} {agent['name']}[/bold cyan]")
    console.print(f"  Auth type: [bold]{auth_type}[/bold]")
    console.print(f"  Homepage:  {agent['homepage']}")

    if auth_note:
        console.print(f"\n  [bold yellow]📝 {auth_note}[/bold yellow]")

    if auth_type == "oauth_browser":
        bin_name = resolve_agent_bin(agent_key) or agent["bin"]
        auth_cmd = agent.get("auth_cmd") or bin_name
        if auth_cmd != bin_name:
            console.print(
                f"\n  [dim]This agent uses OAuth. Run '{auth_cmd}' to sign in "
                f"(or '{bin_name}' for interactive mode).[/dim]"
            )
        else:
            console.print(f"\n  [dim]This agent uses OAuth. Run '{auth_cmd}' and complete the browser login.[/dim]")
        if _use_color() and sys.stdin.isatty():
            try:
                if _prompt_yes_no(f"Launch '{auth_cmd}' now to authenticate?", True):
                    os.system(auth_cmd)
            except KeyboardInterrupt:
                raise

    elif auth_type in ("api_key", "provider_keys", "pat_or_oauth", "oauth_portal", "account_or_byok", "oauth_onboard"):
        auth_cmd = agent.get("auth_cmd")
        if auth_cmd:
            console.print(f"\n  [dim]Recommended command: [bold]{auth_cmd}[/bold][/dim]")
        if env_vars:
            console.print("\n  [bold]Environment variables to set:[/bold]")
            for var in env_vars:
                current = os.environ.get(var, "")
                if current:
                    masked = current[:4] + "***" + current[-4:] if len(current) > 8 else "***"
                    console.print(f"    {var} = [green]{masked}[/green] (already set)")
                else:
                    console.print(f"    {var} = [dim](not set)[/dim]")
                    if _use_color() and sys.stdin.isatty():
                        val = _prompt(f"  Enter value for {var} (or Enter to skip)", "")
                        if val:
                            _save_env_var(var, val)
                            console.print(f"    [green]✓ Saved {var}[/green]")

    elif auth_type == "subscription":
        console.print(f"\n  [dim]This agent requires a paid subscription. Visit {agent['homepage']} to subscribe.[/dim]")

    # Persist only when credentials are actually detected
    discover_and_persist()
    result = discover_auth(agent_key)
    config = load_config()
    entry = {
        **config["agents"].get(agent_key, {}),
        "auth_method": result.get("method", ""),
        "auth_source": result.get("source", ""),
    }
    if result["auth_configured"]:
        entry["auth_configured"] = True
        entry["auth_date"] = config["agents"].get(agent_key, {}).get("auth_date") or time.strftime("%Y-%m-%d")
        config["agents"][agent_key] = entry
        save_config(config)
        print_success(f"{icon} {agent['name']} auth setup complete!")
    else:
        entry["auth_configured"] = False
        config["agents"][agent_key] = entry
        save_config(config)
        print_warning(
            f"{icon} {agent['name']} still needs authentication — follow the steps above, "
            f"then run 'aikit auth {agent_key}' again."
        )


def _save_env_var(var, value):
    """Save an env var to shell profile and current session."""
    os.environ[var] = value

    # Save to persistent locations
    for profile in [
        os.path.expanduser("~/.bashrc"),
        os.path.expanduser("~/.zshrc"),
        os.path.expanduser("~/.profile"),
    ]:
        if os.path.exists(profile):
            try:
                content = Path(profile).read_text()
                if f"export {var}=" not in content:
                    with open(profile, "a") as f:
                        f.write(f"\n# aikit — {var}\nexport {var}={shlex.quote(value)}\n")
            except OSError:
                pass

    # Also save to aikit config
    config = load_config()
    config.setdefault("env_vars", {})[var] = True
    save_config(config)


# =============================================================================
# Gateway — route AI tools through a LiteLLM gateway (reversible, idempotent)
# =============================================================================
# `aikit gateway` wraps every OpenAI-compatible tool/SDK so it talks to a single
# LiteLLM-style gateway with one virtual key, and unwraps again leaving the
# machine pristine. "Support for each provider" ships as *data*: the table below
# drives env routing for ~60 providers — adding a provider is adding a row, not
# a branch. Stage 3 layers native per-tool config files on top of this engine.
#
# Each row is (id, display, prefix, key_envs, base_envs, route, bins, py):
#   prefix    — LiteLLM provider prefix used in model names (provider/model)
#   key_envs  — env vars SDKs read for that provider's API key; all set to the
#               one virtual key so wherever a tool looks, it finds the gateway key
#   base_envs — env vars SDKs read to override the API base URL; pointed at the gateway
#   route     — path appended to the gateway base ("/anthropic" = native pass-through;
#               "/v1" = the gateway's OpenAI-compatible endpoint)
