def create_flask_app():
    """Create the Flask web dashboard app."""
    try:
        from flask import Flask, jsonify, request
    except ImportError:
        console.print("[bold red]Flask is not installed. Run: pip install flask[/bold red]")
        sys.exit(1)

    app = Flask(__name__)

    # ---- API Routes ----

    @app.route("/api/agents")
    def api_agents():
        discover_and_persist()
        config = load_config()
        result = []
        for key in sorted(AGENTS.keys()):
            agent = AGENTS[key]
            agent_cfg = config.get("agents", {}).get(key, {})
            installed = agent_cfg.get("installed", False) or detect_agent_bin(key)
            version = agent_cfg.get("version") or detect_agent_version(key) if installed else None
            result.append({
                "key": key,
                "name": agent["name"],
                "vendor": agent["vendor"],
                "icon": agent["icon"],
                "homepage": agent["homepage"],
                "installed": installed,
                "version": version,
                "latest_version": agent_cfg.get("latest_version"),
                "update_available": agent_cfg.get("update_available"),
                "update_status": format_update_status(key, {
                    "available": agent_cfg.get("update_available"),
                    "latest": agent_cfg.get("latest_version"),
                }),
                "auth_configured": agent_cfg.get("auth_configured", False),
                "auth_type": agent.get("auth_type", "unknown"),
                "bin": resolve_agent_bin(key) or agent["bin"],
                "bin_aliases": agent.get("bin_aliases", []),
                "update_cmd": resolve_update_cmd(key),
                "tags": agent.get("tags", []),
            })
        return jsonify(result)

    @app.route("/api/agents/<agent_key>", methods=["GET"])
    def api_agent_detail(agent_key):
        if agent_key not in AGENTS:
            return jsonify({"error": "Unknown agent"}), 404
        agent = AGENTS[agent_key]
        installed = detect_agent_bin(agent_key)
        version = detect_agent_version(agent_key) if installed else None
        config = load_config()
        agent_cfg = config.get("agents", {}).get(agent_key, {})
        update_status = check_update_status(agent_key) if installed else {}
        return jsonify({
            "key": agent_key,
            "name": agent["name"],
            "vendor": agent["vendor"],
            "icon": agent["icon"],
            "homepage": agent["homepage"],
            "install_cmd": agent["install"].get(_CURRENT_PLATFORM, ""),
            "installed": installed,
            "version": version,
            "latest_version": update_status.get("latest"),
            "update_available": update_status.get("available"),
            "update_status": format_update_status(agent_key, update_status),
            "auth_configured": agent_cfg.get("auth_configured", False),
            "auth_type": agent.get("auth_type", "unknown"),
            "auth_env_vars": agent.get("auth_env_vars", []),
            "auth_note": agent.get("auth_note", ""),
            "bin": resolve_agent_bin(agent_key) or agent["bin"],
            "bin_aliases": agent.get("bin_aliases", []),
            "update_cmd": resolve_update_cmd(agent_key),
            "tags": agent.get("tags", []),
            "requires": agent.get("requires", []),
        })

    @app.route("/api/install/<agent_key>", methods=["POST"])
    def api_install(agent_key):
        if agent_key not in AGENTS:
            return jsonify({"error": "Unknown agent"}), 404
        agent = AGENTS[agent_key]
        cmd = agent["install"].get(_CURRENT_PLATFORM, "")
        if not cmd:
            return jsonify({"error": f"No install command for {_CURRENT_PLATFORM}"}), 400

        exit_code, stdout, stderr = run(cmd, timeout=600)
        success = exit_code == 0 and detect_agent_bin(agent_key)

        if success:
            config = load_config()
            config["agents"][agent_key] = {
                "installed": True,
                "install_date": time.strftime("%Y-%m-%d"),
                "version": detect_agent_version(agent_key),
                "auth_configured": False,
            }
            save_config(config)

        return jsonify({
            "success": success,
            "exit_code": exit_code,
            "stdout": stdout[:500] if stdout else "",
            "stderr": stderr[:500] if stderr else "",
        })

    @app.route("/api/update/<agent_key>", methods=["POST"])
    def api_update(agent_key):
        if agent_key not in AGENTS:
            return jsonify({"error": "Unknown agent"}), 404
        if not resolve_update_cmd(agent_key):
            return jsonify({"error": "No update command"}), 400
        if not detect_agent_bin(agent_key):
            return jsonify({"error": "Agent not installed"}), 400

        force = request.args.get("force", "").lower() in ("1", "true", "yes")
        skip, check = should_skip_update(agent_key, force=force)
        if skip:
            return jsonify({
                "success": True,
                "status": "skipped_up_to_date",
                "old_version": check.get("current"),
                "new_version": check.get("current"),
                "latest_version": check.get("latest"),
            })

        outcome, stdout, stderr = execute_agent_update(agent_key)
        status = outcome["status"] if outcome else "failed"
        success = status not in ("failed",)
        if success:
            config = load_config()
            _persist_agent_after_update(config, agent_key)
            save_config(config)

        return jsonify({
            "success": success,
            "status": status,
            "exit_code": outcome.get("exit_code") if outcome else -1,
            "old_version": outcome.get("old") if outcome else None,
            "new_version": outcome.get("new") if outcome else None,
            "latest_version": outcome.get("latest") if outcome else None,
            "stdout": stdout[:500] if stdout else "",
            "stderr": (outcome.get("error") or stderr)[:500] if (outcome or stderr) else "",
        })

    @app.route("/api/doctor")
    def api_doctor():
        issues = []
        if not which("curl"):
            issues.append("curl not found")
        if not which("node") or not which("npm"):
            issues.append("Node.js/npm not found")
        if not which("git"):
            issues.append("git not found")

        prereqs = {}
        for tool in ["curl", "git", "node", "npm", "python3", "pip"]:
            prereqs[tool] = which(tool)

