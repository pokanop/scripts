_deep_merge = sk.deep_merge
_config_get_nested = sk.get_nested


def _config_set_nested(config, key_path, value):
    # Coerce scalar strings (true/false/null/int/float) to their natural types.
    sk.set_nested(config, key_path, value, coerce=True)


def _config_from_env():
    return sk.config_from_env("AIKIT", coerce=True)


def load_config():
    config = dict(DEFAULT_CONFIG)
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                saved = json.load(f)
            config = _deep_merge(config, saved)
        except (json.JSONDecodeError, OSError):
            pass
    env_overrides = _config_from_env()
    if env_overrides:
        config = _deep_merge(config, env_overrides)
    return config


def save_config(config):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(config, indent=2) + "\n")
    CONFIG_FILE.chmod(0o600)


def _needs_setup():
    return not SETUP_MARKER.exists()


def _npm_global_bin_dirs():
    """npm global bin directories that are on PATH."""
    dirs = []
    for prefix in _npm_global_prefixes():
        npm_bin = prefix / "bin"
        if npm_bin.is_dir() and _path_entry_on_path(npm_bin) and npm_bin not in dirs:
            dirs.append(npm_bin)
    return dirs


# =============================================================================
# Subprocess helpers
# =============================================================================

def run(cmd, timeout=300, shell=True, capture=True, env=None):
    """Run a shell command. Returns (exit_code, stdout, stderr)."""
    run_env = {**os.environ, **env} if env else None
    try:
        result = subprocess.run(
            cmd,
            shell=shell,
            capture_output=capture,
            text=True,
            timeout=timeout,
            env=run_env,
        )
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except subprocess.TimeoutExpired:
        return -1, "", f"Command timed out after {timeout}s: {cmd}"
    except Exception as e:
        return -1, "", str(e)


def _npm_global_prefixes():
    """npm global prefix directories aikit may install into or need to clean up."""
    prefixes = []
    seen = set()

    def add(prefix):
        try:
            path = Path(prefix).expanduser().resolve()
        except OSError:
            return
        if path in seen:
            return
        seen.add(path)
        prefixes.append(path)

    add(_NPM_INSTALL_PREFIX)
    exit_code, prefix, _ = _run_npm("npm config get prefix", timeout=10)
    if exit_code == 0 and prefix:
        add(prefix.strip().strip('"'))

    nvm_root = Path(os.environ.get("NVM_DIR", Path.home() / ".nvm"))
    default_alias = nvm_root / "alias" / "default"
    if default_alias.is_file():
        add(nvm_root / "versions" / "node" / default_alias.read_text().strip())

    for entry in os.environ.get("PATH", "").split(os.pathsep):
        if ".nvm/versions/node/" not in entry:
            continue
        try:
            add(Path(entry).resolve().parent)
        except OSError:
            pass

    node = shutil.which("node")
    if node and ".nvm/versions/node/" in node:
        add(Path(node).resolve().parent)

    return prefixes


def _npm_package_dir(prefix, package):
    return Path(prefix) / "lib" / "node_modules" / package


def npm_uninstall_cmd(package):
    """Uninstall an npm global package from every prefix where it is present."""
    cmds = []
    for prefix in _npm_global_prefixes():
        if not _npm_package_dir(prefix, package).exists():
            continue
        cmds.append(f"npm uninstall -g {package} --prefix {shlex.quote(str(prefix))}")
    if not cmds:
        cmds.append(f"npm uninstall -g {package} --prefix {_npm_prefix_quoted()}")
    return " ; ".join(cmds)


def which(binary):
    """Check if a command is on PATH."""
    return shutil.which(binary) is not None


def _agent_bin_candidates(agent_key):
    """Declared command names for an agent (primary first)."""
    agent = AGENTS.get(agent_key)
    if not agent:
        return []
    return [agent["bin"], *agent.get("bin_aliases", [])]


def _agents_sharing_bin_name(bin_name):
    """Agent keys that declare the same command name (e.g. cursor + grok → 'agent')."""
    return [key for key, agent in AGENTS.items() if bin_name in _agent_bin_candidates(key)]


def bin_path_belongs_to_agent(agent_key, bin_path):
    """True when a resolved PATH entry belongs to this agent (not a name collision)."""
    agent = AGENTS.get(agent_key)
    if not agent or not bin_path:
        return False
    raw = str(bin_path)
    try:
        resolved = str(Path(bin_path).resolve())
    except OSError:
        resolved = raw
    markers = agent.get("path_markers", [])
    for check_path in (resolved, raw):
        if markers and any(marker in check_path for marker in markers):
            return True
    candidates = _agent_bin_candidates(agent_key)
    for check_path in (raw, resolved):
        name = Path(check_path).name
        if name not in candidates:
            continue
        owners = _agents_sharing_bin_name(name)
        if len(owners) == 1:
            return owners[0] == agent_key
    return False


def resolve_agent_bin(agent_key):
    """Return the command name (or absolute path) for an installed agent, or None."""
    agent = AGENTS.get(agent_key)
    if not agent:
        return None
    primary = agent["bin"]
    primary_path = shutil.which(primary)
    if primary_path and bin_path_belongs_to_agent(agent_key, primary_path):
        return primary
    for alias in agent.get("bin_aliases", []):
        alias_path = shutil.which(alias)
        if alias_path and bin_path_belongs_to_agent(agent_key, alias_path):
            return alias
    if "npm" in agent.get("requires", []):
        for bin_dir in _npm_global_bin_dirs():
            for name in _agent_bin_candidates(agent_key):
                candidate = bin_dir / name
                if not candidate.exists():
                    continue
                if bin_path_belongs_to_agent(agent_key, str(candidate)):
                    return str(candidate)
    for rel_path in agent.get("install_paths", []):
        candidate = Path(os.path.expanduser(rel_path))
        if candidate.exists() and bin_path_belongs_to_agent(agent_key, str(candidate)):
            return str(candidate)
    return None


def detect_agent_bin(agent_key):
    """Check if an agent's binary is available on PATH."""
    return resolve_agent_bin(agent_key) is not None


def _version_command(agent_key, bin_name):
    agent = AGENTS.get(agent_key, {})
    template = agent.get("version_cmd")
    if template:
        parts = template.split(None, 1)
        if len(parts) == 2:
            return f"{bin_name} {parts[1]}"
        return bin_name
    return f"{bin_name} --version"


def _version_timeout(agent_key):
    return int(AGENTS.get(agent_key, {}).get("version_timeout", 10))


def _version_env(agent_key):
    return AGENTS.get(agent_key, {}).get("version_env") or None


def _parse_version_stdout(stdout):
    """Pick the best version line from multi-line CLI --version output."""
    if not stdout:
        return None
    lines = [ln.strip() for ln in stdout.splitlines() if ln.strip()]
    if not lines:
        return None
    for line in reversed(lines):
        if re.search(r"\d+\.\d+", line):
            return line
    return lines[-1]


def detect_agent_version(agent_key):
    """Try to get an agent's installed version."""
    bin_name = resolve_agent_bin(agent_key)
    if not bin_name:
        return None
    exit_code, stdout, _ = run(
        _version_command(agent_key, bin_name),
        timeout=_version_timeout(agent_key),
        env=_version_env(agent_key),
    )
    if exit_code == 0 and stdout:
        return _parse_version_stdout(stdout)
    return None


def agent_bin_collision_warnings():
    """Warnings when multiple agents share the ambiguous 'agent' command."""
    if not (detect_agent_bin("cursor") and detect_agent_bin("grok")):
        return []
    agent_path = shutil.which("agent")
    if not agent_path:
        return []
    if bin_path_belongs_to_agent("grok", agent_path):
        winner = "Grok Build"
    elif bin_path_belongs_to_agent("cursor", agent_path):
        winner = "Cursor CLI"
    else:
        winner = "another tool"
    return [
        "Both Cursor CLI and Grok Build are installed; bare 'agent' currently runs "
        f"{winner}. Use 'cursor-agent' or 'grok' to disambiguate."
    ]


def resolve_update_cmd(agent_key):
    """Return the shell command to update an agent, or None."""
    agent = AGENTS.get(agent_key)
    if not agent:
        return None
    update_cmd = agent.get("update_cmd")
    if update_cmd:
        bin_name = resolve_agent_bin(agent_key) or agent["bin"]
        primary = agent["bin"]
        if update_cmd.startswith(f"{primary} "):
            return f"{bin_name}{update_cmd[len(primary):]}"
        if update_cmd == primary:
            return bin_name
        return update_cmd
    if agent.get("update_via_install"):
        return agent.get("install", {}).get(_CURRENT_PLATFORM)
    return None


def extract_version(text):
    """Pull a comparable version token from CLI --version output."""
    if not text:
        return None
    raw = str(text).strip()
    grok_match = re.search(r"grok\s+(\d+\.\d+\.\d+)", raw, re.I)
    if grok_match:
        return grok_match.group(1)
    match = re.search(r"(\d+(?:\.\d+)+(?:[-+][\w.-]+)?)", raw)
    return match.group(1) if match else raw


def _version_tuple(version):
    parts = []
    for piece in re.split(r"[.\-+]", version):
        if not piece:
            continue
        if piece.isdigit():
            parts.append((0, int(piece)))
        else:
            parts.append((1, piece))
    return tuple(parts)


def version_is_older(current, latest):
    """Return True when current is strictly older than latest."""
    if not current or not latest:
        return None
    if current == latest:
        return False
    try:
        return _version_tuple(current) < _version_tuple(latest)
    except (TypeError, ValueError):
        return current != latest


def _http_get_text(url, timeout=15):
    req = Request(url, headers={"User-Agent": "aikit-version-check"})
    with urlopen(req, timeout=timeout) as resp:
        return resp.read().decode("utf-8", errors="replace").strip()


def _antigravity_platform():
    system = platform.system().lower()
    machine = platform.machine().lower()
    arch = "arm64" if machine in ("arm64", "aarch64") else "x64"
    if system == "linux":
        return f"linux_{arch}"
    if system == "darwin":
        return f"darwin_{arch}"
    return f"{system}_{arch}"


def fetch_latest_version(agent_key):
    """Query upstream for the latest published version, or None on failure."""
    agent = AGENTS.get(agent_key, {})
    spec = agent.get("version_check")
    if not spec:
        return None
    kind = spec.get("type")
    try:
        if kind == "npm":
            exit_code, stdout, _ = _run_npm(
                f"npm view {spec['package']} version", timeout=20,
            )
            return stdout.strip() if exit_code == 0 and stdout else None
        if kind == "pip":
            data = json.loads(_http_get_text(f"https://pypi.org/pypi/{spec['package']}/json"))
            return data.get("info", {}).get("version")
        if kind == "url_text":
            return _http_get_text(spec["url"]).splitlines()[0].strip()
        if kind == "json_url":
            data = json.loads(_http_get_text(spec["url"]))
            return data.get(spec.get("key", "version"))
        if kind == "github_release":
            data = json.loads(_http_get_text(f"https://api.github.com/repos/{spec['repo']}/releases/latest"))
            tag = data.get("tag_name", "")
            prefix = spec.get("tag_prefix", "")
            if prefix and tag.startswith(prefix):
                return tag[len(prefix):]
            return tag.lstrip("v")
        if kind == "cursor_install_script":
            body = _http_get_text(spec["url"])
            match = re.search(r"versions/([0-9][0-9.\-]+)", body)
            return match.group(1) if match else None
        if kind == "antigravity_manifest":
            url = (
                "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app"
                f"/manifests/{_antigravity_platform()}.json"
            )
            data = json.loads(_http_get_text(url))
            return data.get("version")
        if kind == "cmd_json":
            if not detect_agent_bin(agent_key):
                return None
            exit_code, stdout, _ = run(spec["cmd"], timeout=30)
            if exit_code != 0 or not stdout:
                return None
            payload = json.loads(stdout)
            if payload.get(spec.get("available_key", "updateAvailable")):
                return payload.get(spec.get("latest_key", "latestVersion"))
            return payload.get(spec.get("current_key", "currentVersion")) or payload.get(
                spec.get("latest_key", "latestVersion")
            )
        if kind == "cmd_text":
            if not detect_agent_bin(agent_key):
                return None
            exit_code, stdout, stderr = run(spec["cmd"], timeout=60)
            if exit_code != 0:
                return None
            haystack = f"{stdout}\n{stderr}"
            if spec.get("available_substr") and spec["available_substr"] in haystack:
                return "latest"
            return None
    except (URLError, TimeoutError, json.JSONDecodeError, OSError, subprocess.SubprocessError):
        return None
    return None


def check_update_status(agent_key, *, config=None, current_raw=None):
    """Check whether an installed agent has a newer upstream release.

    Returns {available: bool|None, current, latest, checked_at}.
    available=None means the check could not be completed.
    """
    config = config or load_config()
    settings = config.get("settings", {})
    if not settings.get("auto_update_check", True):
        return {"available": None, "current": None, "latest": None, "checked_at": None}

    if not detect_agent_bin(agent_key):
        return {"available": None, "current": None, "latest": None, "checked_at": None}

    now = time.time()
    agent = AGENTS.get(agent_key, {})
    spec = agent.get("version_check")
    if current_raw is None and not (spec and spec.get("type") == "cmd_json"):
        current_raw = detect_agent_version(agent_key)
    current = extract_version(current_raw) if current_raw else None

    if spec and spec.get("type") == "cmd_json":
        try:
            exit_code, stdout, _ = run(spec["cmd"], timeout=30)
            if exit_code == 0 and stdout:
                payload = json.loads(stdout)
                latest = payload.get(spec.get("latest_key", "latestVersion"))
                cur = payload.get(spec.get("current_key", "currentVersion")) or current
                available = bool(payload.get(spec.get("available_key", "updateAvailable")))
                result = {
                    "available": available,
                    "current": cur or current,
                    "latest": latest,
                    "checked_at": now,
                }
                UPDATE_CHECK_CACHE[agent_key] = result
                return result
        except (json.JSONDecodeError, OSError):
            pass

    if spec and spec.get("type") == "cmd_text":
        try:
            exit_code, stdout, stderr = run(spec["cmd"], timeout=60)
            if exit_code == 0:
                haystack = f"{stdout}\n{stderr}"
                available = spec.get("available_substr", "") in haystack
                result = {
                    "available": available,
                    "current": current,
                    "latest": "latest" if available else current,
                    "checked_at": now,
                }
                UPDATE_CHECK_CACHE[agent_key] = result
                return result
        except OSError:
            pass

    latest = fetch_latest_version(agent_key)
    if spec and spec.get("type") == "cmd_text" and latest == "latest":
        available = True
    elif latest is None:
        available = None
    else:
        available = version_is_older(current, latest)

    result = {
        "available": available,
        "current": current,
        "latest": latest,
        "checked_at": now,
    }
    UPDATE_CHECK_CACHE[agent_key] = result
    return result


def format_update_status(agent_key, update_status):
    """Human-readable update column text for list/doctor views."""
    if not update_status:
        return "—"
    available = update_status.get("available")
    latest = update_status.get("latest")
    if available is True:
        if latest and latest != "latest":
            return f"↑ {latest}"
        return "upgrade available"
    if available is False:
        return "up to date"
    return "—"


def classify_update_outcome(agent_key, *, old_version_raw, new_version_raw, exit_code, stderr=""):
    """Classify the result of running an agent's update command."""
    old_v = extract_version(old_version_raw)
    new_v = extract_version(new_version_raw)

    if exit_code != 0:
        return {
            "status": "failed",
            "old": old_v,
            "new": new_v,
            "error": (stderr or "")[:200],
        }

    if old_v and new_v and old_v != new_v:
        return {"status": "upgraded", "old": old_v, "new": new_v}

    check = check_update_status(agent_key)
    latest = check.get("latest")
    if check.get("available") is True:
        return {
            "status": "unchanged_outdated",
            "old": old_v or new_v,
            "new": new_v or old_v,
            "latest": latest,
        }
    if check.get("available") is False:
        return {
            "status": "up_to_date",
            "old": old_v or new_v,
            "new": new_v or old_v,
            "latest": latest,
        }
    return {
        "status": "unchanged",
        "old": old_v or new_v,
        "new": new_v or old_v,
        "latest": latest,
    }


def should_skip_update(agent_key, *, force=False, config=None):
    """Return (skip, check_status) when upstream reports the agent is current."""
    if force:
        return False, None
    check = check_update_status(agent_key, config=config)
    if check.get("available") is False:
        return True, check
    return False, check


def execute_agent_update(agent_key):
    """Run an agent's update command and classify the outcome."""
    update_cmd = resolve_update_cmd(agent_key)
    if not update_cmd:
        return None, "", ""
    old_version_raw = detect_agent_version(agent_key)
    exit_code, stdout, stderr = run(update_cmd, timeout=300)
    new_version_raw = detect_agent_version(agent_key)
    UPDATE_CHECK_CACHE.pop(agent_key, None)
    outcome = classify_update_outcome(
        agent_key,
        old_version_raw=old_version_raw,
        new_version_raw=new_version_raw,
        exit_code=exit_code,
        stderr=stderr,
    )
    outcome["exit_code"] = exit_code
    return outcome, stdout, stderr


def _persist_agent_after_update(config, agent_key, new_version_raw=None):
    """Refresh cached agent version and upgrade availability after an update attempt."""
    new_version = new_version_raw or detect_agent_version(agent_key)
    check = check_update_status(agent_key, config=config)
    config["agents"][agent_key] = {
        **config["agents"].get(agent_key, {}),
        "installed": True,
        "version": new_version,
        "update_available": check.get("available") is True,
        "latest_version": check.get("latest") or extract_version(new_version),
    }


def _agent_names(agent_keys):
    return ", ".join(AGENTS[k]["name"] for k in agent_keys)


def validate_agent_keys(agent_keys):
    """Return agent_keys when every key is registered; raise AikitError otherwise."""
    if not agent_keys:
        return agent_keys
    unknown = [k for k in agent_keys if k not in AGENTS]
    if not unknown:
        return agent_keys
    parts = []
    for key in unknown:
        suggestions = difflib.get_close_matches(key, AGENTS.keys(), n=3, cutoff=0.5)
        hint = f" (did you mean: {', '.join(suggestions)}?)" if suggestions else ""
        parts.append(f"{key}{hint}")
    listed = ", ".join(parts)
    hint = "Run 'aikit list' for all agent keys."
    raise AikitError(f"Unknown agent(s): {listed}. {hint}")


def check_prerequisites(agent_key):
    """Check if required tools are available for an agent install."""
    agent = AGENTS.get(agent_key)
    if not agent:
        return []
    return [r for r in agent.get("requires", []) if not which(r.replace("3", "")) and not which(r)]


