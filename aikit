def _do_update_impl(agent_keys):
    config = load_config()

    if agent_keys is None:
        agent_keys = [k for k in AGENTS if detect_agent_bin(k)]
        if not agent_keys:
            print_warning("No agents installed. Run 'aikit install' first.")
            return

    console.print(f"[bold cyan]🔄 Updating {len(agent_keys)} agent(s)...[/bold cyan]\n")

    updated = []
    failed = []

    for i, key in enumerate(agent_keys, 1):
        agent = AGENTS[key]
        icon = agent["icon"]

        if not detect_agent_bin(key):
            print_info(f"{icon} {agent['name']} — not installed, skipping")
            continue

        update_cmd = agent.get("update_cmd")
        if not update_cmd:
            print_info(f"{icon} {agent['name']} — no update command available")
            continue

        print_step(i, len(agent_keys), f"Updating {icon} {agent['name']}")
        exit_code, stdout, stderr = run(update_cmd, timeout=300)

        if exit_code == 0:
            new_version = detect_agent_version(key)
            print_success(f"{icon} {agent['name']} updated [dim]({new_version})[/dim]")
            config["agents"][key] = {
                **config["agents"].get(key, {}),
                "installed": True,
                "version": new_version,
            }
            updated.append(key)
        else:
            print_error(f"{icon} {agent['name']} update failed: {stderr[:100]}")
            failed.append(key)

    save_config(config)

    if updated:
        console.print(f"\n[bold green]✅ Updated:[/bold green] {', '.join(updated)}")
    if failed:
        console.print(f"[bold red]❌ Failed:[/bold red] {', '.join(failed)}")


