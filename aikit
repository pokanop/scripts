_NPM_INSTALL_PREFIX = Path.home() / ".local"


def _npm_prefix_quoted():
    return shlex.quote(str(_NPM_INSTALL_PREFIX))


def npm_install_cmd(package):
    """Install an npm package globally under ~/.local/bin."""
    return f"npm install -g {package} --prefix {_npm_prefix_quoted()}"


def _path_entry_on_path(dir_path):
    """True when a directory is listed on PATH."""
    try:
        target = str(Path(dir_path).resolve())
    except OSError:
        return False
    for entry in os.environ.get("PATH", "").split(os.pathsep):
        if not entry:
            continue
        try:
            if str(Path(entry).resolve()) == target:
                return True
        except OSError:
            if entry == str(dir_path):
                return True
    return False


def binary_uninstall_cmd(bin_name, *, extra_paths=()):
    """Remove a curl-installed CLI binary from standard install locations."""
    paths = [f"$HOME/.local/bin/{bin_name}", f"/usr/local/bin/{bin_name}", *extra_paths]
    if _CURRENT_PLATFORM == "Windows":
        win = f"{bin_name}.exe" if not bin_name.endswith(".exe") else bin_name
        paths.extend([f"$USERPROFILE/.local/bin/{win}", f"$USERPROFILE/goose/{win}"])
    return "rm -f " + " ".join(paths)


def goose_uninstall_cmd():
    """Goose has no official uninstall — remove the curl/brew-installed binary."""
    parts = [binary_uninstall_cmd("goose")]
    goose_path = shutil.which("goose")
    if goose_path:
        try:
            goose_path = str(Path(goose_path).resolve())
        except OSError:
            goose_path = str(goose_path)
        if "homebrew" in goose_path or "Cellar/block-goose" in goose_path:
            parts.insert(0, "brew uninstall block-goose-cli 2>/dev/null")
    return " ; ".join(parts)


def openhands_uninstall_cmd():
    """OpenHands: uv tool uninstall (docs) or remove the install-script binary."""
    uv = "command -v uv >/dev/null 2>&1 && uv tool uninstall openhands 2>/dev/null; "
    return uv + binary_uninstall_cmd("openhands")


def resolve_uninstall_cmd(agent):
    """Return the platform-specific uninstall command for an agent."""
    version_check = agent.get("version_check", {})
    if version_check.get("type") == "npm" and version_check.get("package"):
        return npm_uninstall_cmd(version_check["package"])
    cmd = agent.get("uninstall_cmd")
    if isinstance(cmd, dict):
        return cmd.get(_CURRENT_PLATFORM)
    if callable(cmd):
        return cmd()
    return cmd


