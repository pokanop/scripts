def do_doctor() -> int:
    """Diagnose environment and agent health via the shared doctor report.

    Auto-discovers and persists all agent states to config first, so the report
    reflects reality.
    """
    discover_and_persist()
    config = load_config()

    prereq = [
        sk.check_binary("curl", required=False, hint="curl needed for most install scripts"),
        sk.check_binary("git", required=False, hint="git needed by some agents"),
        sk.check_binary("node", required=False, hint="Node.js/npm needed for npm-based agents"),
        sk.check_binary("npm", required=False, hint="npm needed for npm-based agents"),
        sk.check_binary("python3"),
        sk.check_binary("pip", required=False),
    ]

    agents: list = []
    installed_count = auth_count = upgrade_count = 0
    not_installed: list[str] = []
    for key in AGENTS:
        agent = AGENTS[key]
        agent_cfg = config.get("agents", {}).get(key, {})
        installed = agent_cfg.get("installed", False) or detect_agent_bin(key)
        if not installed:
            not_installed.append(agent["name"])
            continue
        installed_count += 1
        version = agent_cfg.get("version") or detect_agent_version(key)
        label = f"{agent['icon']} {agent['name']}"
        update_note = format_update_status(key, {
            "available": agent_cfg.get("update_available"),
            "latest": agent_cfg.get("latest_version"),
        })
        if agent_cfg.get("update_available") is True:
            upgrade_count += 1
        if agent_cfg.get("auth_configured", False):
            auth_count += 1
            detail = version or "installed"
            if agent_cfg.get("update_available") is True:
                agents.append(sk.Check.warn(label, detail, f"upgrade available ({update_note})"))
            else:
                agents.append(sk.Check.ok(label, detail))
        else:
            hint = f"configure auth: aikit auth {key}"
            if agent_cfg.get("update_available") is True:
                hint = f"{hint}; upgrade available ({update_note})"
            agents.append(sk.Check.warn(label, version or "installed", hint))
    if not agents:
        agents.append(sk.Check.warn("agents", "none installed", "install one: aikit install"))

    tips = [f"{installed_count}/{len(AGENTS)} installed, {auth_count} authenticated"]
    if upgrade_count:
        tips.append(f"{upgrade_count} upgrade(s) available — run aikit update")
    if not_installed:
        tips.append("Not installed: " + ", ".join(not_installed) + "  (aikit install)")
    tips.extend(agent_bin_collision_warnings())

    return sk.doctor(
        "aikit", __version__, TAGLINE, ICON,
        sections={"Prerequisites": prereq, "Agents": agents},
        tips=tips,
    )


