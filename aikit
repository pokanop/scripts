def _agent_entry_changed(current, merged):
    omit = "update_checked_at"
    return {k: v for k, v in merged.items() if k != omit} != {
        k: v for k, v in current.items() if k != omit
    }


def _discover_agent_entry(key, config):
    """Discover install/version/auth/update state for one agent."""
    agents_cfg = config.get("agents", {})
    current = agents_cfg.get(key, {})
    installed = detect_agent_bin(key)
    version = detect_agent_version(key) if installed else None
    auth_result = discover_auth(key)
    update_status = (
        check_update_status(key, config=config, current_raw=version)
        if installed else {}
    )

    new_entry = {
        "installed": installed,
        "version": version,
        "auth_configured": auth_result.get("auth_configured", False),
        "auth_method": auth_result.get("method", ""),
        "auth_source": auth_result.get("source", ""),
        "install_date": current.get("install_date", ""),
        "auth_date": current.get("auth_date", ""),
        "latest_version": update_status.get("latest"),
        "update_available": update_status.get("available"),
        "update_checked_at": update_status.get("checked_at"),
    }

    merged = {**current, **new_entry}
    if not installed:
        merged["install_date"] = ""
        merged["version"] = None
        merged["latest_version"] = None
        merged["update_available"] = None
        merged["update_checked_at"] = None
    if current.get("install_date") and installed:
        merged["install_date"] = current["install_date"]
    if current.get("auth_date") and auth_result.get("auth_configured"):
        merged["auth_date"] = current["auth_date"]

    return key, merged, _agent_entry_changed(current, merged)


def discover_and_persist():
    """Run full system discovery: detect installed agents, versions, and auth state.
    Persists all findings to config. Called automatically by doctor, list, and install."""
    config = load_config()
    agents_cfg = dict(config.get("agents", {}))
    changed = False

    results = sk.parallel_map(
        lambda key: _discover_agent_entry(key, config),
        list(AGENTS.keys()),
        "Discovering agents",
        max_workers=8,
    )

    for key, merged, entry_changed in results:
        if entry_changed:
            agents_cfg[key] = merged
            changed = True

    if changed:
        config["agents"] = agents_cfg
        save_config(config)


def do_auth(agent_key):
    """Guide user through auth for an agent."""
    try:
        _do_auth_impl(agent_key)
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Auth setup cancelled.[/yellow]")
        sys.exit(130)


def _do_auth_impl(agent_key):
    validate_agent_keys([agent_key])
    agent = AGENTS[agent_key]

    icon = agent["icon"]

    if not detect_agent_bin(agent_key):
        print_error(f"{icon} {agent['name']} is not installed. Run 'aikit install {agent_key}' first.")
        return

    auth_type = agent.get("auth_type", "unknown")
    auth_note = agent.get("auth_note", "")
    env_vars = agent.get("auth_env_vars", [])
    
    # Check if already authenticated
    existing = discover_auth(agent_key)
    if existing["auth_configured"]:
        console.print(f"\n[bold cyan]🔑 {icon} {agent['name']}[/bold cyan]")
        print_success(f"Already authenticated! [dim](source: {existing['source']})[/dim]")
        # Ensure config is updated
        config = load_config()
        config["agents"][agent_key] = {
            **config["agents"].get(agent_key, {}),
            "auth_configured": True,
            "auth_date": config["agents"].get(agent_key, {}).get("auth_date", time.strftime("%Y-%m-%d")),
            "auth_method": existing["method"],
            "auth_source": existing["source"],
        }
        save_config(config)
        return

    console.print(f"\n[bold cyan]🔑 Authentication Setup: {icon} {agent['name']}[/bold cyan]")
    console.print(f"  Auth type: [bold]{auth_type}[/bold]")
    console.print(f"  Homepage:  {agent['homepage']}")

    if auth_note:
        console.print(f"\n  [bold yellow]📝 {auth_note}[/bold yellow]")

    if auth_type == "oauth_browser":
        bin_name = resolve_agent_bin(agent_key) or agent["bin"]
        console.print(f"\n  [dim]This agent uses OAuth. Run '{bin_name}' and complete the browser login.[/dim]")
        if _use_color() and sys.stdin.isatty():
            try:
                if _prompt_yes_no(f"Launch '{bin_name}' now to authenticate?", True):
                    os.system(bin_name)
            except KeyboardInterrupt:
                raise

    elif auth_type in ("api_key", "provider_keys", "pat_or_oauth", "oauth_portal", "account_or_byok", "oauth_onboard"):
        if env_vars:
            console.print("\n  [bold]Environment variables to set:[/bold]")
            for var in env_vars:
                current = os.environ.get(var, "")
                if current:
                    masked = current[:4] + "***" + current[-4:] if len(current) > 8 else "***"
                    console.print(f"    {var} = [green]{masked}[/green] (already set)")
                else:
                    console.print(f"    {var} = [dim](not set)[/dim]")
                    if _use_color() and sys.stdin.isatty():
                        val = _prompt(f"  Enter value for {var} (or Enter to skip)", "")
                        if val:
                            _save_env_var(var, val)
                            console.print(f"    [green]✓ Saved {var}[/green]")

    elif auth_type == "subscription":
        console.print(f"\n  [dim]This agent requires a paid subscription. Visit {agent['homepage']} to subscribe.[/dim]")

    # Mark as auth-attempted with real discovery
    discover_and_persist()
    config = load_config()
    config["agents"][agent_key] = {
        **config["agents"].get(agent_key, {}),
        "auth_configured": True,
        "auth_date": time.strftime("%Y-%m-%d"),
    }
    save_config(config)

    print_success(f"{icon} {agent['name']} auth setup complete!")


def _save_env_var(var, value):
    """Save an env var to shell profile and current session."""
    os.environ[var] = value

    # Save to persistent locations
    for profile in [
        os.path.expanduser("~/.bashrc"),
        os.path.expanduser("~/.zshrc"),
        os.path.expanduser("~/.profile"),
    ]:
        if os.path.exists(profile):
            try:
                content = Path(profile).read_text()
                if f"export {var}=" not in content:
                    with open(profile, "a") as f:
                        f.write(f"\n# aikit — {var}\nexport {var}={shlex.quote(value)}\n")
            except OSError:
                pass

    # Also save to aikit config
    config = load_config()
    config.setdefault("env_vars", {})[var] = True
    save_config(config)


