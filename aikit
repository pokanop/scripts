def _renderer_target_rels():
    """agent_key → native-config rel path (None when staged-only), from the specs."""
    return {agent_key: target_rel
            for _, agent_key, _, target_rel, _ in GATEWAY_TOOL_SPECS}


def resolve_passthrough_state(key, entry, *, usable_routes=None, custom=None,
                              credential_mode=GATEWAY_CRED_VIRTUAL_KEY):
    """Resolve a coverage entry's RUNTIME state from discovered routes + custom maps.

    Only entries with passthrough candidacy (a ``passthrough`` block) or a user-declared
    custom mapping can change; everything else returns its static entry untouched — so
    ``gateway_coverage()`` with no discovery is byte-for-byte the POK-66 behaviour.

    A tool resolves to ``passthrough`` when either (a) the user declared a custom mapping
    for it (the user asserts the gateway route + how to reach it), or (b) its built-in
    route is in ``usable_routes`` AND it exposes a base-URL override to point there. A
    built-in route that's usable but has no override stays ``unsupported`` — but the
    reason flips to name the tool-side gap, not the gateway. Returns a fresh dict; the
    internal ``passthrough`` candidacy key is never leaked into the result.
    """
    custom = custom or {}
    decl = custom.get(key)
    pt = entry.get("passthrough")
    out = {k: v for k, v in entry.items() if k != "passthrough"}
    if not decl and not pt:
        return out                                   # nothing to resolve

    route = (decl or {}).get("route") or (pt or {}).get("route")
    base_url_var = (decl or {}).get("base_url_var") or (pt or {}).get("base_url_var")
    auth_var = (decl or {}).get("auth_var") or (pt or {}).get("auth_var")
    auth_mode = ((decl or {}).get("credential_mode") or (decl or {}).get("auth_mode")
                 or (pt or {}).get("credential_mode") or credential_mode)

    if decl and route:                               # user-declared → trusted, routed
        out.update(state=COVERAGE_PASSTHROUGH, reason=None, route=route,
                   auth_var=auth_var, base_url_var=base_url_var, auth_mode=auth_mode,
                   source="custom", via=f"{route} (custom, {auth_mode})")
    elif usable_routes is not None and route and route in usable_routes:
        if base_url_var:                             # route usable + tool can be pointed
            out.update(state=COVERAGE_PASSTHROUGH, reason=None, route=route,
                       auth_var=auth_var, base_url_var=base_url_var, auth_mode=auth_mode,
                       source="builtin", via=f"{route} ({auth_mode})")
        else:                                        # route usable, tool has no override
            out.update(state=COVERAGE_UNSUPPORTED, route=route,
                       reason=f"{route} passthrough is usable, but {key} has no base-URL "
                              "override — needs a native renderer or a custom mapping")
    return out


def gateway_coverage(*, passthrough=None, custom=None,
                     credential_mode=GATEWAY_CRED_VIRTUAL_KEY):
    """Full per-agent gateway coverage — the single map `status`/`on`/`coverage` read.

    Spans **every** agent in AGENTS. ``renderer`` state derives from
    GATEWAY_TOOL_SPECS (so it can't drift from what `on` actually writes); every
    other agent's state comes from GATEWAY_COVERAGE. An agent in neither is returned
    as ``unclassified`` rather than dropped — a newly-registered agent surfaces
    loudly in `coverage` instead of being silently omitted.

    ``passthrough`` (the usable-route set from :func:`discover_passthrough_routes`) and
    ``custom`` (user-declared ``{tool: {...}}`` mappings) drive RUNTIME resolution of
    the vendor-native tools; omit both for the static view.

    Returns ``{agent_id: {"state", "via", "reason", ...}}`` (via/reason may be None;
    ``route``/``auth_mode``/``auth_var``/``base_url_var`` appear on resolved passthroughs).
    """
    renderer_targets = _renderer_target_rels()
    cov = {}
    for key in AGENTS:                       # AGENTS preserves insertion order
        if key in renderer_targets:
            target_rel = renderer_targets[key]
            via = (f"~/{target_rel}" if target_rel
                   else "staged native config (real path varies)")
            cov[key] = {"state": COVERAGE_RENDERER, "via": via, "reason": None}
        else:
            entry = GATEWAY_COVERAGE.get(key) or {
                "state": COVERAGE_UNCLASSIFIED, "via": None,
                "reason": "no gateway coverage declared — add it to GATEWAY_COVERAGE"}
            resolved = resolve_passthrough_state(
                key, entry, usable_routes=passthrough, custom=custom,
                credential_mode=credential_mode)
            cov[key] = {"state": resolved["state"], "via": resolved.get("via"),
                        "reason": resolved.get("reason"), "route": resolved.get("route"),
                        "auth_mode": resolved.get("auth_mode"),
                        "auth_var": resolved.get("auth_var"),
                        "base_url_var": resolved.get("base_url_var")}
    return cov


def _gateway_tools_dir():
    return GATEWAY_DIR / "tools"


def _gateway_env_path():
    return GATEWAY_DIR / "gateway.env"


def _gateway_summary_path():
    return GATEWAY_DIR / "gateway.json"


def detect_gateway_tool(agent_key):
    """Whether a wrapped tool is installed — reuses aikit's agent detection so the
    gateway sees tools exactly as `aikit list` / `doctor` do."""
    return detect_agent_bin(agent_key)


def _write_text_file(path, content, *, mode=None):
    """Write text, creating parent dirs; optionally chmod (0600 for the key file)."""
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    if mode is not None:
        try:
            path.chmod(mode)
        except OSError:
            pass


def _dirs_to_create(leaf):
    """Ancestor dirs of (and including) ``leaf`` that don't exist yet, innermost-first.

    Exactly the dirs ``mkdir(parents=True)`` would create — so `off` can prune them
    again (only while empty) and leave the tree as pristine as it found it.
    """
    out, d = [], Path(leaf)
    while not d.exists() and d != d.parent:
        out.append(d)
        d = d.parent
    return out


def _aikit_installed_targets(manifest):
    """Target paths a prior `on` installed (aikit's own native configs, created_by_aikit)."""
    return {e["path"] for e in manifest.get("config_files", [])
            if e.get("role") == "installed" and e.get("created_by_aikit")}


def gateway_tool_plan(base_url, models, detail, *, home, detector=None, aikit_owned=None):
    """Per-tool install plan — pure given the detector and the current filesystem.

    No writes. For each wrapped tool: render its native config, resolve its real
    target, and decide the action under the never-clobber policy:
      ``install``       target is absent (or an aikit-owned config we regenerate)
      ``keep-existing`` a *user's* config already lives there → keep it, stage ours
      ``not-detected``  the tool isn't installed → stage only
      ``staged-only``   the tool's real config path varies → always stage only

    ``aikit_owned`` is the set of target paths a previous `on` installed; those are
    aikit's own and are regenerated (``install``), never treated as a user's file.
    """
    base = base_url.rstrip("/")
    detector = detector or detect_gateway_tool
    aikit_owned = aikit_owned or set()
    tools_dir = _gateway_tools_dir()
    plan = []
    for tid, agent_key, staged_name, target_rel, render in GATEWAY_TOOL_SPECS:
        content = render(base, models, detail)
        staged = tools_dir / staged_name
        target = (home / target_rel) if target_rel else None
        detected = bool(detector(agent_key))
        if target is None:
            action, reason = "staged-only", "config path varies — staged for manual merge"
        elif not detected:
            action, reason = "not-detected", "tool not detected — staged only"
        elif target.exists() and str(target) not in aikit_owned:
            action, reason = "keep-existing", "existing config kept — staged for manual merge"
        else:
            action, reason = "install", f"installed to {target}"
        plan.append({
            "id": tid, "agent_key": agent_key, "staged": staged, "target": target,
            "detected": detected, "action": action, "reason": reason, "content": content,
        })
    return plan


def plan_config_file_entries(plan):
    """The manifest ``config_files`` the plan *will* produce — computed BEFORE any write.

    This is the write-ahead intent: `on` records these in the manifest before
    :func:`apply_gateway_config_files` touches the disk, so an interrupted `on`
    (crash/Ctrl-C after files land but before the final manifest write) is still fully
    reversible by `off` — including the secret-bearing ``gateway.env``. Every path is
    ``created_by_aikit`` (we're about to create it), and ``created_dirs`` is captured
    here, against the pre-write tree, so `off` can prune exactly the dirs `on` adds.
    """
    entries = [
        {"path": str(_gateway_env_path()), "created_by_aikit": True, "tool": None, "role": "portable"},
        {"path": str(_gateway_summary_path()), "created_by_aikit": True, "tool": None, "role": "portable"},
    ]
    for p in plan:
        entries.append({"path": str(p["staged"]), "created_by_aikit": True,
                        "tool": p["id"], "role": "staged"})
        if p["action"] == "install":
            target = p["target"]
            entries.append({"path": str(target), "created_by_aikit": True,
                            "tool": p["id"], "role": "installed",
                            "created_dirs": [str(d) for d in _dirs_to_create(target.parent)]})
    return entries


def apply_gateway_config_files(plan, base_url, pairs, models, detail, *, generated):
    """Write portable files + stage/install per-tool configs (pure I/O — no manifest).

    Portable ``gateway.env`` (0600 — it holds the key) and ``gateway.json`` land in
    the gateway dir; every tool config is staged under ``tools/``, and installed to its
    real path only for ``install`` rows. The manifest of what this writes is recorded
    separately (and *first*) via :func:`plan_config_file_entries`.
    """
    base = base_url.rstrip("/")
    _write_text_file(_gateway_env_path(), render_gateway_env(pairs), mode=0o600)
    _write_text_file(_gateway_summary_path(), render_gateway_summary(base, models, detail, generated))
    for p in plan:
        _write_text_file(p["staged"], p["content"])
        if p["action"] == "install":
            target = p["target"]
            target.parent.mkdir(parents=True, exist_ok=True)
            target.write_text(p["content"])


def gateway_tool_status(manifest, *, home=None, detector=None):
    """Rows for `status`: [tool, detected?, config state + path] for each wrapped tool."""
    home = home or Path.home()
    detector = detector or detect_gateway_tool
    aikit_installed = _aikit_installed_targets(manifest)
    tools_dir = _gateway_tools_dir()
    rows = []
    for tid, agent_key, staged_name, target_rel, render in GATEWAY_TOOL_SPECS:
        detected = bool(detector(agent_key))
        target = (home / target_rel) if target_rel else None
        staged = tools_dir / staged_name
        if target is not None and str(target) in aikit_installed:
            state = f"installed by aikit → {target}"
        elif target is not None and target.exists():
            state = f"user config (kept) → {target}"
        elif target is None:
            state = f"staged only → {staged}"
        else:
            state = f"staged (not installed) → {staged}"
        rows.append([tid, "yes" if detected else "no", state])
    return rows


def gateway_coverage_rows(*, detector=None, passthrough=None, custom=None,
                          credential_mode=GATEWAY_CRED_VIRTUAL_KEY):
    """Coverage matrix for **every** agent — one row per AGENTS entry, in
    state-grouped display order. Pure given the detector; backs the `coverage`
    command and the `status`/`on` accounting, so a detected agent can never be
    silently dropped from the report.

    ``passthrough``/``custom``/``credential_mode`` are threaded into
    :func:`gateway_coverage` for runtime resolution of the vendor-native tools; omit
    them for the static view.

    Each row: ``{"id", "name", "detected" (bool), "state", "detail"}`` where
    ``detail`` is the routing var/route (renderer/env/passthrough) or the blocking
    reason (pending/unsupported/unclassified).
    """
    detector = detector or detect_gateway_tool
    cov = gateway_coverage(passthrough=passthrough, custom=custom,
                           credential_mode=credential_mode)
    order = {s: i for i, s in enumerate(COVERAGE_STATE_ORDER)}
    rows = []
    for key in AGENTS:
        c = cov[key]
        rows.append({
            "id": key,
            "name": AGENTS[key].get("name", key),
            "detected": bool(detector(key)),
            "state": c["state"],
            "detail": c.get("via") or c.get("reason") or "",
        })
    rows.sort(key=lambda r: (order.get(r["state"], len(order)), r["id"]))
    return rows


def _coverage_detected_unrouted(rows):
    """[(id, state)] for every detected agent that does NOT reach the gateway,
    in display order — the 'detected but not routed' set `on`/`status` must own."""
    return [(r["id"], r["state"]) for r in rows
            if r["detected"] and r["state"] not in COVERAGE_ROUTED_STATES]


def _coverage_detected_env(rows):
    """ids of detected agents routed purely via env (no native config) — so `on`
    can positively confirm they're wrapped, not just the renderer set."""
    return [r["id"] for r in rows
            if r["detected"] and r["state"] == COVERAGE_ENV]


def _coverage_detected_passthrough(rows):
    """[(id, detail)] for detected agents routed through a native-protocol passthrough
    route — reported with their route so `on`/`status` name the credential path used."""
    return [(r["id"], r["detail"]) for r in rows
            if r["detected"] and r["state"] == COVERAGE_PASSTHROUGH]


def _warn_passthrough_401s(base_url, key, specs, *, prober=None):
    """Probe the wired passthrough routes and warn on any mounted-but-401 route, so a
    mis-forwarding upstream credential is surfaced at wire time (POK-62). Only probes
    built-in routes with a known-safe models-list GET; `verify` covers the rest."""
    base = base_url.rstrip("/")
    prober = prober or _probe_status
    for s in specs:
        route = s.get("route")
        spec = GATEWAY_PASSTHROUGH_ROUTES.get(route)
        if not spec or not spec.get("probe"):
            continue                 # custom route with no known safe probe — skip here
        status = prober(f"{base}{route}{spec['probe']}", key)
        if status in (401, 403):
            print_warning(f"Passthrough {route} is mounted but returned HTTP {status} — "
                          "the upstream credential isn't forwarding. Run "
                          "'aikit gateway verify' to diagnose.")


def _passthrough_wiring(cov, credential_mode):
    """(specs, forwarded_token_prefixes) that :func:`build_env_pairs` needs, from a
    resolved coverage map. ``specs`` are the passthrough-routed tools (route + auth/base
    vars); ``forwarded_token_prefixes`` are the built-in native routes whose key var to
    skip because the operator opted into forwarded-token mode (Claude Code Max)."""
    specs = [c for c in cov.values() if c.get("state") == COVERAGE_PASSTHROUGH]
    forwarded = (GATEWAY_FORWARD_CAPABLE_PREFIXES
                 if credential_mode == GATEWAY_CRED_FORWARDED_TOKEN else frozenset())
    return specs, forwarded


def _format_coverage_group(items):
    """'openhands (pending), copilot (unsupported)' from [(id, state), …]."""
    return ", ".join(f"{i} ({s})" for i, s in items)


def _print_gateway_coverage_accounting(rows):
    """After the renderer plan, account for the *other* detected agents so `on`
    (and its dry-run) is honest about everything installed — env- and passthrough-routed
    ones by name, and anything detected-but-not-routed with a pointer to `coverage`."""
    env_routed = _coverage_detected_env(rows)
    if env_routed:
        print_info("Also routed via env (no native config): " + ", ".join(env_routed))
    passthrough_routed = _coverage_detected_passthrough(rows)
    if passthrough_routed:
        print_info("Routed via native passthrough: "
                   + ", ".join(f"{i} → {d}" for i, d in passthrough_routed))
    unrouted = _coverage_detected_unrouted(rows)
    if unrouted:
        print_warning("Detected but not routed through the gateway: "
                      + _format_coverage_group(unrouted)
                      + " — see 'aikit gateway coverage'")


def _print_gateway_tool_plan(plan, *, dry_run):
    """Print the per-tool config matrix for `on` (and its `--dry-run` preview)."""
    print_info("Native per-tool config:")
    verb = "would install" if dry_run else "install"
    for p in plan:
        if p["action"] == "install":
            mark = f"→ {verb} → {p['target']}"
        elif p["action"] == "keep-existing":
            mark = f"• existing config kept → {p['target']} (staged for merge)"
        elif p["action"] == "staged-only":
            mark = "  staged only (config path varies)"
        else:  # not-detected
            mark = "  not detected — staged only"
        sk.detail(f"    {p['id']:<14} {mark}")


def _resolve_gateway_credentials(url, key, *, prompt_missing=True):
    """Resolve (url, key) from flags → saved config → prompt. Key prompt is hidden."""
    cfg = load_gateway_config()
    url = _normalize_gateway_url(url or cfg.get("base_url"))
    key = key or cfg.get("key")
    if prompt_missing and not url:
        url = _normalize_gateway_url(_prompt("Gateway base URL (e.g. https://gw.example.com)"))
    if prompt_missing and not key:
        import getpass

        key = getpass.getpass("  Virtual key (input hidden): ").strip()
    if not url or not key:
        raise AikitError(
            "gateway URL and virtual key are required — pass --url/--key or run 'aikit gateway on'."
        )
    return url, key


# --- commands --------------------------------------------------------------
def do_gateway_on(url=None, key=None, *, shell=None, only_discovered=False,
                  yes=False, dry_run=False):
    """Discover models → render the managed env block → write it + the manifest."""
    url, key = _resolve_gateway_credentials(url, key)

    # Validate url+key and learn what the key can see (also used for --only-discovered).
    models, detail = discover_models(url, key)
    only = providers_in_use(models, detail) if only_discovered else None

    # Passthrough routing: discover which native routes this gateway exposes (inference
    # from the models in use — probing lives in `verify` so `on` stays fast), fold in any
    # user-declared custom routes, and resolve the vendor-native tools accordingly.
    customs = load_custom_passthroughs()
    cred_mode = gateway_credential_mode()
    discovered = discover_passthrough_routes(url, key, models, detail, custom=customs)
    usable = usable_passthrough_routes(discovered)
    cov = gateway_coverage(passthrough=usable, custom=customs, credential_mode=cred_mode)
    specs, forwarded = _passthrough_wiring(cov, cred_mode)

    shell_name, rc = detect_shell(shell)
    pairs = build_env_pairs(url, key, only_providers=only,
                            passthroughs=specs, forwarded_token_prefixes=forwarded)
    body = render_env_block_body(shell_name, pairs)
    block = GATEWAY_BLOCK.render(body)

    home = Path.home()
    prior = read_manifest()
    plan = gateway_tool_plan(url, models, detail, home=home,
                             aikit_owned=_aikit_installed_targets(prior))

    rows = gateway_coverage_rows(passthrough=usable, custom=customs,
                                 credential_mode=cred_mode)
    print_info(f"Gateway: {url}")
    print_info(f"Models visible to this key: {len(models)}")
    if only_discovered:
        targets = ", ".join(sorted(only)) or "(none detected)"
        print_info(f"Targeting providers in use: {targets}")
    else:
        print_info(f"Targeting all {len(GATEWAY_PROVIDERS)} providers at the env layer")
    if cred_mode == GATEWAY_CRED_FORWARDED_TOKEN:
        print_info("Credential mode: forwarded-token (your own subscription token is "
                   "passed through; aikit sets base URLs but leaves auth tokens)")
    if specs:
        print_info(f"Passthrough-routed tool(s): "
                   + ", ".join(f"{s.get('route')} ({s.get('auth_mode')})" for s in specs))
        _warn_passthrough_401s(url, key, specs)
    sk.kv("Shell", shell_name)
    sk.kv("rc file", str(rc))
    print_info(f"{len(pairs)} environment variable(s) in the managed block")
    _print_gateway_tool_plan(plan, dry_run=dry_run)
    # Account for every *other* detected agent (env-routed, passthrough, pending,
    # unsupported) so `on` — like `status`/`coverage` — never silently omits a tool.
    _print_gateway_coverage_accounting(rows)

    if dry_run:
        print_info("Dry run — nothing will be written. Managed block preview:")
        for line in _redact_block(block, key).splitlines():
            sk.detail("    " + line)
        return

    if not yes and not sk.confirm(f"Apply the managed gateway block to {rc}?", default=True):
        print_warning("Aborted — nothing written.")
        return

    applied_at = _utc_now()
    # Re-applying? Reverse the previous run's config files first so the new manifest is
    # the single source of truth (a later `off` reverses exactly one install) and so the
    # intent's created_dirs are computed against the post-undo tree, not stale dirs the
    # prior run left behind.
    for entry in prior.get("config_files", []):
        _undo_config_file(entry)
    # Write-ahead intent: build the manifest from the plan and record it BEFORE writing
    # any file, so an interrupted `on` (apply runs, final write skipped) is still fully
    # reversible by `off` — including the secret-bearing gateway.env.
    config_files = plan_config_file_entries(plan)
    manifest = build_manifest(
        url, shell_name, rc, block,
        model_count=len(models), only_discovered=only_discovered,
        applied_at=applied_at, config_files=config_files,
    )
    write_manifest(manifest)                          # intent recorded before any write
    action = GATEWAY_BLOCK.apply(rc, body, backup_suffix=GATEWAY_RC_BACKUP_SUFFIX)
    apply_gateway_config_files(plan, url, pairs, models, detail, generated=applied_at)
    save_gateway_config(url, key)
    write_manifest(manifest)                          # re-affirm on success
    verb = "updated" if action == "update" else "enabled"
    installed = sorted(e["tool"] for e in config_files if e.get("role") == "installed")
    print_success(f"Gateway {verb} — {len(pairs)} vars route through {url}")
    print_info(f"Portable env + summary + staged tool configs written under {GATEWAY_DIR}")
    if installed:
        print_info(f"Installed native config for: {', '.join(installed)}")
    print_info(f"Reload your shell to pick up the changes:  source {rc}")


def do_gateway_off(*, shell=None, dry_run=False, announce_creds=True):
    """Read the manifest → remove the env block → restore rc → clear the manifest.

    Keeps aikit's credential store (`config.json`) — this is a fast toggle, not a forget.
    ``announce_creds`` is set False when `purge` calls this for the teardown, so we don't
    print the "credentials kept" hint immediately before purge removes them.
    """
    manifest = read_manifest()
    if not manifest or not manifest.get("active"):
        print_info("Gateway is not active — nothing to undo.")
        return

    rc = Path(manifest.get("rc_path") or detect_shell(shell)[1])
    markers = manifest.get("markers") or {}
    block_mgr = sk.ManagedBlock(
        markers.get("begin", GATEWAY_BLOCK.begin),
        markers.get("end", GATEWAY_BLOCK.end),
    )
    present = rc.exists() and block_mgr.present_in(rc.read_text())

    if dry_run:
        where = f"the managed block from {rc}" if present else f"the manifest (no block found in {rc})"
        kept = " (saved credentials are kept — use 'purge' to forget them)" if GATEWAY_CONFIG_FILE.exists() else ""
        print_info(f"Dry run — would remove {where} and clear gateway state{kept}.")
        return

    for entry in manifest.get("config_files", []):
        _undo_config_file(entry)
    removed = block_mgr.clear(rc, backup_suffix=GATEWAY_RC_BACKUP_SUFFIX, remove_backup=True)
    clear_manifest()
    # Prune the now-empty staging dir. The gateway dir itself intentionally PERSISTS: it
    # still holds config.json (aikit's own 0600 credential store), which `off` keeps so a
    # re-`on` is input-free — this is a fast toggle, not a forget. rmdir only removes empty
    # dirs, so the populated gateway dir is left untouched here. (Use `aikit gateway purge`
    # to remove the credential store and prune the dir.)
    for d in (_gateway_tools_dir(), GATEWAY_DIR):
        try:
            d.rmdir()
        except OSError:
            pass

    if removed:
        print_success(f"Gateway disabled — managed block removed from {rc}; rc restored.")
    else:
        print_success("Gateway disabled — state cleared (managed block was already gone).")
    print_info("Open a new shell (or unset the vars) to drop the gateway env.")
    if announce_creds and GATEWAY_CONFIG_FILE.exists():
        print_info("Credentials kept — run 'aikit gateway on' to re-enable (no input needed), "
                   "or 'aikit gateway purge' to forget them.")


def do_gateway_purge(*, shell=None, yes=False, dry_run=False):
    """Forget the saved gateway credentials (the explicit counterpart to the on/off toggle).

    `off` keeps aikit's 0600 credential store so a re-`on` is input-free; `purge` removes
    it. If the gateway is currently active, purge first runs the full `off` teardown
    (agent runtimes → pristine), then deletes ``GATEWAY_CONFIG_FILE`` and prunes the
    now-empty ``GATEWAY_DIR``. With nothing saved, it's a friendly no-op.
    """
    manifest = read_manifest()
    active = bool(manifest and manifest.get("active"))
    configured = GATEWAY_CONFIG_FILE.exists()

    if not active and not configured:
        print_info("No saved gateway credentials — nothing to forget.")
        return

    if dry_run:
        steps = []
        if active:
            steps.append("deactivate the gateway (restore agent runtimes pristine)")
        steps.append(f"remove the saved credential store ({GATEWAY_CONFIG_FILE.name})")
        print_info("Dry run — would " + ", then ".join(steps) + f", and prune {GATEWAY_DIR}.")
        return

    if not yes and not sk.confirm(
        "Forget the saved gateway credentials? Re-enabling will need the URL and key again.",
        default=False,
    ):
        print_warning("Aborted — credentials kept.")
        return

    if active:
        do_gateway_off(shell=shell, announce_creds=False)   # teardown only; purge removes creds next

    GATEWAY_CONFIG_FILE.unlink(missing_ok=True)
    # With the credential store gone, the gateway dir can finally be pruned (rmdir only
    # removes empty dirs, so any unaccounted-for file is still left untouched).
    for d in (_gateway_tools_dir(), GATEWAY_DIR):
        try:
            d.rmdir()
        except OSError:
            pass
    print_success("Credentials removed — run 'aikit gateway on -u <url> -k <key>' to set up again.")


def do_gateway_status():
    """Show active/inactive, URL, masked key, model count, shell/rc, and drift."""
    manifest = read_manifest()
    cfg = load_gateway_config()

    if not manifest or not manifest.get("active"):
        if cfg.get("base_url"):
            print_info("Gateway: inactive (credentials saved)")
            sk.kv("Configured URL", cfg.get("base_url"))
            sk.kv("Key", _mask_secret(cfg.get("key", "")))
            print_info("Run 'aikit gateway on' to re-enable (no input needed), "
                       "or 'aikit gateway purge' to forget the saved credentials.")
        else:
            print_info("Gateway: inactive")
            print_info("Run 'aikit gateway on -u <url> -k <key>' to route tools through the gateway.")
        return

    url = manifest.get("gateway_url") or cfg.get("base_url", "")
    rc = Path(manifest.get("rc_path", ""))
    print_success("Gateway: active")
    sk.kv("URL", url)
    sk.kv("Key", _mask_secret(cfg.get("key", "")))
    sk.kv("Models", manifest.get("model_count", "?"))
    sk.kv("Shell", manifest.get("shell", "?"))
    sk.kv("rc file", str(rc))
    sk.kv("Applied", manifest.get("applied_at", "?"))

    # Wrapped tools — detected? config installed-by-aikit vs user-owned vs staged-only.
    rows = gateway_tool_status(manifest)
    sk.table([{"name": "Tool"}, {"name": "Detected"}, {"name": "Config"}], rows,
             title="Wrapped tools")
    # Account for the *other* detected agents (env-routed, passthrough, pending,
    # unsupported) so status is honest about everything installed, not just the wrapped
    # tools. Custom passthroughs resolve offline; `verify` probes live built-in routes.
    _print_gateway_coverage_accounting(
        gateway_coverage_rows(custom=load_custom_passthroughs(),
                              credential_mode=gateway_credential_mode()))

    # Drift detection — has the managed block been hand-edited or removed?
    markers = manifest.get("markers") or {}
    block_mgr = sk.ManagedBlock(
        markers.get("begin", GATEWAY_BLOCK.begin),
        markers.get("end", GATEWAY_BLOCK.end),
    )
    if not str(rc) or not rc.exists():
        print_warning(f"Drift: rc file {rc} not found.")
        return
    current = block_mgr.block_in(rc.read_text())
    if current is None:
        print_warning(
            "Drift: managed block missing from rc (removed by hand?). "
            "Run 'aikit gateway off' to clear state, or 'on' to reapply."
        )
    elif manifest.get("block_sha256") and _sha256(current) != manifest["block_sha256"]:
        print_warning(
            "Drift: managed block was edited by hand. Run 'aikit gateway on' to restore it."
        )
    else:
        print_info("Managed block matches the manifest (no drift).")


def do_gateway_coverage():
    """Read-only: the full per-agent gateway coverage matrix (every agent in AGENTS).

    Shows how each tool reaches the gateway — native ``renderer``, ``env`` var,
    ``passthrough`` (a native-protocol route), still ``pending`` (a tracked gap with no
    route yet), or ``unsupported`` (no usable route and no override, with the reason) —
    so nothing aikit knows about is left unaccounted for. Detection reflects what's
    installed right now. User-declared custom passthroughs resolve offline; live
    built-in route usability is a runtime property — run `aikit gateway verify`."""
    customs = load_custom_passthroughs()
    cred_mode = gateway_credential_mode()
    rows = gateway_coverage_rows(custom=customs, credential_mode=cred_mode)
    table_rows = [
        [r["id"], "yes" if r["detected"] else "no", r["state"], r["detail"]]
        for r in rows
    ]
    sk.table(
        [{"name": "Agent"}, {"name": "Detected"}, {"name": "Coverage"}, {"name": "How / why"}],
        table_rows, title=f"Gateway tool coverage ({len(rows)} agents)")

    counts = {}
    for r in rows:
        counts[r["state"]] = counts.get(r["state"], 0) + 1
    tally = " · ".join(f"{counts[s]} {s}" for s in COVERAGE_STATE_ORDER if counts.get(s))
    detected = sum(1 for r in rows if r["detected"])
    print_info(f"{tally}  ({detected} detected)")
    print_info("renderer/env/passthrough reach the gateway; pending = tracked gap "
               "(no route yet); unsupported = no usable native route and no override.")
    print_info("Run 'aikit gateway verify' to probe live passthrough routes "
               "(built-in route usability is gateway-dependent).")
    unrouted = _coverage_detected_unrouted(rows)
    if unrouted:
        print_warning("Detected but not routed: " + _format_coverage_group(unrouted))


def do_gateway_verify(url=None, key=None):
    """Probe each candidate passthrough route and report usability (read-only, safe).

    This is the mandatory 'ensure the passthrough is doing its thing' step: a built-in
    route is *always mounted*, so only a live probe (a cheap models-list GET — no tokens)
    confirms the upstream credential forwards. Flags any mounted-but-401 route so a
    mis-forwarding cred is surfaced, not silently broken (POK-62)."""
    url, key = _resolve_gateway_credentials(url, key)
    models, detail = discover_models(url, key)
    customs = load_custom_passthroughs()
    cred_mode = gateway_credential_mode()
    discovered = discover_passthrough_routes(url, key, models, detail,
                                             custom=customs, probe=True)
    table_rows = []
    for route, info in discovered.items():
        table_rows.append([route, info.get("provider") or "", info.get("status") or "—",
                           info.get("via") or "—", "yes" if info.get("usable") else "no"])
    table_rows.sort(key=lambda r: (r[4] != "yes", r[0]))
    sk.table([{"name": "Route"}, {"name": "Provider"}, {"name": "Probe"},
              {"name": "Via"}, {"name": "Usable"}], table_rows,
             title=f"Passthrough routes via {url}")

    usable = usable_passthrough_routes(discovered)
    unauth = sorted(r for r, i in discovered.items() if i.get("status") == "unauthorized")
    if unauth:
        print_warning("Mounted but unauthorized (upstream credential not forwarding): "
                      + ", ".join(unauth)
                      + " — the route exists, but its upstream key is missing/invalid "
                      "on the gateway. Fix the gateway credential, not aikit.")
    # How the vendor-native tools resolve given these live routes + any custom maps.
    prows = gateway_coverage_rows(passthrough=usable, custom=customs,
                                  credential_mode=cred_mode)
    routed = [(r["id"], r["detail"]) for r in prows if r["state"] == COVERAGE_PASSTHROUGH]
    if routed:
        print_info("Tools resolved to passthrough: "
                   + ", ".join(f"{i} → {d}" for i, d in routed))
    print_info(f"{len(usable)} usable passthrough route(s). "
               "Declare custom routes in the gateway config to wire tools without a "
               "native LiteLLM route (see docs/aikit-gateway.md).")


def do_gateway_models(url=None, key=None):
    """Read-only listing of the models this key can see (provider tag when known)."""
    url, key = _resolve_gateway_credentials(url, key)
    models, detail = discover_models(url, key)
    if not models:
        print_info("No models visible to this key.")
        return
    rows = [[m, (detail.get(m) or {}).get("provider") or ""] for m in models]
    sk.table([{"name": "Model"}, {"name": "Provider"}], rows,
             title=f"{len(models)} model(s) via {url}")


def _gateway_doctor_checks():
    """Checks for the Gateway section of `aikit doctor` (configured / reachable / active)."""
    cfg = load_gateway_config()
    manifest = read_manifest()
    checks = []
    if cfg.get("base_url") and cfg.get("key"):
        checks.append(sk.Check.ok("Configured", cfg.get("base_url")))
        try:
            models, _ = discover_models(
                cfg["base_url"], cfg["key"],
                getter=lambda u, k: _gateway_get_json(u, k, timeout=5),
            )
            checks.append(sk.Check.ok("Reachable", f"{len(models)} model(s) via /v1/models"))
        except AikitError as e:
            checks.append(sk.Check.warn("Reachable", "no", str(e)))
    else:
        checks.append(sk.Check.warn("Configured", "no", "run 'aikit gateway on'"))
    if manifest.get("active"):
        checks.append(sk.Check.ok("Active", manifest.get("gateway_url", "")))
    else:
        checks.append(sk.Check.warn("Active", "inactive", "run 'aikit gateway on' to activate"))
    return checks


