def do_install_safe(agent_keys, yes=False):
    """Install agents with full KeyboardInterrupt handling."""
    try:
        do_install(agent_keys, yes)
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Install interrupted.[/yellow]")
        sys.exit(130)


def do_install(agent_keys, yes=False):
    """Install one or more agents."""
    if not agent_keys:
        try:
            agent_keys = interactive_agent_picker("Select agents to install")
        except KeyboardInterrupt:
            console.print("\n[yellow]⏹ Cancelled.[/yellow]")
            return
    if not agent_keys:
        print_warning("No agents selected.")
        return

    validate_agent_keys(agent_keys)

    # Check prerequisites first
    all_missing = set()
    for key in agent_keys:
        missing = check_prerequisites(key)
        all_missing.update(missing)

    if all_missing:
        missing_str = ", ".join(sorted(all_missing))
        print_warning(f"Missing prerequisites detected: {missing_str}")
        if _use_color() and sys.stdin.isatty():
            try:
                if not _prompt_yes_no("Continue anyway?", False):
                    return
            except KeyboardInterrupt:
                console.print("\n[yellow]⏹ Cancelled.[/yellow]")
                return

    config = load_config()
    installed = []
    failed = []

    for i, key in enumerate(agent_keys, 1):
        agent = AGENTS[key]
        icon = agent["icon"]
        cmd = agent["install"].get(_CURRENT_PLATFORM)

        if not cmd:
            print_error(f"No install command for {agent['name']} on {_CURRENT_PLATFORM}")
            failed.append(key)
            continue

        if detect_agent_bin(key) and not yes:
            print_info(f"{icon} {agent['name']} already installed — skipping")
            config["agents"][key] = {
                "installed": True,
                "install_date": config["agents"].get(key, {}).get("install_date", time.strftime("%Y-%m-%d")),
                "version": detect_agent_version(key),
                "auth_configured": config["agents"].get(key, {}).get("auth_configured", False),
            }
            installed.append(key)
            continue

        print_step(i, len(agent_keys), f"Installing {icon} {agent['name']} — {agent['vendor']}")
        print_info(f"  Command: [dim]{cmd}[/dim]")

        if _use_color() and sys.stdin.isatty():
            with Progress(
                SpinnerColumn(),
                TextColumn("[progress.description]{task.description}"),
                console=console,
            ) as progress:
                task = progress.add_task(f"Installing {agent['name']}...", total=None)
                exit_code, stdout, stderr = run(cmd, timeout=600)
                progress.update(task, completed=True)
        else:
            exit_code, stdout, stderr = run(cmd, timeout=600)

        if exit_code == 0 and detect_agent_bin(key):
            version = detect_agent_version(key)
            print_success(f"{icon} {agent['name']} installed successfully! [dim]({version})[/dim]")

            config["agents"][key] = {
                "installed": True,
                "install_date": time.strftime("%Y-%m-%d"),
                "version": version,
                "auth_configured": False,
            }
            installed.append(key)
        else:
            print_error(f"{icon} {agent['name']} installation failed")
            if stderr:
                print_info(f"  Error: {stderr[:200]}")
            if stdout:
                print_info(f"  Output: {stdout[:200]}")
            failed.append(key)

    save_config(config)

    if installed:
        console.print(f"\n[bold green]✅ Installed:[/bold green] {', '.join(installed)}")
    if failed:
        console.print(f"[bold red]❌ Failed:[/bold red] {', '.join(failed)}")

    # Auth nudge
    needs_auth = [k for k in installed if AGENTS[k].get("auth_type")]
    if needs_auth:
        console.print(f"\n[bold yellow]🔑 Some agents need authentication:[/bold yellow] {', '.join(needs_auth)}")
        console.print("  Run [bold]aikit auth <agent>[/bold] for guided setup.")

    for warning in agent_bin_collision_warnings():
        sk.warning(warning)


def do_update(agent_keys=None, *, force=False):
    """Update installed agents."""
    try:
        _do_update_impl(agent_keys, force=force)
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Update interrupted.[/yellow]")
        sys.exit(130)


def _do_update_impl(agent_keys, *, force=False):
    config = load_config()

    if agent_keys is None:
        agent_keys = [k for k in AGENTS if detect_agent_bin(k)]
        if not agent_keys:
            print_warning("No agents installed. Run 'aikit install' first.")
            return
    else:
        validate_agent_keys(agent_keys)

    candidates = []
    for key in agent_keys:
        agent = AGENTS[key]
        icon = agent["icon"]
        if not detect_agent_bin(key):
            print_info(f"{icon} {agent['name']} — not installed, skipping")
            continue
        if not resolve_update_cmd(key):
            print_info(f"{icon} {agent['name']} — no update command available")
            continue
        candidates.append(key)

    if not candidates:
        print_warning("Nothing to update.")
        return

    to_run = []
    already_current = []
    for key in candidates:
        skip, check = should_skip_update(key, force=force, config=config)
        if skip:
            already_current.append((key, check))
        else:
            to_run.append(key)

    for key, check in already_current:
        agent = AGENTS[key]
        ver = check.get("current") or "—"
        print_info(f"{agent['icon']} {agent['name']} — already up to date [dim]({ver})[/dim]")

    if not to_run:
        if already_current:
            console.print(
                f"\n[dim]All {len(already_current)} agent(s) already up to date. "
                "Use [bold]aikit update --force[/bold] to reinstall anyway.[/dim]"
            )
        return

    if already_current:
        console.print()
    console.print(f"[bold cyan]🔄 Updating {len(to_run)} agent(s)...[/bold cyan]\n")

    upgraded = []
    up_to_date = []
    unchanged = []
    unchanged_outdated = []
    failed = []

    for i, key in enumerate(to_run, 1):
        agent = AGENTS[key]
        icon = agent["icon"]
        name = agent["name"]

        print_step(i, len(to_run), f"Updating {icon} {name}")
        outcome, _stdout, stderr = execute_agent_update(key)
        if not outcome:
            print_error(f"{icon} {name} — no update command available")
            failed.append(key)
            continue

        status = outcome["status"]
        old_v = outcome.get("old")
        new_v = outcome.get("new")

        if status == "upgraded":
            print_success(f"{icon} {name} upgraded [dim]({old_v} → {new_v})[/dim]")
            _persist_agent_after_update(config, key)
            upgraded.append(key)
        elif status == "up_to_date":
            ver = new_v or old_v or "—"
            print_info(f"{icon} {name} — already up to date [dim]({ver})[/dim]")
            _persist_agent_after_update(config, key)
            up_to_date.append(key)
        elif status == "unchanged_outdated":
            latest = outcome.get("latest")
            detail = f"still {new_v or old_v or 'unknown'}"
            if latest and latest not in (new_v, old_v, "latest"):
                detail += f", latest is {latest}"
            print_warning(f"{icon} {name} — update ran but version unchanged ({detail})")
            _persist_agent_after_update(config, key)
            unchanged_outdated.append(key)
        elif status == "unchanged":
            ver = new_v or old_v or "—"
            print_info(f"{icon} {name} — no version change detected [dim]({ver})[/dim]")
            _persist_agent_after_update(config, key)
            unchanged.append(key)
        else:
            err = outcome.get("error") or stderr[:100] or "unknown error"
            print_error(f"{icon} {name} update failed: {err}")
            failed.append(key)

    save_config(config)

    console.print()
    if upgraded:
        console.print(f"[bold green]✅ Upgraded ({len(upgraded)}):[/bold green] {_agent_names(upgraded)}")
    current = already_current + [(k, None) for k in up_to_date]
    if current:
        keys = [k for k, _ in current]
        console.print(f"[dim]✓ Already up to date ({len(keys)}):[/dim] {_agent_names(keys)}")
    if unchanged:
        console.print(f"[dim]○ Unchanged ({len(unchanged)}):[/dim] {_agent_names(unchanged)}")
    if unchanged_outdated:
        console.print(
            f"[bold yellow]⚠ Still outdated ({len(unchanged_outdated)}):[/bold yellow] "
            f"{_agent_names(unchanged_outdated)}"
        )
    if failed:
        console.print(f"[bold red]❌ Failed ({len(failed)}):[/bold red] {_agent_names(failed)}")


def do_uninstall(agent_keys, yes=False):
    """Uninstall agents."""
    try:
        _do_uninstall_impl(agent_keys, yes)
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Uninstall interrupted.[/yellow]")
        sys.exit(130)


def _do_uninstall_impl(agent_keys, yes):
    if not agent_keys:
        installed = [k for k in AGENTS if detect_agent_bin(k)]
        if not installed:
            print_warning("No agents installed.")
            return
        try:
            agent_keys = interactive_agent_picker("Select agents to uninstall", preselect_installed=True)
        except KeyboardInterrupt:
            console.print("\n[yellow]⏹ Cancelled.[/yellow]")
            return

    if not agent_keys:
        return

    validate_agent_keys(agent_keys)

    config = load_config()
    removed = []

    for i, key in enumerate(agent_keys, 1):
        agent = AGENTS[key]
        icon = agent["icon"]

        installed = detect_agent_bin(key)
        npm_package = agent.get("version_check", {}).get("package")
        orphan_npm = (
            not installed
            and agent.get("version_check", {}).get("type") == "npm"
            and npm_package
            and any(_npm_package_dir(prefix, npm_package).exists() for prefix in _npm_global_prefixes())
        )
        if not installed and not orphan_npm:
            if config["agents"].pop(key, None) is not None:
                removed.append(key)
            print_info(f"{icon} {agent['name']} — not installed")
            continue
        if orphan_npm:
            print_info(f"{icon} {agent['name']} — cleaning npm copies outside PATH")

        uninstall_cmd = resolve_uninstall_cmd(agent)
        if uninstall_cmd:
            print_step(i, len(agent_keys), f"Uninstalling {icon} {agent['name']}")
            exit_code, stdout, stderr = run(uninstall_cmd, timeout=120)
            if detect_agent_bin(key):
                if exit_code != 0:
                    detail = stderr[:100] or stdout[:100]
                    print_warning(f"{icon} {agent['name']} uninstall may be incomplete: {detail}")
                else:
                    print_warning(f"{icon} {agent['name']} still detected after uninstall")
            elif exit_code == 0:
                print_success(f"{icon} {agent['name']} uninstalled")
            else:
                print_warning(f"{icon} {agent['name']} uninstall may be incomplete: {stderr[:100]}")
        else:
            print_info(f"{icon} {agent['name']} has no automated uninstall — remove manually")
            bin_name = resolve_agent_bin(key) or agent["bin"]
            print_info(f"  Typically: rm $(which {bin_name})")

        if not detect_agent_bin(key):
            if config["agents"].pop(key, None) is not None:
                removed.append(key)
            UPDATE_CHECK_CACHE.pop(key, None)

    save_config(config)
    discover_and_persist()

    if removed:
        console.print(f"\n[bold green]✅ Uninstalled:[/bold green] {', '.join(removed)}")
    else:
        print_warning("No agents were fully removed — binaries may still be on PATH.")


