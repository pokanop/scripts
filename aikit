    # config
    config_p = sub.add_parser("config", help="Manage configuration")
    config_sub = config_p.add_subparsers(dest="config_action")

    config_sub.add_parser("list", help="Show all config (secrets masked)")
    config_get = config_sub.add_parser("get", help="Get a config value")
    config_get.add_argument("config_key", metavar="key", help="Dot-path key (e.g. settings.web_port)")
    config_set = config_sub.add_parser("set", help="Set a config value")
    config_set.add_argument("config_key", metavar="key", help="Dot-path key")
    config_set.add_argument("value", help="Value to set")

    # gateway
    gw_p = sub.add_parser("gateway", help="Route AI tools through a LiteLLM gateway")
    gw_sub = gw_p.add_subparsers(dest="gateway_action")

    gw_on = gw_sub.add_parser("on", help="Wrap tools: write the managed env block + manifest")
    gw_on.add_argument("-u", "--url", help="Gateway base URL (e.g. https://gw.example.com)")
    gw_on.add_argument("-k", "--key", help="Virtual key (sk-…). Hidden prompt if omitted.")
    gw_on.add_argument("--shell", choices=["zsh", "bash", "fish"], help="Override shell detection")
    gw_on.add_argument("--only-discovered", action="store_true",
                       help="Only set vars for providers actually backing discovered models")
    gw_on.add_argument("-y", "--yes", action="store_true", help="Skip the confirmation prompt")
    gw_on.add_argument("--dry-run", action="store_true", help="Preview the block; write nothing")

    gw_off = gw_sub.add_parser("off", help="Unwrap: remove the env block, restore rc pristine")
    gw_off.add_argument("--shell", choices=["zsh", "bash", "fish"], help="Override shell detection")
    gw_off.add_argument("--dry-run", action="store_true", help="Preview the removal; write nothing")
    gw_off.add_argument("--purge", action="store_true",
                        help="Also forget saved credentials (config.json) — same as 'gateway purge'")
    gw_off.add_argument("-y", "--yes", action="store_true",
                        help="Skip the confirmation prompt (only used with --purge)")

    gw_purge = gw_sub.add_parser(
        "purge", help="Forget saved credentials (deactivates first if active)")
    gw_purge.add_argument("--shell", choices=["zsh", "bash", "fish"], help="Override shell detection")
    gw_purge.add_argument("-y", "--yes", action="store_true", help="Skip the confirmation prompt")
    gw_purge.add_argument("--dry-run", action="store_true", help="Preview; write nothing")

    gw_sub.add_parser("status", help="Show gateway state, masked key, and drift")

    gw_sub.add_parser("coverage",
                      help="Show per-agent gateway coverage (renderer/env/passthrough/pending/unsupported)")

    gw_verify = gw_sub.add_parser(
        "verify", help="Probe passthrough routes for usability (flags mounted-but-401)")
    gw_verify.add_argument("-u", "--url", help="Gateway base URL override")
    gw_verify.add_argument("-k", "--key", help="Virtual key override")

    gw_models = gw_sub.add_parser("models", help="List models the key can see (read-only)")
    gw_models.add_argument("-u", "--url", help="Gateway base URL override")
    gw_models.add_argument("-k", "--key", help="Virtual key override")

    # -v/--version is added by sk.make_parser
    return parser


def cmd_install(args):
    do_install(args.agents, yes=args.yes)


def cmd_update(args):
    do_update(args.agents or None, force=args.force)


def cmd_uninstall(args):
    do_uninstall(args.agents, yes=args.yes)


def cmd_list(args):
    print_agent_table()


def cmd_auth(args):
    if args.agent:
        do_auth(args.agent)
        return
    if not any(detect_agent_bin(k) for k in AGENTS):
        print_warning("No agents installed. Run 'aikit install' first.")
        return
    # Ctrl-C inside the picker means "cancel this prompt", not "abort aikit".
    try:
        agent_keys = interactive_agent_picker(
            "Select agent to authenticate",
            single=True,
            only_installed=True,
        )
    except KeyboardInterrupt:
        console.print("\n[yellow]⏹ Cancelled.[/yellow]")
        return
    if not agent_keys:
        print_warning("No agent selected.")
        return
    for key in agent_keys:
        do_auth(key)


def cmd_serve(args):
    do_serve(host=args.host, port=args.port, detach=args.detach, stop=args.stop)


def cmd_doctor(args):
    return do_doctor()


def cmd_setup(args):
    do_setup()


def cmd_config(args):
    action = getattr(args, "config_action", None)
    if action == "get":
        do_config_get(args.config_key)
    elif action == "set":
        do_config_set(args.config_key, args.value)
    else:  # "list" or no sub-action
        do_config_list()


def cmd_gateway(args):
    action = getattr(args, "gateway_action", None)
    if action == "on":
        do_gateway_on(args.url, args.key, shell=args.shell,
                      only_discovered=args.only_discovered, yes=args.yes, dry_run=args.dry_run)
    elif action == "off":
        if getattr(args, "purge", False):
            do_gateway_purge(shell=args.shell, yes=args.yes, dry_run=args.dry_run)
        else:
            do_gateway_off(shell=args.shell, dry_run=args.dry_run)
    elif action == "purge":
        do_gateway_purge(shell=args.shell, yes=args.yes, dry_run=args.dry_run)
    elif action == "coverage":
        do_gateway_coverage()
    elif action == "verify":
        do_gateway_verify(args.url, args.key)
    elif action == "models":
        do_gateway_models(args.url, args.key)
    else:  # "status" or no sub-action — the at-a-glance default
        do_gateway_status()


HANDLERS = {
    "install": cmd_install, "update": cmd_update, "uninstall": cmd_uninstall,
    "list": cmd_list, "auth": cmd_auth, "serve": cmd_serve,
    "doctor": cmd_doctor, "setup": cmd_setup, "config": cmd_config,
    "gateway": cmd_gateway,
}

# Bare `aikit` shows the agent table — the at-a-glance default.
DEFAULT_COMMAND = "list"
_COMMANDS = frozenset(HANDLERS)


def _first_run_notice() -> None:
    """One-time welcome on a fresh machine: discover state, then point the way."""
    discover_and_persist()
    config = load_config()
    installed = sum(1 for k in AGENTS if config.get("agents", {}).get(k, {}).get("installed", False))
    authed = sum(1 for k in AGENTS if config.get("agents", {}).get(k, {}).get("auth_configured", False))
    console.print(Panel(
        "[bold]👋 Welcome to aikit![/bold]\n\n"
        "aikit has auto-discovered your system state:\n"
        f"  [green]• {installed}/{len(AGENTS)} agents installed[/green]\n"
        f"  [green]• {authed} agents authenticated[/green]\n\n"
        "Run: [bold]aikit setup[/bold] for guided setup\n"
        "  or [bold]aikit doctor[/bold] to diagnose everything",
        border_style="cyan",
    ))
    SETUP_MARKER.touch()


def main() -> int:
    parser = build_parser()
    bare = not any(tok in _COMMANDS for tok in sys.argv[1:])
    args = sk.parse_args(parser, default=DEFAULT_COMMAND)
    if bare and _needs_setup():
        _first_run_notice()  # then fall through to the default `list` table
    return sk.dispatch(
        args, HANDLERS, parser, default=DEFAULT_COMMAND,
        banner=sk.banner("aikit", __version__, TAGLINE, ICON),
    )


if __name__ == "__main__":
    sys.exit(sk.run_cli(main))
