# OpenHands (and other LiteLLM-SDK tools) read LLM_* — not OPENAI_* — for their LLM
# config, so the universal OpenAI block alone doesn't route them. Set LLM_BASE_URL /
# LLM_API_KEY so the tool can reach the gateway. Caveat (surfaced in gateway coverage's
# `via` for openhands): the OpenHands CLI only reads these with `--override-with-envs`,
# and its on-disk agent_settings.json, if present, takes precedence — verified against
# OpenHands/OpenHands-CLI (agent_store.py reads exactly LLM_API_KEY/LLM_BASE_URL/LLM_MODEL).
GATEWAY_LLM_SDK_KEY_VARS = ("LLM_API_KEY",)
GATEWAY_LLM_SDK_BASE_VARS = (("LLM_BASE_URL", "/v1"),)

# Built-in LiteLLM passthrough routes — native-protocol endpoints the proxy mounts in
# code (not gated on config), each forwarding a provider's own API through the gateway.
# Verified against litellm/proxy/pass_through_endpoints/llm_passthrough_endpoints.py.
# A route is *always mounted* whenever the proxy runs, so its mere presence proves
# nothing about usability — only discovery (a provider actually serving models, or a
# live probe) tells us the upstream credential forwards. cf. POK-62: /anthropic 401'd
# while /v1 served the same model. Fields per route:
#   provider  the GATEWAY_PROVIDERS prefix it wraps (ties into providers_in_use); a
#             bare label (e.g. "cursor") when it has no OpenAI-compatible provider row
#   probe     a cheap, safe GET sub-path that exercises the upstream credential (a
#             models-list endpoint — no tokens spent), or None when none is safe
GATEWAY_PASSTHROUGH_ROUTES = {
    "/anthropic": {"provider": "anthropic",   "probe": "/v1/models"},
    "/gemini":    {"provider": "gemini",      "probe": "/v1beta/models"},
    "/vertex_ai": {"provider": "vertex_ai",   "probe": None},
    "/bedrock":   {"provider": "bedrock",     "probe": None},
    "/cohere":    {"provider": "cohere",      "probe": "/v1/models"},
    "/mistral":   {"provider": "mistral",     "probe": "/v1/models"},
    "/openai":    {"provider": "openai",      "probe": "/v1/models"},
    "/vllm":      {"provider": "hosted_vllm", "probe": "/v1/models"},
    "/azure":     {"provider": "azure",       "probe": None},
    "/cursor":    {"provider": "cursor",      "probe": "/v0/models"},
}

# Credential modes for a passthrough route (whose upstream key is used):
#   virtual_key     — the caller sends the gateway virtual key; LiteLLM injects the
#                     shared upstream provider key. aikit sets the tool's auth var = key.
#   forwarded_token — the endpoint has forward_headers:true; the caller's OWN token is
#                     forwarded upstream (the personal-subscription case, e.g. Claude
#                     Code Max). aikit sets the base URL but LEAVES the tool's own token.
GATEWAY_CRED_VIRTUAL_KEY = "virtual_key"
GATEWAY_CRED_FORWARDED_TOKEN = "forwarded_token"
GATEWAY_CRED_MODES = (GATEWAY_CRED_VIRTUAL_KEY, GATEWAY_CRED_FORWARDED_TOKEN)
# Built-in native routes where forwarding the caller's OWN token upstream is a real use
# case (LiteLLM mounts /anthropic with _forward_headers=True) — this is what made Claude
# Code Max work for the owner. Used only when the operator opts into forwarded-token mode.
GATEWAY_FORWARD_CAPABLE_PREFIXES = frozenset({"anthropic"})

GATEWAY_DIR = CONFIG_DIR / "gateway"
GATEWAY_CONFIG_FILE = GATEWAY_DIR / "config.json"   # credential store: base_url + virtual key
GATEWAY_STATE_FILE = GATEWAY_DIR / "state.json"     # manifest: what `on` changed
GATEWAY_RC_BACKUP_SUFFIX = ".aikit-gateway.bak"

# aikit-owned markers. The body header is constant (no timestamp) so re-running
# `on` with the same args produces a byte-identical block — true idempotency.
GATEWAY_BLOCK = sk.ManagedBlock(
    "# >>> aikit gateway (managed — run 'aikit gateway off' to remove) >>>",
    "# <<< aikit gateway <<<",
)
_GATEWAY_BODY_HEADER = "# Managed by aikit — do not edit; run 'aikit gateway off' to remove."


# --- credential config (url + virtual key), stored 0600 --------------------
def _gateway_config():
    # No env_prefix: the virtual key must never be injected from AIKIT_* env.
    return sk.Config(GATEWAY_CONFIG_FILE)


def load_gateway_config():
    """Return the saved gateway config ({} when unconfigured): base_url + key, plus any
    user-declared ``passthroughs`` / ``credential_mode`` the operator added by hand."""
    return _gateway_config().load()


def save_gateway_config(base_url, key):
    """Persist gateway URL + virtual key at 0600 (sk.Config.save chmods 0600).

    Merges over the existing file so hand-added keys (``passthroughs``,
    ``credential_mode``) survive a re-``on`` — only base_url/key are overwritten.
    """
    data = _gateway_config().load()
    data.update({"base_url": base_url, "key": key})
    _gateway_config().save(data)


def load_custom_passthroughs():
    """User-declared custom passthrough routes: ``{tool: {route, auth_var, base_url_var,
    credential_mode}}``. The escape hatch for tools with no auto-discoverable native
    route (amp, kiro, copilot, …). Empty dict when none declared or the value is junk."""
    val = load_gateway_config().get("passthroughs")
    return val if isinstance(val, dict) else {}


def gateway_credential_mode():
    """Default credential mode for passthrough routing (``virtual_key`` unless the
    operator set ``credential_mode: forwarded_token`` in the gateway config)."""
    mode = load_gateway_config().get("credential_mode")
    return mode if mode in GATEWAY_CRED_MODES else GATEWAY_CRED_VIRTUAL_KEY


def _mask_secret(value):
    """Mask a secret for display — only a short prefix survives, never the body."""
    if not value:
        return ""
    return (value[:5] + "…") if len(value) > 8 else "***"


def _normalize_gateway_url(url):
    """Trim, default to https://, and drop any trailing slash."""
    url = (url or "").strip().rstrip("/")
    if url and not url.startswith(("http://", "https://")):
        url = "https://" + url
    return url


# --- model discovery client ------------------------------------------------
def _gateway_get_json(url, key, timeout=20):
    """GET ``url`` with gateway auth headers; return parsed JSON.

    Raises :class:`AikitError` with a clean message for an unreachable host, a
    rejected key (401/403), a non-2xx status, or a non-JSON body.
    """
    import requests

    headers = {
        "Authorization": f"Bearer {key}",
        "x-api-key": key,
        "Accept": "application/json",
        "User-Agent": f"aikit/{__version__}",
    }
    try:
        resp = requests.get(url, headers=headers, timeout=timeout)
    except requests.exceptions.RequestException as e:
        raise AikitError(f"could not reach gateway at {url} — {e}")
    if resp.status_code in (401, 403):
        raise AikitError(
            f"gateway rejected the key (HTTP {resp.status_code}) at {url} — check your virtual key"
        )
    if not resp.ok:
        raise AikitError(f"gateway returned HTTP {resp.status_code} on {url}")
    try:
        return resp.json()
    except ValueError:
        raise AikitError(f"gateway returned a non-JSON response from {url}")


def parse_models_list(data):
    """Parse an OpenAI-compatible ``/v1/models`` payload → (models, detail)."""
    models, detail = [], {}
    for m in (data or {}).get("data", []) if isinstance(data, dict) else []:
        mid = m.get("id")
        if mid:
            models.append(mid)
            detail.setdefault(mid, {})
    return models, detail


def merge_model_info(info, models, detail):
    """Fold richer ``/model/info`` metadata (provider, context) into detail."""
    if isinstance(info, list):
        items = info
    elif isinstance(info, dict):
        items = info.get("data", [])
    else:
        items = []
    for item in items:
        if not isinstance(item, dict):
            continue
        mid = item.get("model_name") or item.get("id")
        if not mid:
            continue
        li = item.get("litellm_params", {}) or {}
        mi = item.get("model_info", {}) or {}
        model_field = li.get("model", "") or ""
        provider = li.get("custom_llm_provider") or (
            model_field.split("/")[0] if "/" in model_field else None
        )
        detail[mid] = {
            "provider": provider,
            "max_tokens": mi.get("max_tokens") or mi.get("max_input_tokens"),
        }
        if mid not in models:
            models.append(mid)


def discover_models(base_url, key, *, getter=_gateway_get_json):
    """Ask the gateway which models this key can see.

    ``/v1/models`` is required (any valid key); ``/model/info`` is privileged and
    its failure is ignored. Returns ``(sorted_model_ids, detail)``. ``getter`` is
    injectable so tests can supply canned JSON without real network.
    """
    base = base_url.rstrip("/")
    data = getter(f"{base}/v1/models", key)
    models, detail = parse_models_list(data)
    try:
        info = getter(f"{base}/model/info", key)
    except AikitError:
        info = None
    if info is not None:
        merge_model_info(info, models, detail)
    return sorted(set(models)), detail


def providers_in_use(models, detail):
    """Best-effort set of provider prefixes that actually back the listed models."""
    seen = set()
    known = {p[2] for p in GATEWAY_PROVIDERS}
    for mid in models:
        prov = (detail.get(mid) or {}).get("provider")
        if prov and prov in known:
            seen.add(prov)
        elif "/" in mid and mid.split("/")[0] in known:
            seen.add(mid.split("/")[0])
    return seen


# --- passthrough-route discovery -------------------------------------------
# A passthrough route lets a tool speak a provider's *native* protocol through the
# gateway (claude → /anthropic, gemini → /gemini). aikit stays a pure client: it never
# configures LiteLLM, it discovers what the gateway already exposes and links tools to
# it. Routability is a RUNTIME, gateway-dependent property — not a static table.
_PASSTHROUGH_CACHE: dict = {}


def _reset_passthrough_cache():
    """Drop the in-process discovery cache (tests call this between gateways)."""
    _PASSTHROUGH_CACHE.clear()


def _probe_status(url, key, *, timeout=6):
    """HTTP status for a safe GET to a passthrough probe endpoint; 0 on network error.

    Never raises — unlike :func:`_gateway_get_json` it does not treat 401/403 as fatal,
    because a 401 from a *mounted* passthrough is exactly the signal we want to surface
    (the route exists but the upstream credential doesn't forward — POK-62). Injectable
    for tests so no real network is touched.
    """
    import requests

    headers = {
        "Authorization": f"Bearer {key}",
        "x-api-key": key,
        "Accept": "application/json",
        "User-Agent": f"aikit/{__version__}",
    }
    try:
        return requests.get(url, headers=headers, timeout=timeout).status_code
    except requests.exceptions.RequestException:
        return 0


def _classify_route(route, provider, inferred, status, *, source):
    """One route's usability verdict from (provider-tag inference, probe status)."""
    # Probe wins when conclusive: an explicit 401/403 means the route is mounted but the
    # upstream credential does NOT forward — unusable regardless of inference (POK-62).
    if status in (401, 403):
        return {"route": route, "provider": provider, "usable": False,
                "status": "unauthorized", "via": "probe", "source": source}
    if status and 200 <= status < 300:
        return {"route": route, "provider": provider, "usable": True,
                "status": "ok", "via": "probe", "source": source}
    # No conclusive probe (not probed, timed out, or a non-auth error) → fall back to
    # provider-tag inference: a provider serving models is a strong hint its route works.
    if inferred:
        return {"route": route, "provider": provider, "usable": True,
                "status": "inferred", "via": "inference", "source": source}
    return {"route": route, "provider": provider, "usable": False,
            "status": "unknown", "via": None, "source": source}


def discover_passthrough_routes(base_url, key, models=None, detail=None, *,
                                custom=None, probe=False, prober=None):
    """Composite discovery of the gateway's *usable* passthrough routes.

    usable = known built-in routes ∩ (provider-tag inference ∪ successful probe),
    plus any user-declared custom routes. Cheap and safe: probing (opt-in via
    ``probe=True``) issues at most one models-list GET per probeable route and never
    raises — a probe error is 'unknown', never fatal, so this can't crash ``on``.

    ``models``/``detail`` come from :func:`discover_models` (for inference). ``custom``
    is the user-declared ``{tool: {route, ...}}`` mapping. Returns ``{route: info}``
    where info has ``usable``/``status``/``via``/``source``; call
    :func:`usable_passthrough_routes` for just the usable set.
    """
    base = base_url.rstrip("/")
    live = prober is None and probe
    cache_key = (base, probe, tuple(sorted(models or [])))
    if live and cache_key in _PASSTHROUGH_CACHE:
        discovered = dict(_PASSTHROUGH_CACHE[cache_key])
    else:
        prober = prober or _probe_status
        in_use = providers_in_use(models or [], detail or {})
        discovered = {}
        for route, spec in GATEWAY_PASSTHROUGH_ROUTES.items():
            provider = spec["provider"]
            status = None
            if probe and spec.get("probe"):
                status = prober(f"{base}{route}{spec['probe']}", key)
            discovered[route] = _classify_route(
                route, provider, provider in in_use, status, source="builtin")
        if live:
            _PASSTHROUGH_CACHE[cache_key] = dict(discovered)
    # User-declared custom routes are authoritative (the user asserts the gateway has a
    # matching passthrough); they augment, and can override, the built-in verdict.
    for tool, decl in (custom or {}).items():
        route = (decl or {}).get("route")
        if not route:
            continue
        discovered[route] = {
            "route": route, "provider": (decl.get("provider") or tool),
            "usable": True, "status": "declared", "via": "custom",
            "source": "custom", "tool": tool,
        }
    return discovered


def usable_passthrough_routes(discovered):
    """The set of routes discovery judged usable (drop the mounted-but-401 ones)."""
    return {r for r, info in (discovered or {}).items() if info.get("usable")}


# --- shell detection + env block -------------------------------------------
def detect_shell(explicit=None):
    """Return (shell_name, rc_path), mirroring the reference script's logic."""
    name = explicit or Path(os.environ.get("SHELL", "/bin/bash")).name
    home = Path.home()
    if name == "zsh":
        rc = home / ".zshrc"
    elif name == "fish":
        rc = home / ".config" / "fish" / "config.fish"
    elif name == "bash":
        # macOS login shells read ~/.bash_profile; prefer it if it exists.
        bp = home / ".bash_profile"
        rc = bp if bp.exists() else home / ".bashrc"
    else:
        rc = home / f".{name}rc"
    return name, rc


def build_env_pairs(base_url, key, only_providers=None, *,
                    passthroughs=None, forwarded_token_prefixes=frozenset()):
    """Ordered, de-duped (VAR, VALUE) env pairs routing tools through the gateway.

    A universal OpenAI-compatible block first, then per-provider key + base-URL
    overrides, then any resolved passthrough tools. ``only_providers`` (a set of
    prefixes) restricts the per-provider vars; ``None`` means all providers.

    ``passthroughs`` is an iterable of resolved passthrough specs (each with
    ``route``/``base_url_var``/``auth_var``/``auth_mode``) — a tool's base-URL override
    is pointed at ``{gateway}{route}`` and its auth var set to the virtual key.
    ``forwarded_token_prefixes`` (and a passthrough's ``forwarded_token`` auth mode) mean
    the gateway forwards the caller's OWN token upstream, so aikit sets the base URL but
    LEAVES that tool's auth var untouched. Both extras default off, so the standard
    virtual-key wiring is byte-for-byte unchanged.
    """
    base = base_url.rstrip("/")
    # Universal block, single-sourced from the tables above.
    pairs = [(var, key) for var in GATEWAY_UNIVERSAL_KEY_VARS]
    pairs += [(var, f"{base}{suffix}") for var, suffix in GATEWAY_UNIVERSAL_BASE_VARS]
    # LiteLLM-SDK tools (OpenHands) read LLM_* rather than OPENAI_* — tool-agnostic like
    # the universal block, so wire it unconditionally (kept even under --only-discovered).
    pairs += [(var, key) for var in GATEWAY_LLM_SDK_KEY_VARS]
    pairs += [(var, f"{base}{suffix}") for var, suffix in GATEWAY_LLM_SDK_BASE_VARS]
    for pid, name, prefix, key_envs, base_envs, route, bins, pys in GATEWAY_PROVIDERS:
        if pid == "openai":
            continue  # already covered by the universal block
        if only_providers is not None and prefix not in only_providers:
            continue
        target = f"{base}{route}"
        # forwarded-token mode: the caller's own token is forwarded upstream, so DON'T
        # overwrite the tool's auth var with the virtual key — only redirect the base URL.
        if prefix not in forwarded_token_prefixes:
            for ke in key_envs:
                pairs.append((ke, key))
        for be in base_envs:
            pairs.append((be, target))

    # Resolved / user-declared passthrough tools: wire the tool's own base-URL override
    # env var at the route (and its auth var, unless the route forwards the user's token).
    for pt in (passthroughs or []):
        route, base_url_var = pt.get("route"), pt.get("base_url_var")
        if not route or not base_url_var:
            continue  # nothing to point via env (renderer's job) — skip silently
        pairs.append((base_url_var, f"{base}{route}"))
        auth_var = pt.get("auth_var")
        if auth_var and pt.get("auth_mode") != GATEWAY_CRED_FORWARDED_TOKEN:
            pairs.append((auth_var, key))

    seen, out = set(), []
    for k, v in pairs:
        if k in seen:
            continue
        seen.add(k)
        out.append((k, v))
    return out


def render_env_block_body(shell, pairs):
    """Render the env-block body (no markers, no timestamp → deterministic)."""
    lines = [_GATEWAY_BODY_HEADER]
    if shell == "fish":
        lines += [f'set -gx {k} "{v}"' for k, v in pairs]
    else:
        lines += [f'export {k}="{v}"' for k, v in pairs]
    return "\n".join(lines)


def _redact_block(text, key):
    """Replace every occurrence of the secret with its mask for safe display."""
    return text.replace(key, _mask_secret(key)) if key else text


# --- state manifest --------------------------------------------------------
def _utc_now():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def _sha256(text):
    import hashlib

    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def read_manifest(path=None):
    """Read the gateway state manifest ({} when absent or unreadable)."""
    path = Path(path or GATEWAY_STATE_FILE)
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
        return data if isinstance(data, dict) else {}
    except (json.JSONDecodeError, OSError):
        return {}


def write_manifest(data, path=None):
    """Write the manifest at 0600."""
    path = Path(path or GATEWAY_STATE_FILE)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2) + "\n")
    try:
        path.chmod(0o600)
    except OSError:
        pass


def clear_manifest(path=None):
    """Delete the manifest (idempotent — missing file is fine)."""
    path = Path(path or GATEWAY_STATE_FILE)
    try:
        path.unlink()
    except OSError:
        pass


def build_manifest(base_url, shell, rc, block, *, model_count, only_discovered,
                   applied_at=None, config_files=None):
    """Assemble the manifest describing what `on` changed (no secrets).

    ``config_files`` records every portable/staged/installed file aikit wrote (with
    ``created_by_aikit``) so `off` removes exactly what `on` created. ``applied_at``
    is injectable so the manifest and the generated ``gateway.json`` agree on a time.
    """
    rc = Path(rc)
    return {
        "active": True,
        "gateway_url": base_url,
        "applied_at": applied_at or _utc_now(),
        "shell": shell,
        "rc_path": str(rc),
        "markers": {"begin": GATEWAY_BLOCK.begin, "end": GATEWAY_BLOCK.end},
        "backup_path": str(rc.with_name(rc.name + GATEWAY_RC_BACKUP_SUFFIX)),
        "block_sha256": _sha256(block),
        "model_count": model_count,
        "only_discovered": bool(only_discovered),
        "config_files": config_files or [],  # native per-tool config files written by `on`
    }


def _undo_config_file(entry):
    """Reverse one manifest config-file entry (the Stage 3 install/restore record).

    Deletes a file aikit created and/or restores one it backed up — keyed purely
    by the manifest so `off` removes exactly what `on` wrote. ``created_dirs``
    (directories aikit had to create to install a config) are pruned innermost-first
    when they end up empty, so an install also leaves the tree pristine.
    """
    try:
        path = Path(entry["path"])
    except (KeyError, TypeError):
        return
    if entry.get("created_by_aikit"):
        try:
            path.unlink()
        except OSError:
            pass
    backup = entry.get("backup")
    if backup and Path(backup).exists():
        try:
            shutil.copy2(backup, path)
        except OSError:
            pass
    # Prune directories aikit created for an installed target (innermost-first),
    # but only when still empty — never touch a dir the user already had.
    for d in entry.get("created_dirs", []):
        try:
            Path(d).rmdir()
        except OSError:
            pass


# --- native per-tool config generation ------------------------------------
# Beyond the env layer, tools that read their own config files get a native
# config in their own schema, populated with every model the gateway exposed.
# Secrets are referenced via env var (read from gateway.env / the shell) rather
# than written into files, wherever the tool supports it. Renderers are pure
# (base, models, detail → str) so they unit-test trivially.
GATEWAY_TOOL_PROVIDER_ID = "litellm"        # the provider id registered inside each tool
GATEWAY_TOOL_PROVIDER_NAME = "LiteLLM Gateway"


def _default_model(models):
    return models[0] if models else "<MODEL_ID>"


def _model_ctx(detail, m, fallback=128000):
    return (detail.get(m) or {}).get("max_tokens") or fallback


def render_opencode(base, models, detail):
    # OpenAI-compatible provider via the Vercel AI SDK. apiKey uses {env:...}.
    cfg = {
        "$schema": "https://opencode.ai/config.json",
        "provider": {
            GATEWAY_TOOL_PROVIDER_ID: {
                "npm": "@ai-sdk/openai-compatible",
                "name": GATEWAY_TOOL_PROVIDER_NAME,
                "options": {"baseURL": f"{base}/v1", "apiKey": "{env:OPENAI_API_KEY}"},
                "models": {m: {"name": m} for m in models},
            }
        },
    }
    return json.dumps(cfg, indent=2) + "\n"


def render_codex(base, models, detail):
    return "\n".join([
        "# Codex CLI provider for the LiteLLM gateway — generated by aikit gateway",
        f'model = "{_default_model(models)}"',
        f'model_provider = "{GATEWAY_TOOL_PROVIDER_ID}"',
        "",
        f"[model_providers.{GATEWAY_TOOL_PROVIDER_ID}]",
        f'name = "{GATEWAY_TOOL_PROVIDER_NAME}"',
        f'base_url = "{base}/v1"',
        'env_key = "OPENAI_API_KEY"   # key is read from this env var',
        '# LiteLLM serves Chat Completions. If your codex build requires the',
        '# Responses API, LiteLLM also exposes it: change to wire_api = "responses".',
        'wire_api = "chat"',
    ]) + "\n"


def render_crush(base, models, detail):
    ms = []
    for m in models:
        ctx = _model_ctx(detail, m)
        ms.append({"id": m, "name": m, "context_window": ctx,
                   "default_max_tokens": min(8192, max(1024, ctx // 2))})
    cfg = {
        "$schema": "https://charm.land/crush.json",
        "providers": {
            GATEWAY_TOOL_PROVIDER_ID: {
                "name": GATEWAY_TOOL_PROVIDER_NAME,
                "type": "openai-compat",
                "base_url": f"{base}/v1",
                "api_key": "$OPENAI_API_KEY",
                "models": ms,
            }
        },
    }
    return json.dumps(cfg, indent=2) + "\n"


def render_goose(base, models, detail):
    # Goose uses its built-in openai provider pointed at a custom HOST (no /v1);
    # the path lives in OPENAI_BASE_PATH.
    return "\n".join([
        "# Goose config — merge into ~/.config/goose/config.yaml (generated)",
        "GOOSE_PROVIDER: openai",
        f"GOOSE_MODEL: {_default_model(models)}",
        f"OPENAI_HOST: {base}",
        "OPENAI_BASE_PATH: v1/chat/completions",
        "# API key: run `goose configure` to store it in the keyring,",
        "# or `export OPENAI_API_KEY=...` (already set by gateway.env).",
    ]) + "\n"


def render_pi(base, models, detail):
    cfg = {
        "providers": {
            GATEWAY_TOOL_PROVIDER_ID: {
                "baseUrl": f"{base}/v1",
                "api": "openai-completions",
                # "!" prefix => resolve via shell, so the key stays out of the file.
                "apiKey": '!printf %s "$OPENAI_API_KEY"',
                "models": [{"id": m} for m in models],
            }
        }
    }
    return json.dumps(cfg, indent=2) + "\n"


