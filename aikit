# relies on (AWS_ACCESS_KEY_ID, GITHUB_TOKEN/GH_TOKEN, HF_TOKEN,
# GOOGLE_APPLICATION_CREDENTIALS, DATABRICKS_TOKEN, …). Only inference-scoped vars
