    summary = {
        "gateway_url": base,
        "openai_compatible_base": f"{base}/v1",
        "generated": generated,
        "providers": [
            {"id": p[0], "name": p[1], "prefix": p[2], "route": f"{base}{p[5]}",
             "key_envs": p[3], "base_envs": p[4]} for p in GATEWAY_PROVIDERS
        ],
        "models": [
            {"id": m, "provider": (detail.get(m) or {}).get("provider"),
             "max_tokens": (detail.get(m) or {}).get("max_tokens")} for m in models
        ],
    }
    return json.dumps(summary, indent=2) + "\n"


