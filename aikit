def interactive_agent_picker(title="Select agents", preselect_installed=False):
    """Arrow-key-navigable multi-select agent picker.
    
    Uses readchar for keyboard input and direct ANSI escape codes for rendering.
    This avoids Rich's terminal state interference that breaks raw mode.
    
    Controls:
      ↑/↓ or j/k — move cursor
      Space        — toggle selection
      Enter        — confirm and return selected
      a            — select all
      n            — deselect all
      q/Esc        — cancel (return empty list)
      Numbers 0-9  — jump to that item
    """
    agent_keys = list(AGENTS.keys())
    n = len(agent_keys)
    installed = {k for k in agent_keys if detect_agent_bin(k)}
    
    # Initialize selection
    if preselect_installed:
        selected = installed.copy()
    else:
        selected = set()
    
    cursor_pos = 0
    
    # Height for clearing — track how many lines we last rendered
    last_height = 0
    
    while True:
        # Build the menu as plain text lines (no Rich markup, just ANSI)
        out_lines = []
        
        # Title
        out_lines.append(_ansi(f"\n{title}", _BOLD, _CYAN))
        out_lines.append(_ansi("  \u2191\u2193/jk = navigate  |  Space = toggle  |  Enter = confirm  |  a = all  |  n = none  |  q = cancel", _DIM))
        out_lines.append("")
        
        for i in range(n):
            agent = AGENTS[agent_keys[i]]
            key = agent_keys[i]
            is_cursor = (i == cursor_pos)
            
            # Build each line
            num = f" {i+1:>2} "
            
            if is_cursor:
                line = _ansi("\u2502" + num, _BG_BLUE, _BOLD, _WHITE)
            else:
                line = " " + _ansi(num, _DIM)
            
            if key in selected:
                line += _ansi("[X]", _BOLD, _GREEN)
            else:
                line += _ansi("[ ]", _DIM)
            
            line += f" {agent['icon']} {agent['name']:<20}"
            
            if key in installed:
                line += _ansi(" (installed)", _DIM)
            
            out_lines.append(line)
        
        out_lines.append("")
        out_lines.append(f"  Selected: {len(selected)}/{n}  " + 
                        (", ".join(sorted(selected)) if selected else "(none)"))
        out_lines.append(_ansi(f"  Cursor: #{cursor_pos+1} {AGENTS[agent_keys[cursor_pos]]['name']}", _DIM))
        
        # Clear previous render by moving cursor up
        if last_height > 0:
            sys.stdout.write(f"\033[{last_height}A")
        
        # Write the new frame
        output = "\n".join(out_lines)
        sys.stdout.write(output + "\n")
        sys.stdout.flush()
        last_height = len(out_lines) + 1
        
        # Read input
        ch = _read_key()
        
        if ch is None:
            # Non-TTY or no readchar — degrade to line input  
            print()
            choice = _prompt("Action (enter=done, number=toggle, a=all, n=none, q=cancel)", "")
            if choice == "":
                return sorted(selected)
            elif choice.lower() in ("q", "quit"):
                return []
            elif choice.lower() == "a":
                selected = set(agent_keys)
            elif choice.lower() == "n":
                selected = set()
            else:
                try:
                    idx = int(choice) - 1
                    if 0 <= idx < n:
                        key = agent_keys[idx]
                        if key in selected:
                            selected.discard(key)
                        else:
                            selected.add(key)
                except ValueError:
                    pass
        elif ch in ('up', 'k'):
            cursor_pos = max(0, cursor_pos - 1)
        elif ch in ('down', 'j'):
            cursor_pos = min(n - 1, cursor_pos + 1)
        elif ch == 'space':
            key = agent_keys[cursor_pos]
            if key in selected:
                selected.discard(key)
            else:
                selected.add(key)
        elif ch == 'enter':
            return sorted(selected)
        elif ch in ('q', 'esc'):
            return []
        elif ch == 'a':
            selected = set(agent_keys)
        elif ch == 'n':
            selected = set()
        elif ch and ch.isdigit():
            idx = int(ch) - 1
            if 0 <= idx < n:
                cursor_pos = idx


def print_agent_table(agent_keys=None):
    """Print a Rich table of agents and their status.
    Auto-discovers install status, versions, and auth state from the real system."""
    if agent_keys is None:
        agent_keys = list(AGENTS.keys())

    discover_and_persist()

    config = load_config()

    table = Table(title="AI Coding Agents", header_style="bold cyan")
    table.add_column("#", style="dim", width=3)
    table.add_column("Agent", style="bold")
    table.add_column("Vendor")
    table.add_column("Status")
    table.add_column("Version")
    table.add_column("Update", width=18)
    table.add_column("Auth")

    upgrades = 0
    for i, key in enumerate(agent_keys, 1):
        agent = AGENTS[key]
        agent_cfg = config.get("agents", {}).get(key, {})
        installed = agent_cfg.get("installed", False)
        version = agent_cfg.get("version") or "—"
        # Keep version short for table display — one line max
        if isinstance(version, str) and len(version) > 40:
            version = version[:37].rstrip() + "…"
        auth_done = agent_cfg.get("auth_configured", False)
        update_status = {
            "available": agent_cfg.get("update_available"),
            "latest": agent_cfg.get("latest_version"),
        } if installed else None
        update_label = format_update_status(key, update_status)
        
        if installed:
            status = "[bold green]✓ installed[/bold green]"
        else:
            status = "[dim]not installed[/dim]"
            version = "—"

        if installed and update_status and update_status.get("available") is True:
            upgrades += 1
            if update_label.startswith("↑"):
                update_cell = f"[bold yellow]{update_label}[/bold yellow]"
            else:
                update_cell = "[bold yellow]upgrade available[/bold yellow]"
        elif installed and update_status and update_status.get("available") is False:
            update_cell = "[dim]up to date[/dim]"
        else:
            update_cell = "[dim]—[/dim]"

        if installed and auth_done:
            auth_status = "[green]configured[/green]"
        elif installed:
            auth_status = "[yellow]needs auth[/yellow]"
        else:
            auth_status = "[dim]—[/dim]"

        table.add_row(
            str(i),
            f"{agent['icon']} {agent['name']}",
            agent["vendor"],
            status,
            version,
            update_cell,
            auth_status,
        )

    console.print(table)
    if upgrades:
        sk.info(f"{upgrades} upgrade(s) available — run [bold]aikit update[/bold]")
    for warning in agent_bin_collision_warnings():
        sk.warning(warning)


