    if not which("node") or not which("npm"):
        print_warning("Node.js/npm not found — required for npm-based agents")
        issues += 1
    if not which("git"):
        print_warning("git not found — required by some agents")
        issues += 1

    if issues == 0:
        print_success("No issues detected")
    else:
        print_info(f"  {issues} issue(s) found. Install missing prerequisites first.")


