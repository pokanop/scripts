            status = "[green]✓[/green]"
            vstr = f" — {version}" if version else ""
            astr = " [green]auth✓[/green]" if auth else " [yellow]needs auth[/yellow]"
            console.print(f"  {status} {agent['icon']} {agent['name']}{vstr}{astr}")
        else:
            console.print(f"  [dim]  {agent['icon']} {agent['name']} — not installed[/dim]")

