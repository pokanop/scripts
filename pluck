def resolve_file_format(path: Path, explicit: Optional[str], role: str) -> str:
    if explicit:
        return explicit
    try:
        return detect_format(path).value
    except PluckError as exc:
        raise PluckError(f"{role}: {exc}") from exc


def cmd_get(args) -> None:
    path = Path(args.file)
    fmt = resolve_file_format(path, args.format, "get")
    loaded = load_config(path, fmt)
    value = get_key(loaded, args.path)
    if args.json:
        console.print(json.dumps(value, indent=2, default=str))
    else:
        show_value(f"{path.name} → {args.path}", loaded, value)


def cmd_set(args) -> None:
    path = Path(args.file)
    fmt = resolve_file_format(path, args.format, "set")
    loaded = load_config(path, fmt)
    value = parse_value(args.value, ConfigFormat(fmt))
    create = args.create_missing or loaded.format == ConfigFormat.ENV
    apply_key(loaded, args.path, value, create)
    if args.dry_run:
        show_value(f"would set {args.path}", loaded, value)
        return
    write_config(loaded, path, fmt, backup=args.backup)
    print_success(f"Set {args.path} in {path}")


def _apply_keys(
    source: LoadedConfig,
    dest: LoadedConfig,
    keys: list[str],
    mode: str,
    create_missing: bool,
) -> list[str]:
    changed: list[str] = []
    for key in keys:
        if not key_exists(source, key):
            raise PluckError(f"source missing key: {key}")
        src_val = get_key(source, key)
        if mode == "copy":
            new_val = clone_value(src_val)
        else:
            if key_exists(dest, key):
                if dest.format == ConfigFormat.ENV:
                    existing = get_key(dest, key)
                    if isinstance(existing, str) and isinstance(src_val, dict):
                        try:
                            existing = json.loads(existing)
                        except json.JSONDecodeError:
                            existing = {"value": existing}
                        new_val = deep_merge(existing, src_val)
                    else:
                        new_val = deep_merge(existing, src_val)
                else:
                    new_val = deep_merge(get_key(dest, key), src_val)
            else:
                new_val = clone_value(src_val)
        apply_key(dest, key, new_val, create_missing)
        changed.append(key)
    return changed


def _transfer(args, mode: str) -> None:
    source = Path(args.source)
    dest = Path(args.dest)
    src_fmt = resolve_file_format(source, args.src_format, "source")
    dest_fmt = resolve_file_format(dest, args.dest_format, "destination")
    keys = resolve_keys(args)

    src_loaded = load_config(source, src_fmt)
    if dest.exists():
        dest_loaded = load_config(dest, dest_fmt)
    elif args.create_missing:
        if dest_fmt == "env":
            dest_loaded = LoadedConfig(
                data={},
                format=ConfigFormat.ENV,
                path=dest,
                env_doc=EnvDocument.parse(""),
            )
        else:
            dest_loaded = LoadedConfig(data={}, format=ConfigFormat(dest_fmt), path=dest)
    else:
        raise PluckError(
            f"destination not found: {dest} (pass --create-missing to create)"
        )

    if dest_fmt != "env" and not isinstance(dest_loaded.data, dict):
        raise PluckError(f"{dest} root must be a mapping for key-path updates")

    changed = _apply_keys(src_loaded, dest_loaded, keys, mode, args.create_missing)

    if args.dry_run:
        print_info(
            f"Mode: {mode} · {src_fmt} → {dest_fmt} · keys: {', '.join(changed)}"
        )
        handler = handler_for(ConfigFormat(dest_fmt))
        text = handler.dump_preview(dest_loaded.data)
        lexer = {"yaml": "yaml", "json": "json", "toml": "toml", "env": "bash"}[dest_fmt]
        console.print(
            Panel(
                Syntax(text, lexer, theme="monokai", line_numbers=False),
                title=f"preview → {dest.name}",
                border_style="cyan",
            )
        )
        return

    write_config(dest_loaded, dest, dest_fmt, backup=args.backup)
    verb = "Copied" if mode == "copy" else "Merged"
    print_success(
        f"{verb} {len(changed)} key(s) from {source.name} ({src_fmt}) → "
        f"{dest.name} ({dest_fmt})"
    )
    for key in changed:
        console.print(f"     • {key}", style="dim")


def cmd_copy(args) -> None:
    _transfer(args, mode="copy")


def cmd_merge(args) -> None:
    _transfer(args, mode="merge")


def _brief(value: Any, limit: int = 60) -> str:
    if isinstance(value, (dict, list)):
        text = json.dumps(value, default=str)
    else:
        text = str(value)
    if len(text) > limit:
        return text[: limit - 1] + "…"
    return text


def _path_label_candidates(path: Path, arg: Optional[str] = None) -> list[str]:
    """Progressively more specific labels for a config file path."""
    name = path.name
    candidates = [name]
    parent = path.parent
    if parent.name and str(parent) not in (".", ""):
        parent_label = f"{parent.name}/{name}"
        if parent_label not in candidates:
            candidates.append(parent_label)
    full = (arg or str(path)).strip()
    if full and full not in candidates:
        candidates.append(full)
    return candidates


def _truncate_label(text: str, max_len: int) -> str:
    if len(text) <= max_len:
        return text
    return "..." + text[-(max_len - 3) :]


def diff_column_labels(
    left: Path,
    right: Path,
    left_fmt: str,
    right_fmt: str,
    *,
    left_arg: Optional[str] = None,
    right_arg: Optional[str] = None,
    max_len: int = 48,
) -> tuple[str, str]:
    """Build distinct diff column headers; add path context when basenames collide."""
    left_cands = _path_label_candidates(left, left_arg)
    right_cands = _path_label_candidates(right, right_arg)
    depth = max(len(left_cands), len(right_cands))

    for i in range(depth):
        l_base = left_cands[min(i, len(left_cands) - 1)]
        r_base = right_cands[min(i, len(right_cands) - 1)]
        if l_base != r_base or i == depth - 1:
            return (
                _truncate_label(f"{l_base} ({left_fmt})", max_len),
                _truncate_label(f"{r_base} ({right_fmt})", max_len),
            )

    return (
        _truncate_label(f"{left.name} ({left_fmt})", max_len),
        _truncate_label(f"{right.name} ({right_fmt})", max_len),
    )


def cmd_diff(args) -> None:
    left = Path(args.a)
    right = Path(args.b)
    left_fmt = resolve_file_format(left, args.src_format, "left file")
    right_fmt = resolve_file_format(right, args.dest_format, "right file")
    keys = resolve_keys(args) if args.keys or args.keys_file else None

    left_loaded = load_config(left, left_fmt)
    right_loaded = load_config(right, right_fmt)

    if keys is None:
        if left_fmt == "env" or right_fmt == "env":
            keys = sorted(
                set(left_loaded.data) | set(right_loaded.data)
            )
        elif isinstance(left_loaded.data, dict) and isinstance(right_loaded.data, dict):
            keys = sorted(set(left_loaded.data) | set(right_loaded.data))
        else:
            raise PluckError("diff without keys requires mapping roots on both sides")

    left_label, right_label = diff_column_labels(
        left,
        right,
        left_fmt,
        right_fmt,
        left_arg=args.a,
        right_arg=args.b,
    )

    table = Table(title="Diff", header_style="bold cyan", title_style="bold")
    table.add_column("Key")
    table.add_column(left_label, style="cyan")
    table.add_column(right_label, style="magenta")
    table.add_column("Status")

    for key in keys:
        in_l = key_exists(left_loaded, key)
        in_r = key_exists(right_loaded, key)
        if not in_l and not in_r:
            status = "missing both"
            lv = rv = "—"
        elif not in_l:
            status = "only right"
            lv = "—"
            rv = _brief(get_key(right_loaded, key))
        elif not in_r:
            status = "only left"
            lv = _brief(get_key(left_loaded, key))
            rv = "—"
        else:
            lv = get_key(left_loaded, key)
            rv = get_key(right_loaded, key)
            status = "same" if lv == rv else "different"
            lv, rv = _brief(lv), _brief(rv)
        style = (
            "green"
            if status == "same"
            else "yellow"
            if status == "different"
            else "dim"
        )
        table.add_row(key, lv, rv, f"[{style}]{status}[/{style}]")

    console.print(table)


def cmd_formats(_args) -> None:
    table = Table(show_header=True, header_style="bold cyan")
    table.add_column("Format")
    table.add_column("Extensions")
    table.add_column("Notes")
    table.add_row("yaml", ".yaml .yml", "round-trip comments via ruamel.yaml")
    table.add_row("json", ".json", "pretty-printed output")
    table.add_row("toml", ".toml", "stdlib read + tomli-w write")
    table.add_row("env", ".env .env.*", "flat keys; nested paths → UPPER_SNAKE")
    console.print(table)
    console.print()
    print_info("Format auto-detected from extension; override with --format / --src-format / --dest-format")


def build_parser() -> argparse.ArgumentParser:
    p = sk.make_parser(
        "pluck", __version__, TAGLINE, icon=ICON,
        epilog=textwrap.dedent("""\
            Supported formats: yaml, json, toml, env (auto-detected from extension)

            Key paths use dot notation; list indices use brackets:
              model
              providers.openai
              servers[0].host

            .env files use flat keys; nested paths map to UPPER_SNAKE names:
              providers.openai  →  PROVIDERS_OPENAI

            Examples:
              pluck copy src.yaml dst.json model,providers
              pluck copy settings.toml .env.local database
              pluck get config.yaml model
              pluck set .env API_KEY sk-xxx
              pluck diff a.yaml b.yaml model providers
        """),
    )
    sub = p.add_subparsers(dest="command")

    sub.add_parser("doctor", help="Check Python dependencies")
    sub.add_parser("formats", help="List supported config formats")

    def add_format_flags(parser, include_transfer: bool = False):
        parser.add_argument(
            "--format",
            metavar="FMT",
            help="force file format (yaml, json, toml, env)",
        )
        if include_transfer:
            parser.add_argument(
                "--src-format",
                metavar="FMT",
                help="source format override for cross-format copy/merge/diff",
            )
            parser.add_argument(
                "--dest-format",
                metavar="FMT",
                help="destination format override for cross-format copy/merge/diff",
            )

    gp = sub.add_parser("get", help="Print a key path from a config file")
    gp.add_argument("file", help="config file")
    gp.add_argument("path", help="dot-separated key path")
    gp.add_argument("--json", action="store_true", help="emit JSON instead of formatted output")
    add_format_flags(gp)

    sp = sub.add_parser("set", help="Set a key path in a config file")
    sp.add_argument("file", help="config file")
    sp.add_argument("path", help="dot-separated key path")
    sp.add_argument("value", help="value (parsed per format; plain strings work too)")
    sp.add_argument("--create-missing", action="store_true", help="create missing keys")
    sp.add_argument("-n", "--dry-run", action="store_true", help="preview without writing")
    sp.add_argument("--backup", action="store_true", help="write .bak before saving")
    add_format_flags(sp)

    def add_transfer_flags(parser):
        parser.add_argument("source", help="source config file")
        parser.add_argument("dest", help="destination config file")
        parser.add_argument("key_paths", nargs="*", metavar="KEY",
                            help="key paths (comma/space-separated)")
        parser.add_argument("-k", "--keys", action="append", default=[], metavar="KEYS",
                            help="key paths (comma/space-separated; repeatable)")
        parser.add_argument("--keys-file", metavar="FILE",
                            help="file with key paths, one per line (# comments allowed)")
        parser.add_argument("--create-missing", action="store_true",
                            help="create dest file or missing key paths")
        parser.add_argument("-n", "--dry-run", action="store_true", help="preview without writing")
        parser.add_argument("--backup", action="store_true", help="write .bak before saving")
        add_format_flags(parser, include_transfer=True)

    cp = sub.add_parser("copy", help="Overwrite key paths in dest from source")
    add_transfer_flags(cp)

    mp = sub.add_parser("merge", help="Deep-merge key paths from source into dest")
    add_transfer_flags(mp)

    dp = sub.add_parser("diff", help="Compare key paths between two config files")
    dp.add_argument("a", help="first config file")
    dp.add_argument("b", help="second config file")
    dp.add_argument("key_paths", nargs="*", metavar="KEY",
                    help="key paths to compare (default: all top-level keys)")
    dp.add_argument("-k", "--keys", action="append", default=[], metavar="KEYS",
                    help="key paths (comma/space-separated; repeatable)")
    dp.add_argument("--keys-file", metavar="FILE", help="file with key paths to compare")
    add_format_flags(dp, include_transfer=True)

    return p


HANDLERS = {
    "doctor": cmd_doctor,
    "formats": cmd_formats,
    "get": cmd_get,
    "set": cmd_set,
    "copy": cmd_copy,
    "merge": cmd_merge,
    "diff": cmd_diff,
}


def main() -> int:
    parser = build_parser()
    args = sk.parse_args(parser)
    return sk.dispatch(args, HANDLERS, parser,
                       banner=sk.banner("pluck", __version__, TAGLINE, ICON))


if __name__ == "__main__":
    sys.exit(sk.run_cli(main))