FORMAT_EXTENSIONS: dict[str, str] = {
    ".yaml": "yaml",
    ".yml": "yaml",
    ".json": "json",
    ".toml": "toml",
    ".env": "env",
}


class ConfigFormat(str, Enum):
    YAML = "yaml"
    JSON = "json"
    TOML = "toml"
    ENV = "env"


class PluckError(sk.CliError):
    """User-facing error with a clean message."""


print_success = sk.success
print_error = sk.error
print_info = sk.info
print_warning = sk.warning


def detect_format(path: Path, override: Optional[str] = None) -> ConfigFormat:
    if override:
        try:
            return ConfigFormat(override.lower())
        except ValueError as exc:
            raise PluckError(
                f"unknown format {override!r} (yaml, json, toml, env)"
            ) from exc
    name = path.name.lower()
    if name.startswith(".env") or name.endswith(".env"):
        return ConfigFormat.ENV
    ext = path.suffix.lower()
    fmt = FORMAT_EXTENSIONS.get(ext)
    if fmt:
        return ConfigFormat(fmt)
    raise PluckError(
        f"cannot detect format for {path} "
        "(use --format or a known extension: .yaml .json .toml .env)"
    )


def parse_path(path: str) -> list[str | int]:
    """Parse dot paths with optional bracket indices: foo.bar[0].baz"""
    if not path or not path.strip():
        raise PluckError("key path cannot be empty")
    parts: list[str | int] = []
    for segment in path.split("."):
        if not segment:
            raise PluckError(f"invalid path {path!r}: empty segment")
        buf = ""
        i = 0
        while i < len(segment):
            ch = segment[i]
            if ch == "[":
                if buf:
                    parts.append(buf)
                    buf = ""
                close = segment.find("]", i)
                if close == -1:
                    raise PluckError(f"invalid path {path!r}: unclosed [")
                idx_text = segment[i + 1 : close].strip()
                if not idx_text.isdigit():
                    raise PluckError(f"invalid path {path!r}: index must be numeric")
                parts.append(int(idx_text))
                i = close + 1
                continue
            buf += ch
            i += 1
        if buf:
            parts.append(buf)
    return parts


def get_at(data: Any, path: str) -> Any:
    node = data
    for part in parse_path(path):
        if isinstance(part, int):
            if not isinstance(node, list):
                raise PluckError(f"path {path!r}: expected list at index {part}")
            if part < 0 or part >= len(node):
                raise PluckError(f"path {path!r}: index {part} out of range")
            node = node[part]
        else:
            if not isinstance(node, dict) or part not in node:
                raise PluckError(f"path {path!r}: key {part!r} not found")
            node = node[part]
    return node


def path_exists(data: Any, path: str) -> bool:
    try:
        get_at(data, path)
        return True
    except PluckError:
        return False


def set_at(data: Any, path: str, value: Any) -> None:
    parts = parse_path(path)
    if not parts:
        raise PluckError("key path cannot be empty")

    node = data
    for part in parts[:-1]:
        if isinstance(part, int):
            if not isinstance(node, list):
                raise PluckError(f"path {path!r}: expected list at index {part}")
            node = node[part]
        else:
            if not isinstance(node, dict):
                raise PluckError(f"path {path!r}: expected mapping at {part!r}")
            if part not in node:
                raise PluckError(
                    f"path {path!r}: key {part!r} not found (use --create-missing)"
                )
            node = node[part]

    leaf = parts[-1]
    if isinstance(leaf, int):
        if not isinstance(node, list):
            raise PluckError(f"path {path!r}: expected list at index {leaf}")
        if leaf < 0 or leaf >= len(node):
            raise PluckError(f"path {path!r}: index {leaf} out of range")
        node[leaf] = value
    else:
        if not isinstance(node, dict):
            raise PluckError(f"path {path!r}: expected mapping for key {leaf!r}")
        node[leaf] = value


def ensure_at(data: Any, path: str) -> tuple[Any, str | int]:
    parts = parse_path(path)
    if not parts:
        raise PluckError("key path cannot be empty")

    node = data
    for part in parts[:-1]:
        if isinstance(part, int):
            if not isinstance(node, list):
                raise PluckError(f"path {path!r}: cannot create index under non-list")
            while len(node) <= part:
                node.append({})
            if node[part] is None:
                node[part] = {}
            node = node[part]
        else:
            if not isinstance(node, dict):
                raise PluckError(f"path {path!r}: cannot create key under non-mapping")
            if part not in node or node[part] is None:
                node[part] = {}
            node = node[part]
    return node, parts[-1]


def set_at_create(data: Any, path: str, value: Any) -> None:
    parent, leaf = ensure_at(data, path)
    if isinstance(leaf, int):
        if not isinstance(parent, list):
            raise PluckError(f"path {path!r}: expected list parent")
        while len(parent) <= leaf:
            parent.append(None)
        parent[leaf] = value
    else:
        if not isinstance(parent, dict):
            raise PluckError(f"path {path!r}: expected mapping parent")
        parent[leaf] = value


def deep_merge(base: Any, override: Any) -> Any:
    if isinstance(base, dict) and isinstance(override, dict):
        out = copy.deepcopy(base)
        for key, val in override.items():
            if key in out and isinstance(out[key], dict) and isinstance(val, dict):
                out[key] = deep_merge(out[key], val)
            else:
                out[key] = copy.deepcopy(val)
        return out
    return copy.deepcopy(override)


def clone_value(value: Any) -> Any:
    return copy.deepcopy(value)


def expand_key_specs(specs: list[str]) -> list[str]:
    keys: list[str] = []
    for spec in specs:
        for part in re.split(r"[,\s]+", spec.strip()):
            part = part.strip()
            if part:
                keys.append(part)
    return keys


def resolve_keys(args) -> list[str]:
    keys = expand_key_specs(list(args.keys or []))
    if getattr(args, "key_paths", None):
        keys.extend(expand_key_specs(args.key_paths))
    if args.keys_file:
        path = Path(args.keys_file)
        if not path.exists():
            raise PluckError(f"keys file not found: {path}")
        for line in path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if line and not line.startswith("#"):
                keys.extend(expand_key_specs([line]))
    if not keys:
        raise PluckError(
            "specify at least one key path (positional keys, -k, or --keys-file)"
        )
    seen: set[str] = set()
    unique: list[str] = []
    for key in keys:
        if key not in seen:
            seen.add(key)
            unique.append(key)
    return unique


def parse_value(text: str, fmt: ConfigFormat) -> Any:
    if fmt == ConfigFormat.JSON:
        try:
            return json.loads(text)
        except json.JSONDecodeError:
            return text
    if fmt == ConfigFormat.TOML:
        try:
            return tomllib.loads(f"v = {text}")["v"]
        except tomllib.TOMLDecodeError:
            return text
    if fmt == ConfigFormat.YAML:
        if YAML is None:
            raise PluckError("ruamel.yaml is required for YAML value parsing")
        y = yaml_engine()
        try:
            loaded = y.load(text)
        except Exception:  # noqa: BLE001
            return text
        return loaded
    return text


def path_to_env_key(path: str) -> str:
    """Map a dot-path to a conventional flat .env key."""
    key = re.sub(r"\[(\d+)\]", r"_\1", path)
    return key.replace(".", "_").upper()


def serialize_for_env(value: Any) -> str:
    if isinstance(value, (dict, list)):
        return json.dumps(value, separators=(",", ":"))
    if value is None:
        return ""
    if isinstance(value, bool):
        return "true" if value else "false"
    return str(value)


def yaml_engine() -> YAML:
    if YAML is None:
        raise PluckError("ruamel.yaml is required (pip install ruamel.yaml)")
    y = YAML()
    y.preserve_quotes = True
    y.default_flow_style = False
    y.width = 4096
    return y


@dataclass
class LoadedConfig:
    data: Any
    format: ConfigFormat
    path: Path
    env_doc: Optional["EnvDocument"] = None


class FormatHandler(ABC):
    format: ConfigFormat

    @abstractmethod
    def load(self, path: Path) -> LoadedConfig:
        ...

    @abstractmethod
    def save(self, loaded: LoadedConfig, path: Path) -> None:
        ...

    def dump_preview(self, data: Any) -> str:
        return json.dumps(data, indent=2, default=str)


@dataclass
class EnvLine:
    raw: str
    kind: str  # blank, comment, kv
    key: Optional[str] = None
    value: Optional[str] = None
    exported: bool = False
    quote: Optional[str] = None  # single, double, or None


@dataclass
class EnvDocument:
    lines: list[EnvLine] = field(default_factory=list)
    data: dict[str, str] = field(default_factory=dict)

    @classmethod
    def parse(cls, text: str) -> EnvDocument:
        doc = cls()
        for raw in text.splitlines():
            stripped = raw.strip()
            if not stripped:
                doc.lines.append(EnvLine(raw=raw, kind="blank"))
                continue
            if stripped.startswith("#"):
                doc.lines.append(EnvLine(raw=raw, kind="comment"))
                continue

            line = stripped
            exported = False
            if line.startswith("export "):
                exported = True
                line = line[7:].strip()

            if "=" not in line:
                doc.lines.append(EnvLine(raw=raw, kind="comment"))
                continue

            key, _, value = line.partition("=")
            key = key.strip()
            value = value.strip()
            quote = None
            if len(value) >= 2 and value[0] == value[-1] and value[0] in "\"'":
                quote = "double" if value[0] == '"' else "single"
                value = value[1:-1]

            doc.lines.append(
                EnvLine(
                    raw=raw,
                    kind="kv",
                    key=key,
                    value=value,
                    exported=exported,
                    quote=quote,
                )
            )
            doc.data[key] = value
        return doc

    def set_key(self, key: str, value: str, exported: bool = False) -> None:
        self.data[key] = value
        for line in self.lines:
            if line.kind == "kv" and line.key == key:
                line.value = value
                line.exported = exported or line.exported
                return
        self.lines.append(
            EnvLine(raw="", kind="kv", key=key, value=value, exported=exported)
        )

    def render(self) -> str:
        out: list[str] = []
        for line in self.lines:
            if line.kind in ("blank", "comment"):
                out.append(line.raw)
                continue
            if line.kind == "kv" and line.key is not None:
                val = line.value or ""
                needs_quote = any(ch in val for ch in " #\t\"'\\$") or not val
                if line.quote == "double" or (needs_quote and line.quote != "single"):
                    val = json.dumps(val)
                elif line.quote == "single":
                    val = f"'{val}'"
                prefix = "export " if line.exported else ""
                out.append(f"{prefix}{line.key}={val}")
                continue
            out.append(line.raw)
        return "\n".join(out) + ("\n" if out else "")


class YamlHandler(FormatHandler):
    format = ConfigFormat.YAML

    def load(self, path: Path) -> LoadedConfig:
        if not path.exists():
            raise PluckError(f"file not found: {path}")
        y = yaml_engine()
        try:
            with path.open("r", encoding="utf-8") as fh:
                data = y.load(fh)
        except Exception as exc:  # noqa: BLE001
            raise PluckError(f"could not parse {path}: {exc}") from exc
        if data is None:
            data = {}
        if not isinstance(data, (dict, list)):
            raise PluckError(
                f"{path} root must be a mapping or sequence, got {type(data).__name__}"
            )
        return LoadedConfig(data=data, format=self.format, path=path)

    def save(self, loaded: LoadedConfig, path: Path) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        y = yaml_engine()
        with path.open("w", encoding="utf-8") as fh:
            y.dump(loaded.data, fh)

    def dump_preview(self, data: Any) -> str:
        y = yaml_engine()
        buf = StringIO()
        y.dump(data, buf)
        return buf.getvalue().rstrip() or "(empty)"


class JsonHandler(FormatHandler):
    format = ConfigFormat.JSON

    def load(self, path: Path) -> LoadedConfig:
        if not path.exists():
            raise PluckError(f"file not found: {path}")
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError as exc:
            raise PluckError(f"could not parse {path}: {exc}") from exc
        if not isinstance(data, (dict, list)):
            raise PluckError(
                f"{path} root must be an object or array, got {type(data).__name__}"
            )
        return LoadedConfig(data=data, format=self.format, path=path)

    def save(self, loaded: LoadedConfig, path: Path) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(
            json.dumps(loaded.data, indent=2, ensure_ascii=False) + "\n",
            encoding="utf-8",
        )

    def dump_preview(self, data: Any) -> str:
        return json.dumps(data, indent=2, default=str)


class TomlHandler(FormatHandler):
    format = ConfigFormat.TOML

    def load(self, path: Path) -> LoadedConfig:
        if not path.exists():
            raise PluckError(f"file not found: {path}")
        try:
            with path.open("rb") as fh:
                data = tomllib.load(fh)
        except tomllib.TOMLDecodeError as exc:
            raise PluckError(f"could not parse {path}: {exc}") from exc
        if not isinstance(data, dict):
            raise PluckError(f"{path} root must be a table, got {type(data).__name__}")
        return LoadedConfig(data=data, format=self.format, path=path)

    def save(self, loaded: LoadedConfig, path: Path) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_bytes(tomli_w.dumps(loaded.data))

    def dump_preview(self, data: Any) -> str:
        return tomli_w.dumps(data).decode("utf-8").rstrip() or "(empty)"


class EnvHandler(FormatHandler):
    format = ConfigFormat.ENV

    def load(self, path: Path) -> LoadedConfig:
        if not path.exists():
            raise PluckError(f"file not found: {path}")
        env_doc = EnvDocument.parse(path.read_text(encoding="utf-8"))
        return LoadedConfig(
            data=env_doc.data,
            format=self.format,
            path=path,
            env_doc=env_doc,
        )

    def save(self, loaded: LoadedConfig, path: Path) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        if loaded.env_doc is None:
            loaded.env_doc = EnvDocument.parse("")
            for key, value in loaded.data.items():
                loaded.env_doc.set_key(key, value)
        else:
            for key, value in loaded.data.items():
                if key not in loaded.env_doc.data:
                    loaded.env_doc.set_key(key, str(value))
                else:
                    loaded.env_doc.set_key(key, str(value))
        path.write_text(loaded.env_doc.render(), encoding="utf-8")

    def dump_preview(self, data: Any) -> str:
        lines = [f"{k}={serialize_for_env(v)}" for k, v in data.items()]
        return "\n".join(lines) or "(empty)"


HANDLERS: dict[ConfigFormat, FormatHandler] = {
    ConfigFormat.YAML: YamlHandler(),
    ConfigFormat.JSON: JsonHandler(),
    ConfigFormat.TOML: TomlHandler(),
    ConfigFormat.ENV: EnvHandler(),
}


def handler_for(fmt: ConfigFormat) -> FormatHandler:
    return HANDLERS[fmt]


def load_config(path: Path, fmt: Optional[str] = None) -> LoadedConfig:
    detected = detect_format(path, fmt)
    return handler_for(detected).load(path)


def write_config(
    loaded: LoadedConfig,
    path: Path,
    fmt: Optional[str] = None,
    backup: bool = False,
) -> None:
    target_fmt = detect_format(path, fmt or loaded.format.value)
    if backup and path.exists():
        backup_path = path.with_suffix(path.suffix + ".bak")
        shutil.copy2(path, backup_path)
        print_info(f"Backup: {backup_path}")
    handler_for(target_fmt).save(loaded, path)


def env_apply_key(
    loaded: LoadedConfig,
    path: str,
    value: Any,
    create_missing: bool,
) -> None:
    if loaded.env_doc is None:
        raise PluckError("internal error: env document missing")
    if "." in path or "[" in path:
        env_key = path_to_env_key(path)
        env_val = serialize_for_env(value)
        loaded.env_doc.set_key(env_key, env_val)
        loaded.data[env_key] = env_val
        return

    if not create_missing and path not in loaded.data:
        raise PluckError(
            f"destination missing key: {path} (pass --create-missing to add it)"
        )
    env_val = serialize_for_env(value)
    loaded.env_doc.set_key(path, env_val)
    loaded.data[path] = env_val


def env_get_key(loaded: LoadedConfig, path: str) -> Any:
    if path in loaded.data:
        return loaded.data[path]
    env_key = path_to_env_key(path)
    if env_key in loaded.data:
        raw = loaded.data[env_key]
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            return raw
    raise PluckError(f"path {path!r}: key not found in .env")


def env_path_exists(loaded: LoadedConfig, path: str) -> bool:
    try:
        env_get_key(loaded, path)
        return True
    except PluckError:
        return False


def apply_key(
    dest: LoadedConfig,
    path: str,
    value: Any,
    create_missing: bool,
) -> None:
    if dest.format == ConfigFormat.ENV:
        env_apply_key(dest, path, value, create_missing)
        return
    if create_missing:
        set_at_create(dest.data, path, value)
    else:
        set_at(dest.data, path, value)


def get_key(loaded: LoadedConfig, path: str) -> Any:
    if loaded.format == ConfigFormat.ENV:
        return env_get_key(loaded, path)
    return get_at(loaded.data, path)


def key_exists(loaded: LoadedConfig, path: str) -> bool:
    if loaded.format == ConfigFormat.ENV:
        return env_path_exists(loaded, path)
    return path_exists(loaded.data, path)


def show_value(title: str, loaded: LoadedConfig, value: Any) -> None:
    handler = handler_for(loaded.format)
    if isinstance(value, dict) and loaded.format == ConfigFormat.ENV:
        text = handler.dump_preview(value)
        lexer = "bash"
    else:
        if loaded.format == ConfigFormat.YAML:
            y = yaml_engine()
            buf = StringIO()
            y.dump(value, buf)
            text = buf.getvalue().rstrip() or "(empty)"
            lexer = "yaml"
        elif loaded.format == ConfigFormat.JSON:
            text = json.dumps(value, indent=2, default=str)
            lexer = "json"
        elif loaded.format == ConfigFormat.TOML:
            text = tomli_w.dumps(value).decode("utf-8").rstrip() or "(empty)"
            lexer = "toml"
        else:
            text = str(value)
            lexer = "bash"
    console.print(
        Panel(
            Syntax(text, lexer, theme="monokai", line_numbers=False),
            title=title,
            border_style="cyan",
        )
    )


