            print("No configured media servers.")
            print("\nAdd one with:")
            print("  voxtract sources add spotify --id CLIENT_ID --secret CLIENT_SECRET")
            print("  voxtract sources add jellyfin --name home --url http://jellyfin:8096 --key KEY")
            print("  voxtract sources add plex --name home --url http://plex:32400 --token TOKEN")
            return
        for kind, servers in sources.items():
            print(f"[{kind}]")
            for name, info in servers.items():
                if kind == "spotify":
                    masked = (info.get("client_id", ""))[:6] + "***"
                    print(f"  {name}: client_id={masked}")
                else:
                    masked_token = (info.get("token") or info.get("key", ""))[:6] + "***"
                    print(f"  {name}: {info.get('url','?')}  (auth: {masked_token})")
            print()

    elif args.sources_cmd == "add":
        kind = args.src_type
        name = args.name or "default"

        if kind == "jellyfin":
            if args.url and args.key:
                adapter = JellyfinAdapter()
                creds = adapter._authenticate(args.url, username=args.user,
                                              password=args.password, api_key=args.key)
                cfg.setdefault("sources", {}).setdefault("jellyfin", {})[name] = creds
                save_config(cfg)
                print(f"✓ Jellyfin '{name}' added ({creds['url']})")
            else:
                print("Jellyfin requires --url and --key (or --user/--pass)", file=sys.stderr)

        elif kind == "plex":
            if args.url and args.token:
                cfg.setdefault("sources", {}).setdefault("plex", {})[name] = {
                    "url": args.url.rstrip("/"), "token": args.token
                }
                save_config(cfg)
                print(f"✓ Plex '{name}' added ({args.url})")
            else:
                print("Plex requires --url and --token", file=sys.stderr)

        elif kind == "spotify":
            # Spotify uses --id (client_id) and --secret (client_secret)
            sp_id = getattr(args, "id", None) or args.key
            sp_secret = getattr(args, "secret", None)
            if sp_id and sp_secret:
                # Validate credentials
                try:
                    import spotipy
                    from spotipy.oauth2 import SpotifyClientCredentials
                    auth = SpotifyClientCredentials(client_id=sp_id, client_secret=sp_secret)
                    test = spotipy.Spotify(auth_manager=auth)
                    test.search(q="test", limit=1)  # quick validation
                except ImportError:
                    print("spotipy not installed. Run: pip install spotipy", file=sys.stderr)
                    sys.exit(1)
                except Exception as e:
                    print(f"Spotify auth failed: {e}", file=sys.stderr)
                    print("Get credentials at: https://developer.spotify.com/dashboard", file=sys.stderr)
                    sys.exit(1)

                cfg.setdefault("sources", {}).setdefault("spotify", {})[name] = {
                    "client_id": sp_id, "client_secret": sp_secret,
                }
                save_config(cfg)
                print(f"✓ Spotify '{name}' added (client_id={sp_id[:6]}***)")
            else:
                print("Spotify requires --id CLIENT_ID --secret CLIENT_SECRET", file=sys.stderr)
                print("  Get credentials at: https://developer.spotify.com/dashboard", file=sys.stderr)

        else:
            print(f"Unknown source type: {kind}", file=sys.stderr)
            print("Supported: spotify, jellyfin, plex", file=sys.stderr)

    elif args.sources_cmd == "remove":
        kind = args.src_type
        name = args.name or "default"
        if cfg.get("sources", {}).get(kind, {}).pop(name, None):
            save_config(cfg)
            print(f"✓ Removed {kind} '{name}'")
        else:
            print(f"Not found: {kind} '{name}'")


def cmd_info(args):
    """Show voxtract version and configuration info."""
    print(styled(f"\n  {icon('wave')} voxtract v{__version__}", _BOLD, _CYAN))
    print(styled(f"  {'━' * 38}", _DIM))
    print(f"  {styled('Config:', _BOLD)}    {CONFIG_FILE}")
    print(f"  {styled('Cache:', _BOLD)}     {CACHE_DIR}")
    print(f"  {styled('Demucs:', _BOLD)}    {DEMUCS_MODEL}")

    # Check torch model cache
    model_status = styled("not cached", _YELLOW)
    model_path = ""
    try:
        os.environ["TORCH_HOME"] = TORCH_HOME
        import torch
        hub_dir = torch.hub.get_dir()
        ckpt_dir = Path(hub_dir) / "checkpoints"
        if ckpt_dir.exists():
            ckpts = list(ckpt_dir.glob("*.th"))
            if ckpts:
                model_status = styled(f"cached ({human_size(ckpts[0].stat().st_size)})", _GREEN)
                model_path = str(ckpts[0])
    except ImportError:
        model_status = styled("torch not installed", _RED)
    print(f"  {styled('Model:', _BOLD)}     {model_status}")
    if model_path:
        print(f"  {styled('Model path:', _BOLD)} {model_path}")
    print(f"  {styled('Torch home:', _BOLD)} {TORCH_HOME}")

    # Configured sources
    cfg = load_config()
    sources = cfg.get("sources", {})
    src_count = sum(len(v) for v in sources.values())
    print(f"  {styled('Sources:', _BOLD)}   {src_count} configured ({', '.join(sources.keys()) if sources else 'none'})")
    print()


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    parser = sk.make_parser(
        "voxtract", __version__, TAGLINE, icon=ICON,
        epilog=f"""
Extract and isolate speech from YouTube, Spotify, Jellyfin, Plex, podcasts, and more.

Source URIs:
  youtube://VIDEO_ID           YouTube video
  spotify://track/ID           Spotify track (via spotdl → YouTube)
  spotify://album/ID           Spotify album (browse/list)
  spotify://show/ID            Spotify podcast show
  spotify://episode/ID         Spotify podcast episode
  spotify://search             Spotify search (use -q)
  jellyfin://SERVER/Items/ID   Jellyfin media server
  plex://SERVER/metadata/KEY   Plex media server
  podcast://FEED_URL           Podcast RSS feed
  podcast://FEED_URL#ep-3      Specific episode by index
  http(s)://example.com/file   Direct media URL
  dir:///path/to/media         Directory of media files
  /path/to/file.mp3            Local file

Examples:
  voxtract fetch youtube://dQw4w9WgXcQ
  voxtract sources add spotify --id CLIENT_ID --secret CLIENT_SECRET
  voxtract list spotify://search -q "radiohead" -t album
  voxtract fetch spotify://track/4cOdK2wGLETKBW3PvgPWqT
  voxtract clip spotify://track/4cOdK2wGLETKBW3PvgPWqT -s 0:30 -d 15 --isolate
  voxtract list spotify://show/5Ji1Ts4hJiZ7m4c0ogezC8
  voxtract fetch spotify://episode/abc123
  voxtract clip jellyfin://home/Items/abc123 -s 1:30 -d 30 --isolate
  voxtract list jellyfin://home -q "goodfellas"
  voxtract sources add jellyfin --name home --url http://jellyfin:8096 --key KEY
  voxtract sources list

Config: ~/.voxtract/config.json
Cache:  ~/.voxtract/cache/
"""
    )
    parser.add_argument("--verbose", action="store_true", help="Show debug output (ffmpeg commands)")
    sub = parser.add_subparsers(dest="command", help="Commands")

    # fetch
    f = sub.add_parser("fetch", help="Download/cache source audio")
    f.add_argument("source")
    f.add_argument("--force", "-f", action="store_true")

    # clip
    c = sub.add_parser("clip", help="Extract an audio clip")
    c.add_argument("source")
    c.add_argument("--start", "-s")
    c.add_argument("--end", "-e")
    c.add_argument("--duration", "-d")
    c.add_argument("--isolate", "-i", action="store_true")
    c.add_argument("--output-dir", "-o")
    c.add_argument("--format", "-f", choices=["mp3","wav","flac","ogg","m4a"])
    c.add_argument("--gain", "-g", metavar="dB",
                   help="Apply simple gain boost in dB (e.g. +6, -3). Bypasses loudnorm.")
    c.add_argument("--lufs", "-l", type=float, metavar="LUFS",
                   help="Target loudness in LUFS (default: -16). "
                        "-24=podcast, -16=clear voice, -14=loud/punchy, -23=broadcast")
    c.add_argument("--lra", type=float, metavar="LU",
                   help="Max loudness range in LU (default: 11). Lower=more compressed.")
    c.add_argument("--tp", type=float, metavar="dBTP",
                   help="Max true peak in dBTP (default: -1.5). Prevents clipping.")
    c.add_argument("--no-normalize", action="store_true",
                   help="Skip loudness normalization entirely (raw clip)")

    # list
    l = sub.add_parser("list", help="Search/browse media items")
    l.add_argument("source")
    l.add_argument("--query", "-q")
    l.add_argument("--type", "-t", choices=["track","album","artist","show","episode","movie","audio","series","season"])
    l.add_argument("--limit", "-n", type=int)

    # isolate
    i = sub.add_parser("isolate", help="Isolate speech from cached source")
    i.add_argument("source")
    i.add_argument("--force", "-f", action="store_true")

    # cache
    ca = sub.add_parser("cache", help="Manage cache")
    ca.add_argument("cache_action", choices=["list","clean","remove","info"])
    ca.add_argument("source", nargs="?")

    # info
    sub.add_parser("info", help="Show version, cache location, model status")

    # sources
    src = sub.add_parser("sources", help="Manage media server connections")
    src.add_argument("sources_cmd", choices=["list","add","remove"])
    src.add_argument("src_type", nargs="?", choices=["spotify","jellyfin","plex","youtube","podcast"])
    src.add_argument("--name", "-n")
    src.add_argument("--url", "-u")
    src.add_argument("--key", "-k")
    src.add_argument("--id", dest="id", help="Spotify client ID")
    src.add_argument("--secret", help="Spotify client secret")
    src.add_argument("--token")
    src.add_argument("--user")
    src.add_argument("--password", "--pass")

    args = parser.parse_args()

    global VERBOSE
    VERBOSE = getattr(args, 'verbose', False)

    try:
        if args.command == "fetch":     cmd_fetch(args)
        elif args.command == "clip":    cmd_clip(args)
        elif args.command == "list":    cmd_list(args)
        elif args.command == "isolate": cmd_isolate(args)
        elif args.command == "cache":   cmd_cache(args)
        elif args.command == "info":    cmd_info(args)
        elif args.command == "sources": cmd_sources(args)
        else:                           parser.print_help()
    except KeyboardInterrupt:
        print()
        print_warning("Interrupted — cleaning up temp files...")
        # Clean any orphaned temp files from this process
        for p in Path(tempfile.gettempdir()).glob(f"tmp*.raw.tmp.wav"):
            try:
                p.unlink()
            except OSError:
                pass
        print_info("Done.")
        sys.exit(130)


if __name__ == "__main__":
    main()
