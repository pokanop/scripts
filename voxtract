#!/usr/bin/env python3
"""
voxtract — Voice Extract Tool  v3.1.0
Extract and isolate speech from video and audio across multiple sources.

Sources: YouTube, Spotify, Jellyfin, Plex, podcasts (RSS), HTTP URLs, local files/directories.

Architecture:
    Source adapters (YouTube, Spotify, Jellyfin, Plex, HTTP, Local, Podcast)
    → fetch audio to cache
    → clip by timestamp (ffmpeg)
    → optionally isolate speech (Demucs neural network)

Dependencies:
    pip install yt-dlp demucs requests
    ffmpeg on PATH

Usage:
    # YouTube
    voxtract fetch youtube://dQw4w9WgXcQ

    # Jellyfin
    voxtract sources add jellyfin --url http://jellyfin:8096 --key YOUR_API_KEY
    voxtract list jellyfin://jellyfin  -q "interstellar"
    voxtract fetch jellyfin://jellyfin/Items/abc123

    # Plex
    voxtract sources add plex --url http://plex:32400 --token YOUR_TOKEN
    voxtract list plex://plex  --type movie -q "inception"
    voxtract fetch plex://plex/metadata/45678

    # Direct URL
    voxtract fetch https://example.com/speech.mp3

    # Local directory (batch)
    voxtract fetch dir:///path/to/audiobooks
    voxtract clip dir:///path/to/movies/TheInterview.mkv -s 10:00 -d 30 --isolate
    voxtract clip youtube://dQw4w9WgXcQ -s 0:30 -d 60 --isolate --lufs -14
    voxtract clip spotify://track/4cOdK2wGLETKBW3PvgPWqT -s 0:30 -d 15 --gain +6

    # Podcast RSS feed
    voxtract list podcast://https://feeds.simplecast.com/xyz123
    voxtract fetch podcast://https://feeds.simplecast.com/xyz123#ep-3

    # Spotify
    voxtract sources add spotify --id CLIENT_ID --secret CLIENT_SECRET
    voxtract list spotify://search -q "podcast name" -t show
    voxtract fetch spotify://track/4cOdK2wGLETKBW3PvgPWqT
    voxtract clip spotify://track/4cOdK2wGLETKBW3PvgPWqT -s 0:30 -d 15 --isolate
"""

