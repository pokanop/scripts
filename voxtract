# Plex Adapter
# ---------------------------------------------------------------------------

class PlexAdapter(SourceAdapter):
    scheme = "plex"

    def _resolve_server(self, server_ref: str) -> dict:
        cfg = load_config()
        server = cfg.get("sources", {}).get("plex", {}).get(server_ref)
        if not server:
            print(f"Plex server '{server_ref}' not in config.", file=sys.stderr)
            print(f"Add with: voxtract sources add plex --name {server_ref} --url http://{server_ref}:32400 --token TOKEN", file=sys.stderr)
            sys.exit(1)
        return server

    def _api_call(self, server: dict, path: str, params: dict = None) -> dict:
        import requests
        url = f"{server['url']}{path}"
        p = params or {}
        p["X-Plex-Token"] = server["token"]
        headers = {"Accept": "application/json"}
        r = requests.get(url, params=p, headers=headers, timeout=30)
        if r.status_code == 401:
            print("Plex authentication failed. Check your token.", file=sys.stderr)
            sys.exit(1)
        if r.status_code != 200:
            print(f"Plex API error {r.status_code}: {r.text[:200]}", file=sys.stderr)
            sys.exit(1)
        return r.json()

    def can_handle(self, uri: str) -> bool:
        return uri.startswith("plex://")

    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        # URI: plex://SERVER/metadata/RATING_KEY
        parsed = urlparse(uri)
        server_ref = parsed.hostname
        server = self._resolve_server(server_ref)

        audio_file = dest_dir / f"source.{AUDIO_FORMAT}"
        if audio_file.exists() and not force:
            return json.loads((dest_dir / "meta.json").read_text())

        path = parsed.path.strip("/")
        if not path:
            print("Plex URI must include metadata path: plex://SERVER/metadata/KEY", file=sys.stderr)
            sys.exit(1)

        metadata = self._api_call(server, f"/{path}")
        container = (metadata.get("MediaContainer") or metadata)
        medias = (container.get("Metadata") or [(metadata.get("MediaContainer") or {})])
        if isinstance(medias, list):
            item = medias[0] if medias else {}
        else:
            item = medias

        title = item.get("title", "Unknown")
        duration_ms = item.get("duration", 0)
        duration = duration_ms / 1000 if duration_ms else 0

        print(f"  Source: {title} — {format_time(duration)}")

        # Get media parts for download URL
        parts = item.get("Media", [{}])[0].get("Part", [])
        if not parts:
            print("No media parts found", file=sys.stderr)
            sys.exit(1)

        part_key = parts[0].get("key", "")
        download_url = f"{server['url']}{part_key}?download=1&X-Plex-Token={server['token']}"

        import requests
        print(f"  Downloading from Plex...")
        r = requests.get(download_url, stream=True, timeout=600)
        if r.status_code != 200:
            print(f"Download failed: HTTP {r.status_code}", file=sys.stderr)
            sys.exit(1)

        tmp_file = str(dest_dir / f"source_download")
        with open(tmp_file, 'wb') as f:
            for chunk in r.iter_content(chunk_size=8192):
                f.write(chunk)

        run(["ffmpeg", "-y", "-i", tmp_file,
             "-vn", "-acodec", "pcm_s16le", "-ar", "44100", "-ac", "2",
             str(audio_file)],
            desc="Converting Plex download to WAV")
        Path(tmp_file).unlink(missing_ok=True)

        return {"title": title, "duration": duration or probe_duration(audio_file),
                "source": uri, "server": server_ref}

    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        parsed = urlparse(uri)
        server_ref = parsed.hostname
        server = self._resolve_server(server_ref)

        # List libraries
        path = parsed.path.strip("/")
        if not path or path == "sections":
            libs = self._api_call(server, "/library/sections")
            results = []
            for d in libs.get("MediaContainer", {}).get("Directory", []):
                results.append({
                    "id": d.get("key", ""),
                    "title": d.get("title", ""),
                    "type": d.get("type", "library"),
                    "year": "",
                    "duration": 0,
                    "uri": f"plex://{server_ref}/library/sections/{d.get('key')}/all",
                })
            return results

        # Browse section or search
        if query:
            data = self._api_call(server, f"/hubs/search", {"query": query, "limit": limit})
            hubs = data.get("MediaContainer", {}).get("Hub", [])
            results = []
            for hub in hubs:
                for item in hub.get("Metadata", []):
                    dur = item.get("duration", 0) / 1000 if item.get("duration") else 0
                    results.append({
                        "id": item.get("ratingKey", ""),
                        "title": item.get("title", ""),
                        "type": item.get("type", ""),
                        "year": item.get("year", ""),
                        "duration": dur,
                        "uri": f"plex://{server_ref}/library/metadata/{item.get('ratingKey')}",
                    })
            return results
        else:
            data = self._api_call(server, f"/{path}")
            container = data.get("MediaContainer", {})
            items = container.get("Metadata", container.get("Directory", []))
            results = []
            for item in items:
                dur = item.get("duration", 0) / 1000 if item.get("duration") else 0
                if item_type and item.get("type", "").lower() != item_type.lower():
                    continue
                results.append({
                    "id": item.get("ratingKey", item.get("key", "")),
                    "title": item.get("title", ""),
                    "type": item.get("type", "unknown"),
                    "year": item.get("year", ""),
                    "duration": dur,
                    "uri": f"plex://{server_ref}/library/metadata/{item.get('ratingKey', item.get('key'))}",
                })
            return results


