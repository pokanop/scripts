        if not sources:
            print_info("Cache is empty.")
            return
        total_size = sum(
            sum(f.stat().st_size for f in d.rglob("*") if f.is_file())
            for d in sources
        )
        print(f"  {styled(f'{len(sources)} cached source(s)', _BOLD)}  •  {human_size(total_size)} total\n")
        for d in sorted(sources):
            meta = json.loads((d / "meta.json").read_text())
            sid = meta.get("id", d.name)
            title = meta.get("title", "Unknown")
            source = meta.get("source", "?")
            duration = meta.get("duration", 0)
            has_vocals = (d / "vocals.wav").exists()
            audio_size = (d / f"source.{AUDIO_FORMAT}").stat().st_size if (d / f"source.{AUDIO_FORMAT}").exists() else 0
            vocals_icon = styled(f"{icon('mic')} vocals", _GREEN) if has_vocals else styled("no vocals", _DIM)
            print(f"  {icon('folder')} {styled(sid, _BOLD)}")
            print(f"     {styled('Title:', _BOLD)}    {title}")
            print(f"     {styled('Source:', _BOLD)}   {source}")
            print(f"     {styled('Duration:', _BOLD)} {format_time(duration)}")
            print(f"     {styled('Audio:', _BOLD)}    {human_size(audio_size)}  •  {vocals_icon}")
            print()

    elif args.cache_action == "clean":
        if CACHE_DIR.exists():
            size = sum(f.stat().st_size for f in CACHE_DIR.rglob("*") if f.is_file())
            shutil.rmtree(CACHE_DIR)
            print_success(f"Cache cleaned ({human_size(size)} freed)")
        else:
            print_info("Cache is already empty.")

    elif args.cache_action == "remove":
        adapter, sid, source_dir = resolve_source(args.source)
        if source_dir.exists():
            size = sum(f.stat().st_size for f in source_dir.rglob("*") if f.is_file())
            shutil.rmtree(source_dir)
            print_success(f"Removed: {sid} ({human_size(size)} freed)")
        else:
            print_info(f"Not in cache: {sid}")

    elif args.cache_action == "info":
        adapter, sid, source_dir = resolve_source(args.source)
        meta = json.loads((source_dir / "meta.json").read_text())
        print(json.dumps(meta, indent=2))


