def cmd_fetch(args):
    """Fetch and cache audio from any source."""
    print_header(f"{icon('download')} FETCH")
    adapter = find_adapter(args.source)
    sid = adapter.get_source_key(args.source)
    source_dir = CACHE_DIR / sid
    audio_file = source_dir / f"source.{AUDIO_FORMAT}"

    if audio_file.exists() and not args.force:
        print_success(f"Already cached: {sid}")
        meta = json.loads((source_dir / "meta.json").read_text()) if (source_dir / "meta.json").exists() else {}
        print(f"    {styled('Title:', _BOLD)}    {meta.get('title', 'Unknown')}")
        print(f"    {styled('Duration:', _BOLD)} {format_time(meta.get('duration', 0))}")
        print(f"    {styled('Source:', _BOLD)}   {args.source}")
        print(f"    {styled('Size:', _BOLD)}     {human_size(audio_file.stat().st_size)}")
        return

    ensure_dirs()
    t0 = time.monotonic()
    with cache_lock(source_dir):
        source_dir.mkdir(parents=True, exist_ok=True)
        # Double-check after acquiring lock (another process may have fetched)
        if audio_file.exists() and not args.force:
            print_info("Source was fetched by another process while waiting")
        else:
            meta = adapter.fetch(args.source, source_dir, force=args.force)
            meta["id"] = sid
            meta["audio_file"] = str(audio_file)
            (source_dir / "meta.json").write_text(json.dumps(meta, indent=2))

            if "duration" not in meta or not meta["duration"]:
                meta["duration"] = probe_duration(audio_file)
                (source_dir / "meta.json").write_text(json.dumps(meta, indent=2))

    elapsed = time.monotonic() - t0
    print_success(f"Cached: {sid}")
    print(f"    {styled('Title:', _BOLD)}    {meta.get('title', 'Unknown')}")
    print(f"    {styled('Duration:', _BOLD)} {format_time(meta.get('duration', 0))}")
    print(f"    {styled('Audio:', _BOLD)}    {audio_file}")
    print(f"    {styled('Size:', _BOLD)}     {human_size(audio_file.stat().st_size)}")
    print_elapsed("Fetch time", elapsed)


def cmd_clip(args):
    """Extract a clip from a source with optimized performance.
    
    Performance strategy:
    - Uses input-side seeking (-ss before -i) for fast seeks without decoding
      the entire source file from the beginning.
    - Clips to raw PCM first (no encode overhead), then normalizes once.
    - For clips from pre-isolated vocals, skips the decode/re-encode round trip.
    - Parallel-safe: locks the source cache dir so concurrent clips from the
      same source serialize at the isolation step without data corruption.
    """
    print_header(f"{icon('clip')} CLIP")
    adapter, sid, source_dir = resolve_source(args.source)
    audio_file = source_dir / f"source.{AUDIO_FORMAT}"

    meta = json.loads((source_dir / "meta.json").read_text()) if (source_dir / "meta.json").exists() else {}
    title = meta.get("title", sid)

    # Parse timing
    start = parse_time(args.start) if args.start else 0.0
    if args.end:
        end = parse_time(args.end)
        duration = end - start
    elif args.duration:
        duration = float(args.duration)
        end = start + duration
    else:
        end = meta.get("duration", probe_duration(audio_file))
        duration = end - start

    if duration <= 0:
        print_error(f"Invalid clip duration ({duration:.1f}s)")
        sys.exit(1)

    print(f"  {styled('Source:', _BOLD)}   {title}")
    print(f"  {styled('Segment:', _BOLD)} {format_time(start)} → {format_time(end)} ({duration:.1f}s)")

    # Output path
    output_dir = Path(args.output_dir) if args.output_dir else Path.cwd()
    output_dir.mkdir(parents=True, exist_ok=True)
    out_fmt = args.format or "mp3"

    safe_title = "".join(c if c.isalnum() or c in "- _." else "_" for c in title)[:60]
    clip_name = f"{safe_title}_{format_time(start).replace(':','-')}_to_{format_time(end).replace(':','-')}"
    if args.isolate:
        clip_name += "_voice"
    clip_name += f".{out_fmt}"
    output_path = output_dir / clip_name

    # Determine clip source — isolate vocals if requested (with lock!)
    clip_source = audio_file
    if args.isolate:
        vocals_file = source_dir / "vocals.wav"
        with cache_lock(source_dir):
            # Re-check after acquiring lock — another process may have isolated
            if vocals_file.exists():
                print_info("Vocals already isolated (possibly by parallel process)")
            else:
                print_step(1, 3, f"{icon('brain')} Isolating speech with Demucs...")
                ensure_demucs_model_cached()
                cmd_isolate_source(sid, source_dir, audio_file)
        clip_source = vocals_file

    # Resolve loudness settings
    gain_db = getattr(args, 'gain', None)
    if gain_db is not None:
        gain_db = float(gain_db)
    target_lufs = getattr(args, 'lufs', None)
    if target_lufs is not None:
        target_lufs = float(target_lufs)
    lra = getattr(args, 'lra', None)
    if lra is not None:
        lra = float(lra)
    true_peak = getattr(args, 'tp', None)
    if true_peak is not None:
        true_peak = float(true_peak)

    skip_normalize = getattr(args, 'no_normalize', False)
    needs_normalize = not skip_normalize and (gain_db is not None or target_lufs is not None)

    # Format-specific ffmpeg codec args
    fmts = {
        "mp3": ["-codec:a", "libmp3lame", "-qscale:a", "2"],
        "wav": ["-acodec", "pcm_s16le", "-ar", "44100", "-ac", "2"],
        "flac": ["-acodec", "flac"],
        "ogg": ["-codec:a", "libvorbis", "-qscale:a", "5"],
        "m4a": ["-codec:a", "aac", "-b:a", "192k"],
    }
    codec_args = fmts.get(out_fmt, fmts["mp3"])

    t0 = time.monotonic()

    if skip_normalize and not needs_normalize:
        # ── Fast path: single-pass seek + encode, no normalization ──
        step_label = f"{icon('extract')} Extracting raw clip"
        print_step(2 if args.isolate else 1, 2 if args.isolate else 1, step_label)
        # Input-side seeking (-ss BEFORE -i) = fast keyframe seek, no full decode
        ffmpeg_args = ["ffmpeg", "-y", "-ss", str(start), "-t", str(duration),
                       "-i", str(clip_source)] + codec_args + [str(output_path)]
        run(ffmpeg_args, desc=f"Extracting {out_fmt} (fast seek, raw)")
    else:
        # ── Optimized path: clip + normalize in minimal passes ──
        step_num = 2 if args.isolate else 1
        total_steps = 3 if args.isolate else 2

        # Step 1: Extract clip to raw PCM temp (no encode overhead — just bytes)
        print_step(step_num, total_steps, f"{icon('extract')} Extracting clip segment...")
        tmp_raw = output_path.with_suffix(".raw.tmp.wav")
        # -ss before -i for fast seek, output raw PCM so no encoding cost
        run(["ffmpeg", "-y", "-ss", str(start), "-t", str(duration),
             "-i", str(clip_source),
             "-acodec", "pcm_s16le", "-ar", "44100", "-ac", "2",
             str(tmp_raw)],
            desc="Extracting segment (fast seek → raw PCM)")

        # Step 2: Normalize from raw temp to final output
        print_step(step_num + 1, total_steps, f"{icon('normalize')} Normalizing loudness...")
        loudnorm_audio(tmp_raw, output_path,
                       target_lufs=target_lufs, lra=lra,
                       true_peak=true_peak, gain_db=gain_db)
        tmp_raw.unlink(missing_ok=True)

    elapsed = time.monotonic() - t0

    file_size = output_path.stat().st_size
    print_success(f"Clip saved: {output_path}")
    print(f"    {styled('Source:', _BOLD)}    {title}")
    print(f"    {styled('Segment:', _BOLD)}  {format_time(start)} → {format_time(end)}")
    print(f"    {styled('Isolated:', _BOLD)} {'Yes' if args.isolate else 'No'}")
    print(f"    {styled('Format:', _BOLD)}   {out_fmt}")
    print(f"    {styled('Size:', _BOLD)}     {human_size(file_size)}")
    print_elapsed("Extraction time", elapsed)


