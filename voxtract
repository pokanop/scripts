# We need the REAL user home for a shared model cache.
def _resolve_real_home() -> Path:
    """Find the actual user home, stripping Hermes profile overrides."""
    h = Path(os.environ.get("HOME", "/root")).resolve()
    # Walk up: /root/.hermes/profiles/coder/home → /root
    parts = h.parts
    if ".hermes" in parts:
        idx = parts.index(".hermes")
        return Path(*parts[:idx]) if idx > 0 else Path("/")
    return h

