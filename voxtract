# ---------------------------------------------------------------------------
# File Locking for Parallel Safety
# ---------------------------------------------------------------------------

@contextmanager
def cache_lock(cache_dir: Path, timeout: float = 300):
    """Acquire exclusive lock on a cache directory for parallel safety.

    Prevents concurrent voxtract processes from corrupting shared cache
    files (vocals.wav, meta.json) when clipping from the same source.
    Parallel clips from DIFFERENT sources use different lock files and
    never block each other.
    """
    cache_dir.mkdir(parents=True, exist_ok=True)
    lock_path = cache_dir / ".lock"
    lock_fd = open(lock_path, "w")
    acquired = False
    try:
        deadline = time.monotonic() + timeout
        while not acquired:
            try:
                fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
                acquired = True
            except (IOError, OSError):
                if time.monotonic() >= deadline:
                    print_error(f"Lock timeout after {timeout:.0f}s — another voxtract process holds {lock_path}")
                    sys.exit(1)
                wait = min(2.0, deadline - time.monotonic())
                if wait > 0:
                    print_info(f"Waiting for lock on {cache_dir.name}...")
                    time.sleep(0.5)
        lock_fd.write(f"{os.getpid()}\n{time.time()}\n")
        lock_fd.flush()
        yield
    finally:
        if acquired:
            try:
                fcntl.flock(lock_fd, fcntl.LOCK_UN)
            except (IOError, OSError):
                pass
        lock_fd.close()

