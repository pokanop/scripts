class HTTPAdapter(SourceAdapter):
    scheme = "http"

    def __init__(self):
        self._yt = YouTubeAdapter()

    def can_handle(self, uri: str) -> bool:
        if uri.startswith(("http://", "https://")):
            # Check if it's a known media site that yt-dlp handles
            if any(domain in uri for domain in
                   ["youtube.com", "youtu.be", "vimeo.com", "dailymotion.com",
                    "soundcloud.com", "bandcamp.com", "twitch.tv", "rumble.com",
                    "bitchute.com", "odysee.com", "nicovideo.jp", "bilibili.com"]):
                return False  # Let YouTubeAdapter handle these
            return True
        return False

    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        audio_file = dest_dir / f"source.{AUDIO_FORMAT}"
        if audio_file.exists() and not force:
            return json.loads((dest_dir / "meta.json").read_text())

        import requests
        print(f"  Downloading: {uri}")
        r = requests.get(uri, stream=True, timeout=600, allow_redirects=True,
                         headers={"User-Agent": "voxtract/2.0"})
        if r.status_code != 200:
            print(f"HTTP download failed: {r.status_code}", file=sys.stderr)
            sys.exit(1)

        tmp_file = str(dest_dir / "source_download")
        total = int(r.headers.get("content-length", 0))
        downloaded = 0
        with open(tmp_file, 'wb') as f:
            for chunk in r.iter_content(chunk_size=65536):
                f.write(chunk)
                downloaded += len(chunk)
                if total:
                    pct = downloaded * 100 // total
                    print(f"\r  Progress: {pct}%", end="", flush=True)
        print()

        # Convert to WAV (strip video if present)
        run(["ffmpeg", "-y", "-i", tmp_file,
             "-vn", "-acodec", "pcm_s16le", "-ar", "44100", "-ac", "2",
             str(audio_file)],
            desc="Converting to WAV")
        Path(tmp_file).unlink(missing_ok=True)

        # Try to get a filename from URL or Content-Disposition
        title = uri.rstrip("/").split("/")[-1].split("?")[0] or "download"
        cd = r.headers.get("Content-Disposition", "")
        if cd and "filename=" in cd:
            title = cd.split("filename=")[-1].strip('"')

        return {"title": title, "duration": probe_duration(audio_file),
                "source": uri}

    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        return []  # HTTP adapter doesn't browse


