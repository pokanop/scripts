class PodcastAdapter(SourceAdapter):
    scheme = "podcast"

    def _parse_feed(self, feed_url: str) -> list[dict]:
        """Parse an RSS feed and return episode list."""
        import requests
        import xml.etree.ElementTree as ET

        r = requests.get(feed_url, timeout=30,
                         headers={"User-Agent": "voxtract/2.0"})
        if r.status_code != 200:
            print(f"RSS feed fetch failed: {r.status_code}", file=sys.stderr)
            return []

        try:
            root = ET.fromstring(r.content)
        except ET.ParseError as e:
            print(f"RSS parse error: {e}", file=sys.stderr)
            return []

        # Handle both RSS 2.0 and Atom
        ns = {"itunes": "http://www.itunes.com/dtds/podcast-1.0.dtd",
              "atom": "http://www.w3.org/2005/Atom",
              "content": "http://purl.org/rss/1.0/modules/content/"}

        results = []
        # Try RSS items first
        for item in root.findall(".//item"):
            title = item.findtext("title", "Untitled")
            enclosure = item.find("enclosure")
            audio_url = enclosure.get("url") if enclosure is not None else ""

            if not audio_url:
                # Try media:content
                media_ns = {"media": "http://search.yahoo.com/mrss/"}
                media_el = item.find("media:content", media_ns)
                if media_el is not None:
                    audio_url = media_el.get("url", "")

            if audio_url:
                results.append({
                    "id": cache_id(audio_url),
                    "title": title,
                    "type": "podcast_episode",
                    "year": item.findtext("pubDate", "")[-4:] if item.findtext("pubDate") else "",
                    "duration": 0,
                    "uri": f"http://{audio_url}" if not audio_url.startswith("http") else audio_url,
                    "feed_url": feed_url,
                })

        # Try Atom entries
        for entry in root.findall("{http://www.w3.org/2005/Atom}entry"):
            title = entry.findtext("{http://www.w3.org/2005/Atom}title", "Untitled")
            for link in entry.findall("{http://www.w3.org/2005/Atom}link"):
                rel = link.get("rel", "alternate")
                href = link.get("href", "")
                if "audio" in rel or "enclosure" in rel:
                    results.append({
                        "id": cache_id(href),
                        "title": title,
                        "type": "podcast_episode",
                        "year": "",
                        "duration": 0,
                        "uri": href if href.startswith("http") else f"http://{href}",
                        "feed_url": feed_url,
                    })

        return results

    def can_handle(self, uri: str) -> bool:
        return uri.startswith("podcast://")

    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        # URI: podcast://FEED_URL  or  podcast://FEED_URL#ep-N (fragment = index)
        # or:   podcast://FEED_URL#episode_audio_url
        actual_uri = uri.replace("podcast://", "")
        fragment = ""
        if "#" in actual_uri:
            actual_uri, fragment = actual_uri.split("#", 1)

        episodes = self._parse_feed(actual_uri)

        if fragment:
            if fragment.startswith("ep-"):
                idx = int(fragment.split("-")[1])
                if 0 <= idx < len(episodes):
                    ep_uri = episodes[idx]["uri"]
                else:
                    print(f"Episode index {idx} out of range (0-{len(episodes)-1})", file=sys.stderr)
                    sys.exit(1)
            else:
                ep_uri = fragment
            http_adapter = HTTPAdapter()
            return http_adapter.fetch(ep_uri, dest_dir, force)
        else:
            # Fetch latest episode
            if episodes:
                ep_uri = episodes[0]["uri"]
                http_adapter = HTTPAdapter()
                result = http_adapter.fetch(ep_uri, dest_dir, force)
                result["source"] = uri
                result["feed_url"] = actual_uri
                return result
            print("No episodes found in feed", file=sys.stderr)
            sys.exit(1)

    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        feed_url = uri.replace("podcast://", "")
        all_episodes = self._parse_feed(feed_url)

        if query:
            all_episodes = [e for e in all_episodes
                           if query.lower() in e["title"].lower()]

        return all_episodes[:limit]


# ---------------------------------------------------------------------------
# Spotify Adapter
# ---------------------------------------------------------------------------

class SpotifyAdapter(SourceAdapter):
    """Spotify source adapter using spotipy for metadata and spotdl for audio download.

    URI scheme:
        spotify://track/ID             - Fetch a music track (via spotdl → YouTube match)
        spotify://album/ID             - List album tracks
        spotify://playlist/ID          - List playlist tracks
        spotify://show/ID              - List podcast show episodes
        spotify://episode/ID           - Fetch a podcast episode (via YouTube search fallback)
        spotify://artist/ID            - List artist top tracks
        spotify://search               - Search (use -q query)

    Configuration (via `voxtract sources add spotify`):
        client_id, client_secret  — Spotify Web API credentials
    """

    scheme = "spotify"

    # -- Config / Auth -------------------------------------------------------

    def _get_creds(self) -> dict:
        """Load Spotify credentials from config."""
        cfg = load_config()
        creds = cfg.get("sources", {}).get("spotify", {}).get("default")
        if not creds or not creds.get("client_id"):
            print("Spotify not configured. Run:", file=sys.stderr)
            print("  voxtract sources add spotify --id CLIENT_ID --secret CLIENT_SECRET", file=sys.stderr)
            print("  Get credentials at: https://developer.spotify.com/dashboard", file=sys.stderr)
            sys.exit(1)
        return creds

    def _get_spotify_client(self):
        """Return an authenticated spotipy.Spotify client."""
        import spotipy
        from spotipy.oauth2 import SpotifyClientCredentials
        creds = self._get_creds()
        auth = SpotifyClientCredentials(
            client_id=creds["client_id"],
            client_secret=creds["client_secret"],
        )
        return spotipy.Spotify(auth_manager=auth)

    def _get_spotdl(self):
        """Return a spotdl.Spotdl instance for downloading."""
        from spotdl import Spotdl
        creds = self._get_creds()
        return Spotdl(
            client_id=creds["client_id"],
            client_secret=creds["client_secret"],
            downloader_settings={
                "format": "mp3",
                "output": "source",
            },
        )

    # -- Adapter Protocol ----------------------------------------------------

    def can_handle(self, uri: str) -> bool:
        return uri.startswith("spotify://")

    def get_source_key(self, uri: str) -> str:
        # Use the Spotify URI directly as the key basis
        return cache_id(uri)

    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        audio_file = dest_dir / f"source.{AUDIO_FORMAT}"
        if audio_file.exists() and not force:
            return json.loads((dest_dir / "meta.json").read_text())

        # Parse URI: spotify://type/id
        parsed = urlparse(uri)
        path = parsed.path.strip("/")
        if not path:
            print("Spotify URI requires a path: spotify://track/ID, spotify://album/ID, etc.", file=sys.stderr)
            sys.exit(1)

        parts = path.split("/", 1)
        sp_type = parts[0]  # track, album, episode, etc.
        sp_id = parts[1] if len(parts) > 1 else ""

        sp = self._get_spotify_client()

        if sp_type == "track":
            return self._fetch_track(sp, sp_id, dest_dir, uri)
        elif sp_type == "episode":
            return self._fetch_episode(sp, sp_id, dest_dir, uri)
        elif sp_type == "album":
            # Fetch first track of the album as convenience
            tracks = sp.album_tracks(sp_id, limit=1)
            if tracks["items"]:
                return self._fetch_track(sp, tracks["items"][0]["id"], dest_dir, uri)
            print("Album has no tracks", file=sys.stderr)
            sys.exit(1)
        elif sp_type == "playlist":
            results = sp.playlist_items(sp_id, limit=1)
            items = results.get("items", [])
            if items and items[0].get("track"):
                return self._fetch_track(sp, items[0]["track"]["id"], dest_dir, uri)
            print("Playlist is empty", file=sys.stderr)
            sys.exit(1)
        else:
            print(f"Cannot fetch Spotify type '{sp_type}'. Supported: track, album, playlist, episode", file=sys.stderr)
            sys.exit(1)

    def _fetch_track(self, sp, track_id: str, dest_dir: Path, uri: str) -> dict:
        """Fetch a Spotify music track via spotdl (matches to YouTube)."""
        # Get metadata first
        track = sp.track(track_id)
        artists = ", ".join(a["name"] for a in track["artists"])
        title = f"{artists} - {track['name']}"
        duration_s = track["duration_ms"] / 1000

        print(f"  Track: {title}")
        print(f"  Duration: {format_time(duration_s)}")
        print(f"  Album: {track['album']['name']}")

        # Use spotdl to download (it matches to YouTube internally)
        print(f"  Matching to YouTube via spotdl...")
        try:
            sdl = self._get_spotdl()
            songs = sdl.search([f"https://open.spotify.com/track/{track_id}"])
            if songs:
                song, path = sdl.download(songs[0])
                if path and Path(path).exists():
                    # Convert spotdl output to our standard WAV
                    audio_file = dest_dir / f"source.{AUDIO_FORMAT}"
                    run(["ffmpeg", "-y", "-i", str(path),
                         "-vn", "-acodec", "pcm_s16le", "-ar", "44100", "-ac", "2",
                         str(audio_file)],
                        desc="Converting to WAV")
                    Path(path).unlink(missing_ok=True)
                    return {"title": title, "duration": duration_s, "source": uri,
                            "spotify_id": track_id, "type": "track"}
        except Exception as e:
            print(f"  spotdl failed: {e}", file=sys.stderr)

        # Fallback: search YouTube directly using the track info
        print(f"  Fallback: searching YouTube for '{title}'...")
        yt_query = title
        tmp = tempfile.mkdtemp()
        try:
            tmp_audio = os.path.join(tmp, "source.%(ext)s")
            dl = subprocess.run(
                ["yt-dlp", "-x", "--audio-format", AUDIO_FORMAT,
                 "--audio-quality", "0", "-o", tmp_audio,
                 f"ytsearch1:{yt_query}"],
                capture_output=True, text=True
            )
            downloaded = list(Path(tmp).glob("source.*"))
            if downloaded:
                audio_file = dest_dir / f"source.{AUDIO_FORMAT}"
                shutil.move(str(downloaded[0]), str(audio_file))
                return {"title": title, "duration": duration_s, "source": uri,
                        "spotify_id": track_id, "type": "track"}
        finally:
            shutil.rmtree(tmp, ignore_errors=True)

        print("Failed to download track", file=sys.stderr)
        sys.exit(1)

    def _fetch_episode(self, sp, episode_id: str, dest_dir: Path, uri: str) -> dict:
        """Fetch a Spotify podcast episode.

        spotdl doesn't support episodes, so we get metadata from Spotify
        and search YouTube for the audio.
        """
        ep = sp.episode(episode_id)
        show_name = ep.get("show", {}).get("name", "")
        title = f"{show_name} - {ep['name']}" if show_name else ep["name"]
        duration_s = ep["duration_ms"] / 1000

        print(f"  Episode: {title}")
        print(f"  Show: {show_name}")
        print(f"  Duration: {format_time(duration_s)}")
        print(f"  Released: {ep.get('release_date', 'unknown')}")

        # Search YouTube for the episode audio
        search_query = title
        description = ep.get("description", "")[:200]
        print(f"  Searching YouTube for episode audio...")

        tmp = tempfile.mkdtemp()
        try:
            tmp_audio = os.path.join(tmp, "source.%(ext)s")
            subprocess.run(
                ["yt-dlp", "-x", "--audio-format", AUDIO_FORMAT,
                 "--audio-quality", "0", "-o", tmp_audio,
                 f"ytsearch3:{search_query}"],
                capture_output=True, text=True, timeout=120,
            )
            downloaded = list(Path(tmp).glob("source.*"))
            if downloaded:
                audio_file = dest_dir / f"source.{AUDIO_FORMAT}"
                shutil.move(str(downloaded[0]), str(audio_file))
                return {"title": title, "duration": duration_s, "source": uri,
                        "spotify_id": episode_id, "type": "episode",
                        "show": show_name, "description": description}
        finally:
            shutil.rmtree(tmp, ignore_errors=True)

        print("Could not find episode audio on YouTube", file=sys.stderr)
        sys.exit(1)

    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        sp = self._get_spotify_client()
        parsed = urlparse(uri)
        path = parsed.path.strip("/")

        if not path or path == "search":
            return self._search(sp, query, item_type or "track", limit)

        parts = path.split("/", 1)
        sp_type = parts[0]
        sp_id = parts[1] if len(parts) > 1 else ""

        if sp_type == "album" and sp_id:
            return self._list_album(sp, sp_id, limit)
        elif sp_type == "playlist" and sp_id:
            return self._list_playlist(sp, sp_id, limit)
        elif sp_type == "show" and sp_id:
            return self._list_show(sp, sp_id, limit)
        elif sp_type == "artist" and sp_id:
            return self._list_artist(sp, sp_id, limit)
        else:
            return self._search(sp, query, item_type or "track", limit)

    def _search(self, sp, query: str, item_type: str, limit: int) -> list[dict]:
        """Search Spotify."""
        if not query:
            print("Provide a search query with -q", file=sys.stderr)
            return []

        # Map voxtract types to Spotify types
        type_map = {
            "track": "track", "audio": "track",
            "album": "album",
            "show": "show", "series": "show",
            "episode": "episode",
            "artist": "artist",
            "movie": "track",  # no movie type on Spotify
        }
        sp_type = type_map.get(item_type, "track")

        try:
            results = sp.search(q=query, type=sp_type, limit=limit)
        except Exception as e:
            print(f"Spotify search failed: {e}", file=sys.stderr)
            return []

        results_key = f"{sp_type}s"
        items = results.get(results_key, {}).get("items", [])
        output = []

        for item in items:
            if sp_type == "track":
                artists = ", ".join(a["name"] for a in item["artists"])
                dur = item["duration_ms"] / 1000
                output.append({
                    "id": item["id"],
                    "title": f"{artists} - {item['name']}",
                    "type": "track",
                    "year": item.get("album", {}).get("release_date", "")[:4],
                    "duration": dur,
                    "uri": f"spotify://track/{item['id']}",
                })
            elif sp_type == "album":
                output.append({
                    "id": item["id"],
                    "title": f"{', '.join(a['name'] for a in item['artists'])} - {item['name']}",
                    "type": "album",
                    "year": item.get("release_date", "")[:4],
                    "duration": 0,
                    "uri": f"spotify://album/{item['id']}",
                })
            elif sp_type == "show":
                output.append({
                    "id": item["id"],
                    "title": item["name"],
                    "type": "show",
                    "year": "",
                    "duration": 0,
                    "uri": f"spotify://show/{item['id']}",
                })
            elif sp_type == "episode":
                dur = item["duration_ms"] / 1000
                output.append({
                    "id": item["id"],
                    "title": item["name"],
                    "type": "episode",
                    "year": item.get("release_date", "")[:4],
                    "duration": dur,
                    "uri": f"spotify://episode/{item['id']}",
                })
            elif sp_type == "artist":
                output.append({
                    "id": item["id"],
                    "title": item["name"],
                    "type": "artist",
                    "year": "",
                    "duration": 0,
                    "uri": f"spotify://artist/{item['id']}",
                })

        return output

    def _list_album(self, sp, album_id: str, limit: int) -> list[dict]:
        results = sp.album_tracks(album_id, limit=limit)
        album = sp.album(album_id)
        album_name = album["name"]
        album_artist = ", ".join(a["name"] for a in album["artists"])
        output = []
        for i, t in enumerate(results["items"]):
            artists = ", ".join(a["name"] for a in t["artists"])
            dur = t["duration_ms"] / 1000
            output.append({
                "id": t["id"],
                "title": f"{artists} - {t['name']}",
                "type": "track",
                "year": album.get("release_date", "")[:4],
                "duration": dur,
                "uri": f"spotify://track/{t['id']}",
            })
        print(f"  Album: {album_artist} - {album_name} ({len(results['items'])} tracks)")
        return output

    def _list_playlist(self, sp, playlist_id: str, limit: int) -> list[dict]:
        results = sp.playlist_items(playlist_id, limit=limit)
        pl_name = sp.playlist(playlist_id, fields="name")["name"]
        output = []
        for item in results["items"]:
            track = item.get("track")
            if not track:
                continue
            artists = ", ".join(a["name"] for a in track["artists"])
            dur = track["duration_ms"] / 1000
            output.append({
                "id": track["id"],
                "title": f"{artists} - {track['name']}",
                "type": "track",
                "year": track.get("album", {}).get("release_date", "")[:4],
                "duration": dur,
                "uri": f"spotify://track/{track['id']}",
            })
        print(f"  Playlist: {pl_name}")
        return output

    def _list_show(self, sp, show_id: str, limit: int) -> list[dict]:
        results = sp.show_episodes(show_id, limit=limit)
        show = sp.show(show_id)
        output = []
        for ep in results["items"]:
            dur = ep["duration_ms"] / 1000
            output.append({
                "id": ep["id"],
                "title": ep["name"],
                "type": "episode",
                "year": ep.get("release_date", "")[:4],
                "duration": dur,
                "uri": f"spotify://episode/{ep['id']}",
            })
        print(f"  Show: {show['name']} ({len(results['items'])} episodes)")
        return output

    def _list_artist(self, sp, artist_id: str, limit: int) -> list[dict]:
        results = sp.artist_top_tracks(artist_id)
        artist = sp.artist(artist_id)
        output = []
        for t in results["tracks"][:limit]:
            dur = t["duration_ms"] / 1000
            output.append({
                "id": t["id"],
                "title": t["name"],
                "type": "track",
                "year": t.get("album", {}).get("release_date", "")[:4],
                "duration": dur,
                "uri": f"spotify://track/{t['id']}",
            })
        print(f"  Artist: {artist['name']} (top tracks)")
        return output


# ---------------------------------------------------------------------------
# Adapter Registry
# ---------------------------------------------------------------------------

ADAPTERS: list[SourceAdapter] = [
    SpotifyAdapter(),
    JellyfinAdapter(),
    PlexAdapter(),
    PodcastAdapter(),
    DirAdapter(),
    YouTubeAdapter(),
    HTTPAdapter(),
    LocalFileAdapter(),
]


def find_adapter(uri: str) -> SourceAdapter:
    for a in ADAPTERS:
        if a.can_handle(uri):
            return a
    # Last resort: test if local path
    p = Path(uri)
    if p.exists():
        return LocalFileAdapter()
    # Try YouTube as catch-all
    yt = YouTubeAdapter()
    if yt.can_handle(uri):
        return yt
    print(f"Cannot handle source: {uri}", file=sys.stderr)
    print("Supported: youtube://, jellyfin://, plex://, podcast://, http(s)://, file://, dir://", file=sys.stderr)
    sys.exit(1)


def resolve_source(uri: str, force_fetch: bool = False) -> tuple[SourceAdapter, str, Path]:
    """Resolve a URI to an adapter + cache_id + cache_dir. Fetch if not cached.
    
    Uses file locking for parallel safety — concurrent clips from the same
    source will serialize at the fetch/isolation step without corrupting cache.
    """
    adapter = find_adapter(uri)
    sid = adapter.get_source_key(uri)
    source_dir = CACHE_DIR / sid
    audio_file = source_dir / f"source.{AUDIO_FORMAT}"

    with cache_lock(source_dir):
        if not audio_file.exists() or force_fetch:
            source_dir.mkdir(parents=True, exist_ok=True)
            meta = adapter.fetch(uri, source_dir, force=force_fetch)
            meta["id"] = sid
            meta["audio_file"] = str(audio_file)
            meta_path = source_dir / "meta.json"
            meta_path.write_text(json.dumps(meta, indent=2))
            return adapter, sid, source_dir

    return adapter, sid, source_dir


