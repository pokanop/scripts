def ensure_dirs():
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)


def load_config() -> dict:
    ensure_dirs()
    if CONFIG_FILE.exists():
        return json.loads(CONFIG_FILE.read_text())
    return {"sources": {}}


def save_config(cfg: dict):
    ensure_dirs()
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))


def parse_time(t: str) -> float:
    if ":" not in t:
        return float(t)
    parts = t.split(":")
    if len(parts) == 2:   return float(parts[0]) * 60 + float(parts[1])
    if len(parts) == 3:  return float(parts[0]) * 3600 + float(parts[1]) * 60 + float(parts[2])
    raise ValueError(f"Invalid time: {t}")


def format_time(seconds: float) -> str:
    h, m, s = int(seconds // 3600), int((seconds % 3600) // 60), seconds % 60
    if h: return f"{h}:{m:02d}:{s:05.2f}"
    return f"{m}:{s:05.2f}"


def cache_id(key: str) -> str:
    return hashlib.sha256(key.encode()).hexdigest()[:16]


def run(cmd: list[str], desc: str = ""):
    if desc: print(f"  {desc}...")
    if VERBOSE:
        print(styled(f"    $ {' '.join(str(c) for c in cmd)}", _DIM))
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        print_error(f"Command failed: {' '.join(str(c) for c in cmd)}")
        if r.stderr: print(styled(r.stderr.strip(), _RED), file=sys.stderr)
        sys.exit(1)
    return r


def probe_duration(audio_path: Path) -> float:
    out = run(["ffprobe", "-v", "quiet", "-show_entries", "format=duration",
               "-of", "csv=p=0", str(audio_path)]).stdout.strip()
    return float(out)


def probe_loudness(audio_path: Path) -> dict:
    """Analyze audio loudness stats via ffmpeg loudnorm single-pass (dry run)."""
    r = subprocess.run(
        ["ffmpeg", "-i", str(audio_path),
         "-af", f"loudnorm=I={LOUDNESS_TARGET}:LRA={LOUDNESS_RANGE}:TP={LOUDNESS_PEAK}:print_format=json",
         "-f", "null", "-"],
        capture_output=True, text=True
    )
    # loudnorm prints JSON stats to stderr
    stderr = r.stderr
    json_start = stderr.rfind("{")
    json_end = stderr.rfind("}") + 1
    if json_start >= 0 and json_end > json_start:
        try:
            return json.loads(stderr[json_start:json_end])
        except json.JSONDecodeError:
            pass
    return {}


def loudnorm_audio(input_path: Path, output_path: Path, target_lufs: float = None,
                   lra: float = None, true_peak: float = None, gain_db: float = None):
    """Two-pass EBU R128 loudness normalization — broadcast-quality, no distortion.

    Pass 1: Analyze the audio's loudness characteristics.
    Pass 2: Apply precise linear normalization using measured values.

    This is the standard broadcast normalization pipeline used by Netflix, BBC, etc.
    It guarantees perceptually consistent volume without clipping or dynamic compression.

    Args:
        input_path:  Source audio file
        output_path: Destination file (format detected from extension)
        target_lufs: Target integrated loudness in LUFS (default: -16)
                     -24 = podcast standard (AES recommended)
                     -16 = loud, clear voice (YouTube/Spotify typical)
                     -14 = very loud, punchy
                     -23 = EBU R128 broadcast standard
        lra:         Maximum Loudness Range in LU (default: 11)
                     Lower = more compressed/dynamic range reduced
                     Higher = more dynamic, quiet parts stay quiet
        true_peak:   Maximum true peak in dBTP (default: -1.5)
                     -1.0 to -2.0 is safe; prevents inter-sample clipping
        gain_db:     Simple gain boost in dB (bypasses loudnorm if set)
                     Positive = louder, Negative = quieter
    """
    t_lufs = target_lufs if target_lufs is not None else LOUDNESS_TARGET
    t_lra = lra if lra is not None else LOUDNESS_RANGE
    t_peak = true_peak if true_peak is not None else LOUDNESS_PEAK

    if gain_db is not None:
        # Simple linear gain — bypass loudnorm entirely
        print(f"  {icon('speaker')} Applying gain: {gain_db:+.1f} dB")
        run(["ffmpeg", "-y", "-i", str(input_path),
             "-af", f"volume={gain_db}dB",
             str(output_path)],
            desc="Applying gain")
        return

    # ---- Pass 1: Measure ----
    print(f"  {icon('normalize')} Loudnorm pass 1: measuring loudness (target: {t_lufs} LUFS)...")
    stats = probe_loudness(input_path)

    if not stats:
        # Fallback: single-pass normalization (less precise but still works)
        print_warning("Could not measure loudness — using single-pass fallback")
        run(["ffmpeg", "-y", "-i", str(input_path),
             "-af", f"loudnorm=I={t_lufs}:LRA={t_lra}:TP={t_peak}",
             str(output_path)],
            desc="Normalizing (single-pass)")
        return

    measured_i = float(stats.get("input_i", t_lufs))
    measured_lra = float(stats.get("input_lra", t_lra))
    measured_tp = float(stats.get("input_tp", t_peak))
    measured_thresh = float(stats.get("input_thresh", -70))
    offset = float(stats.get("target_offset", 0))

    delta = t_lufs - measured_i
    print(f"  {icon('normalize')} Measured: {measured_i:.1f} LUFS → target: {t_lufs} LUFS (Δ {delta:+.1f} dB)")
    print(f"     Range: {measured_lra:.1f} LU | Peak: {measured_tp:.1f} dBTP")

    # ---- Pass 2: Apply with measured values for precision ----
    linear_filter = (
        f"loudnorm=I={t_lufs}:LRA={t_lra}:TP={t_peak}"
        f":measured_I={measured_i}:measured_LRA={measured_lra}"
        f":measured_TP={measured_tp}:measured_thresh={measured_thresh}"
        f":offset={offset}:linear=true"
    )
    run(["ffmpeg", "-y", "-i", str(input_path),
         "-af", linear_filter,
         str(output_path)],
        desc="Normalizing (two-pass precision)")

    # Verify
    final_stats = probe_loudness(output_path)
    if final_stats:
        final_i = float(final_stats.get("output_i", 0))
        final_tp = float(final_stats.get("output_tp", 0))
        print(f"  {icon('check')} Result: {final_i:.1f} LUFS | Peak: {final_tp:.1f} dBTP")


# ---------------------------------------------------------------------------
# Source Adapter Protocol
# ---------------------------------------------------------------------------

class SourceAdapter(ABC):
    """Base for all media source adapters."""
    scheme: str = ""           # e.g. "jellyfin", "youtube", "file"
    scheme_prefix: str = ""    # e.g. "jellyfin" → voxtract parses "jellyfin://"

    @abstractmethod
    def can_handle(self, uri: str) -> bool:
        """Does this adapter handle this URI?"""
        ...

    @abstractmethod
    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        """Download/import audio to dest_dir. Returns metadata dict."""
        ...

    @abstractmethod
    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        """Search/browse items. Returns list of {id, title, type, year, duration}."""
        ...

    def get_source_key(self, uri: str) -> str:
        """Stable cache key for the source."""
        return cache_id(uri)


# ---------------------------------------------------------------------------
# YouTube / yt-dlp Adapter
# ---------------------------------------------------------------------------

class YouTubeAdapter(SourceAdapter):
    scheme = "youtube"

    def can_handle(self, uri: str) -> bool:
        # Normalize: youtube://VIDEOID or full youtube.com/watch?v=ID or youtu.be/ID
        if uri.startswith("youtube://"): return True
        if uri.startswith(("http://", "https://")):
            if not uri.startswith(("jellyfin://", "plex://", "podcast://", "file://", "dir://")):
                # Assume any HTTP URL without a known scheme prefix could be yt-dlp compatible
                return True
        return False

    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        url = uri
        if uri.startswith("youtube://"):
            video_id = uri.replace("youtube://", "")
            url = f"https://www.youtube.com/watch?v={video_id}"

        audio_file = dest_dir / f"source.{AUDIO_FORMAT}"
        if audio_file.exists() and not force:
            title = json.loads((dest_dir / "meta.json").read_text()).get("title", "")
            return {"title": title, "duration": probe_duration(audio_file)}

        print(f"  Downloading audio with yt-dlp: {url}")
        tmp = tempfile.mkdtemp()
        try:
            tmp_audio = os.path.join(tmp, "source.%(ext)s")
            run(["yt-dlp", "-x", "--audio-format", AUDIO_FORMAT,
                 "--audio-quality", "0", "-o", tmp_audio, url],
                desc="yt-dlp download")
            downloaded = list(Path(tmp).glob("source.*"))
            if not downloaded:
                print("Error: yt-dlp produced no audio", file=sys.stderr)
                sys.exit(1)
            shutil.move(str(downloaded[0]), str(audio_file))
        finally:
            shutil.rmtree(tmp, ignore_errors=True)

        title = run(["yt-dlp", "--get-title", url]).stdout.strip()
        return {"title": title, "duration": probe_duration(audio_file), "source": uri}

    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        args = ["yt-dlp", f"ytsearch{limit}:{query}", "--dump-json", "--flat-playlist"]
        r = subprocess.run(args, capture_output=True, text=True)
        if r.returncode != 0:
            print(f"Search failed: {r.stderr}", file=sys.stderr)
            return []
        results = []
        for line in r.stdout.strip().split("\n"):
            if line:
                data = json.loads(line)
                results.append({
                    "id": data.get("id", ""),
                    "title": data.get("title", ""),
                    "type": "video",
                    "year": data.get("upload_date", "")[:4] if data.get("upload_date") else "",
                    "duration": data.get("duration", 0),
                    "uri": f"youtube://{data.get('id', '')}",
                })
        return results


# ---------------------------------------------------------------------------
# Jellyfin Adapter
# ---------------------------------------------------------------------------

class JellyfinAdapter(SourceAdapter):
    scheme = "jellyfin"

    def _resolve_server(self, server_ref: str) -> dict:
        """Look up a named server from config."""
        cfg = load_config()
        server = cfg.get("sources", {}).get("jellyfin", {}).get(server_ref)
        if not server:
            # Try as hostname directly
            if "." in server_ref or server_ref == "localhost":
                print(f"Server '{server_ref}' not in config. Add it with: voxtract sources add jellyfin --name {server_ref} --url http://{server_ref}:8096 --key KEY")
                sys.exit(1)
            print(f"Jellyfin server '{server_ref}' not found in config.", file=sys.stderr)
            sys.exit(1)
        return server

    def _api_call(self, server: dict, path: str, params: dict = None,
                   method: str = "GET", body: dict = None) -> dict | list:
        """Make an authenticated Jellyfin API call."""
        import requests
        url = f"{server['url']}{path}"
        headers = {
            "Authorization": f'MediaBrowser Client="voxtract", Device="Linux", DeviceId="voxtract-1", Version="1.0", Token="{server["token"]}"',
        }
        if method == "GET":
            r = requests.get(url, params=params, headers=headers, timeout=30)
        elif method == "POST":
            r = requests.post(url, json=body, params=params, headers=headers, timeout=30)
        else:
            r = requests.request(method, url, json=body, params=params, headers=headers, timeout=30)

        if r.status_code == 401:
            print("Jellyfin authentication failed. Check your API key/token.", file=sys.stderr)
            print("Update with: voxtract sources update jellyfin --key NEW_KEY", file=sys.stderr)
            sys.exit(1)
        if r.status_code != 200:
            print(f"Jellyfin API error {r.status_code}: {r.text[:200]}", file=sys.stderr)
            sys.exit(1)
        return r.json()

    def _authenticate(self, url: str, username: str = None, password: str = None,
                       api_key: str = None) -> dict:
        """Authenticate with Jellyfin, return {url, token, user_id}."""
        import requests

        url = url.rstrip("/")
        headers = {
            "Authorization": 'MediaBrowser Client="voxtract", Device="Linux", DeviceId="voxtract-1", Version="1.0"',
        }

        if api_key:
            # Test the API key
            test_headers = headers.copy()
            test_headers["Authorization"] = f'MediaBrowser Token="{api_key}"'
            r = requests.get(f"{url}/System/Info/Public", headers=test_headers, timeout=10)
            if r.status_code == 200:
                # Get user info
                r2 = requests.get(f"{url}/Users", headers=test_headers, timeout=10)
                users = r2.json() if r2.status_code == 200 else [{"Id": "me"}]
                return {"url": url, "token": api_key, "user_id": users[0]["Id"]}
            print(f"API key test failed: {r.status_code}", file=sys.stderr)
            sys.exit(1)

        elif username and password:
            body = {"Username": username, "Pw": password}
            r = requests.post(f"{url}/Users/AuthenticateByName", headers=headers,
                              json=body, timeout=10)
            if r.status_code != 200:
                print(f"Jellyfin login failed: {r.status_code}", file=sys.stderr)
                sys.exit(1)
            data = r.json()
            return {"url": url, "token": data["AccessToken"], "user_id": data["User"]["Id"]}

        print("Provide either --key (API key) or --user/--pass for Jellyfin", file=sys.stderr)
        sys.exit(1)

    def can_handle(self, uri: str) -> bool:
        return uri.startswith("jellyfin://")

    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        # URI: jellyfin://SERVER/Items/ITEMID
        # or:   jellyfin://SERVER/Search?q=term  (picks first result)
        parsed = urlparse(uri)
        server_ref = parsed.hostname  # e.g. "homelab" or "jellyfin.local"
        server = self._resolve_server(server_ref)

        audio_file = dest_dir / f"source.{AUDIO_FORMAT}"

        if audio_file.exists() and not force:
            meta = json.loads((dest_dir / "meta.json").read_text())
            return meta

        # Extract item path
        path = parsed.path.strip("/")
        if not path:
            print("Jellyfin URI must include an item path: jellyfin://SERVER/Items/ID", file=sys.stderr)
            sys.exit(1)

        # Get item metadata
        parts = path.split("/")
        if "Items" in parts:
            item_id = parts[parts.index("Items") + 1]
        else:
            item_id = parts[-1]

        item_data = self._api_call(server, f"/Users/{server['user_id']}/Items/{item_id}")
        title = item_data.get("Name", "Unknown")
        runtime_ticks = item_data.get("RunTimeTicks", 0)
        duration = runtime_ticks / 10_000_000 if runtime_ticks else 0

        item_type = item_data.get("Type", "")
        print(f"  Source: {title} ({item_type}) — {format_time(duration)}")

        # Stream/download: use Audio endpoint for everything (works for video too)
        audio_url = item_data.get("MediaSources", [{}])[0].get("Path", "")
        print(f"  Media path: {audio_url}")

        if audio_url and Path(audio_url).exists():
            # Local file on the Jellyfin server — copy directly if accessible
            # (this relies on the same filesystem, which may not be the case)
            # Fall back to streaming
            pass

        # Use the universal audio stream
        stream_url = (f"{server['url']}/Audio/{item_id}/universal"
                      f"?UserId={server['user_id']}"
                      f"&AudioCodec=pcm_s16le"
                      f"&Container=wav"
                      f"&TranscodingContainer=ts"
                      f"&TranscodingProtocol=hls"
                      f"&MaxStreamingBitrate=999999999")

        # Download with streaming + ffmpeg
        import requests
        print(f"  Streaming audio from Jellyfin...")
        r = requests.get(stream_url, headers={
            "Authorization": f'MediaBrowser Token="{server["token"]}"',
        }, stream=True, timeout=600)

        tmp_wav = str(dest_dir / f"source_raw.wav")
        if r.status_code == 200:
            with open(tmp_wav, 'wb') as f:
                for chunk in r.iter_content(chunk_size=8192):
                    f.write(chunk)

            # Convert to standard WAV
            run(["ffmpeg", "-y", "-i", tmp_wav,
                 "-acodec", "pcm_s16le", "-ar", "44100", "-ac", "2",
                 str(audio_file)],
                desc="Converting Jellyfin stream to WAV")
            Path(tmp_wav).unlink(missing_ok=True)
        else:
            print(f"Stream failed: HTTP {r.status_code}", file=sys.stderr)
            sys.exit(1)

        return {"title": title, "duration": duration or probe_duration(audio_file),
                "source": uri, "server": server_ref, "item_id": item_id}

    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        parsed = urlparse(uri)
        server_ref = parsed.hostname
        server = self._resolve_server(server_ref)

        params = {"Recursive": "true", "Limit": str(limit), "SortBy": "SortName",
                  "SortOrder": "Ascending"}
        if query:
            params["SearchTerm"] = query

        # Determine what to list
        path = parsed.path.strip("/")
        if not path:
            path = "Items"

        if "Views" in path:
            items = self._api_call(server, f"/Users/{server['user_id']}/Views", params)
        elif "Items" in path:
            parts = path.split("/")
            if len(parts) > 1 and parts[-2] == "Items":
                parent_id = parts[-1]
                items = self._api_call(server, f"/Users/{server['user_id']}/Items",
                                       {"ParentId": parent_id, **params})
            else:
                items = self._api_call(server, f"/Users/{server['user_id']}/Items", params)
        elif "Search" in path:
            items = self._api_call(server, f"/Items", {"SearchTerm": query, **params})
        else:
            items = self._api_call(server, f"/Users/{server['user_id']}/Items", params)

        results = []
        for item in (items if isinstance(items, list) else items.get("Items", [])):
            if item_type and item.get("Type", "").lower() != item_type.lower():
                continue
            duration = (item.get("RunTimeTicks", 0) / 10_000_000) if item.get("RunTimeTicks") else 0
            results.append({
                "id": item.get("Id", ""),
                "title": item.get("Name", ""),
                "type": item.get("Type", ""),
                "year": item.get("ProductionYear", ""),
                "duration": duration,
                "uri": f"jellyfin://{server_ref}/Items/{item.get('Id')}",
            })
        return results


