def ensure_demucs_model_cached():
    """Ensure the Demucs model is cached at a stable location.
    
    The #1 cause of repeated 300MB downloads is torch.hub.get_dir() returning
    a profile-specific or session-specific path. We pin TORCH_HOME to a stable
    shared location so the model persists across runs.
    """
    os.environ["TORCH_HOME"] = TORCH_HOME
    try:
        import torch
        hub_dir = torch.hub.get_dir()
        ckpt_dir = Path(hub_dir) / "checkpoints"
        if ckpt_dir.exists() and any(ckpt_dir.glob("*.th")):
            cached = list(ckpt_dir.glob("*.th"))[0]
            print_success(f"Demucs model cached ({human_size(cached.stat().st_size)}): {cached}")
            return
    except ImportError:
        pass
    print_info(f"Downloading Demucs model (~300MB, first run only)...")
    print_info(f"Model cache: {TORCH_HOME}/hub/checkpoints/")


def cmd_isolate(args):
    """Isolate speech from a cached source."""
    print_header(f"{icon('brain')} ISOLATE")
    adapter, sid, source_dir = resolve_source(args.source)
    audio_file = source_dir / f"source.{AUDIO_FORMAT}"
    vocals_file = source_dir / "vocals.wav"

    meta = json.loads((source_dir / "meta.json").read_text()) if (source_dir / "meta.json").exists() else {}

    if vocals_file.exists() and not args.force:
        print_success(f"Already isolated: {vocals_file}")
        print(f"    {styled('Source:', _BOLD)} {meta.get('title', sid)}")
        print(f"    {styled('Size:', _BOLD)}   {human_size(vocals_file.stat().st_size)}")
        return

    ensure_demucs_model_cached()
    t0 = time.monotonic()
    with cache_lock(source_dir):
        # Double-check after lock
        if vocals_file.exists() and not args.force:
            print_info("Isolation completed by parallel process while waiting")
        else:
            cmd_isolate_source(sid, source_dir, audio_file)

    elapsed = time.monotonic() - t0
    print_success(f"Isolated: {vocals_file}")
    print(f"    {styled('Source:', _BOLD)} {meta.get('title', sid)}")
    print(f"    {styled('Size:', _BOLD)}   {human_size(vocals_file.stat().st_size)}")
    print_elapsed("Isolation time", elapsed)


def cmd_isolate_source(sid: str, source_dir: Path, audio_file: Path):
    """Run Demucs voice isolation."""
    r = subprocess.run([sys.executable, "-c", "import demucs"], capture_output=True)
    if r.returncode != 0:
        print_info("Installing demucs...")
        subprocess.run([sys.executable, "-m", "pip", "install", "demucs"], check=True)

    print(f"  {icon('brain')} Running Demucs {DEMUCS_MODEL}...")
    print_info("Neural network separates vocals from instruments/background noise")

    demucs_out = source_dir / "demucs_out"
    run([sys.executable, "-m", "demucs",
         "--two-stems", "vocals",
         "-n", DEMUCS_MODEL,
         "-o", str(demucs_out),
         str(audio_file)],
        desc="Demucs separation")

    candidates = list(demucs_out.glob("*/source/vocals.wav"))
    if not candidates:
        candidates = list(demucs_out.glob("*/**/vocals.wav"))
    if not candidates:
        print_error("Demucs produced no vocals file")
        sys.exit(1)

    # Move raw vocals to temp, then normalize into final vocals.wav
    raw_vocals = source_dir / "vocals_raw.wav"
    shutil.move(str(candidates[0]), str(raw_vocals))
    shutil.rmtree(demucs_out, ignore_errors=True)

    vocals_file = source_dir / "vocals.wav"
    loudnorm_audio(raw_vocals, vocals_file)
    raw_vocals.unlink(missing_ok=True)

    print(f"  {icon('wave')} Isolated → {vocals_file}")


