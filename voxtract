class DirAdapter(SourceAdapter):
    scheme = "dir"

    def can_handle(self, uri: str) -> bool:
        if uri.startswith("dir://"):
            return True
        p = Path(uri)
        return p.exists() and p.is_dir()

    def fetch(self, uri: str, dest_dir: Path, force: bool = False) -> dict:
        # For a directory, fetch the first file as a convenience
        # The real power is in list_items → then fetch individual files
        items = self.list_items(uri)
        if not items:
            print("No media files found in directory", file=sys.stderr)
            sys.exit(1)
        print(f"Found {len(items)} media files. Use dir:///<path> with list to browse, then fetch specific files.")
        print(f"First candidate: {items[0]['uri']}")

        local = LocalFileAdapter()
        return local.fetch(items[0]['path'], dest_dir, force)

    def list_items(self, uri: str, query: str = "", item_type: str = "",
                    limit: int = 20) -> list[dict]:
        d = Path(uri.replace("dir://", ""))
        if not d.exists():
            print(f"Directory not found: {d}", file=sys.stderr)
            return []

        media_exts = {".mp3", ".wav", ".flac", ".ogg", ".m4a", ".aac", ".opus",
                      ".mp4", ".mkv", ".avi", ".mov", ".webm", ".wmv", ".flv",
                      ".m4v", ".ts", ".mts", ".m2ts"}

        results = []
        for f in sorted(d.rglob("*")):
            if f.suffix.lower() in media_exts and (not query or query.lower() in f.name.lower()):
                # Get duration
                try:
                    dur_out = subprocess.run(
                        ["ffprobe", "-v", "quiet", "-show_entries", "format=duration",
                         "-of", "csv=p=0", str(f)],
                        capture_output=True, text=True, timeout=30)
                    duration = float(dur_out.stdout.strip()) if dur_out.stdout.strip() else 0
                except:
                    duration = 0

                results.append({
                    "id": cache_id(str(f)),
                    "title": f.relative_to(d).as_posix(),
                    "path": str(f),
                    "type": "audio" if f.suffix.lower() in {".mp3", ".wav", ".flac", ".ogg", ".m4a", ".aac", ".opus"} else "video",
                    "year": "",
                    "duration": duration,
                    "uri": f"file://{f}",
                })
                if len(results) >= limit:
                    break

        return results


