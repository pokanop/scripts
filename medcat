def safe_filename(s: str) -> str:
    """Sanitize a string for use in filenames."""
    s = re.sub(r'[<>:"/\\|?*\x00-\x1f]', "-", s)
    s = re.sub(r"\s+", " ", s).strip()
    s = s.rstrip(".")
    return s


def format_structure(template: str, metadata: dict) -> str:
    """Format a directory structure template with metadata variables."""
    # First ensure all values are strings, using defaults for missing keys
    defaults = {
        "Author": "Unknown Author",
        "Title": "Unknown Title",
        "Series": "Unknown Series",
        "Volume": 1,
        "Issue": 0,
        "Chapter": 0,
        "Year": "0000",
        "Show": "Unknown Show",
        "Season": 1,
        "Episode": 1,
        "Artist": "Unknown Artist",
        "Album": "Unknown Album",
        "Track": 1,
        "ext": "unknown",
    }
    fmt_vars = dict(defaults)
    fmt_vars.update(metadata)

    # Handle format specifiers like {Issue:03d}
    result = template
    for key, val in fmt_vars.items():
        if isinstance(val, (int, float)):
            result = re.sub(
                rf"\{{{key}:?([^}}]*)\}}",
                lambda m, k=key, v=val: format(v, m.group(1)) if m.group(1) else str(v),
                result,
            )
        else:
            result = re.sub(
                rf"\{{{key}[^}}]*\}}", str(safe_filename(str(val))), result
            )

    # Clean up any remaining format spec curly braces
    result = re.sub(r"\{[^}]+\}", "unknown", result)
    return result


