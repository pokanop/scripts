}


def _resolve_sources(sources_arg: str, media_type: str = None) -> list:
    """Resolve source argument to list of source names.
    
    sources_arg can be:
      - comma-separated list of source names
      - "all" for all available sources
      - "auto" or None for media-type defaults
    """
    if not sources_arg or sources_arg == "auto":
        if media_type:
            return DEFAULT_SOURCES_BY_TYPE.get(media_type, ["prowlarr", "archive"])
        return ["prowlarr", "archive"]

    if sources_arg == "all":
        return list(SEARCH_SOURCES.keys())

    return [s.strip() for s in sources_arg.split(",") if s.strip() in SEARCH_SOURCES]


