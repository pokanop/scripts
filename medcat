def write_epub_metadata(filepath: str, metadata: dict):
    """Write enriched metadata back into EPUB."""
    try:
        from ebooklib import epub

        book = epub.read_epub(filepath)

        ns = {"dc": "http://purl.org/dc/elements/1.1/", "opf": "http://www.idpf.org/2007/opf"}

        if "Title" in metadata:
            book.set_title(metadata["Title"])
        if "Author" in metadata:
            book.add_author(metadata["Author"])
        if "Publisher" in metadata:
            book.add_metadata("DC", "publisher", metadata["Publisher"])
        if "Language" in metadata:
            book.set_language(metadata["Language"])
        if "ISBN" in metadata:
            book.add_metadata(
                "DC", "identifier", metadata["ISBN"],
                {f"{ns['opf']}scheme": "ISBN"},
            )

        # Set custom series metadata (Calibre extension)
        cal_ns = "http://calibre.kovidgoyal.net/2009/metadata"
        if "Series" in metadata:
            book.add_metadata(None, "meta", metadata["Series"], {
                "name": f"{cal_ns}:series",
                "content": metadata["Series"],
            })

        epub.write_epub(filepath, book)

    except Exception as e:
        console.print(f"[yellow]⚠ Could not write EPUB metadata: {e}[/]")


# ---------------------------------------------------------------------------
# Media type detection
# ---------------------------------------------------------------------------


BOOK_EXTENSIONS = {".epub", ".pdf"}
COMIC_EXTENSIONS = {".cbz", ".cbr"}
AUDIOBOOK_EXTENSIONS = {".m4b", ".aa", ".aax"}
VIDEO_EXTENSIONS = {".mkv", ".mp4", ".avi", ".mov", ".m4v"}
MUSIC_EXTENSIONS = {".flac", ".mp3", ".ogg", ".opus", ".wav", ".aac", ".alac"}
SKIP_EXTENSIONS = {".nfo", ".srt", ".sfv", ".txt", ".log", ".url", ".m3u"}
SHOW_FILENAME_RE = re.compile(r"[Ss]\d{2}[Ee]\d{2}")


def is_likely_audiobook(filepath: str) -> bool:
    """Heuristic to distinguish audiobook MP3s from music tracks."""
    ext = Path(filepath).suffix.lower()
    if ext in AUDIOBOOK_EXTENSIONS:
        return True
    if ext != ".mp3":
        return False

    try:
        result = subprocess.run(
            ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", filepath],
            capture_output=True, text=True, timeout=30,
        )
        if result.returncode != 0:
            return False

        fmt = json.loads(result.stdout).get("format", {})
        tags = fmt.get("tags", {})
        duration = float(fmt.get("duration", 0))
        genre = tags.get("genre", "").lower()

        if any(word in genre for word in ("audiobook", "audiobooks", "speech", "spoken")):
            return True
        if tags.get("isbn"):
            return True
        if duration >= 3600 and tags.get("album"):
            return True
    except Exception:
        pass

    return False


def is_likely_show(filepath: str) -> bool:
    """Detect TV episodes from filename patterns like S01E01."""
    return bool(SHOW_FILENAME_RE.search(Path(filepath).stem))


def file_matches_media_type(filepath: str, media_type: str) -> bool:
    """Return True if filepath belongs to the requested media type."""
    ext = Path(filepath).suffix.lower()

    if media_type == "books":
        return ext in BOOK_EXTENSIONS
    if media_type == "comics":
        return ext in COMIC_EXTENSIONS
    if media_type == "audiobooks":
        return ext in AUDIOBOOK_EXTENSIONS or (ext == ".mp3" and is_likely_audiobook(filepath))
    if media_type == "music":
        return ext in MUSIC_EXTENSIONS and not (ext == ".mp3" and is_likely_audiobook(filepath))
    if media_type in ("movies", "documentaries"):
        return ext in VIDEO_EXTENSIONS and not is_likely_show(filepath)
    if media_type == "shows":
        return ext in VIDEO_EXTENSIONS and is_likely_show(filepath)
    return False


def detect_media_type(filepath: str) -> str:
    """Detect media type from file extension and light heuristics."""
    ext = Path(filepath).suffix.lower()
    if ext in BOOK_EXTENSIONS:
        return "books"
    if ext in COMIC_EXTENSIONS:
        return "comics"
    if ext in AUDIOBOOK_EXTENSIONS:
        return "audiobooks"
    if ext in MUSIC_EXTENSIONS:
        if is_likely_audiobook(filepath):
            return "audiobooks"
        return "music"
    if ext in VIDEO_EXTENSIONS:
        if is_likely_show(filepath):
            return "shows"
        return "movies"
    return "unknown"


def find_media_files(path: str, media_type: Optional[str] = None) -> list:
    """Recursively find media files of given type."""
    p = Path(path)
    if p.is_file():
        if media_type:
            return [str(p)] if file_matches_media_type(str(p), media_type) else []
        return [str(p)] if p.suffix.lower() not in SKIP_EXTENSIONS else []

    if not p.is_dir():
        return []

    files = []
    for root, _, filenames in os.walk(p):
        for fname in filenames:
            filepath = str(Path(root) / fname)
            ext = Path(fname).suffix.lower()
            if ext in SKIP_EXTENSIONS:
                continue
            if media_type and not file_matches_media_type(filepath, media_type):
                continue
            files.append(filepath)

    return sorted(files)


# ---------------------------------------------------------------------------
# Media Handlers
# ---------------------------------------------------------------------------


class MediaHandler(ABC):
    """Base handler for a media type."""

    media_type: str = "unknown"
    human_name: str = "Unknown"

    @abstractmethod
    def extract_metadata(self, filepath: str) -> dict:
        ...

    def enrich_metadata(self, metadata: dict) -> dict:
        """Override for API enrichment."""
        return metadata

    def writeback_metadata(self, filepath: str, metadata: dict):
        """Override to write metadata back to file."""
        pass

    def build_destination(self, metadata: dict, dest_config: dict) -> Path:
        """Build destination path from metadata and config."""
        structure = format_structure(dest_config["structure"], metadata)
        rename = format_structure(dest_config["rename"], metadata)
        dest_dir = Path(dest_config["path"]) / structure
        dest_file = dest_dir / rename
        return dest_file


class BookHandler(MediaHandler):
    media_type = "books"
    human_name = "Books"

    def extract_metadata(self, filepath: str) -> dict:
