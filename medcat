def process_file(
    filepath: str,
    media_type: str,
    config: dict,
    dry_run: bool = False,
    no_enrich: bool = False,
    no_prompt: bool = False,
    scan: bool = False,
    yes: bool = False,
) -> dict:
    """Process a single media file: extract, enrich, move, scan."""
    handler = get_handler(media_type)
    if not handler:
        return {"status": "error", "error": f"No handler for type: {media_type}", "file": filepath}

    dest_config = config.get("destinations", {}).get(media_type, {})
    if not dest_config:
        return {"status": "error", "error": f"No destination config for: {media_type}", "file": filepath}

    # Step 1: Extract metadata
    metadata = handler.extract_metadata(filepath)

    # Step 2: Enrich (unless disabled)
    if not no_enrich:
        with Progress(SpinnerColumn(), TextColumn("[dim]Enriching metadata...[/]"), transient=True) as progress:
            progress.add_task("enrich", total=None)
            metadata = handler.enrich_metadata(metadata)

    # Step 2b: Prompt for missing critical metadata
    if not no_prompt:
        metadata = prompt_missing_metadata(metadata, handler, filepath)

    # Step 3: Build destination
    dest_file = handler.build_destination(metadata, dest_config)

    result = {
        "status": "ok",
        "file": filepath,
        "dest": str(dest_file),
        "metadata": metadata,
        "media_type": media_type,
        "handler": handler,
    }

    # Step 4: Present and move
    if not dry_run:
        # Show what we found with rich formatting
        render_file_result(result)

        # Confirm or auto-confirm
        if not yes:
            confirm = console.input("\n[bold yellow]Proceed with move?[/] [dim](y/n/q)[/] ").strip().lower()
            if confirm in ("q", "quit"):
                result["status"] = "cancelled"
                return result
            if confirm not in ("y", "yes", ""):
                result["status"] = "skipped"
                return result

        # Writeback metadata to file
        try:
            handler.writeback_metadata(filepath, metadata)
        except Exception:
            pass  # Best effort

        # Copy to destination
        try:
            copy_to_destination(Path(filepath), dest_file, dest_config, config)
            host = _get_transport_host(dest_config, config)
            if destination_root_is_local(dest_config):
                console.print(f"[green]  ✓ Moved to[/] [bold]{dest_file}[/]")
            elif host:
                console.print(
                    f"[green]  ✓ Copied to[/] [bold]{dest_file}[/] "
                    f"[dim](on {host})[/]"
                )
            else:
                console.print(f"[green]  ✓ Copied to[/] [bold]{dest_file}[/]")

            src = Path(filepath).resolve()
            try:
                if destination_root_is_local(dest_config):
                    if src != dest_file.resolve():
                        os.remove(filepath)
                else:
                    os.remove(filepath)
            except OSError as exc:
                console.print(f"[yellow]  ⚠ Copied but could not remove source: {exc}[/]")
        except Exception as e:
            result["status"] = "error"
            result["error"] = str(e)
            console.print(f"[red]  ✗ Failed: {e}[/]")
            if not destination_root_is_local(dest_config):
                console.print(
                    "[dim]  Tip: mount the destination path locally or configure transport "
                    "with [bold]medcat setup --section transport[/][/]"
                )
            return result

        if scan:
            trigger_scan(media_type, config)
    else:
        render_file_result(result)
        host = _get_transport_host(dest_config, config)
        if destination_root_is_local(dest_config):
            console.print(f"  [dim]→ (dry-run)[/] {dest_file}")
        elif host:
            console.print(f"  [dim]→ (dry-run via SCP to {escape(host)})[/] {escape(dest_file)}")
        else:
            console.print(f"  [dim]→ (dry-run)[/] {dest_file}")

    return result


def render_file_result(result: dict):
    """Render a single file result with rich formatting."""
    meta = result["metadata"]
    media_type = result["media_type"]

    # Icon per type
    icons = {"books": "📖", "comics": "💬", "audiobooks": "🎧", "movies": "🎬",
             "shows": "📺", "music": "🎵", "documentaries": "🎥"}
    icon = icons.get(media_type, "📄")

    console.print(f"\n{icon} [bold]{meta.get('Title', 'Unknown')}[/]")

    # Author/Artist line
    author_line = ""
    if meta.get("Author"):
        author_line = f"by [cyan]{meta['Author']}[/]"
    elif meta.get("Artist"):
        author_line = f"by [cyan]{meta['Artist']}[/]"
    if author_line:
        console.print(f"   {author_line}")

    # Extra metadata
    extras = []
    if meta.get("Series"):
        extras.append(f"Series: [green]{meta['Series']}[/]")
    if meta.get("Issue"):
        extras.append(f"#{meta['Issue']}")
    if meta.get("Volume"):
        extras.append(f"Vol. {meta['Volume']}")
    if meta.get("Publisher"):
        extras.append(f"Publisher: {meta['Publisher']}")
    if meta.get("ISBN"):
        extras.append(f"ISBN: [dim]{meta['ISBN']}[/]")
    if meta.get("Year") and meta.get("Year") != "0000":
        extras.append(f"Year: {meta['Year']}")
    if meta.get("Season"):
        extras.append(f"S{meta['Season']:02d}")
    if meta.get("Episode"):
        extras.append(f"E{meta['Episode']:02d}")
    if meta.get("Album"):
        extras.append(f"Album: {meta['Album']}")
    if meta.get("Track"):
        extras.append(f"Track: {meta['Track']:02d}")

    if extras:
        console.print(f"   {' | '.join(extras)}")

    source = meta.get("Source", "unknown")
    sources = {
        "Google Books API": "green",
        "Open Library": "blue",
        "MusicBrainz": "blue",
        "EPUB metadata": "cyan",
        "ComicInfo.xml": "cyan",
        "PDF XMP": "cyan",
        "ffprobe tags": "cyan",
        "ffprobe": "cyan",
        "filename": "yellow",
    }
    color = sources.get(source, "dim")
    console.print(f"   Source: [{color}]{source}[/]")

    if meta.get("_error"):
        console.print(f"   [yellow]⚠ {meta['_error']}[/]")


