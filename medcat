def _mask_secrets(obj):
    """Recursively mask api_key values in a config dict for display."""
    if isinstance(obj, dict):
        return {k: ("***" if k in ("api_key", "apikey", "key") and isinstance(v, str) and v else
                     _mask_secrets(v) if isinstance(v, (dict, list)) else v)
                for k, v in obj.items()}
    if isinstance(obj, list):
        return [_mask_secrets(item) for item in obj]
    return obj


def cmd_config(args):
    """Handle 'config' command — view and manage configuration."""
    config = load_config()

    # --- config get <key> ---
    if getattr(args, "config_action", None) == "get":
        key = args.config_key
        val = _config_get_nested(config, key)
        if val is None:
            console.print(f"[yellow]Key not found: {key}[/]")
        elif isinstance(val, dict):
            masked = _mask_secrets(val)
            console.print(json.dumps(masked, indent=2))
        else:
            display = "***" if "api_key" in key.lower() else val
            console.print(f"{display}")
        return

    # --- config set <key> <value> ---
    if getattr(args, "config_action", None) == "set":
        key = args.config_key
        value = args.config_value
        _config_set_nested(config, key, value)
        save_config(config)
        display = "***" if "api_key" in key.lower() else value
        console.print(f"[green]✓[/] Set [bold]{key}[/] = [dim]{display}[/]")
        return

    # --- config unset <key> ---
    if getattr(args, "config_action", None) == "unset":
        key = args.config_key
        if _config_unset_nested(config, key):
            save_config(config)
            console.print(f"[green]✓[/] Removed [bold]{key}[/]")
        else:
            console.print(f"[yellow]Key not found: {key}[/]")
        return

    # --- config list [section] ---
    if getattr(args, "config_action", None) == "list":
        section = getattr(args, "section", None)
        if section:
            node = _config_get_nested(config, section)
            if isinstance(node, dict):
                for k, v in _mask_secrets(node).items():
                    if isinstance(v, dict):
                        console.print(f"  [bold]{k}:[/]")
                        for sub_k, sub_v in v.items():
                            console.print(f"    {sub_k} = {sub_v}")
                    else:
                        console.print(f"  {k} = {v}")
            else:
                console.print(f"[yellow]Section not found: {section}[/]")
        else:
            # List all top-level sections
            for section_name in ("transport", "destinations", "services"):
                node = config.get(section_name)
                if node:
                    count = len(node) if isinstance(node, dict) else 0
                    console.print(f"  [bold]{section_name}[/] ({count} entries)")
                else:
                    console.print(f"  [dim]{section_name}[/] (not configured)")
        return

    # --- config --show ---
    if getattr(args, "show", False):
        masked = _mask_secrets(config)
        console.print(json.dumps(masked, indent=2))
        return

    # --- config --check ---
    if getattr(args, "check", False):
        issues = validate_config(config)
        if not issues:
            console.print("[green]✓ Configuration looks good![/]")
            return

        severity_colors = {"critical": "red", "warn": "yellow", "info": "blue"}
        for issue in issues:
            color = severity_colors.get(issue["severity"], "dim")
            icon = {"critical": "✗", "warn": "⚠", "info": "ℹ"}.get(issue["severity"], "•")
            console.print(f"  [{color}]{icon} {issue['section']}:[/] {issue['message']}")
        return

    # --- config test [services...] ---
    if getattr(args, "config_action", None) == "test":
        services_to_test = getattr(args, "test_services", []) or list(config.get("services", {}).keys())
        if not services_to_test:
            console.print("[yellow]No services configured to test. Run: [bold]medcat setup --section services[/][/]")
            return

        for svc_name in services_to_test:
            if svc_name not in config.get("services", {}):
                console.print(f"  [dim]• {svc_name}: not configured, skipping[/]")
                continue
            console.print(f"  [dim]Testing {svc_name}...[/]", end="")
            result = test_service_connection(svc_name, config)
            if result["ok"]:
                msg = "[green]✓ connected[/]"
                if result.get("warning"):
                    msg += f" [yellow]({result['warning']})[/]"
                console.print(f"\r  [green]✓ {svc_name}:[/] connected")
            else:
                console.print(f"\r  [red]✗ {svc_name}:[/] {result.get('error', 'Failed')}")
        return

    # --- config --reset ---
    if getattr(args, "reset", False):
        save_config(dict(DEFAULT_CONFIG))
        SETUP_MARKER.unlink(missing_ok=True)
        console.print("[green]✓ Config reset to clean defaults.[/]")
        console.print("[dim]Run [bold]medcat setup[/] to reconfigure.[/]")
        return


