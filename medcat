_deep_merge = sk.deep_merge
_config_get_nested = sk.get_nested


def _config_set_nested(config: dict, key_path: str, value):
    """Set a nested config value by dot-path, coercing scalar strings."""
    sk.set_nested(config, key_path, value, coerce=True)


def _config_unset_nested(config: dict, key_path: str):
    """Delete a nested config key. Returns True if key existed."""
    parts = key_path.split(".")
    node = config
    for part in parts[:-1]:
        if not isinstance(node, dict) or part not in node:
            return False
        node = node[part]
    if isinstance(node, dict) and parts[-1] in node:
        del node[parts[-1]]
        return True
    return False


def _config_from_env():
    """Load overrides from MEDCAT_ env vars (e.g. MEDCAT_SERVICES__KAVITA__URL)."""
    return sk.config_from_env("MEDCAT", coerce=True)


def _needs_setup():
    """Return True if the tool hasn't been through initial setup."""
    return not SETUP_MARKER.exists()


def load_config():
    """Load config with defaults, file, and env overrides."""
    config = dict(DEFAULT_CONFIG)
    if CONFIG_FILE.exists():
        try:
            with open(CONFIG_FILE) as f:
                saved = json.load(f)
            config = _deep_merge(config, saved)
        except (json.JSONDecodeError, OSError):
            pass
    # Apply environment variable overrides last (highest priority)
    env_overrides = _config_from_env()
    if env_overrides:
        config = _deep_merge(config, env_overrides)
    return config


def save_config(config):
    """Persist config to disk (strips version for clean diff)."""
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)
        f.write("\n")


def get_transport_config(config: dict) -> dict:
    """Get transport config with resolved SSH key path."""
    tc = config.get("transport", {})
    ssh_key = tc.get("ssh_key", "")
    if not ssh_key:
        # Auto-detect: check common SSH key locations
        for candidate in (
            os.path.expanduser("~/.ssh/id_ed25519"),
            os.path.expanduser("~/.ssh/id_rsa"),
            os.path.expanduser("~/.ssh/id_ecdsa"),
        ):
            if os.path.exists(candidate):
                ssh_key = candidate
                break
    return {
        "method": tc.get("method", "auto"),
        "host": tc.get("host", ""),
        "user": tc.get("user", "root"),
        "ssh_key": ssh_key,
        "ssh_timeout": tc.get("ssh_timeout", 5),
    }


def validate_config(config: dict) -> list:
    """Validate config completeness. Returns list of issue dicts."""
    issues = []
    tc = get_transport_config(config)
    dests = config.get("destinations", {})

    # Check destinations
    configured_dests = 0
    for name, dest in dests.items():
        path = dest.get("path", "")
        if not path:
            issues.append({
                "severity": "info",
                "section": f"destinations.{name}",
                "message": f"No path configured for '{name}'. Run: medcat setup",
            })
        else:
            configured_dests += 1
            scan_svc = dest.get("scan", "")
            if scan_svc and scan_svc not in config.get("services", {}):
                issues.append({
                    "severity": "warn",
                    "section": f"destinations.{name}.scan",
                    "message": f"Scan service '{scan_svc}' is not configured in services.",
                })

    if configured_dests == 0:
        issues.append({
            "severity": "critical",
            "section": "destinations",
            "message": "No destinations configured. Run: medcat setup",
        })

    # Check services
    for svc_name, svc in config.get("services", {}).items():
        if not svc.get("url"):
            issues.append({
                "severity": "warn",
                "section": f"services.{svc_name}.url",
                "message": f"Service '{svc_name}' has no URL configured.",
            })
        if not svc.get("api_key"):
            issues.append({
                "severity": "warn",
                "section": f"services.{svc_name}.api_key",
                "message": f"Service '{svc_name}' has no API key set.",
            })

    # Check transport
    if tc["method"] == "scp" and not tc["host"]:
        issues.append({
            "severity": "critical",
            "section": "transport.host",
            "message": "SCP transport selected but no host configured.",
        })

    return issues


def test_service_connection(svc_name: str, config: dict) -> dict:
    """Test connectivity to a configured service. Returns result dict."""
    svc = config.get("services", {}).get(svc_name, {})
    url = svc.get("url", "").rstrip("/")
    api_key = svc.get("api_key", "")

    if not url:
        return {"ok": False, "error": "No URL configured"}

    try:
        headers = {}
        if api_key:
            if svc_name == "abs":
                # Audiobookshelf uses Bearer token, not X-Api-Key
                headers["Authorization"] = f"Bearer {api_key}"
            else:
                headers["X-Api-Key"] = api_key
                headers["X-API-Key"] = api_key  # Kavita uses this form

        # Try a lightweight status/ping endpoint
        test_paths = {
            "kavita": "/api/server/version",
            "radarr": "/api/v3/system/status",
            "sonarr": "/api/v3/system/status",
            "readarr": "/api/v1/system/status",
            "lidarr": "/api/v1/system/status",
            "abs": "/ping",  # Audiobookshelf unauthenticated health check
            "prowlarr": "/api/v1/system/status",
            "deluge": "/json",  # Deluge Web UI JSON-RPC endpoint
            "qbittorrent": "/api/v2/auth/login",  # qBittorrent API
        }
        test_path = test_paths.get(svc_name, "/api/status")
        resp = requests.get(f"{url}{test_path}", headers=headers, timeout=10)

        if resp.status_code == 401:
            return {"ok": False, "error": f"Authentication failed (HTTP {resp.status_code}). Check API key."}
        if resp.status_code == 404:
            # Service might be running but different endpoint — still counts as reachable
            return {"ok": True, "warning": f"Reached {url} but status endpoint returned 404"}
        if resp.status_code >= 500:
            return {"ok": False, "error": f"Server error (HTTP {resp.status_code})"}

        # For ABS, /ping is unauthenticated — do a second check to validate the API key
        if svc_name == "abs" and api_key:
            auth_resp = requests.get(f"{url}/api/libraries", headers=headers, timeout=10)
            if auth_resp.status_code == 401:
                return {"ok": False, "error": "Server reachable but API key rejected (HTTP 401)"}
            if auth_resp.status_code >= 400:
                return {"ok": True, "warning": f"Server up, but API check returned HTTP {auth_resp.status_code}"}

        return {"ok": True, "status": resp.status_code}
    except requests.ConnectionError:
        return {"ok": False, "error": f"Cannot connect to {url}"}
    except requests.Timeout:
        return {"ok": False, "error": f"Connection to {url} timed out"}
    except Exception as e:
        return {"ok": False, "error": str(e)}


