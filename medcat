def _archive_search(query: str, media_type: str = None, limit: int = 20) -> list:
    """Search Internet Archive. Returns list of SearchResult."""
    # Build media-type-specific query filters
    mediatype_map = {
        "books": "texts",
        "audiobooks": "audio",
        "movies": "movies",
        "shows": "movies",
        "music": "audio",
        "documentaries": "movies",
    }
    ia_mediatype = mediatype_map.get(media_type)

    # Build the query
    q_parts = [query]
    if ia_mediatype:
        q_parts.append(f"mediatype:{ia_mediatype}")

    params = {
        "q": " AND ".join(q_parts),
        "fl": "identifier,title,creator,date,description,downloads,avg_rating,num_reviews,language,format,size",
        "sort": ["downloads desc", "avg_rating desc"],
        "rows": limit,
        "page": 1,
        "output": "json",
    }

    try:
        resp = requests.get(
            "https://archive.org/advancedsearch.php",
            params=params,
            timeout=20,
        )
        if resp.status_code != 200:
            console.print(f"[red]✗ Internet Archive returned HTTP {resp.status_code}[/]")
            return []

        data = resp.json()
        docs = data.get("response", {}).get("docs", [])
        results = []
        for doc in docs:
            title = doc.get("title", doc.get("identifier", "Unknown"))
            creator = doc.get("creator", "")
            # Parse date to year
            date_str = doc.get("date", "")
            year = date_str[:4] if len(date_str) >= 4 else None
            # Format list
            formats = doc.get("format", [])
            if isinstance(formats, str):
                formats = [formats]

            r = SearchResult(
                title=title,
                source="archive.org",
                size=doc.get("size"),
                guid=doc.get("identifier"),
                identifier=doc.get("identifier"),
                info_url=f"https://archive.org/details/{doc.get('identifier', '')}",
                download_url=f"https://archive.org/download/{doc.get('identifier', '')}",
                author=creator if isinstance(creator, str) else "; ".join(creator or []),
                year=year,
                protocol="direct",
                media_type=media_type,
                format=", ".join(formats[:5]) if formats else None,
                raw=doc,
            )
            results.append(r)
        return results

    except Exception as e:
        console.print(f"[red]✗ Internet Archive error: {e}[/]")
        return []


def _archive_download(result: SearchResult, dest_dir: str = None) -> bool:
    """Download an Internet Archive item. Uses 'ia' CLI if available, else direct HTTP."""
    identifier = result.identifier
    if not identifier:
        return False

    dest = dest_dir or tempfile.mkdtemp(prefix="medcat_ia_")

    # Try 'ia' CLI first (handles large multi-file items well)
    ia_cli = shutil.which("ia")
    if ia_cli:
        console.print(f"[dim]  Using ia CLI to download {identifier}...[/]")
        try:
            proc = subprocess.run(
                ["ia", "download", "--destdir", dest, identifier],
                capture_output=True, text=True, timeout=300,
            )
            if proc.returncode == 0:
                console.print(f"[green]  ✓ Downloaded to {escape(dest)}[/]")
                return True
            else:
                console.print(f"[yellow]  ⚠ ia CLI failed: {proc.stderr[:200]}[/]")
        except FileNotFoundError:
            pass

    # Fallback: direct HTTP download for single-file items
    console.print("[dim]  Downloading from archive.org...[/]")
    try:
        # Get the item metadata to find files
        meta_resp = requests.get(
            f"https://archive.org/metadata/{identifier}",
            params={"output": "json"},
            timeout=15,
        )
        if meta_resp.status_code != 200:
            return False

        metadata = meta_resp.json()
        files = metadata.get("files", [])

        # Pick the best file based on media type preferences
        preferred_exts = {
            "books": [".epub", ".pdf"],
            "audiobooks": [".mp3", ".m4b", ".ogg"],
            "music": [".flac", ".mp3", ".ogg"],
            "movies": [".mp4", ".mkv"],
        }
        prefs = preferred_exts.get(result.media_type, [])
        target_file = None

        for ext in prefs:
            for f in files:
                name = f.get("name", "")
                if name.lower().endswith(ext) and f.get("source") != "metadata":
                    target_file = name
                    break
            if target_file:
                break

        if not target_file and files:
            # Fall back to first non-metadata file
            for f in files:
                if f.get("source") != "metadata" and not f["name"].startswith("_"):
                    target_file = f["name"]
                    break

        if not target_file:
            console.print("[yellow]  ⚠ No downloadable file found[/]")
            return False

        dl_url = f"https://archive.org/download/{identifier}/{target_file}"
        console.print(f"[dim]  Downloading {escape(target_file)} ({dl_url})[/]")

        r = requests.get(dl_url, stream=True, timeout=120)
        if r.status_code != 200:
            console.print(f"[red]  ✗ Download failed: HTTP {r.status_code}[/]")
            return False

        out_path = os.path.join(dest, target_file)
        with open(out_path, "wb") as f:
            downloaded = 0
            for chunk in r.iter_content(chunk_size=8192):
                f.write(chunk)
                downloaded += len(chunk)

        console.print(f"[green]  ✓ Downloaded to {escape(out_path)}[/]")
        return True

    except Exception as e:
        console.print(f"[red]  ✗ Download error: {e}[/]")
        return False


