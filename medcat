def cmd_grab(args):
    """Handle 'grab' command — download from any URL with auto-routing."""
    config = load_config()
    url = getattr(args, "url", "")
    media_type = getattr(args, "type", None) or getattr(args, "dest", None)
    audio_only = getattr(args, "audio", False)
    scan = getattr(args, "scan", False)
    no_ingest = getattr(args, "no_ingest", False)
    dry_run = getattr(args, "dry_run", False)
    info_only = getattr(args, "info", False)

    if not url:
        console.print("[red]✗ No URL provided[/]")
        return

    url_source = _classify_url(url)

    console.print()
    console.print(f"⬇ [bold]Grab:[/] {escape(url[:80])}{'...' if len(url) > 80 else ''}")
    console.print(f"[dim]  Detected: {url_source}[/]")
    if media_type:
        console.print(f"[dim]  Media type: {media_type}[/]")
    console.print()

    result = None

    # ── YouTube ──
    if url_source == "youtube":
        result = _probe_youtube_url(url, audio_only)
        if not result:
            console.print("[red]✗ Could not probe YouTube URL (yt-dlp required)[/]")
            return
        if not media_type and audio_only:
            media_type = "music"

        _render_single_result(result, media_type)

        if info_only:
            return

        # Determine destination
        dest_dir = None
        mt = media_type or result.media_type
        if mt and not no_ingest:
            dest_config = config.get("destinations", {}).get(mt, {})
            dest_path = dest_config.get("path", "")
            if dest_path and destination_root_is_local(dest_config):
                dest_dir = dest_path

        if dry_run:
            if dest_dir:
                console.print(f"[dim]  Would download to: {escape(dest_dir)}[/]")
            else:
                console.print("[dim]  Would download to temp directory[/]")
            return

        use_audio = audio_only or mt in ("music", "audiobooks")
        ok = _youtube_download(result, dest_dir=dest_dir, audio_only=use_audio)
        if not ok:
            return

    # ── Magnet ──
    elif url_source == "magnet":
        result = SearchResult(
            title=url[:80],
            source="magnet",
            magnet_url=url,
            protocol="torrent",
            media_type=media_type,
            download_url=url,
        )
        _render_single_result(result, media_type)

        if info_only:
            return
        if dry_run:
            console.print("[dim]  Would send magnet to torrent client[/]")
            return

        ok = _send_magnet_to_client(url, config)
        if ok:
            console.print("[green]  ✓ Magnet sent to torrent client[/]")
        else:
            return

    # ── Internet Archive ──
    elif url_source == "archive":
        # Extract identifier from archive.org URL
        ident_match = re.search(r"archive\.org/(details|download)/([^/?#]+)", url)
        if not ident_match:
            console.print("[red]✗ Could not extract Archive.org identifier from URL[/]")
            return
        identifier = ident_match.group(2)

        # Try to get metadata
        try:
            meta = requests.get(
                f"https://archive.org/metadata/{identifier}",
                timeout=15,
            ).json()
            title = meta.get("metadata", {}).get("title", identifier)
            creator = meta.get("metadata", {}).get("creator", "")
            result = SearchResult(
                title=title,
                source="archive.org",
                identifier=identifier,
                guid=identifier,
                info_url=f"https://archive.org/details/{identifier}",
                download_url=f"https://archive.org/download/{identifier}",
                author=creator,
                protocol="direct",
                media_type=media_type,
                raw=meta,
            )
        except Exception:
            result = SearchResult(
                title=identifier,
                source="archive.org",
                identifier=identifier,
                guid=identifier,
                download_url=f"https://archive.org/download/{identifier}",
                protocol="direct",
            )

        _render_single_result(result, media_type)

        if info_only:
            return

        dest_dir = None
        mt = media_type
        if mt and not no_ingest:
            dest_config = config.get("destinations", {}).get(mt, {})
            dest_path = dest_config.get("path", "")
            if dest_path and destination_root_is_local(dest_config):
                dest_dir = dest_path

        if dry_run:
            if dest_dir:
                console.print(f"[dim]  Would download to: {escape(dest_dir)}[/]")
            else:
                console.print("[dim]  Would download to temp directory[/]")
            return

        ok = _archive_download(result, dest_dir=dest_dir)
        if not ok:
            return

    # ── Torrent file ──
    elif url_source == "torrent":
        result = SearchResult(
            title=Path(urlparse(url).path).name or url[:60],
            source="torrent",
            download_url=url,
            protocol="torrent",
            media_type=media_type,
        )
        _render_single_result(result, media_type)

        if info_only:
            return
        if dry_run:
            console.print("[dim]  Would download .torrent and send to client[/]")
            return

        ok = _download_torrent_file(url, config)
        if not ok:
            return

    # ── Direct URL ──
    else:
        result = _probe_direct_url(url)
        if not result:
            console.print("[red]✗ Could not probe URL[/]")
            return

        if not media_type:
            media_type = result.media_type

        _render_single_result(result, media_type)

        if info_only:
            return

        # Determine destination
        dest_dir = None
        mt = media_type
        if mt and not no_ingest:
            dest_config = config.get("destinations", {}).get(mt, {})
            dest_path = dest_config.get("path", "")
            if dest_path and destination_root_is_local(dest_config):
                dest_dir = dest_path

        if not dest_dir:
            dest_dir = tempfile.mkdtemp(prefix="medcat_dl_")

        if dry_run:
            console.print(f"[dim]  Would download to: {escape(dest_dir)}[/]")
            return

        ok = _download_direct_url(result, dest_dir)
        if not ok:
            return

        # Rename to media-type-appropriate name if we know the type
        if mt and ok:
            _auto_rename_downloaded(dest_dir, mt, result)

    # ── Post-download ingest and scan ──
    mt = media_type
    if mt and not no_ingest and not dry_run and ok:
        dest_config = config.get("destinations", {}).get(mt, {})
        dest_path = dest_config.get("path", "")
        if dest_path and dest_path != dest_dir:
            # Downloaded to temp — need to ingest properly
            console.print(f"\n[dim]  Ingesting into {escape(dest_path)}...[/]")
            # Find the downloaded file
            try:
                downloaded_files = list(Path(dest_dir).glob("*"))
                if downloaded_files:
                    downloaded_file = str(downloaded_files[0].resolve())
                    # Use medcat ingest subshell
                    cmd = [sys.executable, sys.argv[0], "ingest",
                           "--dest", mt, "--yes", downloaded_file]
                    proc = subprocess.run(cmd, capture_output=True, text=True, timeout=120)
                    if proc.returncode == 0:
                        console.print(proc.stdout.strip())
                    else:
                        console.print(f"[yellow]  ⚠ Ingest had issues: {proc.stderr[:300]}[/]")
            except Exception as e:
                console.print(f"[yellow]  ⚠ Ingest error: {e}[/]")

        if scan:
            dest_config = config.get("destinations", {}).get(mt, {})
            scan_svc = dest_config.get("scan", "")
            if scan_svc:
                trigger_scan(mt, config)

    console.print()


def _render_single_result(result: SearchResult, media_type: str = None):
    """Render a single search result as a summary panel."""
    panel = Panel(
        f"[bold]{escape(result.title[:100])}[/]\n"
        + (f"  Author: {escape(result.author)}\n" if result.author else "")
        + (f"  Source: {result.source}\n")
        + (f"  Size: {result.size_human}\n" if result.size else "")
        + (f"  Duration: {result.format}\n" if result.format and result.source == "youtube" else "")
        + (f"  Type: {media_type or result.media_type or 'unknown'}\n")
        + (f"  Content: {result.description}\n" if result.description else ""),
        title="🔍 URL Info",
        border_style="cyan",
    )
    console.print(panel)


def _auto_rename_downloaded(dest_dir: str, media_type: str, result: SearchResult):
    """Rename a directly-downloaded file to match media type conventions."""
    try:
        files = [f for f in Path(dest_dir).iterdir() if f.is_file()]
        if not files:
            return
        target = files[0]
        ext = target.suffix

        # Derive a better name
        if media_type in ("books", "audiobooks"):
            author = result.author or ""
            title = result.title.replace("/", "-").replace(":", " -")
            if author and title and title != target.stem:
                new_name = f"{title} - {author}{ext}"
            else:
                new_name = f"{title}{ext}"
        elif media_type in ("music",):
            new_name = result.title.replace("/", "-") + ext
        else:
            # Movies/shows/comics — keep as is for now, ingest will handle
            return

        # Sanitise and rename
        new_name = re.sub(r'[<>:"/\\|?*]', '_', new_name)
        if new_name != target.name:
            new_path = target.with_name(new_name)
            target.rename(new_path)
            console.print(f"[dim]  Renamed: {escape(target.name)} → {escape(new_name)}[/]")
    except Exception:
        pass  # Non‑critical; ingest will handle naming anyway


