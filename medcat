def _prompt(prompt_text: str, default: str = "", style: str = "bold cyan") -> str:
    """Prompt user for input with optional default.

    Uses rich.text.Text to avoid Rich markup parsing crashes when
    default values contain square brackets (e.g. /media/books/books).
    """
    from rich.text import Text
    prompt = Text()
    prompt.append(f"  {prompt_text}", style=style)
    if default:
        prompt.append(f" [{default}]", style="dim")
    prompt.append(": ", style=style)
    prompt.append(" ")
    try:
        val = console.input(prompt).strip()
    except EOFError:
        return default
    # KeyboardInterrupt is deliberately NOT caught — it propagates to the
    # wizard so Ctrl-C exits the entire setup, not just one prompt.
    return val or default


def _prompt_choice(prompt_text: str, choices: list, default: str = "") -> str:
    """Prompt user to pick from a list of choices."""
    from rich.text import Text
    choice_str = "/".join(choices)
    prompt = Text()
    prompt.append(f"  {prompt_text} ", style="bold cyan")
    prompt.append(f"({choice_str})", style="dim")
    if default:
        prompt.append(f" [{default}]", style="dim")
    prompt.append(": ", style="bold cyan")
    prompt.append(" ")
    while True:
        try:
            val = console.input(prompt).strip().lower()
        except EOFError:
            return default
        # KeyboardInterrupt propagates — see _prompt
        if not val and default:
            return default
        if val in [c.lower() for c in choices]:
            return val
        console.print(f"    [yellow]Please choose one of: {choice_str}[/]")


def _prompt_yes_no(prompt_text: str, default: bool = True) -> bool:
    """Prompt for yes/no."""
    from rich.text import Text
    suffix = "Y/n" if default else "y/N"
    prompt = Text()
    prompt.append(f"  {prompt_text} ", style="bold cyan")
    prompt.append(f"({suffix})", style="dim")
    prompt.append(": ", style="bold cyan")
    prompt.append(" ")
    try:
        val = console.input(prompt).strip().lower()
    except EOFError:
        return default
    # KeyboardInterrupt propagates — see _prompt
    if not val:
        return default
    return val in ("y", "yes")


def run_setup_wizard(section: str = None):
    """Run the interactive setup wizard. If section given, only configure that part."""
    config = load_config()

    console.print()
    console.print(Panel.fit(
        "[bold]🐱 medcat setup wizard[/]\n[dim]Configure your media stack. Press Enter to accept defaults.\n"
        "Skip any field with empty input to configure later.\n"
        "Press Ctrl-C at any time to cancel.[/]",
        border_style="cyan",
    ))
    console.print()

    try:
        _run_wizard_sections(config, section)
    except KeyboardInterrupt:
        console.print()
        console.print("[yellow]⏹ Setup cancelled.[/]")
        if config != load_config():
            # One-attempt save prompt — if Ctrl-C again, just exit
            try:
                if _prompt_yes_no("Save partial configuration?", True):
                    save_config(config)
                    SETUP_MARKER.touch()
                    console.print("[green]✓ Partial config saved.[/]")
            except (KeyboardInterrupt, EOFError):
                pass
        sys.exit(130)

    # --- Save ---
    save_config(config)
    SETUP_MARKER.touch()
    console.print("[green]✓ Configuration saved.[/]")
    console.print(f"[dim]  Config file: {CONFIG_FILE}[/]")
    console.print()
    console.print("[dim]Run [bold]medcat config --check[/] to verify, or [bold]medcat setup[/] to reconfigure.][/]")


def _run_wizard_sections(config: dict, section: str = None):
    """Inner wizard logic — runs inside a KeyboardInterrupt catch block."""

    # --- Transport ---
    if section in (None, "transport"):
        console.print("[bold]📡 Transport[/]")
        console.print("[dim]  How should medcat reach your media storage?[/]")
        tc = get_transport_config(config)

        method = _prompt_choice(
            "Transport method",
            ["auto", "local", "scp"],
            default=tc.get("method", "auto") or "auto",
        )
        config.setdefault("transport", {})["method"] = method

        if method == "scp":
            host = _prompt("Remote host (IP or hostname)", tc.get("host", ""))
            user = _prompt("SSH user", tc.get("user", "root"))
            ssh_key = _prompt("SSH key path (blank = auto-detect)", tc.get("ssh_key", ""))
            config["transport"]["host"] = host
            config["transport"]["user"] = user
            if ssh_key:
                config["transport"]["ssh_key"] = ssh_key
        console.print()

    # --- Destinations ---
    if section in (None, "destinations", "destination"):
        console.print("[bold]📂 Destinations[/]")
        console.print("[dim]  Where should each media type be stored? Leave blank to skip.[/]")
        console.print()

        for dest_name, dest_defaults in DEFAULT_CONFIG["destinations"].items():
            existing = config.get("destinations", {}).get(dest_name, {})
            current_path = existing.get("path", "")
            current_scan = existing.get("scan", "")

            console.print(f"  [bold magenta]{dest_name}[/]")
            path = _prompt("  Storage path", current_path)
            if path:
                config.setdefault("destinations", {}).setdefault(dest_name, {})
                config["destinations"][dest_name]["path"] = path

                if _prompt_yes_no("  Auto-scan after ingest?", bool(current_scan)):
                    scan_svc = _prompt("  Scan service (e.g. kavita, radarr)", current_scan)
                    config["destinations"][dest_name]["scan"] = scan_svc
                    if scan_svc and scan_svc != "abs":
                        lib_id = _prompt("  Library ID (for Kavita, blank if N/A)",
                                         str(existing.get("scan_library_id") or ""))
                        config["destinations"][dest_name]["scan_library_id"] = int(lib_id) if lib_id else None
                else:
                    config["destinations"][dest_name]["scan"] = ""
            console.print()

    # --- Services ---
    if section in (None, "services", "service"):
        console.print("[bold]🔌 Services[/]")
        console.print("[dim]  Configure your *arr / Kavita / Audiobookshelf services.[/]")
        console.print()

        # Ask which services to configure
        available = list(KNOWN_SERVICES.keys())
        existing_services = list(config.get("services", {}).keys())
        all_svc = list(dict.fromkeys(existing_services + available))

        for svc_name in all_svc:
            svc_info = KNOWN_SERVICES.get(svc_name, {"label": svc_name})
            label = svc_info.get("label", svc_name)
            existing_svc = config.get("services", {}).get(svc_name, {})

            if section and svc_name != section:
                continue

            console.print(f"  [bold blue]{label}[/] ({svc_name})")
            configure = _prompt_yes_no(
                f"  Configure {label}?",
                bool(existing_svc.get("url")),
            )
            if not configure:
                # Remove if it existed
                if svc_name in config.get("services", {}):
                    if _prompt_yes_no(f"  Remove {label} config?", False):
                        config["services"].pop(svc_name, None)
                console.print()
                continue

            url = _prompt("  URL (e.g. http://192.168.1.100:5080)",
                          existing_svc.get("url", ""))

            # Some services use username/password instead of API key
            if svc_name in ("deluge", "qbittorrent"):
                username = _prompt("  Username",
                                   existing_svc.get("username", "admin" if svc_name == "qbittorrent" else ""))
                password = _prompt("  Password",
                                   existing_svc.get("password", ""))
                if url:
                    config.setdefault("services", {}).setdefault(svc_name, {})
                    config["services"][svc_name]["url"] = url.rstrip("/")
                    if username:
                        config["services"][svc_name]["username"] = username
                    if password:
                        config["services"][svc_name]["password"] = password
            else:
                api_key = _prompt("  API key",
                                  existing_svc.get("api_key", ""))
                if url:
                    config.setdefault("services", {}).setdefault(svc_name, {})
                    config["services"][svc_name]["url"] = url.rstrip("/")
                    if api_key:
                        config["services"][svc_name]["api_key"] = api_key

                # Test connection
                if _prompt_yes_no("  Test connection?", False):
                    test_config = config.copy()
                    result = test_service_connection(svc_name, test_config)
                    if result["ok"]:
                        console.print("    [green]✓ Connection successful![/]")
                    else:
                        console.print(f"    [red]✗ {result.get('error', 'Failed')}[/]")
            console.print()


