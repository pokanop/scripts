# Sentinel values that indicate "no real data"
_UNKNOWN_VALUES = {
    "unknown author", "unknown title", "unknown series", "unknown artist",
    "unknown album", "unknown show", "unknown", "",
}


def _is_unknown(value) -> bool:
    """Check if a metadata value is effectively missing."""
    if value is None:
        return True
    if isinstance(value, (int, float)):
        return False
    return str(value).strip().lower() in _UNKNOWN_VALUES


# Per handler-type, which fields are critical and how to label them
_CRITICAL_FIELDS = {
    "books": [
        ("Title",  "Title"),
        ("Author", "Author"),
    ],
    "audiobooks": [
        ("Title",  "Title"),
        ("Author", "Author"),
    ],
    "comics": [
        ("Series", "Series"),
        ("Issue",  "Issue #"),
    ],
    "manga": [
        ("Series", "Series"),
        ("Volume", "Volume"),
    ],
    "movies": [
        ("Title", "Title"),
        ("Year",  "Year"),
    ],
    "shows": [
        ("Show",    "Show name"),
        ("Season",  "Season"),
        ("Episode", "Episode"),
    ],
    "music": [
        ("Artist", "Artist"),
        ("Title",  "Track title"),
    ],
    "documentaries": [
        ("Title", "Title"),
        ("Year",  "Year"),
    ],
}


def prompt_missing_metadata(metadata: dict, handler, filepath: str) -> dict:
    """Prompt the user to fill in critical metadata that couldn't be determined.

    Only prompts in interactive (TTY) sessions. In batch/piped mode, returns
    metadata as-is with defaults intact.

    Returns the (possibly updated) metadata dict.
    """
    import sys

    # Don't prompt if stdin is not a TTY (piped / batch mode)
    if not sys.stdin.isatty():
        return metadata

    media_type = getattr(handler, "media_type", "unknown")
    fields = _CRITICAL_FIELDS.get(media_type, [])

    if not fields:
        return metadata

    # Check which fields are actually missing
    missing = []
    for key, label in fields:
        val = metadata.get(key)
        if _is_unknown(val):
            missing.append((key, label))

    if not missing:
        return metadata

    # Determine source quality — if enrichment succeeded, don't nag
    source = metadata.get("Source", "filename")
    enriched = source in (
        "Google Books API", "Open Library", "MusicBrainz",
        "ComicVine", "TMDb", "IMDb",
    )
    if enriched:
        return metadata

    # Show a warning header
    fname = Path(filepath).name
    console.print()
    console.print(
        f"[yellow]⚠ Could not determine all metadata for[/] [bold]{escape(fname)}[/]"
    )
    console.print("[dim]  Fill in the blanks, or press Enter to use the default.[/]")
    console.print()

    for key, label in missing:
        current = metadata.get(key, "")
        # For numeric fields, show the raw default
        if key in ("Issue", "Volume", "Season", "Episode", "Track", "Year"):
            prompt_label = f"  {label}"
            default_display = str(current) if current else ""
        else:
            prompt_label = f"  {label}"
            default_display = str(current) if not _is_unknown(current) else ""

        val = _prompt(prompt_label, default=default_display)
        if val:
            # Try to coerce numeric fields
            if key in ("Issue", "Volume", "Season", "Episode", "Track", "Year"):
                try:
                    if "." in val:
                        val = float(val)
                    else:
                        val = int(val)
                except ValueError:
                    pass  # Keep as string
            metadata[key] = val

    # Re-derive title from filename if still unknown
    if _is_unknown(metadata.get("Title")) and not _is_unknown(metadata.get("Series")):
        metadata.setdefault("Title", Path(filepath).stem)

    return metadata


