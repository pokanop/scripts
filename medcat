# Recognised URL patterns — return source name + optional parsing
URL_PATTERNS = [
    # YouTube / YouTube Music / Shorts
    (r"^(https?://)?(www\.|music\.)?(youtube\.com/watch\?v=|youtu\.be/|youtube\.com/shorts/)", "youtube"),
    # Internet Archive
    (r"^(https?://)?archive\.org/(details|download)/", "archive"),
    # Magnet links
    (r"^magnet:\?xt=urn:btih:", "magnet"),
    # Torrent files
    (r"\.torrent(\?.*)?$", "torrent"),
]


def _looks_like_url(s: str) -> bool:
    """Return True when the string is likely a URL (or magnet link)."""
    s = s.strip()
    return s.startswith(("http://", "https://", "magnet:"))


def _classify_url(url: str) -> str:
    """Classify a URL into: youtube, archive, magnet, torrent, direct, unknown."""
    url = url.strip()
    for pattern, source in URL_PATTERNS:
        if re.search(pattern, url, re.IGNORECASE):
            return source
    # Recognise generic torrent file URLs
    if url.lower().endswith(".torrent"):
        return "torrent"
    return "direct"


def _guess_media_type_from_url(url: str, content_type: str = "") -> Optional[str]:
    """Guess the medcat media type from URL path or Content-Type header."""
    # Try Content-Type first
    ct = content_type.lower()
    ct_map = {
        "application/epub+zip": "books",
        "application/pdf": "books",
        "application/x-cbz": "comics",
        "application/x-cbr": "comics",
        "audio/mpeg": "music",
        "audio/flac": "music",
        "audio/m4b": "audiobooks",
        "audio/aac": "audiobooks",
        "audio/x-m4a": "audiobooks",
        "video/mp4": "movies",
        "video/x-matroska": "movies",
        "video/webm": "movies",
    }
    for prefix, mt in ct_map.items():
        if prefix in ct:
            return mt

    # Try file extension from URL path
    ext = Path(urlparse(url).path).suffix.lower()
    ext_map = {
        ".epub": "books",
        ".pdf": "books",
        ".cbz": "comics",
        ".cbr": "comics",
        ".m4b": "audiobooks",
        ".aax": "audiobooks",
        ".aa": "audiobooks",
        ".mp3": "music",
        ".flac": "music",
        ".opus": "music",
        ".mkv": "movies",
        ".mp4": "movies",
        ".avi": "movies",
        ".mov": "movies",
        ".torrent": None,  # skip — handled separately
    }
    return ext_map.get(ext)


def _probe_youtube_url(url: str, audio_only: bool = False) -> Optional[SearchResult]:
    """Probe a YouTube URL with yt-dlp to get title, duration, and preview."""
    yt_dlp = shutil.which("yt-dlp")
    if not yt_dlp:
        return None

    try:
        cmd = [
            yt_dlp, "--dump-json", "--no-download", "--no-playlist",
            "--flat-playlist",
        ]
        proc = subprocess.run(
            cmd + [url],
            capture_output=True, text=True, timeout=20,
        )
        if proc.returncode != 0:
            return None
        import json as _json
        item = _json.loads(proc.stdout)

        duration = item.get("duration")
        dur_str = None
        if duration and isinstance(duration, (int, float)):
            mins, secs = divmod(int(duration), 60)
            hours, mins = divmod(mins, 60)
            dur_str = f"{hours}:{mins:02d}:{secs:02d}" if hours else f"{mins}:{secs:02d}"

        description = item.get("description", "")[:200] if item.get("description") else None

        title = item.get("title", "Unknown")
        channel = item.get("channel") or item.get("uploader", "")
        vid_id = item.get("id") or item.get("display_id", "")

        return SearchResult(
            title=title,
            source="youtube",
            guid=vid_id,
            identifier=vid_id,
            info_url=f"https://youtube.com/watch?v={vid_id}",
            download_url=f"https://youtube.com/watch?v={vid_id}",
            protocol="stream",
            media_type=None,  # caller can override
            author=channel,
            format=dur_str,
            description=description,
            raw=item,
        )
    except Exception:
        return None


def _probe_direct_url(url: str) -> Optional[SearchResult]:
    """Probe a direct file URL via HEAD request to get size, type, filename."""
    try:
        resp = requests.head(url, allow_redirects=True, timeout=15,
                             headers={"User-Agent": "medcat/2.1"})
        if resp.status_code >= 400:
            # Some servers reject HEAD — fall back to GET with stream
            resp = requests.get(url, allow_redirects=True, stream=True,
                                timeout=15,
                                headers={"User-Agent": "medcat/2.1"})
            resp.close()

        content_type = resp.headers.get("content-type", "").split(";")[0].strip()
        content_length = resp.headers.get("content-length")
        size = int(content_length) if content_length and content_length.isdigit() else None

        # Derive filename from URL path or Content-Disposition
        filename = None
        cd = resp.headers.get("content-disposition", "")
        cd_match = re.search(r'filename[^;=\n]*=["\']?([^"\';\n]*)', cd, re.IGNORECASE)
        if cd_match:
            filename = cd_match.group(1).strip()
        if not filename:
            filename = Path(urlparse(url).path).name or None

        # Derive media type
        media_type = _guess_media_type_from_url(url, content_type)

        return SearchResult(
            title=filename or url.rstrip("/").split("/")[-1] or "Unknown",
            source="direct",
            size=size,
            download_url=url,
            protocol="direct",
            media_type=media_type,
            format=content_type or "unknown",
            description=f"Content-Type: {content_type}" if content_type else None,
            guid=url,
        )
    except Exception:
        return None


def _download_direct_url(result: SearchResult, dest_dir: str) -> bool:
    """Download a direct HTTP/HTTPS file to a destination directory."""
    url = result.download_url
    if not url:
        return False

    # Derive safe output filename
    output_name = result.title
    if not output_name or output_name == "Unknown":
        output_name = Path(urlparse(url).path).name or "download"
    # Sanitise
    output_name = re.sub(r'[<>:"/\\|?*]', '_', output_name)
    out_path = os.path.join(dest_dir, output_name)

    # Prefer wget for resume support, fall back to requests
    wget = shutil.which("wget")
    if wget:
        console.print(f"[dim]  Using wget → {escape(out_path)}[/]")
        try:
            proc = subprocess.run(
                [wget, "-q", "--show-progress", "-O", out_path, url],
                timeout=600,
            )
            if proc.returncode == 0:
                console.print(f"[green]  ✓ Downloaded to {escape(out_path)}[/]")
                return True
        except subprocess.TimeoutExpired:
            console.print("[red]  ✗ wget timed out[/]")
            return False
        except Exception as e:
            console.print(f"[yellow]  ⚠ wget failed: {e} — falling back to requests[/]")

    # Fallback: requests streaming download
    console.print(f"[dim]  Downloading with requests → {escape(out_path)}[/]")
    try:
        r = requests.get(url, stream=True, timeout=120)
        if r.status_code >= 400:
            console.print(f"[red]  ✗ Download failed: HTTP {r.status_code}[/]")
            return False

        total = int(r.headers.get("content-length", 0))
        downloaded = 0
        last_pct = -1
        with open(out_path, "wb") as f:
            for chunk in r.iter_content(chunk_size=65536):
                f.write(chunk)
                downloaded += len(chunk)
                if total:
                    pct = int(downloaded / total * 100)
                    if pct >= last_pct + 10 or pct == 100:
                        console.print(f"[dim]    {pct}% ({_human_size(downloaded)} / {_human_size(total)})[/]")
                        last_pct = pct

        console.print(f"[green]  ✓ Downloaded to {escape(out_path)}[/]")
        return True
    except Exception as e:
        console.print(f"[red]  ✗ Download error: {e}[/]")
        return False


def _download_torrent_file(url: str, config: dict) -> bool:
    """Download a .torrent file and send it to the torrent client."""
    try:
        r = requests.get(url, timeout=30)
        if r.status_code != 200:
            console.print(f"[red]  ✗ Failed to fetch .torrent: HTTP {r.status_code}[/]")
            return False

        torrent_data = r.content

        # If the response IS a magnet link or torrent data, handle accordingly
        if "magnet:" in r.text[:20]:
            return _send_magnet_to_client(r.text.strip(), config)

        # Save to temp file and try to send to client
        tmp = tempfile.NamedTemporaryFile(suffix=".torrent", delete=False)
        try:
            tmp.write(torrent_data)
            tmp.close()

            # Try qBittorrent
            qbt = config.get("services", {}).get("qbittorrent", {})
            if qbt.get("url"):
                session = requests.Session()
                auth = session.post(
                    qbt["url"].rstrip("/") + "/api/v2/auth/login",
                    data={"username": qbt.get("username", "admin"),
                          "password": qbt.get("password", "")},
                    timeout=10,
                )
                if auth.status_code == 200:
                    with open(tmp.name, "rb") as tf:
                        resp = session.post(
                            qbt["url"].rstrip("/") + "/api/v2/torrents/add",
                            files={"torrents": ("file.torrent", tf, "application/x-bittorrent")},
                            timeout=15,
                        )
                    if resp.status_code == 200:
                        console.print("[green]  ✓ Torrent added to qBittorrent[/]")
                        return True
                    else:
                        console.print(f"[yellow]  ⚠ qBittorrent rejected torrent: HTTP {resp.status_code}[/]")

            # Try Deluge
            deluge = config.get("services", {}).get("deluge", {})
            if deluge.get("url"):
                import base64
                encoded = base64.b64encode(torrent_data).decode()
                # Auth
                auth = requests.post(
                    deluge["url"].rstrip("/") + "/json",
                    json={"id": 1, "method": "auth.login",
                          "params": [deluge.get("password", "")]},
                    timeout=10,
                )
                cookie = auth.headers.get("Set-Cookie", "")
                headers = {"Cookie": cookie} if cookie else {}
                # Add torrent (base64-encoded)
                resp = requests.post(
                    deluge["url"].rstrip("/") + "/json",
                    json={"id": 2, "method": "core.add_torrent_file",
                          "params": ["medcat.torrent", encoded, {}]},
                    headers=headers,
                    timeout=10,
                )
                if resp.json().get("result"):
                    console.print("[green]  ✓ Torrent added to Deluge[/]")
                    return True
        finally:
            try:
                os.unlink(tmp.name)
            except OSError:
                pass

        console.print("[red]  ✗ Could not add torrent to any configured client[/]")
        return False
    except Exception as e:
        console.print(f"[red]  ✗ Torrent download error: {e}[/]")
        return False


