def _send_magnet_to_client(magnet_url: str, config: dict) -> bool:
    """Send a magnet link to the configured torrent client."""
    # Try Deluge first
    deluge = config.get("services", {}).get("deluge", {})
    if deluge.get("url"):
        if _deluge_add_magnet(magnet_url, deluge):
            return True

    # Try qBittorrent
    qbt = config.get("services", {}).get("qbittorrent", {})
    if qbt.get("url"):
        if _qbittorrent_add_magnet(magnet_url, qbt):
            return True

    console.print("[yellow]⚠ No torrent client configured. Run: [bold]medcat setup --section services[/][/]")
    return False


def _deluge_add_magnet(magnet_url: str, svc_config: dict) -> bool:
    """Add magnet to Deluge via Web UI JSON-RPC."""
    url = svc_config["url"].rstrip("/")
    password = svc_config.get("password", "")

    try:
        # Step 1: Authenticate
        auth = requests.post(
            f"{url}/json",
            json={"id": 1, "method": "auth.login", "params": [password]},
            timeout=10,
        )
        if auth.status_code != 200 or not auth.json().get("result"):
            console.print("[red]✗ Deluge auth failed[/]")
            return False

        cookie = auth.headers.get("Set-Cookie", "")
        headers = {"Cookie": cookie} if cookie else {}

        # Step 2: Add magnet
        resp = requests.post(
            f"{url}/json",
            json={"id": 2, "method": "core.add_torrent_magnet", "params": [magnet_url, {}]},
            headers=headers,
            timeout=10,
        )
        result = resp.json().get("result")
        if result:
            console.print(f"[green]  ✓ Added to Deluge: {escape(str(result)[:50])}[/]")
            return True
        else:
            console.print("[red]✗ Deluge rejected magnet[/]")
            return False

    except Exception as e:
        console.print(f"[red]✗ Deluge error: {e}[/]")
        return False


def _qbittorrent_add_magnet(magnet_url: str, svc_config: dict) -> bool:
    """Add magnet to qBittorrent via Web API."""
    url = svc_config["url"].rstrip("/")
    username = svc_config.get("username", "admin")
    password = svc_config.get("password", "")

    try:
        session = requests.Session()
        # Authenticate
        auth = session.post(
            f"{url}/api/v2/auth/login",
            data={"username": username, "password": password},
            timeout=10,
        )
        if auth.status_code != 200 or auth.text.strip().lower() not in ("ok", "ok."):
            console.print("[red]✗ qBittorrent auth failed[/]")
            return False

        # Add magnet
        resp = session.post(
            f"{url}/api/v2/torrents/add",
            data={"urls": magnet_url},
            timeout=10,
        )
        if resp.status_code == 200:
            console.print("[green]  ✓ Added to qBittorrent[/]")
            return True
        else:
            console.print(f"[red]✗ qBittorrent returned {resp.status_code}[/]")
            return False

    except Exception as e:
        console.print(f"[red]✗ qBittorrent error: {e}[/]")
        return False


