def trigger_kavita_scan(library_id: int, config: dict):
    """Trigger a Kavita library scan."""
    svc = config.get("services", {}).get("kavita", {})
    api_key = svc.get("api_key", "")
    url = svc.get("url", "")

    if not api_key or not url:
        console.print("[yellow]⚠ Kavita not configured. Run: [bold]medcat setup --section services[/][/]")
        return

    try:
        resp = requests.post(
            f"{url}/api/library/scan?libraryId={library_id}",
            headers={"X-API-Key": api_key},
            timeout=10,
        )
        if resp.status_code == 200:
            console.print(f"[green]✓ Triggered Kavita library {library_id} scan[/]")
        else:
            console.print(f"[yellow]⚠ Kavita scan trigger returned {resp.status_code}[/]")
    except Exception as e:
        console.print(f"[yellow]⚠ Could not trigger Kavita scan: {e}[/]")


def trigger_readarr_scan(config: dict):
    """Trigger a Readarr library scan."""
    svc = config.get("services", {}).get("readarr", {})
    api_key = svc.get("api_key", "")
    url = svc.get("url", "")

    if not api_key or not url:
        return

    try:
        resp = requests.post(
            f"{url}/api/v1/command",
            json={"name": "RescanFolders"},
            headers={"X-Api-Key": api_key},
            timeout=10,
        )
        if resp.status_code in (200, 201):
            console.print("[green]✓ Triggered Readarr library scan[/]")
    except Exception as e:
        console.print(f"[yellow]⚠ Could not trigger Readarr scan: {e}[/]")


def trigger_arr_scan(service: str, command: str, config: dict, label: str):
    """Trigger a Radarr/Sonarr/Lidarr disk scan."""
    svc = config.get("services", {}).get(service, {})
    api_key = svc.get("api_key", "")
    url = svc.get("url", "").rstrip("/")
    api_version = "v3" if service in ("radarr", "sonarr") else "v1"

    if not api_key or not url:
        console.print(
            f"[yellow]⚠ {label} not configured. "
            f"Run: [bold]medcat setup --section services[/][/]"
        )
        return

    try:
        resp = requests.post(
            f"{url}/api/{api_version}/command",
            json={"name": command},
            headers={"X-Api-Key": api_key},
            timeout=10,
        )
        if resp.status_code in (200, 201):
            console.print(f"[green]✓ Triggered {label} {command}[/]")
        else:
            console.print(f"[yellow]⚠ {label} scan trigger returned {resp.status_code}[/]")
    except Exception as e:
        console.print(f"[yellow]⚠ Could not trigger {label} scan: {e}[/]")


def trigger_scan(media_type: str, config: dict):
    """Trigger appropriate scan based on media type."""
    dest = config.get("destinations", {}).get(media_type, {})
    scan_service = dest.get("scan", "")

    if scan_service == "kavita":
        library_id = dest.get("scan_library_id", 1)
        trigger_kavita_scan(library_id, config)
    elif scan_service == "readarr":
        trigger_readarr_scan(config)
    elif scan_service == "radarr":
        trigger_arr_scan("radarr", "DownloadedMoviesScan", config, "Radarr")
    elif scan_service == "sonarr":
        trigger_arr_scan("sonarr", "DownloadedEpisodesScan", config, "Sonarr")
    elif scan_service == "lidarr":
        trigger_arr_scan("lidarr", "DownloadedAlbumsScan", config, "Lidarr")
    elif scan_service == "abs":
        console.print("[dim]Audiobookshelf uses folder watcher — scan not needed[/]")


