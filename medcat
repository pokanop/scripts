def destination_root_is_local(dest_config: dict) -> bool:
    """Return True when the configured destination root is mounted locally."""
    root = dest_config.get("path", "")
    return bool(root) and os.path.isdir(root)


def _get_transport_host(dest_config: dict, config: dict) -> str:
    """Get transport host from dest config (legacy) or global transport config."""
    # Per-destination host override (backward compat)
    host = dest_config.get("nfs_host", "")
    if host:
        return host
    # Global transport config
    tc = get_transport_config(config)
    return tc.get("host", "")


def _transport_ssh_scp_bases(config: dict) -> tuple[list[str], list[str]]:
    """Build SSH/SCP base command lists from transport config."""
    tc = get_transport_config(config)
    timeout = str(tc.get("ssh_timeout", 5))
    ssh_base = ["ssh", "-o", f"ConnectTimeout={timeout}", "-F", "/dev/null", "-o", "BatchMode=yes"]
    scp_base = ["scp", "-o", f"ConnectTimeout={timeout}", "-F", "/dev/null", "-o", "BatchMode=yes"]
    ssh_key = tc.get("ssh_key", "")
    if ssh_key and os.path.exists(ssh_key):
        ssh_base += ["-i", ssh_key]
        scp_base += ["-i", ssh_key]
    return ssh_base, scp_base


def _run_transport(cmd: list[str], action: str) -> None:
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        if detail:
            detail = f": {detail.splitlines()[-1]}"
        raise RuntimeError(f"{action} failed (exit {result.returncode}){detail}")


def _verify_local_copy(dest_file: Path, expected_size: int) -> None:
    if not dest_file.is_file():
        raise RuntimeError(f"Destination file missing after copy: {dest_file}")
    actual_size = dest_file.stat().st_size
    if actual_size != expected_size:
        raise RuntimeError(
            f"Destination file size mismatch for {dest_file} "
            f"(expected {expected_size}, got {actual_size})"
        )


def _verify_remote_copy(host: str, remote_path: str, expected_size: int, ssh_base: list[str]) -> None:
    quoted = shlex.quote(remote_path)
    result = subprocess.run(
        ssh_base + [f"root@{host}", f"test -f {quoted} && stat -c %s {quoted}"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        raise RuntimeError(f"Destination file missing on {host}: {remote_path}")
    try:
        remote_size = int(result.stdout.strip())
    except ValueError as exc:
        raise RuntimeError(f"Could not verify remote file: {remote_path}") from exc
    if remote_size != expected_size:
        raise RuntimeError(
            f"Remote file size mismatch for {remote_path} "
            f"(expected {expected_size}, got {remote_size})"
        )


def ensure_destination_dir(remote_path: str, dest_config: dict, config: dict):
    """Create destination directory, handling SSH if path is remote."""
    if destination_root_is_local(dest_config):
        os.makedirs(remote_path, exist_ok=True)
        return

    host = _get_transport_host(dest_config, config)
    if not host:
        raise RuntimeError(
            f"Destination path '{remote_path}' is not local and no transport host configured. "
            "Run: medcat setup"
        )
    ssh_base, _ = _transport_ssh_scp_bases(config)
    _run_transport(
        ssh_base + [f"root@{host}", f"mkdir -p {shlex.quote(remote_path)}"],
        f"Creating remote directory on {host}",
    )


def copy_to_destination(local_file: Path, dest_file: Path, dest_config: dict, config: dict):
    """Copy file to destination, using SCP if the destination root is not mounted locally."""
    local_file = Path(local_file)
    if not local_file.is_file():
        raise RuntimeError(f"Source file not found: {local_file}")

    expected_size = local_file.stat().st_size
    dest_dir = dest_file.parent

    if destination_root_is_local(dest_config):
        os.makedirs(dest_dir, exist_ok=True)
        shutil.copy2(local_file, dest_file)
        _verify_local_copy(dest_file, expected_size)
        return

    host = _get_transport_host(dest_config, config)
    if not host:
        raise RuntimeError(
            f"Destination path '{dest_file}' is not local and no transport host configured. "
            "Run: medcat setup"
        )
    ssh_base, scp_base = _transport_ssh_scp_bases(config)
    remote_dir = str(dest_dir)
    remote_file = str(dest_file)
    remote_target = f"root@{host}:{shlex.quote(remote_file)}"

    _run_transport(
        ssh_base + [f"root@{host}", f"mkdir -p {shlex.quote(remote_dir)}"],
        f"Creating remote directory on {host}",
    )
    _run_transport(
        scp_base + [str(local_file), remote_target],
        f"Copying to {host}",
    )
    _verify_remote_copy(host, remote_file, expected_size, ssh_base)


