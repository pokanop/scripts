def cmd_ingest(args):
    """Handle 'ingest' command."""
    config = load_config()

    if _needs_setup():
        console.print("[yellow]⚠ medcat hasn't been configured yet. Run [bold]medcat setup[/] first.[/]")
        console.print()

    # Validate dest type
    media_type = args.dest
    if not media_type:
        # Detect from first file
        files = find_media_files(args.paths[0])
        if files:
            media_type = detect_media_type(files[0])
        else:
            media_type = "books"

    if media_type not in HANDLERS:
        console.print(f"[red]Unknown media type: {media_type}[/]")
        console.print(f"[dim]Supported types: {', '.join(HANDLERS.keys())}[/]")
        sys.exit(1)

    handler = HANDLERS[media_type]
    dest_config = config.get("destinations", {}).get(media_type, {})

    if not dest_config or not dest_config.get("path"):
        console.print(f"[red]No destination configured for: {media_type}[/]")
        console.print("[dim]Run: medcat setup --section destinations[/]")
        sys.exit(1)

    # Collect all files
    all_files = []
    for path in args.paths:
        all_files.extend(find_media_files(path, media_type))

    if not all_files:
        console.print("[yellow]No matching media files found.[/]")
        return

    host = _get_transport_host(dest_config, config)
    transport = (
        "local"
        if destination_root_is_local(dest_config)
        else (f"SCP → {host}" if host else "remote (no host)")
    )
    console.print(f"[bold]{handler.human_name}[/] → [dim]{escape(dest_config['path'])}[/] [dim]({escape(transport)})[/]")
    console.print(f"[dim]Found {len(all_files)} file(s) to process[/]")
    if args.dry_run:
        console.print("[yellow]🔍 DRY RUN — no files will be moved[/]")

    # Process files
    results = []
    process_kwargs = {
        "media_type": media_type,
        "config": config,
        "dry_run": args.dry_run,
        "no_enrich": args.no_enrich,
        "no_prompt": args.no_prompt,
        "scan": args.scan,
        "yes": args.yes,
    }
    interactive = not args.yes and not args.dry_run

    if interactive:
        # Progress bars refresh the terminal and hide console.input() prompts.
        for i, filepath in enumerate(all_files, 1):
            if len(all_files) > 1:
                console.print(f"\n[dim]File {i}/{len(all_files)}[/]")
            results.append(process_file(filepath, **process_kwargs))
    else:
        with Progress(
            SpinnerColumn(),
            TextColumn("[progress.description]{task.description}"),
            BarColumn(),
            TaskProgressColumn(),
            console=console,
        ) as progress:
            task = progress.add_task(f"Processing {handler.human_name.lower()}...", total=len(all_files))
            for filepath in all_files:
                results.append(process_file(filepath, **process_kwargs))
                progress.update(task, advance=1)

    # Summary
    ok = [r for r in results if r["status"] == "ok"]
    skipped = [r for r in results if r["status"] == "skipped"]
    errors = [r for r in results if r["status"] == "error"]
    cancelled = [r for r in results if r["status"] == "cancelled"]

    summary = []
    if ok:
        summary.append(f"[green]{len(ok)} ingested[/]")
    if skipped:
        summary.append(f"[yellow]{len(skipped)} skipped[/]")
    if errors:
        summary.append(f"[red]{len(errors)} errors[/]")
    if cancelled:
        summary.append(f"[dim]{len(cancelled)} cancelled[/]")

    if summary:
        console.print(f"\n[bold]Summary:[/] {' | '.join(summary)}")

    if errors:
        console.print("\n[red]Errors:[/]")
        for r in errors:
            console.print(f"  [red]✗[/] {r['file']}: {r.get('error', 'unknown')}")

    if not args.dry_run and ok and not args.scan:
        console.print("\n[dim]💡 Run [bold]medcat scan --service kavita[/] (or another service) to refresh the library after ingestion.[/]")


def cmd_identify(args):
    """Handle 'identify' command."""
    config = load_config()

    files = []
    for path in args.paths:
        files.extend(find_media_files(path))

    if not files:
        console.print("[yellow]No files found.[/]")
        return

    for filepath in files:
        media_type = detect_media_type(filepath)
        handler = get_handler(media_type)
        if not handler:
            console.print(f"[dim]{filepath}[/] → [yellow]unknown type[/]")
            continue

        dest_config = config.get("destinations", {}).get(media_type, {})
        metadata = handler.extract_metadata(filepath)

        if not args.no_enrich:
            metadata = handler.enrich_metadata(metadata)

        dest_file = handler.build_destination(metadata, dest_config)

        result = {"status": "ok", "file": filepath, "dest": str(dest_file),
                  "metadata": metadata, "media_type": media_type, "handler": handler}
        render_file_result(result)
        console.print(f"  → [dim]{dest_file}[/]")


def cmd_scan(args):
    """Handle 'scan' command."""
    config = load_config()

    service = args.service
    if not service:
        # Default to first configured service with scan capability
        for svc_name in KNOWN_SERVICES:
            if svc_name in config.get("services", {}):
                service = svc_name
                break
    if not service:
        console.print("[yellow]No services configured. Run: [bold]medcat setup --section services[/][/]")
        return

    library_id = args.library_id or 1

    if service == "kavita":
        trigger_kavita_scan(library_id, config)
    elif service == "readarr":
        trigger_readarr_scan(config)
    elif service == "radarr":
        trigger_arr_scan("radarr", "DownloadedMoviesScan", config, "Radarr")
    elif service == "sonarr":
        trigger_arr_scan("sonarr", "DownloadedEpisodesScan", config, "Sonarr")
    elif service == "lidarr":
        trigger_arr_scan("lidarr", "DownloadedAlbumsScan", config, "Lidarr")
    else:
        console.print(f"[yellow]Scan not implemented for: {service}[/]")
        console.print(f"[dim]Supported: {', '.join(KNOWN_SERVICES.keys())}[/]")


