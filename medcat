def extract_epub_metadata(filepath: str) -> dict:
    """Extract metadata from EPUB file by parsing OPF directly from the ZIP."""
    metadata = {
        "Title": Path(filepath).stem,
        "Author": "Unknown Author",
        "ext": Path(filepath).suffix.lower().lstrip("."),
        "Source": "filename",
    }
    try:
        import zipfile
        import xml.etree.ElementTree as ET

        with zipfile.ZipFile(filepath, 'r') as zf:
            # Find the container.xml to locate the OPF
            container = None
            try:
                container = ET.fromstring(zf.read("META-INF/container.xml"))
            except:
                pass

            opf_path = None
            if container is not None:
                for rootfile in container.iter():
                    tag = rootfile.tag.split('}')[-1] if '}' in rootfile.tag else rootfile.tag
                    if tag == 'rootfile':
                        opf_path = rootfile.attrib.get('full-path', '')
                        break

            if not opf_path:
                # Fallback: search for any .opf file
                for name in zf.namelist():
                    if name.lower().endswith('.opf'):
                        opf_path = name
                        break

            if not opf_path:
                return metadata

            opf_xml = zf.read(opf_path)
            root = ET.fromstring(opf_xml)

        # Namespace map
        opf_ns = 'http://www.idpf.org/2007/opf'

        def find_text(tag_local):
            """Find text content for a tag, handling namespaces."""
            for child in root.iter():
                t = child.tag.split('}')[-1] if '}' in child.tag else child.tag
                if t == tag_local and child.text:
                    return child.text.strip()
            return None

        # Dublin Core elements
        for child in root.iter():
            tag = child.tag.split('}')[-1] if '}' in child.tag else child.tag
            if tag == 'title' and child.text:
                metadata["Title"] = child.text.strip()
            elif tag == 'creator' and child.text:
                metadata["Author"] = child.text.strip()
            elif tag == 'publisher' and child.text:
                metadata["Publisher"] = child.text.strip()
            elif tag == 'language' and child.text:
                metadata["Language"] = child.text.strip()
            elif tag == 'date' and child.text:
                metadata["Year"] = child.text.strip()[:4]
            elif tag == 'identifier' and child.text:
                val = child.text.strip()
                clean = val.replace('-', '').replace(' ', '')
                # Check for ISBN in scheme attribute or numeric pattern
                scheme = child.attrib.get(f'{{{opf_ns}}}scheme', '').lower()
                if 'isbn' in scheme or (len(clean) in (10, 13) and clean.isdigit()):
                    metadata["ISBN"] = clean

        metadata["Source"] = "EPUB metadata"

    except Exception as e:
        metadata["_error"] = str(e)

    return metadata


def extract_pdf_metadata(filepath: str) -> dict:
    """Extract metadata from PDF file."""
    metadata = {}
    try:
        import fitz  # pymupdf

        doc = fitz.open(filepath)
        pdf_meta = doc.metadata

        title = pdf_meta.get("title", "") or Path(filepath).stem
        author = pdf_meta.get("author", "") or "Unknown Author"
        metadata["Title"] = title
        metadata["Author"] = author
        if pdf_meta.get("subject"):
            metadata["Subject"] = pdf_meta["subject"]

        # Check for ISBN in XMP metadata
        xmp = doc.xref_get_key(-1, "Info")
        if xmp and "ISBN" in str(xmp):
            import re as _re
            m = _re.search(r"ISBN[:\s]+([\d-]+)", str(xmp))
            if m:
                metadata["ISBN"] = m.group(1).replace("-", "")

        ext = Path(filepath).suffix.lower()
        metadata["ext"] = ext.lstrip(".")
        metadata["Source"] = "PDF XMP"
        doc.close()

    except Exception as e:
        metadata["Title"] = Path(filepath).stem
        ext = Path(filepath).suffix.lower()
        metadata["ext"] = ext.lstrip(".")
        metadata["Source"] = "filename"
        metadata["_error"] = str(e)

    return metadata


def _parse_comicinfo_xml(xml_data: bytes, metadata: dict) -> dict:
    """Parse ComicInfo.xml bytes into metadata fields."""
    root = ET.fromstring(xml_data)
    for elem in root.iter():
        tag = elem.tag.split("}")[-1] if "}" in elem.tag else elem.tag
        if tag == "Title" and elem.text:
            metadata["Title"] = elem.text
        elif tag == "Series" and elem.text:
            metadata["Series"] = elem.text
        elif tag == "Number" and elem.text:
            try:
                metadata["Issue"] = int(elem.text)
            except ValueError:
                pass
        elif tag == "Writer" and elem.text:
            metadata["Author"] = elem.text
        elif tag == "Volume" and elem.text:
            try:
                metadata["Volume"] = int(elem.text)
            except ValueError:
                pass
    metadata["Source"] = "ComicInfo.xml"
    return metadata


def _read_comicinfo_xml(filepath: str) -> Optional[bytes]:
    """Read ComicInfo.xml from a CBZ or CBR archive."""
    import zipfile

    lower = filepath.lower()
    if lower.endswith(".cbz"):
        with zipfile.ZipFile(filepath, "r") as zf:
            for name in zf.namelist():
                if name.lower().endswith("comicinfo.xml"):
                    return zf.read(name)
        return None

    if lower.endswith(".cbr"):
        with tempfile.TemporaryDirectory() as tmp:
            tmp_path = Path(tmp)
            extract_cmds = [
                ["7z", "e", "-y", f"-o{tmp}", filepath, "ComicInfo.xml"],
                ["unar", "-q", "-o", tmp, filepath],
                ["bsdtar", "-xf", filepath, "-C", tmp],
            ]
            for cmd in extract_cmds:
                try:
                    subprocess.run(cmd, capture_output=True, timeout=60, check=False)
                except (FileNotFoundError, subprocess.TimeoutExpired):
                    continue
                for candidate in tmp_path.rglob("ComicInfo.xml"):
                    return candidate.read_bytes()
                comicinfo = tmp_path / "ComicInfo.xml"
                if comicinfo.exists():
                    return comicinfo.read_bytes()
        return None

    return None


def extract_comic_metadata(filepath: str) -> dict:
    """Extract metadata from CBZ/CBR comic archive."""
    metadata = {
        "Title": Path(filepath).stem,
        "Author": "Unknown Author",
        "Series": Path(filepath).stem,
        "ext": Path(filepath).suffix.lower().lstrip("."),
        "Source": "filename",
    }
    try:
        xml_data = _read_comicinfo_xml(filepath)
        if xml_data:
            _parse_comicinfo_xml(xml_data, metadata)
    except Exception as e:
        metadata["_error"] = str(e)

    return metadata


def extract_audiobook_metadata(filepath: str) -> dict:
    """Extract metadata from audiobook file (M4B/MP3)."""
    metadata = {"Title": Path(filepath).stem, "Author": "Unknown Author",
                "ext": Path(filepath).suffix.lower().lstrip("."), "Source": "ffprobe"}

    try:
        result = subprocess.run(
            ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", filepath],
            capture_output=True, text=True, timeout=30,
        )
        if result.returncode == 0:
            fmt = json.loads(result.stdout).get("format", {}).get("tags", {})
            if fmt.get("title"):
                metadata["Title"] = fmt["title"]
            if fmt.get("artist"):
                metadata["Author"] = fmt["artist"]
            elif fmt.get("album_artist"):
                metadata["Author"] = fmt["album_artist"]
            if fmt.get("album"):
                metadata["Album"] = fmt["album"]
            if fmt.get("isbn"):
                metadata["ISBN"] = fmt["isbn"]
            metadata["Source"] = "ffprobe tags"
    except Exception:
        pass

    return metadata


def extract_filename_metadata(filepath: str, media_type: str) -> dict:
    """Extract metadata from filename using heuristics."""
    stem = Path(filepath).stem
    ext = Path(filepath).suffix.lower().lstrip(".")
    metadata = {"Title": stem, "ext": ext, "Source": "filename"}

    if media_type == "shows":
        # Show Name S01E01 or Show.Name.S01E01
        m = re.search(r"(.+?)[.\s]+[Ss](\d{2})[Ee](\d{2})", stem)
        if m:
            metadata["Show"] = m.group(1).replace(".", " ").strip()
            metadata["Season"] = int(m.group(2))
            metadata["Episode"] = int(m.group(3))
            metadata["Title"] = f"{metadata['Show']} S{m.group(2)}E{m.group(3)}"

    elif media_type == "movies":
        # Title (Year) or Title.Year
        m = re.search(r"(.+?)[.\s]+\(?(\d{4})\)?", stem)
        if m:
            metadata["Title"] = m.group(1).replace(".", " ").strip()
            metadata["Year"] = m.group(2)

        # Quality indicators
        for qual in ["1080p", "2160p", "720p", "HDR", "DV", "WEB-DL", "BluRay"]:
            if qual.lower() in stem.lower():
                metadata.setdefault("Quality", []).append(qual)

    elif media_type == "music":
        # Artist - Album - Track# - Title
        parts = re.split(r"\s*[-–—]\s*", stem)
        if len(parts) >= 2:
            metadata["Artist"] = parts[0].strip()
            metadata["Title"] = parts[-1].strip()
            if len(parts) == 3:
                metadata["Album"] = parts[1].strip()
            elif len(parts) == 4:
                metadata["Album"] = parts[1].strip()
                try:
                    metadata["Track"] = int(re.search(r"\d+", parts[2]).group())
                except:
                    pass

    return metadata


