#!/usr/bin/env python3
"""
medcat — Media Stack Ingest Tool  v2.3.0
Ingest media files into your media stack with metadata enrichment.

Supported types: books (EPUB/PDF), comics (CBZ/CBR), audiobooks (M4B/MP3),
movies (MKV/MP4), shows (MKV/MP4), music (FLAC/MP3), documentaries (MKV/MP4).

Architecture:
    Handler adapters (BookHandler, ComicHandler, MovieHandler, etc.)
    → extract internal metadata (EPUB OPF, PDF XMP, ComicInfo.xml, ffprobe)
    → enrich via free APIs (Google Books, Open Library, MusicBrainz, filename heuristics)
    → organize into destination directory structure
    → optionally trigger service scan (Kavita, Readarr, Radarr, Sonarr, Lidarr)

Direct URL grab:
    Auto-routes any URL to the correct handler:
    → YouTube/YouTube Music → yt-dlp (video or audio extraction)
    → Magnet links → torrent client (Deluge/qBittorrent)
    → Archive.org → Internet Archive download
    → Torrent files (.torrent) → torrent client
    → HTTP/HTTPS direct files → content-type detection + download

Configuration:
    Zero hardcoded secrets or hosts. All config lives in ~/.medcat/config.json.
    Environment variables (MEDCAT_*) override file config.
    Run 'medcat setup' for interactive first-launch configuration.

Dependencies:
    pip install rich ebooklib pymupdf musicbrainzngs requests

Usage:
    # First-time interactive setup
    medcat setup
    medcat setup --section services

    # Identify (just show what would happen, don't move)
    medcat identify book.epub
    medcat identify ~/Downloads/*.epub

    # Ingest to default destination based on file type
    medcat ingest book.epub
    medcat ingest --dest books ~/Downloads/

    # Dry run — show what would happen without doing it
    medcat ingest --dest comics ./comics/ --dry-run

    # Auto-scan after ingest
    medcat ingest book.epub --scan

    # Grab any URL — auto-detects source, downloads, optionally ingests
    medcat grab https://youtube.com/watch?v=dQw4w9WgXcQ
    medcat grab https://youtube.com/watch?v=dQw4w9WgXcQ --audio
    medcat grab magnet:?xt=urn:btih:... --type movies
    medcat grab https://archive.org/details/example --type books
    medcat grab https://example.com/file.epub
    medcat grab URL --dest music --scan

    # Search for media
    medcat search "Dune"
    medcat search "Foundation" --type books
    medcat search https://youtube.com/watch?v=...   # auto-grabs URLs

    # Manage config
    medcat config get services.kavita.url
    medcat config set services.radarr.api_key YOUR_KEY
    medcat config list destinations
    medcat config --check
    medcat config test

    # Trigger a service scan
    medcat scan --service kavita --library-id 1
    medcat scan --service readarr
"""

