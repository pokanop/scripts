def _youtube_search(query: str, media_type: str = None, limit: int = 15) -> list:
    """Search YouTube. Returns list of SearchResult."""
    yt_dlp = shutil.which("yt-dlp")
    if not yt_dlp:
        console.print("[yellow]⚠ yt-dlp not found. Install: pip install yt-dlp[/]")
        return []

    try:
        cmd = [
            yt_dlp, "--flat-playlist", "--dump-json", "--no-download",
            f"--playlist-end={limit}",
            f"ytsearch{limit}:{query}",
        ]
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=30)

        if proc.returncode != 0:
            # Try line-by-line parsing
            results = []
            for line in proc.stdout.strip().split("\n"):
                if not line.strip():
                    continue
                try:
                    import json as _json
                    item = _json.loads(line)
                    results.append(item)
                except Exception:
                    continue
        else:
            import json as _json
            results = [_json.loads(line) for line in proc.stdout.strip().split("\n") if line.strip()]

        out = []
        for item in results:
            duration = item.get("duration")
            # Format duration
            if duration and isinstance(duration, (int, float)):
                mins, secs = divmod(int(duration), 60)
                hours, mins = divmod(mins, 60)
                dur_str = f"{hours}:{mins:02d}:{secs:02d}" if hours else f"{mins}:{secs:02d}"
            else:
                dur_str = "—"

            r = SearchResult(
                title=item.get("title", "?"),
                source="youtube",
                guid=item.get("id"),
                identifier=item.get("id"),
                info_url=f"https://youtube.com/watch?v={item.get('id', '')}",
                download_url=f"https://youtube.com/watch?v={item.get('id', '')}",
                size=None,
                protocol="stream",
                media_type=media_type,
                author=item.get("channel"),
                format=dur_str,
                raw=item,
            )
            out.append(r)
        return out

    except subprocess.TimeoutExpired:
        console.print("[yellow]⚠ YouTube search timed out[/]")
        return []
    except Exception as e:
        console.print(f"[red]✗ YouTube search error: {e}[/]")
        return []


def _youtube_download(result: SearchResult, dest_dir: str = None,
                      audio_only: bool = False) -> bool:
    """Download a YouTube video/audio using yt-dlp.

    Video format strategy (QuickTime / Apple ecosystem compatible):
        1. H.264 video + AAC audio in MP4  (universal, no re-encode)
        2. Any video + AAC audio in MP4     (may remux VP9/AV1 video)
        3. Best single pre-merged stream    (fallback, still MP4)

    Audio-only: extracted to MP3 at highest quality.
    """
    yt_dlp = shutil.which("yt-dlp")
    if not yt_dlp:
        console.print("[red]✗ yt-dlp not found. Install: pip install yt-dlp[/]")
        return False

    dest = dest_dir or tempfile.mkdtemp(prefix="medcat_yt_")
    url = result.download_url or result.info_url
    if not url:
        return False

    cmd = [yt_dlp, "--no-playlist", "-o", os.path.join(dest, "%(title)s.%(ext)s")]

    if audio_only or result.media_type in ("music", "audiobooks"):
        cmd += ["-x", "--audio-format", "mp3", "--audio-quality", "0"]
    else:
        # Format selection that ensures QuickTime / macOS / iOS compatibility.
        #
        # YouTube serves its best video in VP9 (webm) or AV1 — codecs that
        # QuickTime cannot decode.  The old format string
        #   bestvideo[ext=mp4]+bestaudio[ext=m4a]
        # could still pick VP9 video (ext is about the *container*, not the
        # codec) or pair H.264 video with Opus audio, both of which cause
        # "media not compatible" errors in QuickTime.
        #
        # Fix: explicitly request H.264 video (vcodec^=avc1) + AAC audio
        # (acodec^=mp4a) in an MP4 container.  Fall back progressively to
        # any MP4 pre-merged stream, then to remuxing whatever we get.
        cmd += [
            "-f",
            # 1) Ideal: H.264 + AAC (no re-encode needed)
            "bestvideo[vcodec^=avc1][ext=mp4]+bestaudio[acodec^=mp4a]/"
            # 2) H.264 video + any audio → remux to MP4
            "bestvideo[vcodec^=avc1]+bestaudio/"
            # 3) Any pre-merged MP4 (often 720p)
            "best[ext=mp4]/"
            # 4) Last resort: best single stream of any format
            "best",
            # Force output to MP4 container regardless of source format
            "--merge-output-format", "mp4",
            # Remux (no re-encode) into mp4 if the container isn't mp4
            "--remux-video", "mp4",
        ]

    cmd.append(url)

    try:
        console.print("[dim]  Downloading from YouTube...[/]")
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=600)
        if proc.returncode == 0:
            console.print(f"[green]  ✓ Downloaded to {escape(dest)}[/]")
            return True
        else:
            console.print(f"[red]  ✗ yt-dlp failed: {proc.stderr[:200]}[/]")
            return False
    except subprocess.TimeoutExpired:
        console.print("[red]  ✗ Download timed out[/]")
        return False


