        metadata = {"_filepath": filepath, "ext": Path(filepath).suffix.lower().lstrip("."),
                    "Source": "ffprobe", "Title": Path(filepath).stem, "Artist": "Unknown Artist",
                    "Album": "Unknown Album", "Track": 1}

        try:
            result = subprocess.run(
                ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_format", filepath],
                capture_output=True, text=True, timeout=30,
            )
            if result.returncode == 0:
                tags = json.loads(result.stdout).get("format", {}).get("tags", {})
                if tags.get("title"):
                    metadata["Title"] = tags["title"]
                if tags.get("artist"):
                    metadata["Artist"] = tags["artist"]
                if tags.get("album"):
                    metadata["Album"] = tags["album"]
                try:
                    if tags.get("track"):
                        metadata["Track"] = int(tags["track"].split("/")[0])
                except:
                    pass
        except Exception:
            pass

        if metadata["Artist"] == "Unknown Artist":
            filename_meta = extract_filename_metadata(filepath, "music")
            metadata.update(filename_meta)

        return metadata

    def enrich_metadata(self, metadata: dict) -> dict:
        return enrich_music_musicbrainz(metadata)


