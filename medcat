def enrich_books_google(metadata: dict) -> dict:
    """Enrich book metadata using Google Books API (free, no key needed)."""
    isbn = metadata.get("ISBN")
    title = metadata.get("Title", "")
    author = metadata.get("Author", "")

    if not title:
        return metadata

    try:
        if isbn:
            url = f"https://www.googleapis.com/books/v1/volumes?q=isbn:{isbn}"
        else:
            query = f'{title} {author}'.strip()
            url = f"https://www.googleapis.com/books/v1/volumes?q={requests.utils.quote(query)}"

        resp = requests.get(url, timeout=10)
        if resp.status_code != 200:
            return metadata

        data = resp.json()
        items = data.get("items", [])
        if not items:
            return metadata

        vol = items[0]["volumeInfo"]
        if vol.get("title"):
            metadata["Title"] = vol["title"]
        if vol.get("authors"):
            metadata["Author"] = vol["authors"][0]
        if vol.get("publisher"):
            metadata["Publisher"] = vol["publisher"]
        if vol.get("publishedDate"):
            metadata["Year"] = vol["publishedDate"][:4]
        if vol.get("description") and not metadata.get("Description"):
            metadata["Description"] = vol["description"]
        if vol.get("categories"):
            metadata["Categories"] = ", ".join(vol["categories"])

        # Industry identifiers
        for ident in vol.get("industryIdentifiers", []):
            if ident.get("type") == "ISBN_13":
                metadata["ISBN"] = ident["identifier"]
            elif ident.get("type") == "ISBN_10" and "ISBN" not in metadata:
                metadata["ISBN"] = ident["identifier"]

        metadata["Source"] = "Google Books API"

    except Exception:
        pass

    return metadata


def enrich_books_openlibrary(metadata: dict) -> dict:
    """Fallback enrichment via Open Library API (free, no key needed)."""
    if metadata.get("Source") == "Google Books API":
        return metadata  # Already enriched

    title = metadata.get("Title", "")
    author = metadata.get("Author", "")

    if not title:
        return metadata

    try:
        query = f'{title} {author}'.strip()
        url = f"https://openlibrary.org/search.json?q={requests.utils.quote(query)}&limit=1"
        resp = requests.get(url, timeout=10)
        if resp.status_code != 200:
            return metadata

        data = resp.json()
        docs = data.get("docs", [])
        if not docs:
            return metadata

        doc = docs[0]
        if doc.get("title"):
            metadata["Title"] = doc["title"]
        if doc.get("author_name"):
            metadata["Author"] = doc["author_name"][0]
        if doc.get("first_publish_year"):
            metadata["Year"] = str(doc["first_publish_year"])
        if doc.get("isbn"):
            metadata["ISBN"] = doc["isbn"][0]
        if doc.get("publisher"):
            metadata["Publisher"] = doc["publisher"][0] if isinstance(doc["publisher"], list) else doc["publisher"]

        metadata.setdefault("Source", "Open Library")

    except Exception:
        pass

    return metadata


def enrich_comics(metadata: dict) -> dict:
    """Enrich comic metadata — primarily from ComicInfo.xml already parsed."""
    # Comics primarily rely on ComicInfo.xml. If we got filename-only, try harder.
    if metadata.get("Source") == "filename":
        stem = Path(metadata.get("_filepath", "")).stem if metadata.get("_filepath") else ""
        # Try common naming: Series #Issue - Title
        m = re.match(r"(.+?)\s+#(\d+)(?:\s*[-–]\s*(.+))?", stem)
        if m:
            metadata["Series"] = m.group(1).strip()
            metadata["Issue"] = int(m.group(2))
            if m.group(3):
                metadata["Title"] = m.group(3).strip()
            else:
                metadata["Title"] = f"{m.group(1).strip()} #{m.group(2)}"

    return metadata


def enrich_music_musicbrainz(metadata: dict) -> dict:
    """Enrich music metadata using MusicBrainz API (free, rate-limited)."""
    title = metadata.get("Title", "")
    artist = metadata.get("Artist", "")

    if not title or not artist:
        return metadata

    try:
        import musicbrainzngs
        musicbrainzngs.set_useragent("medcat", __version__, "https://github.com/pokanop/scripts")
        musicbrainzngs.set_rate_limit(1)

        result = musicbrainzngs.search_recordings(
            recording=f'"{title}" AND artist:"{artist}"', limit=1
        )
        recordings = result.get("recording-list", [])
        if not recordings:
            return metadata

        rec = recordings[0]
        if rec.get("title"):
            metadata["Title"] = rec["title"]
        if rec.get("artist-credit"):
            metadata["Artist"] = rec["artist-credit"][0].get("artist", {}).get("name", artist)

        metadata.setdefault("Source", "MusicBrainz")
        time.sleep(1)  # Rate limit compliance

    except Exception:
        pass

    return metadata


