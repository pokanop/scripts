def _human_size(n: int) -> str:
    """Format byte count as human-readable string."""
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if abs(n) < 1024:
            return f"{n:.1f} {unit}" if isinstance(n, float) else f"{n} {unit}"
        n /= 1024
    return f"{n:.1f} PB"


def _format_age(age_minutes: float) -> str:
    """Format age in minutes as human-readable string."""
    if age_minutes < 60:
        return f"{int(age_minutes)}m ago"
    hours = age_minutes / 60
    if hours < 24:
        return f"{int(hours)}h ago"
    days = hours / 24
    if days < 30:
        return f"{int(days)}d ago"
    return f"{int(days / 30)}mo ago"


# ---------------------------------------------------------------------------
# Search result type
# ---------------------------------------------------------------------------


class SearchResult:
    """Normalized search result from any source."""

    def __init__(self, *, title, source, size=None, seeders=None, leechers=None,
                 age=None, guid=None, download_url=None, magnet_url=None,
                 info_url=None, indexer=None, categories=None, protocol=None,
                 raw=None, media_type=None, author=None, year=None,
                 identifier=None, format=None, description=None):
        self.title = title
        self.source = source          # "prowlarr", "archive.org", "youtube", "magnet", "direct"
        self.size = size              # bytes (int)
        self.seeders = seeders
        self.leechers = leechers
        self.age = age                # minutes (float)
        self.guid = guid
        self.download_url = download_url
        self.magnet_url = magnet_url
        self.info_url = info_url
        self.indexer = indexer
        self.categories = categories or []
        self.protocol = protocol      # "torrent", "usenet", "nzb", "direct", "stream"
        self.raw = raw                # original API response
        self.media_type = media_type
        self.author = author
        self.year = year
        self.identifier = identifier  # Archive.org item ID, YouTube video ID, etc.
        self.format = format
        self.description = description  # Short description (from URL probes, etc.)

    @property
    def size_human(self):
        return _human_size(self.size) if self.size else "—"

    @property
    def age_human(self):
        return _format_age(self.age) if self.age else "—"

    def __repr__(self):
        return f"<SearchResult: {self.title[:50]} ({self.source})>"


