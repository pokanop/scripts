def _prowlarr_search(query: str, config: dict, media_type: str = None,
                     limit: int = 30) -> list:
    """Search Prowlarr indexers. Returns list of SearchResult."""
    svc = config.get("services", {}).get("prowlarr", {})
    url = svc.get("url", "").rstrip("/")
    api_key = svc.get("api_key", "")

    if not url or not api_key:
        console.print("[yellow]⚠ Prowlarr not configured. Run: [bold]medcat setup --section services[/][/]")
        return []

    categories = []
    if media_type and media_type in PROWLARR_CATEGORIES:
        categories = PROWLARR_CATEGORIES[media_type]

    params = {"query": query, "limit": limit}
    if categories:
        params["categories"] = categories

    try:
        resp = requests.get(
            f"{url}/api/v1/search",
            params=params,
            headers={"X-Api-Key": api_key},
            timeout=30,
        )
        if resp.status_code != 200:
            console.print(f"[red]✗ Prowlarr returned HTTP {resp.status_code}[/]")
            return []

        results = []
        for item in resp.json():
            r = SearchResult(
                title=item.get("title", "?"),
                source="prowlarr",
                size=item.get("size"),
                seeders=item.get("seeders"),
                leechers=item.get("leechers"),
                age=item.get("ageMinutes"),
                guid=item.get("guid"),
                download_url=item.get("downloadUrl"),
                magnet_url=item.get("magnetUrl"),
                info_url=item.get("infoUrl"),
                indexer=item.get("indexer"),
                categories=[c.get("name", "") for c in item.get("categories", [])],
                protocol=item.get("protocol", "").lower() if item.get("protocol") else None,
                raw=item,
            )
            results.append(r)
        return results

    except requests.ConnectionError:
        console.print(f"[red]✗ Cannot connect to Prowlarr at {url}[/]")
        return []
    except Exception as e:
        console.print(f"[red]✗ Prowlarr error: {e}[/]")
        return []


def _prowlarr_download(result: SearchResult, config: dict) -> bool:
    """Trigger download via Prowlarr — pushes to configured download client."""
    svc = config.get("services", {}).get("prowlarr", {})
    url = svc.get("url", "").rstrip("/")
    api_key = svc.get("api_key", "")

    if not result.guid or not result.raw:
        console.print("[red]✗ No download info in search result[/]")
        return False

    try:
        # Prowlarr: POST the release back to trigger download
        resp = requests.post(
            f"{url}/api/v1/search",
            json=result.raw,
            headers={"X-Api-Key": api_key},
            timeout=15,
        )
        if resp.status_code in (200, 201):
            return True
        else:
            console.print(f"[red]✗ Prowlarr download failed: HTTP {resp.status_code}[/]")
            return False
    except Exception as e:
        console.print(f"[red]✗ Prowlarr download error: {e}[/]")
        return False


def _prowlarr_download_magnet(result: SearchResult, config: dict) -> bool:
    """Send a magnet URL to torrent client via Prowlarr indexer download."""
    svc = config.get("services", {}).get("prowlarr", {})
    url = svc.get("url", "").rstrip("/")
    api_key = svc.get("api_key", "")
    indexer_id = result.raw.get("indexerId") if result.raw else None

    if not indexer_id:
        return False

    try:
        link = result.magnet_url or result.download_url
        if not link:
            return False
        resp = requests.get(
            f"{url}/api/v1/indexer/{indexer_id}/download",
            params={"link": link},
            headers={"X-Api-Key": api_key},
            timeout=15,
        )
        return resp.status_code == 200
    except Exception:
        return False


