# CLI: medcat search
# ---------------------------------------------------------------------------


def cmd_search(args):
    """Handle 'search' command — search for media across multiple sources."""
    config = load_config()

    query = args.query
    media_type = getattr(args, "type", None) or None

    # --- URL auto-detection: if query looks like a URL, redirect to grab ---
    if _looks_like_url(query):
        console.print("[dim]  Detected URL → using grab mode[/]")
        # Build a synthetic args namespace for grab
        class _GrabArgs:
            pass
        ga = _GrabArgs()
        ga.url = query
        ga.type = media_type
        ga.dest = getattr(args, "dest", None) or media_type
        ga.audio = getattr(args, "audio", False)
        ga.scan = getattr(args, "scan", False)
        ga.no_ingest = getattr(args, "no_ingest", False)
        ga.dry_run = False
        ga.info = False
        return cmd_grab(ga)

    sources = _resolve_sources(getattr(args, "source", "auto"), media_type)
    limit = getattr(args, "limit", 20)

    console.print()
    console.print(f"🔎 [bold]Searching:[/] {escape(query)}")
    if media_type:
        console.print(f"[dim]  Type: {media_type}[/]")
    console.print(f"[dim]  Sources: {', '.join(sources)}[/]")
    console.print()

    # Search all selected sources
    all_results = []
    for src_name in sources:
        src = SEARCH_SOURCES.get(src_name)
        if not src:
            continue
        if src["needs_config"] and not config.get("services", {}).get(src_name, {}).get("url"):
            console.print(f"[dim]  Skipping {src_name} (not configured)[/]")
            continue

        console.print(f"[dim]  Searching {src['label']}...[/]")
        try:
            results = src["search"](query, config, media_type, limit)
            all_results.extend(results)
            console.print(f"[dim]    → {len(results)} results[/]")
        except Exception as e:
            console.print(f"[yellow]    ⚠ {src_name} error: {e}[/]")

    if not all_results:
        console.print("[yellow]No results found.[/]")
        return

    # Sort: torrents by seeders desc, then by source
    def sort_key(r):
        s = r.seeders if r.seeders is not None else -1
        return (-s, r.source)
    all_results.sort(key=sort_key)

    # Render results
    _render_search_results(all_results, f"Results for: {query}")

    # Interactive selection (if not --list-only)
    if getattr(args, "list_only", False):
        return

    if not sys.stdin.isatty():
        console.print("\n[dim]Run without piping to select and download results.[/]")
        return

    # Let user pick results to download
    console.print()
    while True:
        choice = console.input(
            "[bold cyan]Download[/] (number, range, 'a'll, 'q'uit): "
        ).strip().lower()

        if choice in ("q", "quit", ""):
            break

        if choice == "a":
            selected = list(all_results)
        elif "-" in choice and choice.replace("-", "").isdigit():
            # Range like 3-7
            parts = choice.split("-", 1)
            start, end = int(parts[0]), int(parts[1])
            selected = all_results[start-1:end]
        elif choice.isdigit():
            idx = int(choice)
            if 1 <= idx <= len(all_results):
                selected = [all_results[idx - 1]]
            else:
                console.print(f"[yellow]  Invalid: {idx}. Pick 1-{len(all_results)}.[/]")
                continue
        else:
            # Try comma-separated
            try:
                indices = [int(x.strip()) for x in choice.split(",")]
                selected = [all_results[i - 1] for i in indices if 1 <= i <= len(all_results)]
                if not selected:
                    continue
            except (ValueError, IndexError):
                console.print("[yellow]  Invalid input. Use number, range, 'a', or 'q'.[/]")
                continue

        # Download selected
        for r in selected:
            console.print(f"\n[bold]  → {escape(r.title[:60])}[/] ({r.source})")
            src = SEARCH_SOURCES.get(r.source)
            if not src:
                continue

            # Determine download destination
            dest_dir = None
            mt = r.media_type or media_type
            if mt and not getattr(args, "no_ingest", False):
                dest_config = config.get("destinations", {}).get(mt, {})
                dest_path = dest_config.get("path", "")
                if dest_path and destination_root_is_local(dest_config):
                    dest_dir = dest_path

            # Handle YouTube audio extraction
            if r.source == "youtube" and mt in ("music", "audiobooks"):
                ok = _youtube_download(r, dest_dir=dest_dir, audio_only=True)
            elif r.source == "archive":
                ok = _archive_download(r, dest_dir=dest_dir)
            elif r.source == "prowlarr" and r.magnet_url and not r.download_url:
                ok = _send_magnet_to_client(r.magnet_url, config)
            else:
                ok = src["download"](r, config)

            if ok:
                # Source-appropriate success messaging
                if r.source == "prowlarr":
                    # Prowlarr pushes to download client (sabnzbd, Deluge, etc.)
                    # File lands in the download client's configured directory,
                    # and the *arr services (Sonarr/Radarr/Readarr) typically
                    # auto-import from there. No manual ingest needed.
                    console.print("[green]  ✓ Sent to download client via Prowlarr[/]")
                    console.print("[dim]  The download client will handle the file. No manual ingest needed — your *arr services auto-import.[/]")
                elif r.source in ("youtube", "archive") and dest_dir and not getattr(args, "no_ingest", False):
                    # Direct local download — file lands in dest_dir
                    console.print(f"[green]  ✓ Downloaded to {escape(dest_dir)}[/]")
                    console.print(f"[dim]  Run 'medcat ingest {escape(dest_dir)}' to process.[/]")
                elif r.source in ("youtube", "archive"):
                    # Direct download to temp dir — tell user where it went
                    console.print("[green]  ✓ Download complete[/]")
                    console.print("[dim]  File downloaded to temp directory. Use --no-ingest with a destination path, or move manually.[/]")
                else:
                    # Magnet/torrent sent to client
                    console.print("[green]  ✓ Sent to torrent client[/]")
                    console.print("[dim]  The torrent client will download the file to its configured directory.[/]")
            else:
                console.print("[red]  ✗ Download failed[/]")

        # Ask if they want to select more
        if not _prompt_yes_no("\n  Download more?", default=False):
            break

    console.print()


def build_parser():
    parser = sk.make_parser(
        "medcat", __version__, TAGLINE, icon=ICON,
        epilog=textwrap.dedent("""\
            examples:
              medcat setup                           # First-time interactive setup
              medcat setup --section services        # Reconfigure just services
              medcat identify ~/Downloads/*.epub     # Show metadata without moving
              medcat ingest book.epub                # Ingest with auto-detection
              medcat ingest --dest comics ./comics/ --dry-run
              medcat ingest --dest books ~/Downloads/ --scan --yes
              # Manage config
              medcat config get services.kavita.url
              medcat config set services.radarr.api_key YOUR_KEY
              medcat config unset services.lidarr
              medcat config list destinations
              medcat config --check
              medcat config test kavita radarr

              # Search for media (supports queries and URLs)
              medcat search "Dune"
              medcat search "Foundation" --type books
              medcat search "Interstellar" --source prowlarr,youtube
              medcat search "Miles Davis" --type music --source all --limit 10
              medcat search "1948 George Orwell" --list-only
              medcat search https://youtube.com/watch?v=... --type music  # URL auto-grab

              # Grab — direct download from any URL
              medcat grab https://youtube.com/watch?v=dQw4w9WgXcQ
              medcat grab https://youtube.com/watch?v=... --audio --dest music
              medcat grab magnet:?xt=urn:btih:... --type movies
              medcat grab https://archive.org/details/example --type books
              medcat grab https://example.com/file.epub --dest books --scan
              medcat grab URL --info    # Just show metadata, don't download
              medcat grab URL --dry-run # Preview what would happen

              # Trigger a service scan
              medcat scan --service kavita
              medcat scan --service kavita --library-id 1
        """),
    )

    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # --- setup ---
    setup_p = subparsers.add_parser("setup", help="Interactive setup wizard (first launch or reconfigure)")
    setup_p.add_argument("--section", "-s",
                         choices=["transport", "destinations", "services"],
                         help="Only configure a specific section")

    # --- ingest ---
    ingest = subparsers.add_parser("ingest", help="Ingest media files into the stack")
    ingest.add_argument("paths", nargs="+", help="Files or directories to process")
    ingest.add_argument("--dest", "-d", choices=list(HANDLERS.keys()),
                        help="Destination type (auto-detected from files if not set)")
    ingest.add_argument("--dry-run", "-n", action="store_true", help="Show what would happen without moving files")
    ingest.add_argument("--no-enrich", action="store_true", help="Skip metadata enrichment via APIs")
    ingest.add_argument("--no-prompt", action="store_true", help="Don't prompt for missing metadata (use defaults)")
    ingest.add_argument("--scan", "-s", action="store_true", help="Trigger library scan after ingestion")
    ingest.add_argument("--yes", "-y", action="store_true", help="Auto-confirm all actions (no prompts)")

    # --- identify ---
    identify = subparsers.add_parser("identify", help="Show file metadata without moving anything")
    identify.add_argument("paths", nargs="+", help="Files or directories to inspect")
    identify.add_argument("--no-enrich", action="store_true", help="Skip API enrichment")

    # --- scan ---
    scan = subparsers.add_parser("scan", help="Trigger a library scan on a service")
    scan.add_argument("--service",
                      help="Service to trigger scan on (auto-detected if omitted)")
    scan.add_argument("--library-id", type=int, help="Library ID for Kavita (default: 1)")

    # --- search ---
    search = subparsers.add_parser("search", help="Search for media across multiple sources")
    search.add_argument("query", help="Search query (title, author, or URL for direct grab)")
    search.add_argument("--type", "-t", choices=list(HANDLERS.keys()),
                        help="Media type to filter by (books, movies, etc.)")
    search.add_argument("--source", "-s",
                        help="Search source(s): prowlarr, archive, youtube, all, auto (default: auto)")
    search.add_argument("--limit", "-n", type=int, default=20,
                        help="Max results per source (default: 20)")
    search.add_argument("--list-only", action="store_true",
                        help="Only show results, don't prompt for download")
    search.add_argument("--no-ingest", action="store_true",
                        help="Don't auto-ingest downloaded files")
    search.add_argument("--audio", action="store_true",
                        help="Force audio extraction (YouTube/grab mode)")
    search.add_argument("--dest", "-d", choices=list(HANDLERS.keys()),
                        help="Destination type for URL grabs (overrides auto-detection)")

    # --- grab ---
    grab = subparsers.add_parser("grab", help="Download media from any URL (YouTube, magnet, archive, direct)")
    grab.add_argument("url", help="URL to download from (YouTube, magnet link, archive.org, torrent, direct file)")
    grab.add_argument("--type", "-t", "--dest", "-d", dest="dest",
                      choices=list(HANDLERS.keys()),
                      help="Media type / destination (books, movies, music, etc.)")
    grab.add_argument("--audio", action="store_true",
                      help="Force audio extraction for YouTube/media")
    grab.add_argument("--scan", "-s", action="store_true",
                      help="Trigger library scan after download")
    grab.add_argument("--no-ingest", action="store_true",
                      help="Download only, don't auto-ingest into media stack")
    grab.add_argument("--dry-run", "-n", action="store_true",
                      help="Show what would happen without downloading")
    grab.add_argument("--info", action="store_true",
                      help="Only show URL metadata, don't download")

    # --- config ---
    config_p = subparsers.add_parser("config", help="Manage configuration")
    config_p.add_argument("--show", action="store_true", help="Show full configuration (secrets masked)")
    config_p.add_argument("--check", action="store_true", help="Validate configuration completeness")
    config_p.add_argument("--reset", action="store_true", help="Reset to clean defaults")

    config_sub = config_p.add_subparsers(dest="config_action", help="Config sub-commands")
    config_list = config_sub.add_parser("list", help="List config sections or keys within a section")
    config_list.add_argument("section", nargs="?", default=None, help="Section to list (e.g. destinations, services)")
    config_get = config_sub.add_parser("get", help="Get a config value by dot-separated path")
    config_get.add_argument("config_key", metavar="key", help="Dot-separated key path")
    config_set = config_sub.add_parser("set", help="Set a config value")
    config_set.add_argument("config_key", metavar="key", help="Dot-separated key path")
    config_set.add_argument("config_value", metavar="value", help="Value to set")
    config_unset = config_sub.add_parser("unset", help="Remove a config key")
    config_unset.add_argument("config_key", metavar="key", help="Dot-separated key path")
    config_test = config_sub.add_parser("test", help="Test service connections")
    config_test.add_argument("test_services", nargs="*", metavar="service",
                             help="Service names to test (default: all configured)")

    # --- doctor ---
    subparsers.add_parser("doctor", help="Check media tools, Python packages, and config")

    return parser


def cmd_doctor(args) -> int:
    """Diagnose media tools, Python packages, and configuration."""
    media = [
        sk.check_binary("ffmpeg", required=False, hint="brew install ffmpeg — audio/video metadata"),
        sk.check_binary("yt-dlp", required=False, hint="pip install yt-dlp — YouTube/archive downloads"),
        sk.check_binary("ia", required=False, hint="pip install internetarchive — archive.org access"),
        sk.check_binary("wget", required=False, hint="direct file downloads"),
    ]
    packages = [
        sk.check_python("ebooklib", hint="pip install ebooklib"),
        sk.check_python("fitz", hint="pip install pymupdf"),
        sk.check_python("musicbrainzngs", hint="pip install musicbrainzngs"),
        sk.check_python("yt_dlp", hint="pip install yt-dlp", required=False),
    ]
    config = [
        sk.Check.ok("Config file", str(CONFIG_FILE)) if CONFIG_FILE.exists()
        else sk.Check.warn("Config file", "not found", "run: medcat setup")
    ]
    return sk.doctor(
        "medcat", __version__, TAGLINE, ICON,
        sections={"Media tools": media, "Python packages": packages, "Config": config},
        tips=[
            "Validate configuration completeness: medcat config --check",
            "Test service connections: medcat config test",
        ],
    )


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


# Command dispatch. (Note: the module-level ``HANDLERS`` dict is media-type
# destinations, not commands — keep these separate.)
COMMANDS = {
    "setup": cmd_setup,
    "ingest": cmd_ingest,
    "identify": cmd_identify,
    "scan": cmd_scan,
    "search": cmd_search,
    "grab": cmd_grab,
    "config": cmd_config,
    "doctor": cmd_doctor,
}


def main() -> int:
    parser = build_parser()
    args = sk.parse_args(parser)

    # Bare invocation: first-run welcome, otherwise banner-led help.
    if not args.command:
        if _needs_setup():
            console.print(Panel.fit(
                "[bold]🐱 Welcome to medcat![/]\n\n"
                "No configuration found. Let's set things up:\n\n"
                "[cyan]  medcat setup[/]\n\n"
                "[dim]This will guide you through configuring destinations, services, and transport.[/]",
                border_style="cyan",
            ))
            return 0
        parser.print_help()
        return 0

    return sk.dispatch(
        args, COMMANDS, parser,
        banner=sk.banner("medcat", __version__, TAGLINE, ICON),
    )


if __name__ == "__main__":
    sys.exit(sk.run_cli(main))
